{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zag",
  "scopeName": "source.zag",
  "fileTypes": [".zag"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zag",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.zag",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.zag",
              "match": "\\\\(n|t|r|\\\\|\")"
            }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.modifier.annotation.zag",
          "match": "@(realtime|noalloc|pure|total|kernel|device|link|import|strEq|zag_argc|zag_arg|zag_println|zag_print|zag_read_file|zag_write_file|zag_exec_cmd|zag_i64_to_str|zag_str_concat|zag_file_exists)\\b"
        },
        {
          "name": "keyword.other.at.zag",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.zag",
          "match": "\\b(if|else|while|return|switch|try|catch)\\b"
        },
        {
          "name": "keyword.declaration.zag",
          "match": "\\b(fn|let|struct|union|enum|interface|operator|error|pub|extern)\\b"
        },
        {
          "name": "keyword.operator.zag",
          "match": "\\b(as|in)\\b"
        },
        {
          "name": "constant.language.zag",
          "match": "\\b(true|false|null|void)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.zag",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|[]u8)\\b"
        },
        {
          "name": "support.type.heterogeneous.zag",
          "match": "\\b(u[3-9]|u[1-9][0-9]|u1[0-1][0-9]|u12[0-7]|sat_i8|sat_i16|sat_i32|sat_i64|sat_u8|sat_u16|sat_u32|sat_u64|u_any|rns_[0-9]+|vsa_b[0-9]+|mx_fp8)\\b"
        },
        {
          "name": "support.type.collection.zag",
          "match": "\\b(ArrayList|StringMap)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.zag",
          "match": "0x[0-9a-fA-F]+"
        },
        {
          "name": "constant.numeric.zag",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.zag",
          "match": "(=>|->|==|!=|<=|>=|&&|\\|\\||[+\\-*/%&^~!<>|=])"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.zag",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "name": "entity.name.type.zag",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        },
        {
          "name": "variable.other.zag",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
