{
  "name": "zag-lang",
  "displayName": "Zag Language",
  "description": "Zag language support: syntax highlighting, diagnostics, completion, hover, and go-to-definition via the Zag LSP server.",
  "version": "0.1.0",
  "publisher": "sylorlabs",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:zag"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "zag",
        "aliases": ["Zag", "zag"],
        "extensions": [".zag"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zag",
        "scopeName": "source.zag",
        "path": "./syntaxes/zag.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Zag",
      "properties": {
        "zag.serverPath": {
          "type": "string",
          "default": "znc-lsp",
          "description": "Path to the Zag LSP server binary (znc-lsp or zag-lsp)."
        },
        "zag.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP communication in the Output panel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
