# ── Build system outputs ──────────────────────────────────────────────────────
.zig-cache/
zig-out/
.venv/
*.o
*.a
*.a.o

# ── C intermediates and ELF outputs from the Zag compiler ────────────────────
# *.zag.c  = C intermediate emitted by the C backend (selfhost/codegen.zag)
# *.zag.out = ELF binary emitted by znc (the native backend)
# *.zag.zir.c = ZIR path intermediate
#
# NOTE: selfhost/native/znc.zag.c and selfhost/native/znc.zag.out are the
# committed seed files; git tracks them regardless of the glob below because
# tracked files are never un-tracked by .gitignore rules.
*.zag.c
*.zag.out
*.zag.zir.c

