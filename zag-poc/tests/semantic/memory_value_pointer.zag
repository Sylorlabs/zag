struct Pair { left: i32, right: i32 }

fn mutate_copy(pair: Pair) i32 {
    pair.left = 99;
    return pair.left;
}

fn main() i32 {
    let original: Pair = Pair{ .left = 20, .right = 2 };
    let ignored: i32 = mutate_copy(original);
    let heap: *Pair = new(Pair{ .left = original.left, .right = original.right });
    let field: *i32 = &heap.*.left;
    field.* = field.* + 20;
    return heap.*.left + heap.*.right;
}

