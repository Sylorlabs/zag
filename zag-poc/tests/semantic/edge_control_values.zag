enum State { Empty, Ready }

fn maybe(flag: bool) ?i32 {
    if (flag) { return 40; }
    return null;
}

fn main() i32 {
    let value: i32 = maybe(true) orelse 0;
    let state: State = State.Ready;
    let extra: i32 = switch (state) {
        .Empty => 0,
        .Ready => 2,
    };
    if (false && (1 / 0 == 0)) { return 1; }
    if (true || (1 / 0 == 0)) { return value + extra; }
    return 0;
}

