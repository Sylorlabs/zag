union Number { item: i32 }

fn main() i32 {
    let value: i32 = 40;
    let optional: ?i32 = 99;
    if (optional) |value| {
        if (value != 99) { return 0; }
    }
    let number: Number = Number{ .item = 2 };
    switch (number) {
        .item => |value| {
            if (value.* != 2) { return 0; }
        }
    }
    return value + 2;
}
