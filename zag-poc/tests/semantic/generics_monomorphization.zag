struct Box[T] { value: T }

fn identity[T](value: T) T {
    return value;
}

fn unbox[T](box: Box[T]) T {
    return box.value;
}

fn main() i32 {
    let box: Box[i32] = Box[i32]{ .value = 40 };
    let inferred: i32 = unbox(box);
    let explicit: i32 = identity[i32](2);
    return inferred + explicit;
}

