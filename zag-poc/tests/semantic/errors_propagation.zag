error { Zero }

fn divide(a: i32, b: i32) !i32 {
    if (b == 0) { return error.Zero; }
    return a / b;
}

fn doubled(a: i32, b: i32) !i32 {
    let value: i32 = try divide(a, b);
    return value * 2;
}

fn main() i32 {
    let good: i32 = doubled(84, 4) catch 0;
    let recovered: i32 = doubled(1, 0) catch 0;
    return good + recovered;
}

