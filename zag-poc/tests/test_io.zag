@import("../selfhost/std/io.zag")

fn main() i32 {
    let path: []u8 = "/tmp/zag_stdlib_io_test.txt";
    let r: i32 = io_write_file(path, "stdlib io test content");
    print_int(r);
    let content: []u8 = io_read_file(path);
    _zag_println(content);
    let exists: i32 = io_file_exists(path);
    print_int(exists);
    io_stderr_println("stderr test line");
    return 0;
}
