// tests/stdlib.zag — comprehensive test suite for selfhost/std/*.zag
//
// Each test prints "PASS" or "FAIL <what>".
// At the end, prints "TOTAL PASS=<n> FAIL=<n>" and exits 0 if all pass.

@import("../selfhost/std/std.zag")

// ── test helpers ──────────────────────────────────────────────────────────────

fn ok(name: []u8) void {
    _zag_print("PASS ");
    _zag_println(name);
}

fn fail(name: []u8) void {
    _zag_print("FAIL ");
    _zag_println(name);
}

fn check_i32(name: []u8, got: i32, want: i32) i32 {
    if (got == want) { ok(name); return 1; }
    _zag_print("FAIL ");
    _zag_print(name);
    _zag_print(" got=");
    _zag_print(_zag_i64_to_str(got as i64));
    _zag_print(" want=");
    _zag_println(_zag_i64_to_str(want as i64));
    return 0;
}

fn check_str(name: []u8, got: []u8, want: []u8) i32 {
    if (_zag_strcmp(got, want) == 1) { ok(name); return 1; }
    _zag_print("FAIL ");
    _zag_print(name);
    _zag_print(" got=[");
    _zag_print(got);
    _zag_print("] want=[");
    _zag_print(want);
    _zag_println("]");
    return 0;
}

// ── str module ────────────────────────────────────────────────────────────────

fn test_str(pass: *i32, fail_: *i32) void {
    _zag_println("-- str module --");

    if (check_i32("str_len hello", str_len("hello"), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("str_len empty", str_len(""), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("str_eq equal", str_eq("abc", "abc"), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("str_eq different", str_eq("abc", "xyz"), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("str_eq empty", str_eq("", ""), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("starts_with yes", str_starts_with("hello world", "hello"), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("starts_with no", str_starts_with("hello world", "world"), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("starts_with empty prefix", str_starts_with("hello", ""), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("starts_with longer prefix", str_starts_with("hi", "hello"), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("ends_with yes", str_ends_with("hello world", "world"), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("ends_with no", str_ends_with("hello world", "hello"), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("ends_with empty suffix", str_ends_with("hello", ""), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("index_of found", str_index_of("hello world", "world"), 6) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("index_of not found", str_index_of("hello world", "xyz"), -1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("index_of at start", str_index_of("hello", "hel"), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("index_of empty sub", str_index_of("hello", ""), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("contains yes", str_contains("hello world", "llo"), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("contains no", str_contains("hello world", "xyz"), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let sl: []u8 = str_slice("hello world", 6, 11);
    if (check_str("str_slice", sl, "world") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let t1: []u8 = str_trim("  hello  ");
    if (check_str("str_trim spaces", t1, "hello") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    let t2: []u8 = str_trim("no trim");
    if (check_str("str_trim none", t2, "no trim") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    let t3: []u8 = str_trim("   ");
    if (check_i32("str_trim all spaces", t3.len, 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let sp: StrSplit = str_split_once("key:value", ':');
    if (check_str("split_once left", sp.left, "key") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_str("split_once right", sp.right, "value") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("split_once found", sp.found, 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let sp2: StrSplit = str_split_once("nocolon", ':');
    if (check_i32("split_once not found", sp2.found, 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_str("split_once left when not found", sp2.left, "nocolon") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let sv: i64 = str_to_i64("12345");
    if (check_i32("str_to_i64", sv as i32, 12345) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    let sv2: i64 = str_to_i64("-99");
    if (check_i32("str_to_i64 negative", sv2 as i32, -99) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let is: []u8 = i64_to_str(42 as i64);
    if (check_str("i64_to_str", is, "42") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    let is2: []u8 = i64_to_str(-1 as i64);
    if (check_str("i64_to_str negative", is2, "-1") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
}

// ── fmt module ────────────────────────────────────────────────────────────────

fn test_fmt(pass: *i32, fail_: *i32) void {
    _zag_println("-- fmt module --");

    if (check_str("fmt_int 0", fmt_int(0 as i64), "0") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_str("fmt_int pos", fmt_int(42 as i64), "42") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_str("fmt_int neg", fmt_int(-7 as i64), "-7") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_str("fmt_bool true", fmt_bool(1), "true") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_str("fmt_bool false", fmt_bool(0), "false") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_str("fmt_bool nonzero", fmt_bool(42), "true") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let parts: StrList = strlist_new(3);
    strlist_push(&parts, "hello");
    strlist_push(&parts, " ");
    strlist_push(&parts, "world");
    let cat: []u8 = fmt_concat(&parts);
    if (check_str("fmt_concat", cat, "hello world") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    strlist_free(&parts);

    let parts2: StrList = strlist_new(3);
    strlist_push(&parts2, "one");
    strlist_push(&parts2, "two");
    strlist_push(&parts2, "three");
    let joined: []u8 = fmt_join(&parts2, ",");
    if (check_str("fmt_join", joined, "one,two,three") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    strlist_free(&parts2);

    let empty: StrList = strlist_new(1);
    let ej: []u8 = fmt_join(&empty, ",");
    if (check_str("fmt_join empty", ej, "") == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    strlist_free(&empty);
}

// ── io module ─────────────────────────────────────────────────────────────────

fn test_io(pass: *i32, fail_: *i32) void {
    _zag_println("-- io module --");

    let path: []u8 = "/tmp/zag_stdlib_test_io.txt";
    let data: []u8 = "stdlib io roundtrip";

    let wr: i32 = io_write_file(path, data);
    if (check_i32("io_write_file ok", wr, 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let ex: i32 = io_file_exists(path);
    if (check_i32("io_file_exists after write", ex, 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let content: []u8 = io_read_file(path);
    if (check_str("io_read_file roundtrip", content, data) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let ex2: i32 = io_file_exists("/tmp/no_such_file_zag_12345.txt");
    if (check_i32("io_file_exists missing", ex2, 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
}

// ── collections module ────────────────────────────────────────────────────────

fn double(x: i32) i32 { return x * 2; }
fn is_even(x: i32) i32 { if ((x % 2) == 0) { return 1; } return 0; }
fn is_gt_2(x: i32) i32 { if (x > 2) { return 1; } return 0; }

fn test_collections(pass: *i32, fail_: *i32) void {
    _zag_println("-- collections module --");

    let v: I32List = i32list_new(4);
    i32list_push(&v, 3);
    i32list_push(&v, 1);
    i32list_push(&v, 4);
    i32list_push(&v, 1);
    i32list_push(&v, 5);

    if (check_i32("i32list_len", i32list_len(&v), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("i32list_get 0", i32list_get(&v, 0), 3) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("i32list_get 4", i32list_get(&v, 4), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    i32list_set(&v, 2, 99);
    if (check_i32("i32list_set", i32list_get(&v, 2), 99) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    i32list_set(&v, 2, 4);  // restore

    if (check_i32("list_contains yes", list_contains(&v, 4), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_contains no", list_contains(&v, 9), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("list_sum", list_sum(&v), 14) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_min", list_min(&v), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_max", list_max(&v), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    let doubled: I32List = list_map_i32(&v, double);
    if (check_i32("list_map first", i32list_get(&doubled, 0), 6) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_map last", i32list_get(&doubled, 4), 10) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    i32list_free(&doubled);

    let evens: I32List = list_filter_i32(&v, is_even);
    if (check_i32("list_filter len", i32list_len(&evens), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_filter val", i32list_get(&evens, 0), 4) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    i32list_free(&evens);

    // [3,1,4,1,5]: elements > 2 are 3, 4, 5  → length 3
    let gt2: I32List = list_filter_i32(&v, is_gt_2);
    if (check_i32("list_filter gt2 len", i32list_len(&gt2), 3) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_filter gt2 first", i32list_get(&gt2, 0), 3) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_filter gt2 last", i32list_get(&gt2, 2), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    i32list_free(&gt2);

    let rev: I32List = list_reverse_i32(&v);
    if (check_i32("list_reverse first", i32list_get(&rev, 0), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("list_reverse last", i32list_get(&rev, 4), 3) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    i32list_free(&rev);

    i32list_free(&v);
}

// ── math module ───────────────────────────────────────────────────────────────

fn test_math(pass: *i32, fail_: *i32) void {
    _zag_println("-- math module --");

    if (check_i32("math_abs neg", math_abs(-42), 42) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_abs zero", math_abs(0), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_abs pos", math_abs(17), 17) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("math_min a<b", math_min(3, 7), 3) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_min a>b", math_min(7, 3), 3) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_min eq", math_min(5, 5), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("math_max a>b", math_max(7, 3), 7) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_max a<b", math_max(3, 7), 7) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("math_clamp in range", math_clamp(5, 0, 10), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_clamp below", math_clamp(-5, 0, 10), 0) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_clamp above", math_clamp(15, 0, 10), 10) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("math_pow 2^10", math_pow_i32(2, 10), 1024) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_pow 3^4", math_pow_i32(3, 4), 81) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_pow x^0", math_pow_i32(5, 0), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_pow 0^0", math_pow_i32(0, 0), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }

    if (check_i32("math_gcd 12,8", math_gcd(12, 8), 4) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_gcd 100,75", math_gcd(100, 75), 25) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_gcd 0,5", math_gcd(0, 5), 5) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_gcd coprime", math_gcd(7, 13), 1) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
    if (check_i32("math_gcd neg", math_gcd(-12, 8), 4) == 1) { pass.* = pass.* + 1; } else { fail_.* = fail_.* + 1; }
}

// ── entry point ───────────────────────────────────────────────────────────────

fn main() i32 {
    let pass: i32 = 0;
    let fail_: i32 = 0;

    test_str(&pass, &fail_);
    test_fmt(&pass, &fail_);
    test_io(&pass, &fail_);
    test_collections(&pass, &fail_);
    test_math(&pass, &fail_);

    _zag_println("-- summary --");
    _zag_print("TOTAL PASS=");
    _zag_print(_zag_i64_to_str(pass as i64));
    _zag_print(" FAIL=");
    _zag_println(_zag_i64_to_str(fail_ as i64));

    if (fail_ == 0) { return 0; }
    return 1;
}
