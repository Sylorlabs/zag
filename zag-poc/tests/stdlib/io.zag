@import("../../std/rt.zag")

fn main() void {
    // string formatting
    let s: []u8 = _zag_i64_to_str(12345);
    _zag_println(s);
    let joined: []u8 = _zag_str_concat("hello ", "world");
    _zag_println(joined);

    // write then read a file
    let path: []u8 = "/tmp/zag_selfhost_io_test.txt";
    let code: i32 = _zag_write_file(path, "roundtrip-ok");
    print_i32(code);                       // 0
    let content: []u8 = _zag_read_file(path);
    _zag_println(content);                 // roundtrip-ok
    print_i32(content.len);                // 12

    // string compare
    print_i32(_zag_strcmp("abc", "abc"));  // 1
    print_i32(_zag_strcmp("abc", "abd"));  // 0
}
