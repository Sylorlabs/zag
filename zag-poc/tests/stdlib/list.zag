@import("../../std/list.zag") as list

fn main() void {
    let xs: list.ArrayList[i32] = list.make[i32](2);
    let i: i32 = 0;
    while (i < 10) {
        list.push[i32](&xs, i * i);
        i = i + 1;
    }
    print_i32(list.len[i32](xs));      // 10
    print_i32(list.get[i32](xs, 0));   // 0
    print_i32(list.get[i32](xs, 9));   // 81
    print_i32(list.cap[i32](xs));      // grew past 2
    let last: i32 = list.pop[i32](&xs);
    print_i32(last);                   // 81
    print_i32(list.len[i32](xs));      // 9
    list.set[i32](&xs, 0, 999);
    print_i32(list.get[i32](xs, 0));   // 999
    list.free[i32](&xs);
}
