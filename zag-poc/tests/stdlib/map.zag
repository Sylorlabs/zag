@import("../../std/map.zag") as map

fn main() void {
    let m: map.StringMap[i32] = map.make[i32](4);
    map.put[i32](&m, "one", 1);
    map.put[i32](&m, "two", 2);
    map.put[i32](&m, "three", 3);
    map.put[i32](&m, "four", 4);
    map.put[i32](&m, "five", 5);
    map.put[i32](&m, "six", 6);
    map.put[i32](&m, "two", 22);        // update

    print_i32(map.count[i32](m));        // 6
    print_i32(map.get[i32](m, "one") orelse 0);    // 1
    print_i32(map.get[i32](m, "two") orelse 0);    // 22
    print_i32(map.get[i32](m, "six") orelse 0);    // 6
    print_i32(map.get[i32](m, "missing") orelse 0);// 0

    if (map.has[i32](m, "three")) { print_i32(100); } else { print_i32(0); }  // 100
    if (map.has[i32](m, "nope"))  { print_i32(1); }   else { print_i32(0); }  // 0
    map.free[i32](&m);
}
