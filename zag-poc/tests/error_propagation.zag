// tests/error_propagation.zag — tests for error union propagation: !T, try, catch
//
// This file exercises:
//   fn foo() !T        — function returning error union
//   return error.X     — return an error value
//   try expr           — propagate error upward from !T callee
//   expr catch val     — handle error with fallback value
//   expr catch |e| val — handle error and bind error code to e

error { NotFound, OutOfRange, ParseFail }

// Returns !i32: either an error or a valid integer.
fn safe_div(a: i32, b: i32) !i32 {
    if (b == 0) { return error.OutOfRange; }
    return a / b;
}

// Uses try to propagate the error from safe_div.
fn compute(a: i32, b: i32) !i32 {
    let q: i32 = try safe_div(a, b);
    return q * 2;
}

// Parse an unsigned decimal integer from a []u8 slice; errors on empty or bad chars.
fn parse_int_eu(s: []u8) !i32 {
    if (s.len == 0) { return error.ParseFail; }
    let result: i32 = 0;
    let i: i32 = 0;
    while (i < s.len) {
        let c: i32 = s[i] as i32;
        if (c < 48) { return error.ParseFail; }
        if (c > 57) { return error.ParseFail; }
        result = result * 10 + (c - 48);
        i = i + 1;
    }
    return result;
}

// Lookup in a simple table; returns error on miss.
fn lookup(key: i32) !i32 {
    if (key == 1) { return 100; }
    if (key == 2) { return 200; }
    return error.NotFound;
}

fn print_result(ok: i32, label: []u8) void {
    if (ok == 1) {
        _zag_print("PASS: ");
        _zag_println(label);
    } else {
        _zag_print("FAIL: ");
        _zag_println(label);
    }
}

fn main() i32 {
    let failures: i32 = 0;

    // 1. Basic catch on success path.
    let r1: i32 = safe_div(10, 2) catch -1;
    print_result((r1 == 5) as i32, "catch success path (10/2=5)");
    if (r1 != 5) { failures = failures + 1; }

    // 2. Basic catch on error path (div by zero).
    let r2: i32 = safe_div(5, 0) catch -1;
    print_result((r2 == 0 - 1) as i32, "catch error path (5/0 -> -1)");
    if (r2 != 0 - 1) { failures = failures + 1; }

    // 3. try propagates error through compute().
    let r3: i32 = compute(10, 2) catch -1;
    print_result((r3 == 10) as i32, "try propagation success (compute(10,2)=10)");
    if (r3 != 10) { failures = failures + 1; }

    // 4. try propagates error: compute(10,0) -> OutOfRange -> catch -1.
    let r4: i32 = compute(10, 0) catch -1;
    print_result((r4 == 0 - 1) as i32, "try propagation error (compute(10,0) -> -1)");
    if (r4 != 0 - 1) { failures = failures + 1; }

    // 5. catch with error code capture — code must be nonzero.
    let r5: i32 = safe_div(7, 0) catch |e| e;
    print_result((r5 > 0) as i32, "catch |e| binds nonzero error code");
    if (r5 <= 0) { failures = failures + 1; }

    // 6. parse_int_eu: valid input.
    let p1: i32 = parse_int_eu("42") catch -1;
    print_result((p1 == 42) as i32, "parse_int success (\"42\"=42)");
    if (p1 != 42) { failures = failures + 1; }

    // 7. parse_int_eu: empty input -> ParseFail.
    let p2: i32 = parse_int_eu("") catch -1;
    print_result((p2 == 0 - 1) as i32, "parse_int error on empty string");
    if (p2 != 0 - 1) { failures = failures + 1; }

    // 8. parse_int_eu: non-digit chars -> ParseFail.
    let p3: i32 = parse_int_eu("abc") catch -1;
    print_result((p3 == 0 - 1) as i32, "parse_int error on non-digit chars");
    if (p3 != 0 - 1) { failures = failures + 1; }

    // 9. lookup success.
    let v1: i32 = lookup(1) catch 0;
    print_result((v1 == 100) as i32, "lookup hit (key=1 -> 100)");
    if (v1 != 100) { failures = failures + 1; }

    // 10. lookup miss -> NotFound -> fallback 0.
    let v2: i32 = lookup(99) catch 0;
    print_result((v2 == 0) as i32, "lookup miss (key=99 -> 0)");
    if (v2 != 0) { failures = failures + 1; }

    // 11. Chained: compute(8,4) catch -99 -> 4.
    let chained: i32 = compute(8, 4) catch -99;
    print_result((chained == 4) as i32, "chained try+catch success (compute(8,4)=4)");
    if (chained != 4) { failures = failures + 1; }

    // 12. Chained: compute(8,0) -> error -> -99.
    let chained2: i32 = compute(8, 0) catch -99;
    print_result((chained2 == 0 - 99) as i32, "chained try+catch error (compute(8,0)=-99)");
    if (chained2 != 0 - 99) { failures = failures + 1; }

    if (failures == 0) {
        _zag_println("ALL PASS");
        return 0;
    }
    _zag_println("SOME FAILED");
    return failures;
}
