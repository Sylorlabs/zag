@import("../selfhost/std/collections.zag")
fn main() i32 {
    let v: I32List = i32list_new(6);
    i32list_push(&v, 5); i32list_push(&v, 2); i32list_push(&v, 8);
    i32list_push(&v, 1); i32list_push(&v, 9); i32list_push(&v, 3);
    list_sort_asc(&v);
    if (i32list_get(&v, 0) == 1 && i32list_get(&v, 5) == 9) {
        _zag_println("sort_asc: PASS");
    } else { _zag_println("sort_asc: FAIL"); }
    let idx: i32 = list_bsearch(&v, 8);
    if (idx == 4) { _zag_println("bsearch: PASS"); } else { _zag_println("bsearch: FAIL"); }
    let miss: i32 = list_bsearch(&v, 7);
    if (miss == -1) { _zag_println("bsearch miss: PASS"); } else { _zag_println("bsearch miss: FAIL"); }
    list_sort_desc(&v);
    if (i32list_get(&v, 0) == 9 && i32list_get(&v, 5) == 1) {
        _zag_println("sort_desc: PASS");
    } else { _zag_println("sort_desc: FAIL"); }
    i32list_free(&v);
    return 0;
}
