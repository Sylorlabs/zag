@import("../selfhost/std/str.zag")

fn main() i32 {
    print_int(str_len("hello"));
    print_int(str_eq("abc", "abc"));
    print_int(str_eq("abc", "xyz"));
    print_int(str_starts_with("hello world", "hello"));
    print_int(str_starts_with("hello world", "world"));
    print_int(str_ends_with("hello world", "world"));
    print_int(str_ends_with("hello world", "hello"));
    print_int(str_index_of("hello world", "world"));
    print_int(str_index_of("hello world", "xyz"));
    print_int(str_contains("hello world", "llo"));
    print_int(str_contains("hello world", "xyz"));
    let t: []u8 = str_trim("  hello  ");
    _zag_println(t);
    let sp: StrSplit = str_split_once("key:value", ':');
    _zag_println(sp.left);
    _zag_println(sp.right);
    print_int(sp.found);
    let n: i64 = str_to_i64("12345");
    let s: []u8 = i64_to_str(n);
    _zag_println(s);
    return 0;
}
