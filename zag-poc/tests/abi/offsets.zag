// ABI/layout edge-case regression suite — RUNTIME field-offset checks.
//
// Documents CURRENT znc layout behavior (see COMPATIBILITY.md). ABI is NOT
// frozen; these tests detect regressions only.
//
// main() returns 0 on success, else the 1-based index of the first failure.

struct P { x: i32, y: i32 }
struct S { a: i32, b: []u8, c: i32 }
struct Inner { x: i32, y: i32 }
struct Outer { inner: Inner, z: i32 }
struct F32Pair { x: f32, y: f32 }

error { E }
fn eu_ok() !i32 { return 42; }

struct EuPair { a: i32, b: !i32, c: i32 }

union U { a: i32, b: []u8 }
struct SliceBox { sl: []u8 }

fn delta_i32(a: *i32, b: *i32) i32 {
    return ((b as i64) - (a as i64)) as i32;
}

fn delta_f32(a: *f32, b: *f32) i32 {
    return ((b as i64) - (a as i64)) as i32;
}

fn check_scalar_i32_slots() i32 {
    let p: P = P{ .x = 1, .y = 2 };
    if (delta_i32(&p.x, &p.y) != 8) { return 1; }
    return 0;
}

fn check_slice_between_i32() i32 {
    let s: S = S{ .a = 40, .b = "x", .c = 2 };
    if (delta_i32(&s.a, &s.c) != 24) { return 1; }
    if (s.a + s.c != 42) { return 1; }
    return 0;
}

fn check_nested_struct_offset() i32 {
    let o: Outer = Outer{ .inner = Inner{ .x = 10, .y = 20 }, .z = 30 };
    if (delta_i32(&o.inner.x, &o.z) != 16) { return 1; }
    if (o.inner.x + o.inner.y + o.z != 60) { return 1; }
    return 0;
}

fn check_f32_field_spacing() i32 {
    let f: F32Pair = F32Pair{ .x = 1.0, .y = 2.0 };
    if (delta_f32(&f.x, &f.y) != 8) { return 1; }
    return 0;
}

fn check_error_union_inline() i32 {
    let p: EuPair = EuPair{ .a = 1, .b = eu_ok(), .c = 2 };
    if (delta_i32(&p.a, &p.c) != 24) { return 1; }
    let v: i32 = p.b catch 0;
    if (v != 42) { return 1; }
    return 0;
}

fn check_union_tag_payload() i32 {
    let u1: U = U{ .a = 7 };
    let got_a: i32 = switch (u1) {
        .a => |v| v,
        .b => |s| s.*.len,
    };
    if (got_a != 7) { return 1; }
    let u2: U = U{ .b = "hi" };
    let got_b: i32 = switch (u2) {
        .a => |v| 0,
        .b => |s| s.*.len,
    };
    if (got_b != 2) { return 1; }
    return 0;
}

fn id(x: i32) i32 { return x; }

fn apply(f: fn(i32) i32, v: i32) i32 { return f(v); }

fn check_fat_fn_call() i32 {
    if (apply(id, 42) != 42) { return 1; }
    let scale: i32 = 3;
    if (apply(fn[scale](v: i32) i32 { return v * scale; }, 7) != 21) { return 1; }
    return 0;
}

fn check_slice_layout() i32 {
    let b: SliceBox = SliceBox{ .sl = "hello" };
    if (b.sl.len != 5) { return 1; }
    let q: []u8 = b.sl;
    if (q.len != 5) { return 1; }
    if (q[1] != 101) { return 1; }
    return 0;
}

fn main() i32 {
    if (check_scalar_i32_slots() != 0) { return 1; }
    if (check_slice_between_i32() != 0) { return 2; }
    if (check_nested_struct_offset() != 0) { return 3; }
    if (check_f32_field_spacing() != 0) { return 4; }
    if (check_error_union_inline() != 0) { return 5; }
    if (check_union_tag_payload() != 0) { return 6; }
    if (check_fat_fn_call() != 0) { return 7; }
    if (check_slice_layout() != 0) { return 8; }
    return 0;
}