// tests/stdlib_test.zag — comprehensive PASS/FAIL test for all stdlib modules.
// Imports each module directly via relative path (no std.zag umbrella).
// Compile and run with:  ./znc tests/stdlib_test.zag -o /tmp/stdlib_test && /tmp/stdlib_test

@import("../selfhost/std/str.zag")
@import("../selfhost/std/math.zag")
@import("../selfhost/std/fmt.zag")
@import("../selfhost/std/collections.zag")

// helpers for list_map_i32 / list_filter_i32
fn _t_double(x: i32) i32 { return x * 2; }
fn _t_is_even(x: i32) i32 { if ((x % 2) == 0) { return 1; } return 0; }

fn main() i32 {
    // ══ str.zag ══════════════════════════════════════════════════════════════

    if (str_len("hello") == 5) { _zag_println("str_len: PASS"); } else { _zag_println("str_len: FAIL"); }

    if (str_eq("abc", "abc") == 1) { _zag_println("str_eq_same: PASS"); } else { _zag_println("str_eq_same: FAIL"); }
    if (str_eq("abc", "xyz") == 0) { _zag_println("str_eq_diff: PASS"); } else { _zag_println("str_eq_diff: FAIL"); }

    if (str_starts_with("hello world", "hello") == 1) { _zag_println("str_starts_with_t: PASS"); } else { _zag_println("str_starts_with_t: FAIL"); }
    if (str_starts_with("hello world", "world") == 0) { _zag_println("str_starts_with_f: PASS"); } else { _zag_println("str_starts_with_f: FAIL"); }

    if (str_ends_with("hello world", "world") == 1) { _zag_println("str_ends_with_t: PASS"); } else { _zag_println("str_ends_with_t: FAIL"); }
    if (str_ends_with("hello world", "hello") == 0) { _zag_println("str_ends_with_f: PASS"); } else { _zag_println("str_ends_with_f: FAIL"); }

    if (str_index_of("hello world", "world") == 6) { _zag_println("str_index_of_t: PASS"); } else { _zag_println("str_index_of_t: FAIL"); }
    if (str_index_of("hello world", "xyz") == -1) { _zag_println("str_index_of_f: PASS"); } else { _zag_println("str_index_of_f: FAIL"); }

    if (str_contains("hello world", "llo") == 1) { _zag_println("str_contains_t: PASS"); } else { _zag_println("str_contains_t: FAIL"); }
    if (str_contains("hello world", "xyz") == 0) { _zag_println("str_contains_f: PASS"); } else { _zag_println("str_contains_f: FAIL"); }

    let trimmed: []u8 = str_trim("  hi  ");
    if (str_eq(trimmed, "hi") == 1) { _zag_println("str_trim: PASS"); } else { _zag_println("str_trim: FAIL"); }

    let sliced: []u8 = str_slice("hello", 1, 4);
    if (str_eq(sliced, "ell") == 1) { _zag_println("str_slice: PASS"); } else { _zag_println("str_slice: FAIL"); }

    let sp: StrSplit = str_split_once("key:value", ':');
    if (sp.found == 1) {
        if (str_eq(sp.left, "key") == 1) {
            if (str_eq(sp.right, "value") == 1) {
                _zag_println("str_split_once: PASS");
            } else { _zag_println("str_split_once: FAIL"); }
        } else { _zag_println("str_split_once: FAIL"); }
    } else { _zag_println("str_split_once: FAIL"); }

    let sp2: StrSplit = str_split_once("nocolon", ':');
    if (sp2.found == 0) { _zag_println("str_split_once_nf: PASS"); } else { _zag_println("str_split_once_nf: FAIL"); }

    let n64: i64 = str_to_i64("12345");
    if (n64 == 12345 as i64) { _zag_println("str_to_i64: PASS"); } else { _zag_println("str_to_i64: FAIL"); }

    let ns: []u8 = i64_to_str(99 as i64);
    if (str_eq(ns, "99") == 1) { _zag_println("i64_to_str: PASS"); } else { _zag_println("i64_to_str: FAIL"); }

    // ══ math.zag ═════════════════════════════════════════════════════════════

    if (math_abs(-7) == 7) { _zag_println("math_abs_neg: PASS"); } else { _zag_println("math_abs_neg: FAIL"); }
    if (math_abs(7) == 7)  { _zag_println("math_abs_pos: PASS"); } else { _zag_println("math_abs_pos: FAIL"); }
    if (math_abs(0) == 0)  { _zag_println("math_abs_zero: PASS"); } else { _zag_println("math_abs_zero: FAIL"); }

    if (math_min(3, 7) == 3) { _zag_println("math_min: PASS"); } else { _zag_println("math_min: FAIL"); }
    if (math_max(3, 7) == 7) { _zag_println("math_max: PASS"); } else { _zag_println("math_max: FAIL"); }

    if (math_clamp(5, 0, 10) == 5)  { _zag_println("math_clamp_mid: PASS"); } else { _zag_println("math_clamp_mid: FAIL"); }
    if (math_clamp(-5, 0, 10) == 0) { _zag_println("math_clamp_low: PASS"); } else { _zag_println("math_clamp_low: FAIL"); }
    if (math_clamp(15, 0, 10) == 10){ _zag_println("math_clamp_hi: PASS");  } else { _zag_println("math_clamp_hi: FAIL");  }

    if (math_pow_i32(2, 10) == 1024) { _zag_println("math_pow_i32: PASS");      } else { _zag_println("math_pow_i32: FAIL");      }
    if (math_pow_i32(3, 0)  == 1)    { _zag_println("math_pow_i32_zero: PASS"); } else { _zag_println("math_pow_i32_zero: FAIL"); }
    if (math_pow_i32(5, 3)  == 125)  { _zag_println("math_pow_i32_5x3: PASS"); } else { _zag_println("math_pow_i32_5x3: FAIL"); }

    if (math_gcd(12, 8) == 4) { _zag_println("math_gcd: PASS");       } else { _zag_println("math_gcd: FAIL");       }
    if (math_gcd(0, 5)  == 5) { _zag_println("math_gcd_zero: PASS");   } else { _zag_println("math_gcd_zero: FAIL");  }
    if (math_gcd(7, 7)  == 7) { _zag_println("math_gcd_equal: PASS");  } else { _zag_println("math_gcd_equal: FAIL"); }

    // ══ fmt.zag ══════════════════════════════════════════════════════════════

    let fi: []u8 = fmt_int(42 as i64);
    if (str_eq(fi, "42") == 1)   { _zag_println("fmt_int: PASS"); } else { _zag_println("fmt_int: FAIL"); }

    let fi2: []u8 = fmt_int(0 - 7 as i64);
    if (str_eq(fi2, "-7") == 1)  { _zag_println("fmt_int_neg: PASS"); } else { _zag_println("fmt_int_neg: FAIL"); }

    if (str_eq(fmt_bool(1), "true")  == 1) { _zag_println("fmt_bool_t: PASS"); } else { _zag_println("fmt_bool_t: FAIL"); }
    if (str_eq(fmt_bool(0), "false") == 1) { _zag_println("fmt_bool_f: PASS"); } else { _zag_println("fmt_bool_f: FAIL"); }

    // strlist
    let sl: StrList = strlist_new(4);
    strlist_push(&sl, "foo");
    strlist_push(&sl, "bar");
    if (str_eq(strlist_get(&sl, 0), "foo") == 1) { _zag_println("strlist_get0: PASS"); } else { _zag_println("strlist_get0: FAIL"); }
    if (str_eq(strlist_get(&sl, 1), "bar") == 1) { _zag_println("strlist_get1: PASS"); } else { _zag_println("strlist_get1: FAIL"); }

    let cat: []u8 = fmt_concat(&sl);
    if (str_eq(cat, "foobar") == 1) { _zag_println("fmt_concat: PASS"); } else { _zag_println("fmt_concat: FAIL"); }

    let jl: StrList = strlist_new(3);
    strlist_push(&jl, "a");
    strlist_push(&jl, "b");
    strlist_push(&jl, "c");
    let joined: []u8 = fmt_join(&jl, ",");
    if (str_eq(joined, "a,b,c") == 1) { _zag_println("fmt_join: PASS"); } else { _zag_println("fmt_join: FAIL"); }

    strlist_free(&sl);
    strlist_free(&jl);

    // ══ collections.zag ══════════════════════════════════════════════════════

    let v: I32List = i32list_new(4);
    i32list_push(&v, 10);
    i32list_push(&v, 20);
    i32list_push(&v, 30);

    if (i32list_len(&v) == 3)     { _zag_println("i32list_len: PASS");  } else { _zag_println("i32list_len: FAIL");  }
    if (i32list_get(&v, 0) == 10) { _zag_println("i32list_get: PASS");  } else { _zag_println("i32list_get: FAIL");  }
    if (i32list_get(&v, 2) == 30) { _zag_println("i32list_get2: PASS"); } else { _zag_println("i32list_get2: FAIL"); }

    i32list_set(&v, 1, 99);
    if (i32list_get(&v, 1) == 99) { _zag_println("i32list_set: PASS"); } else { _zag_println("i32list_set: FAIL"); }
    i32list_set(&v, 1, 20);

    if (list_contains(&v, 20) == 1) { _zag_println("list_contains_t: PASS"); } else { _zag_println("list_contains_t: FAIL"); }
    if (list_contains(&v, 99) == 0) { _zag_println("list_contains_f: PASS"); } else { _zag_println("list_contains_f: FAIL"); }

    if (list_sum(&v) == 60)  { _zag_println("list_sum: PASS"); } else { _zag_println("list_sum: FAIL"); }
    if (list_min(&v) == 10)  { _zag_println("list_min: PASS"); } else { _zag_println("list_min: FAIL"); }
    if (list_max(&v) == 30)  { _zag_println("list_max: PASS"); } else { _zag_println("list_max: FAIL"); }

    let doubled: I32List = list_map_i32(&v, _t_double);
    if (i32list_get(&doubled, 0) == 20) { _zag_println("list_map_i32: PASS"); } else { _zag_println("list_map_i32: FAIL"); }
    if (i32list_get(&doubled, 2) == 60) { _zag_println("list_map_i32_2: PASS"); } else { _zag_println("list_map_i32_2: FAIL"); }

    // list with mixed parity for filter: 10 (even), 20 (even), 30 (even) → all even
    let evens: I32List = list_filter_i32(&v, _t_is_even);
    if (i32list_len(&evens) == 3) { _zag_println("list_filter_i32: PASS"); } else { _zag_println("list_filter_i32: FAIL"); }

    // add an odd element and re-filter
    let v2: I32List = i32list_new(4);
    i32list_push(&v2, 1);
    i32list_push(&v2, 2);
    i32list_push(&v2, 3);
    i32list_push(&v2, 4);
    let evens2: I32List = list_filter_i32(&v2, _t_is_even);
    if (i32list_len(&evens2) == 2) { _zag_println("list_filter_odd: PASS"); } else { _zag_println("list_filter_odd: FAIL"); }

    let rev: I32List = list_reverse_i32(&v);
    if (i32list_get(&rev, 0) == 30) { _zag_println("list_reverse_first: PASS"); } else { _zag_println("list_reverse_first: FAIL"); }
    if (i32list_get(&rev, 2) == 10) { _zag_println("list_reverse_last: PASS");  } else { _zag_println("list_reverse_last: FAIL");  }

    i32list_free(&v);
    i32list_free(&v2);
    i32list_free(&doubled);
    i32list_free(&evens);
    i32list_free(&evens2);
    i32list_free(&rev);

    return 0;
}
