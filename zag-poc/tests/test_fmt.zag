@import("../selfhost/std/fmt.zag")

fn main() i32 {
    let s: []u8 = fmt_int(42 as i64);
    _zag_println(s);
    _zag_println(fmt_bool(1));
    _zag_println(fmt_bool(0));

    let parts: StrList = strlist_new(3);
    strlist_push(&parts, "hello");
    strlist_push(&parts, " ");
    strlist_push(&parts, "world");
    let joined: []u8 = fmt_concat(&parts);
    _zag_println(joined);

    let parts2: StrList = strlist_new(3);
    strlist_push(&parts2, "one");
    strlist_push(&parts2, "two");
    strlist_push(&parts2, "three");
    let joined2: []u8 = fmt_join(&parts2, ",");
    _zag_println(joined2);

    print_int32(123);
    println_int32(456);
    print_bool(1);
    print_bool(0);
    return 0;
}
