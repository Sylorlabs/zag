// tests/module_system/utils.zag — example module with public and private fns.
// `pub` declarations are part of the module's public API.
// Non-pub declarations are private to the module.

pub fn add(a: i32, b: i32) i32 {
    return a + b;
}

pub fn mul(a: i32, b: i32) i32 {
    return a * b;
}

fn internal() i32 {
    return 0;
}
