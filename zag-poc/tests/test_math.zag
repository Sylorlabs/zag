@import("../selfhost/std/math.zag")

fn main() i32 {
    print_int(math_abs(-42));
    print_int(math_abs(0));
    print_int(math_abs(17));
    print_int(math_min(3, 7));
    print_int(math_max(3, 7));
    print_int(math_clamp(5, 0, 10));
    print_int(math_clamp(-5, 0, 10));
    print_int(math_clamp(15, 0, 10));
    print_int(math_pow_i32(2, 10));
    print_int(math_pow_i32(3, 4));
    print_int(math_pow_i32(5, 0));
    print_int(math_gcd(12, 8));
    print_int(math_gcd(100, 75));
    print_int(math_gcd(0, 5));
    return 0;
}
