// Native-only v1 standard-library surface test.
@import("../selfhost/std/std.zag")

fn main() i32 {
    let t: TestState = test_state();

    let list: I32List = i32list_new(2);
    i32list_push(&list, 7);
    i32list_push(&list, 11);
    test_expect_eq_i32(&t, list_sum(&list), 18, "collections");

    test_expect(&t, str_contains("owned by Zag", "Zag"), "strings");

    let path: []u8 = "/tmp/zag_stdlib_v1.txt";
    test_expect_eq_i32(&t, io_write_file(path, "native"), 0, "file write");
    test_expect_str(&t, io_read_file(path), "native", "file read");

    test_expect(&t, process_arg_count() >= 1, "process argc");
    test_expect(&t, process_arg(0).len > 0, "process argv");
    test_expect_eq_i32(&t, process_run_shell("exit 7"), 7, "process execution");

    let before: i64 = time_monotonic_ms();
    let after: i64 = time_monotonic_ms();
    test_expect(&t, before >= 0, "monotonic clock available");
    test_expect(&t, after >= before, "monotonic clock ordered");

    i32list_free(&list);
    return test_exit_code(&t);
}
