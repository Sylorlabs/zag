// Test: heap closures with aggregate (struct) captures.
// Uses explicit capture-list syntax fn[var](params) ret { body }.

struct Vec2 { x: i32, y: i32 }

fn apply(op: fn(i32) i32, v: i32) i32 {
    return op(v);
}

fn apply2(op: fn() i32) i32 {
    return op();
}

fn main() i32 {
    // Scalar capture: existing path, must still work
    let scale: i32 = 3;
    let r1: i32 = apply(fn[scale](v: i32) i32 { return v * scale; }, 7);
    if (r1 == 21) {
        _zag_println("scalar_cap: PASS");
    } else {
        _zag_println("scalar_cap: FAIL");
    }

    // Aggregate capture: struct Vec2 passed by value → heap copy
    let p: Vec2 = Vec2{ .x = 4, .y = 6 };
    let r2: i32 = apply2(fn[p]() i32 { return p.x + p.y; });
    if (r2 == 10) {
        _zag_println("agg_cap: PASS");
    } else {
        _zag_println("agg_cap: FAIL");
    }

    return 0;
}
