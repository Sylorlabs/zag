// tests/stdlib2_test.zag — PASS/FAIL tests for sort, hashmap, and strbuf.
// Compile and run:
//   ./znc tests/stdlib2_test.zag -o /tmp/stdlib2_test && /tmp/stdlib2_test

@import("../selfhost/std/collections.zag")
@import("../selfhost/std/hashmap.zag")
@import("../selfhost/std/strbuf.zag")

fn main() i32 {
    // ══ collections.zag — sort ════════════════════════════════════════════════

    // list_sort_asc
    let sa: I32List = i32list_new(5);
    i32list_push(&sa, 5);
    i32list_push(&sa, 2);
    i32list_push(&sa, 8);
    i32list_push(&sa, 1);
    i32list_push(&sa, 9);
    list_sort_asc(&sa);
    if (i32list_get(&sa, 0) == 1 && i32list_get(&sa, 1) == 2 && i32list_get(&sa, 2) == 5 && i32list_get(&sa, 3) == 8 && i32list_get(&sa, 4) == 9) {
        _zag_println("list_sort_asc: PASS");
    } else {
        _zag_println("list_sort_asc: FAIL");
    }

    // list_sort_desc
    let sd: I32List = i32list_new(5);
    i32list_push(&sd, 5);
    i32list_push(&sd, 2);
    i32list_push(&sd, 8);
    i32list_push(&sd, 1);
    i32list_push(&sd, 9);
    list_sort_desc(&sd);
    if (i32list_get(&sd, 0) == 9 && i32list_get(&sd, 1) == 8 && i32list_get(&sd, 2) == 5 && i32list_get(&sd, 3) == 2 && i32list_get(&sd, 4) == 1) {
        _zag_println("list_sort_desc: PASS");
    } else {
        _zag_println("list_sort_desc: FAIL");
    }

    // list_bsearch — found
    let idx_f: i32 = list_bsearch(&sa, 5);
    if (idx_f == 2) {
        _zag_println("list_bsearch_found: PASS");
    } else {
        _zag_println("list_bsearch_found: FAIL");
    }

    // list_bsearch — not found
    let idx_nf: i32 = list_bsearch(&sa, 7);
    if (idx_nf == -1) {
        _zag_println("list_bsearch_notfound: PASS");
    } else {
        _zag_println("list_bsearch_notfound: FAIL");
    }

    // bsearch on first/last element
    if (list_bsearch(&sa, 1) == 0) {
        _zag_println("list_bsearch_first: PASS");
    } else {
        _zag_println("list_bsearch_first: FAIL");
    }
    if (list_bsearch(&sa, 9) == 4) {
        _zag_println("list_bsearch_last: PASS");
    } else {
        _zag_println("list_bsearch_last: FAIL");
    }

    i32list_free(&sa);
    i32list_free(&sd);

    // ══ hashmap.zag ══════════════════════════════════════════════════════════

    let m: StrMap = strmap_new(8);

    // Basic insert + get
    strmap_put(&m, "foo", 42);
    strmap_put(&m, "bar", 99);
    strmap_put(&m, "baz", 7);

    if (strmap_get(&m, "foo") == 42) {
        _zag_println("strmap_get_foo: PASS");
    } else {
        _zag_println("strmap_get_foo: FAIL");
    }
    if (strmap_get(&m, "bar") == 99) {
        _zag_println("strmap_get_bar: PASS");
    } else {
        _zag_println("strmap_get_bar: FAIL");
    }
    if (strmap_get(&m, "baz") == 7) {
        _zag_println("strmap_get_baz: PASS");
    } else {
        _zag_println("strmap_get_baz: FAIL");
    }

    // has — present and absent
    if (strmap_has(&m, "foo") == 1) {
        _zag_println("strmap_has_t: PASS");
    } else {
        _zag_println("strmap_has_t: FAIL");
    }
    if (strmap_has(&m, "qux") == 0) {
        _zag_println("strmap_has_f: PASS");
    } else {
        _zag_println("strmap_has_f: FAIL");
    }

    // count
    if (strmap_count(&m) == 3) {
        _zag_println("strmap_count: PASS");
    } else {
        _zag_println("strmap_count: FAIL");
    }

    // Update existing key
    strmap_put(&m, "foo", 100);
    if (strmap_get(&m, "foo") == 100) {
        _zag_println("strmap_update: PASS");
    } else {
        _zag_println("strmap_update: FAIL");
    }
    if (strmap_count(&m) == 3) {
        _zag_println("strmap_count_after_update: PASS");
    } else {
        _zag_println("strmap_count_after_update: FAIL");
    }

    // Delete
    strmap_del(&m, "bar");
    if (strmap_has(&m, "bar") == 0) {
        _zag_println("strmap_del: PASS");
    } else {
        _zag_println("strmap_del: FAIL");
    }
    if (strmap_count(&m) == 2) {
        _zag_println("strmap_count_after_del: PASS");
    } else {
        _zag_println("strmap_count_after_del: FAIL");
    }

    // Other entries unaffected after deletion
    if (strmap_get(&m, "foo") == 100 && strmap_get(&m, "baz") == 7) {
        _zag_println("strmap_others_intact: PASS");
    } else {
        _zag_println("strmap_others_intact: FAIL");
    }

    // Missing key returns -1
    if (strmap_get(&m, "missing") == -1) {
        _zag_println("strmap_get_missing: PASS");
    } else {
        _zag_println("strmap_get_missing: FAIL");
    }

    strmap_free(&m);

    // ══ strbuf.zag ═══════════════════════════════════════════════════════════

    let b: StrBuf = strbuf_new(4);

    // append + len
    strbuf_append(&b, "hello");
    strbuf_append(&b, " world");
    if (strbuf_len(&b) == 11) {
        _zag_println("strbuf_len: PASS");
    } else {
        _zag_println("strbuf_len: FAIL");
    }

    // finish
    let r1: []u8 = strbuf_finish(&b);
    if (_zag_strcmp(r1, "hello world") == 1) {
        _zag_println("strbuf_finish: PASS");
    } else {
        _zag_println("strbuf_finish: FAIL");
    }

    // append_int
    strbuf_append_int(&b, 42 as i64);
    let r2: []u8 = strbuf_finish(&b);
    if (_zag_strcmp(r2, "hello world42") == 1) {
        _zag_println("strbuf_append_int: PASS");
    } else {
        _zag_println("strbuf_append_int: FAIL");
    }

    // append_int negative
    let b2: StrBuf = strbuf_new(8);
    strbuf_append_int(&b2, -7 as i64);
    let r3: []u8 = strbuf_finish(&b2);
    if (_zag_strcmp(r3, "-7") == 1) {
        _zag_println("strbuf_append_int_neg: PASS");
    } else {
        _zag_println("strbuf_append_int_neg: FAIL");
    }
    strbuf_free(&b2);

    // reset
    strbuf_reset(&b);
    if (strbuf_len(&b) == 0) {
        _zag_println("strbuf_reset: PASS");
    } else {
        _zag_println("strbuf_reset: FAIL");
    }

    // append_char
    strbuf_append_char(&b, 65);   // 'A'
    strbuf_append_char(&b, 66);   // 'B'
    strbuf_append_char(&b, 67);   // 'C'
    let r4: []u8 = strbuf_finish(&b);
    if (_zag_strcmp(r4, "ABC") == 1) {
        _zag_println("strbuf_append_char: PASS");
    } else {
        _zag_println("strbuf_append_char: FAIL");
    }

    // growth: start with small cap and grow by appending more than initial cap
    let b3: StrBuf = strbuf_new(4);
    strbuf_append(&b3, "0123456789abcdef0123456789abcdef");  // 32 bytes > initial 16
    if (strbuf_len(&b3) == 32) {
        _zag_println("strbuf_grow: PASS");
    } else {
        _zag_println("strbuf_grow: FAIL");
    }
    strbuf_free(&b3);

    strbuf_free(&b);

    return 0;
}
