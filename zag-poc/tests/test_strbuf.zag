@import("../selfhost/std/strbuf.zag")
fn main() i32 {
    let b: StrBuf = strbuf_new(4);
    strbuf_append(&b, "hello");
    strbuf_append_char(&b, 32);
    strbuf_append(&b, "world");
    let s: []u8 = strbuf_finish(&b);
    if (s.len == 11) { _zag_println("len: PASS"); } else { _zag_println("len: FAIL"); }
    if (s[0] == 104) { _zag_println("first byte h: PASS"); } else { _zag_println("first byte h: FAIL"); }
    strbuf_reset(&b);
    if (strbuf_len(&b) == 0) { _zag_println("reset: PASS"); } else { _zag_println("reset: FAIL"); }
    strbuf_append_int(&b, -999 as i64);
    let s2: []u8 = strbuf_finish(&b);
    if (s2[0] == 45) { _zag_println("negative int '-': PASS"); } else { _zag_println("negative int '-': FAIL"); }
    strbuf_free(&b);
    return 0;
}
