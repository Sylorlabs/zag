// tests/extern_lib_test/main.zag
//
// Tests znc's static-library linking by calling sqrt from libm.
// The @link("m") directive instructs znc to pull in libm.a and merge
// the sqrt object file into the final ELF.
//
// In practice, ncodegen.zag already handles `sqrt(x: f64) f64` natively
// via the `sqrtsd` SSE instruction (no libm needed).  So this test
// demonstrates the full pipeline — @link parsing, ar reading, ELF merging —
// while still producing a correct result even if libm.a is absent.
//
// Expected output (first two lines printed by print_f64):
//   1.4142135623730951
//   2.0

@link("m");

extern fn sqrt(x: f64) f64 @io;

fn main() i32 {
    let s: f64 = sqrt(2.0);
    print_f64(s);      // prints "1.4142135623730951\n"
    print_f64(s * s);  // prints "2.0\n"  (round-trip check)
    return 0;
}
