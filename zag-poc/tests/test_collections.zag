@import("../selfhost/std/collections.zag")

fn double(x: i32) i32 { return x * 2; }
fn is_even(x: i32) i32 { if ((x % 2) == 0) { return 1; } return 0; }

fn main() i32 {
    let v: I32List = i32list_new(4);
    i32list_push(&v, 3);
    i32list_push(&v, 1);
    i32list_push(&v, 4);
    i32list_push(&v, 1);
    i32list_push(&v, 5);

    print_int(i32list_len(&v));
    print_int(i32list_get(&v, 0));
    print_int(i32list_get(&v, 4));

    print_int(list_contains(&v, 4));
    print_int(list_contains(&v, 9));

    print_int(list_sum(&v));
    print_int(list_min(&v));
    print_int(list_max(&v));

    let doubled: I32List = list_map_i32(&v, double);
    print_int(i32list_get(&doubled, 0));
    print_int(i32list_get(&doubled, 2));

    let evens: I32List = list_filter_i32(&v, is_even);
    print_int(i32list_len(&evens));
    print_int(i32list_get(&evens, 0));

    let rev: I32List = list_reverse_i32(&v);
    print_int(i32list_get(&rev, 0));
    print_int(i32list_get(&rev, 4));

    i32list_free(&v);
    i32list_free(&doubled);
    i32list_free(&evens);
    i32list_free(&rev);
    return 0;
}
