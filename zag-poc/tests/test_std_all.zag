@import("../selfhost/std/std.zag")

fn main() i32 {
    // str
    print_int(str_len("hello"));
    print_int(str_eq("abc", "abc"));
    // fmt
    _zag_println(fmt_int(99 as i64));
    _zag_println(fmt_bool(1));
    _zag_println(fmt_bool(0));
    // io
    let path: []u8 = "/tmp/zag_std_all_test.txt";
    let _r: i32 = io_write_file(path, "test");
    print_int(io_file_exists(path));
    // collections
    let v: I32List = i32list_new(3);
    i32list_push(&v, 10);
    i32list_push(&v, 20);
    i32list_push(&v, 30);
    print_int(list_sum(&v));
    print_int(list_min(&v));
    print_int(list_max(&v));
    i32list_free(&v);
    // math
    print_int(math_abs(-7));
    print_int(math_gcd(12, 8));
    print_int(math_pow_i32(2, 8));
    return 0;
}
