// std/rt.zag — low-level runtime bindings (FFI to std/runtime.c)
//
// These are the primitive operations the rest of the standard library is built
// on. They are `extern fn` declarations: the compiler emits C prototypes and
// links std/runtime.c (auto-discovered next to this module).
//
// Effect declarations on extern fns are REAL: the effect checker treats
// @alloc/@panic/@io/@lock here as the latent effects the function introduces,
// and propagates them to every caller. A @realtime function that transitively
// calls _zag_malloc is therefore rejected at compile time.
//
// Pointer convention: raw byte buffers are typed `*i8` and cast to `*T` with
// `as` at the typed boundary (see std/list.zag, std/map.zag).

// ── memory ────────────────────────────────────────────────────────────────
extern fn _zag_malloc(n: i32) *i8 @alloc @panic;
extern fn _zag_realloc(p: *i8, n: i32) *i8 @alloc @panic;
extern fn _zag_free(p: *i8) void @alloc;
extern fn _zag_memcpy(dst: *i8, src: *i8, n: i32) void;
extern fn _zag_memcmp(a: *i8, b: *i8, n: i32) i32;

// ── strings (slice-based, NUL-free) ─────────────────────────────────────────
extern fn _zag_strlen(s: []u8) i32;
extern fn _zag_strcmp(a: []u8, b: []u8) i32;          // 1 if equal, else 0
extern fn _zag_strcmp_ord(a: []u8, b: []u8) i32;      // <0 / 0 / >0
extern fn _zag_strdup(s: []u8) []u8 @alloc;
extern fn _zag_str_concat(a: []u8, b: []u8) []u8 @alloc;
extern fn _zag_str_index_of_byte(s: []u8, b: i32) i32;
extern fn _zag_i64_to_str(v: i64) []u8 @alloc;
extern fn _zag_u64_to_str(v: u64) []u8 @alloc;
extern fn _zag_str_to_i64(s: []u8) i64;

// ── io ──────────────────────────────────────────────────────────────────────
extern fn _zag_print(s: []u8) void @io;
extern fn _zag_println(s: []u8) void @io;
extern fn _zag_eprintln(s: []u8) void @io;
extern fn _zag_flush() void @io;

// ── filesystem ───────────────────────────────────────────────────────────────
// _zag_read_file returns a slice with len == -1 on failure.
extern fn _zag_read_file(path: []u8) []u8 @io @alloc;
extern fn _zag_write_file(path: []u8, content: []u8) i32 @io;
extern fn _zag_file_exists(path: []u8) i32 @io;

// ── process ───────────────────────────────────────────────────────────────────
extern fn _zag_exec_cmd(cmd: []u8) i32 @io;
extern fn _zag_exec_capture(cmd: []u8) []u8 @io @alloc;

// ── control ───────────────────────────────────────────────────────────────────
extern fn _zag_exit(code: i32) void @io;

// ── command-line args ─────────────────────────────────────────────────────────
extern fn _zag_argc() i32 @io;
extern fn _zag_arg(idx: i32) []u8 @io;
