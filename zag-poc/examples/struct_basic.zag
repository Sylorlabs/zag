// Structs: declaration, construction (Name{ .field = .. }), and field access.

struct Osc { freq: f32, amp: f32 }

fn sample(o: Osc) f32 @realtime {
    return o.amp * sinf(o.freq);     // field access + pure math => realtime-safe
}

fn main() i32 {
    let o: Osc = Osc{ .freq = 0.05, .amp = 0.8 };
    print_f32(sample(o));            // 0.8 * sin(0.05) ≈ 0.04
    return 0;
}
