// Airtight check: @realtime forbids Lock and IO too, not just Alloc.
// printMeter does IO (print) and takes a lock — both illegal on the audio thread.

fn printMeter(level: f32) void @realtime {
    lock();              // Lock — parking the audio thread = dropout
    print_f32(level);    // IO   — syscalls on the audio thread = dropout
}

fn main() i32 {
    printMeter(0.5);
    return 0;
}
