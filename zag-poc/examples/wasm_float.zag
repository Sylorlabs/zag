// f32/f64 locals, arithmetic, and casts for the self-contained WASM backend.

fn scale(x: f32, y: f64) f64 {
    return x as f64 * y;
}

fn main() i32 {
    let a: f32 = 1.5;
    let b: f32 = 2.5;
    let c: f32 = a + b;          // 4.0
    let d: f64 = scale(c, 2.0);  // 8.0
    return d as i32;
}