// utils.zag — simple utility functions for testing qualified @import

fn clamp(v: i32, lo: i32, hi: i32) i32 {
    if (v < lo) { return lo; }
    if (v > hi) { return hi; }
    return v;
}

fn abs_i32(v: i32) i32 {
    if (v < 0) { return 0 - v; }
    return v;
}

fn max_i32(a: i32, b: i32) i32 {
    if (a > b) { return a; }
    return b;
}

fn min_i32(a: i32, b: i32) i32 {
    if (a < b) { return a; }
    return b;
}
