// Closures are allocation-free because their environment lives on the stack. The price:
// a closure that captures locals may NOT escape its scope (its environment would dangle).
// Returning one is rejected — heap-allocated escaping closures are deferred Phase-1 work.

fn makeScaler(k: f32) fn(f32) f32 ! pure {
    return fn[k](x: f32) f32 { return x * k; };   // REJECTED: capturing closure escapes
}

fn main() i32 {
    return 0;
}
