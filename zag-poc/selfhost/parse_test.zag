// selfhost/parse_test.zag — exercises the self-hosted parser.
// Parses a function and prints a pre-order dump (node codes + key strings),
// which the test harness checks against a golden sequence.

@import("parse.zag")

fn dump_list(xs: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](xs)) {
        dump(get[*Node](xs, i));
        i = i + 1;
    }
}

fn dump(n: *Node) void {
    print_i32(node_code(n));
    switch (n.*) {
        .fn_decl => |f| { print_str(f.name); print_str(f.ret); dump_list(f.body); }
        .let_    => |l| { print_str(l.name); dump(l.expr); }
        .ret     => |r| { if (r.has_expr == 1) { dump(r.expr); } }
        .if_     => |x| { dump(x.cond); dump_list(x.then_body); if (x.has_els == 1) { dump_list(x.els_body); } }
        .while_  => |w| { dump(w.cond); dump_list(w.body); }
        .assign  => |a| { dump(a.target); dump(a.expr); }
        .estmt   => |e| { dump(e.expr); }
        .ilit    => |i| { print_str(i.text); }
        .slit    => |s| { print_str(s.text); }
        .id      => |d| { print_str(d.name); }
        .bin     => |b| { print_str(b.op); dump(b.l); dump(b.r); }
        .un      => |u| { print_str(u.op); dump(u.e); }
        .call    => |c| { dump(c.callee); dump_list(c.args); }
        .idx     => |x| { dump(x.base); dump(x.idx); }
        .fld     => |x| { dump(x.base); print_str(x.fname); }
    }
}

fn main() void {
    let src: []u8 = "fn fib(n: i32) i32 { if (n < 2) { return n; } return fib(n - 1) + fib(n - 2); }";
    let decls: ArrayList[*Node] = parse_program(src);
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        dump(get[*Node](decls, i));
        i = i + 1;
    }
}
