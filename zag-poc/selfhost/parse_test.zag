// selfhost/parse_test.zag — exercises the self-hosted parser.
// Parses a function and prints a pre-order dump (node codes + key strings),
// which the test harness checks against a golden sequence.

@import("parse.zag")

fn dump_list(xs: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](xs)) {
        dump(get[*Node](xs, i));
        i = i + 1;
    }
}

fn dump_params(xs: ArrayList[Param]) void {
    let i: i32 = 0;
    while (i < len[Param](xs)) {
        let p: Param = get[Param](xs, i);
        print_str(p.name);
        print_str(p.pty);
        i = i + 1;
    }
}

fn dump_strs(xs: ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[[]u8](xs)) {
        print_str(get[[]u8](xs, i));
        i = i + 1;
    }
}

fn dump_fields(xs: ArrayList[FieldInit]) void {
    let i: i32 = 0;
    while (i < len[FieldInit](xs)) {
        let f: FieldInit = get[FieldInit](xs, i);
        print_str(f.name);
        dump(f.val);
        i = i + 1;
    }
}

fn dump(n: *Node) void {
    print_i32(node_code(n));
    switch (n.*) {
        .fn_decl => |f| { print_str(f.name); print_str(f.ret); dump_list(f.body); }
        .let_    => |l| { print_str(l.name); dump(l.expr); }
        .ret     => |r| { if (r.has_expr == 1) { dump(r.expr); } }
        .if_     => |x| { dump(x.cond); dump_list(x.then_body); if (x.has_els == 1) { dump_list(x.els_body); } }
        .while_  => |w| { dump(w.cond); dump_list(w.body); }
        .assign  => |a| { dump(a.target); dump(a.expr); }
        .estmt   => |e| { dump(e.expr); }
        .ilit    => |i| { print_str(i.text); }
        .slit    => |s| { print_str(s.text); }
        .id      => |d| { print_str(d.name); }
        .bin     => |b| { print_str(b.op); dump(b.l); dump(b.r); }
        .un      => |u| { print_str(u.op); dump(u.e); }
        .call    => |c| { dump(c.callee); dump_list(c.args); }
        .idx     => |x| { dump(x.base); dump(x.idx); }
        .fld     => |x| { dump(x.base); print_str(x.fname); }
        .slit_   => |s| { print_str(s.sname); dump_fields(s.fields); }
        .struct_ => |s| { print_str(s.name); dump_params(s.fields); }
        .enum_   => |e| { print_str(e.name); dump_strs(e.members); }
        .union_  => |u| { print_str(u.name); dump_params(u.fields); }
    }
}

fn dump_program(src: []u8) void {
    let decls: ArrayList[*Node] = parse_program(src);
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        dump(get[*Node](decls, i));
        i = i + 1;
    }
}

fn main() void {
    // Recursive fn — checks if/return/call/operator-precedence.
    dump_program("fn fib(n: i32) i32 { if (n < 2) { return n; } return fib(n - 1) + fib(n - 2); }");
    // Type decls + struct literal + field access.
    dump_program("enum Color { Red, Green, Blue }");
    dump_program("struct Point { x: i32, y: i32 }");
    dump_program("union Val { num: i32, flag: bool }");
    dump_program("fn origin() Point { return Point{ .x = 0, .y = 0 }; }");
    dump_program("fn getx(p: *Point) i32 { return p.*.x; }");
}
