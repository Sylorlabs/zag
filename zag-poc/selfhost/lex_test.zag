// selfhost/lex_test.zag — exercises the self-hosted lexer.
// Lexes a representative Zag snippet and prints "code:text" for each token.

@import("lex.zag")

fn main() void {
    let src: []u8 = "fn add(a: i32, b: i32) i32 @realtime { let x: i32 = a + b; return x >= 0; }";
    let toks: ArrayList[Token] = lex(src);
    let i: i32 = 0;
    let n: i32 = len[Token](toks);
    // Print kind codes only (purely numeric, unambiguous for the test harness).
    while (i < n) {
        let t: Token = get[Token](toks, i);
        print_i32(tk_code(t.kind));
        i = i + 1;
    }
    // Then a few token texts, prefixed, to verify slice extraction works.
    print_str(get[Token](toks, 0).val);   // fn
    print_str(get[Token](toks, 1).val);   // add
    print_str(get[Token](toks, 12).val);  // @realtime
}
