// selfhost/sema_eu_test.zag — unit test for the error-union assignment check.
//
// Parses a mini-program that contains two !T calls:
//   - parse_ok  uses `catch 0`          → valid, NOT flagged
//   - drop_err  assigns bare !i32 call  → violation
//
// Expected output: exactly one VIOLATION line mentioning drop_err.

@import("sema.zag")

fn main() void {
    let src: []u8 = "error { Oops } fn may_fail() !i32 { return error.Oops; } fn parse_ok() i32 { let v: i32 = may_fail() catch 0; return v; } fn drop_err() i32 { let v: i32 = may_fail(); return v; }";

    let decls: ArrayList[*Node] = parse_program(src);
    let eff: map.StringMap[i32] = analyze(decls);
    let n: i32 = report_violations(decls, eff);
    if (n == 1) {
        _zag_println("sema_eu_test: PASS (1 violation caught)");
    } else {
        _zag_print("sema_eu_test: FAIL (expected 1 violation, got ");
        _zag_print(_zag_i64_to_str(n as i64));
        _zag_println(")");
    }
}
