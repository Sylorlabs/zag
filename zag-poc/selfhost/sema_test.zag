// selfhost/sema_test.zag — exercises the self-hosted effect/capability checker.
//
// Parses a program, runs the fixpoint effect analysis, and for every function
// carrying a capability constraint prints:  <name> <violated-mask>
// where 0 means the constraint is PROVEN, and a nonzero mask names the
// forbidden effect that leaked through (Alloc=1, Panic=2, IO=4, Lock=8).

@import("sema.zag")

fn check_fn(f: FnDecl, eff: map.StringMap[i32]) void {
    let myeff: i32 = map.get[i32](eff, f.name) orelse 0;
    let i: i32 = 0;
    while (i < len[[]u8](f.annots)) {
        let a: []u8 = get[[]u8](f.annots, i);
        let forb: i32 = forbidden_bits(a);
        if (forb != 0) {
            print_str(f.name);
            print_i32(myeff & forb);   // 0 = proven safe; else violating effect bits
        }
        i = i + 1;
    }
}

fn check_decl(d: *Node, eff: map.StringMap[i32]) void {
    switch (d.*) {
        .fn_decl => |f| { check_fn(f, eff); }
        else => { }
    }
}

fn main() void {
    let src: []u8 = "extern fn alloc_mem(n: i32) *i8 @alloc; fn safe_add(a: i32, b: i32) i32 @realtime { return a + b; } fn bad_rt(n: i32) i32 @realtime { let p: *i8 = alloc_mem(n); return 0; } fn uses_io() void { print_i32(5); } fn rt_io() void @realtime { uses_io(); } fn pure_calc(x: i32) i32 @total { return x + 1; } fn total_div(x: i32, d: i32) i32 @total { return x / d; }";

    let decls: ArrayList[*Node] = parse_program(src);
    let eff: map.StringMap[i32] = analyze(decls);
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        check_decl(get[*Node](decls, i), eff);
        i = i + 1;
    }
}
