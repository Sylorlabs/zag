// selfhost/lsp/zag-lsp.zag — entry point for the Zag Language Server.
//
// Build:
//   ./znc selfhost/lsp/zag-lsp.zag -o zag-lsp
//
// Usage (editors connect to this process via stdio):
//   ./zag-lsp
//
// Test (send an LSP initialize message):
//   echo -e 'Content-Length: 97\r\n\r\n{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"capabilities":{},"rootUri":null}}' | ./zag-lsp

@import("server.zag")

fn main() i32 {
    lsp_main();
    return 0;
}
