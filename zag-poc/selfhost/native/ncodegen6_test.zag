// selfhost/native/ncodegen6_test.zag — REAL end-to-end verification of ROUND-3
// of NATIVE SELF-HOSTING: a NATIVE SYSCALL RUNTIME (every `_zag_*` extern is now
// raw x86-64 + Linux syscalls — NOT one bit of C), plus the codegen tail
// (`&expr`, `.slice_`, aggregate let from a call, boolean literals, >6 args,
// aggregate ArrayList elements, byte-packed buffers, capture-aggregate fields).
//
// Every program is COMPILED straight to a runnable native ELF (no cc/as/ld/libc/
// LLVM) and is PROVEN by running the emitted binary and checking its stdout/exit:
//
//   parse → lower_program(decls,&err,&data) → encode → write_elf_exec_data → run
//
//   Build:  ./zagc build selfhost/native/ncodegen6_test.zag --run
//   Then:   the bash driver runs each /tmp/n6_* and checks exit code / stdout.

@import("x86.zag")
@import("elf.zag")
@import("ncodegen.zag")

// Compile `src` to a runnable native ELF at `path`; report err/instr/code sizes.
fn build(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, "selfhost/native");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let code: ArrayList[u8] = encode(prog);
    let rc: i32 = write_elf_exec_data(path, code, 0, data);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    _zag_print(" instrs=");
    _zag_print(_zag_i64_to_str(prog.len as i64));
    _zag_print(" code=");
    _zag_print(_zag_i64_to_str(code.len as i64));
    _zag_print(" -> ");
    _zag_print(path);
    if (rc == 0) { _zag_println(" OK"); }
    else { _zag_println(" WRITE-FAILED"); }
}

fn main() void {
    // ══ 1. NATIVE SYSCALL RUNTIME — I/O via write(2) ═══════════════════════════
    // _zag_println → write(1, ptr, len) + '\n'. Prints "native runtime works".
    build("rt1_println", "/tmp/n6_rt1",
        "@import(\"std/rt.zag\") fn main() i32 { _zag_println(\"native runtime works\"); return 0; }");

    // _zag_str_concat("ab","cd") → malloc + memcpy → {ptr,4}. Prints "abcd", exit 4.
    build("rt2_str_concat", "/tmp/n6_rt2",
        "@import(\"std/rt.zag\") fn main() i32 { let s: []u8 = _zag_str_concat(\"ab\",\"cd\"); _zag_println(s); return s.len; }");

    // aggregate let FROM A CALL: `let s = _zag_str_concat(\"x\",\"y\"); return s.len;` → 2.
    build("rt3_agg_let_call", "/tmp/n6_rt3",
        "@import(\"std/rt.zag\") fn main() i32 { let s: []u8 = _zag_str_concat(\"x\",\"y\"); return s.len; }");

    // _zag_i64_to_str(12345) → decimal into a malloc'd buffer → slice. Prints "12345".
    build("rt4_i64_to_str", "/tmp/n6_rt4",
        "@import(\"std/rt.zag\") fn main() i32 { _zag_println(_zag_i64_to_str(12345)); return 0; }");

    // read_file ROUNDTRIP: write \"hello\\n\" via _zag_write_file (open/write/close),
    // read it back via _zag_read_file (open/read-loop/close), print → \"hello\".
    build("rt5_read_file", "/tmp/n6_rt5",
        "@import(\"std/rt.zag\") fn main() i32 { let w: i32 = _zag_write_file(\"/tmp/nrt_test\", \"hello\\n\"); let c: []u8 = _zag_read_file(\"/tmp/nrt_test\"); _zag_print(c); return c.len; }");

    // argc/arg via r15 (the initial rsp): _zag_print(_zag_arg(0)) prints argv[0]
    // (the program's own path). Exit = _zag_argc().
    build("rt6_argc_arg", "/tmp/n6_rt6",
        "@import(\"std/rt.zag\") fn main() i32 { _zag_print(_zag_arg(0)); _zag_print(\"\\n\"); return _zag_argc(); }");

    // _zag_file_exists → access(2): the file we just wrote exists (1).
    build("rt7_file_exists", "/tmp/n6_rt7",
        "@import(\"std/rt.zag\") fn main() i32 { return _zag_file_exists(\"/tmp/nrt_test\"); }");

    // ══ 2. CODEGEN TAIL ════════════════════════════════════════════════════════
    // .slice_ : sub-slice of a []u8 string literal → {ptr+1, 2}. \"hello\"[1..3] len 2.
    build("cg1_slice_lit", "/tmp/n6_cg1",
        "fn main() i32 { let s: []u8 = \"hello\"; let t: []u8 = s[1..3]; return t.len; }");

    // .slice_ of an ArrayList[u8] `.data` (a *u8 pointer base), printed byte-packed.
    build("cg2_slice_data", "/tmp/n6_cg2",
        "@import(\"../../std/list.zag\") fn main() i32 { let b: ArrayList[u8] = make[u8](4); push[u8](&b, 65); push[u8](&b, 66); push[u8](&b, 67); _zag_print(b.data[0..b.len]); _zag_print(\"\\n\"); return b.len; }");

    // &s.field write-through (round-2 style): &s.x → *i32; write 42; read s.x.
    build("cg3_addr_field", "/tmp/n6_cg3",
        "struct P{x:i32,y:i32} fn main() i32 { let s:P = P{.x=1,.y=2}; let q:*i32 = &s.x; q.* = 42; return s.x; }");

    // &xs.data[i] write-through (a *T index lvalue) → mutate element, read back.
    build("cg4_addr_index", "/tmp/n6_cg4",
        "@import(\"../../std/list.zag\") fn main() i32 { let xs:ArrayList[i32] = make[i32](4); push[i32](&xs,1); push[i32](&xs,2); let q:*i32 = &xs.data[0]; q.* = 40; return get[i32](xs,0) + get[i32](xs,1); }");

    // boolean literals true/false → 1/0.
    build("cg5_bools", "/tmp/n6_cg5",
        "fn main() i32 { if (true) { if (false) { return 0; } return 42; } return 1; }");

    // >6 args (System V stack args): add8(1..8) = 36.
    build("cg6_many_args", "/tmp/n6_cg6",
        "fn add8(a:i32,b:i32,c:i32,d:i32,e:i32,f:i32,g:i32,h:i32) i32 { return a+b+c+d+e+f+g+h; } fn main() i32 { return add8(1,2,3,4,5,6,7,8); }");

    // aggregate ArrayList ELEMENT (struct via *T index): push/get a 3-word struct.
    build("cg7_agg_element", "/tmp/n6_cg7",
        "@import(\"../../std/list.zag\") struct T{k:i32,v:[]u8} fn main() i32 { let xs:ArrayList[T] = make[T](2); push[T](&xs, T{.k=40,.v=\"hi\"}); let t:T = get[T](xs,0); return t.k + t.v.len; }");

    // capture-aggregate field: a union variant holds a struct with an ArrayList;
    // read its .len through the |cap| capture (the round-3 layout/scan fix).
    build("cg8_capture_agg", "/tmp/n6_cg8",
        "@import(\"../../std/list.zag\") struct FD{name:[]u8,params:ArrayList[i32]} union Nd{fd:FD,lit:i32} fn build() *Nd { let ps:ArrayList[i32] = make[i32](2); push[i32](&ps,7); return new(Nd{.fd=FD{.name=\"foo\",.params=ps}}); } fn main() i32 { let n:*Nd = build(); switch (n.*) { .fd => |f| { return f.*.name.len + len[i32](f.*.params); } .lit => |l| { return 0; } } return 0; }");

    // ══ NON-REGRESSION (rounds 1-2 must be unchanged) ══════════════════════════
    build("r1_ret42", "/tmp/n6_r1", "fn main() i32 { return 42; }");
    build("r2_fib10", "/tmp/n6_r2",
        "fn fib(n:i32) i32 { if (n < 2) { return n; } return fib(n-1) + fib(n-2); } fn main() i32 { return fib(10); }");
    build("r3_list42", "/tmp/n6_r3",
        "@import(\"../../std/list.zag\") fn main() i32 { let xs: ArrayList[i32] = make[i32](4); push[i32](&xs, 30); push[i32](&xs, 12); return get[i32](xs,0) + get[i32](xs,1); }");
    build("r4_union_lit", "/tmp/n6_r4",
        "struct IntLit { text: []u8 } struct Bin { op: []u8, l: *IntLit, r: *IntLit } union Node { ilit: IntLit, bin: Bin } fn main() i32 { let n: *Node = new(Node{ .ilit = IntLit{ .text = \"hello\" } }); return switch (n.*) { .ilit => |x| x.*.text.len, .bin => |x| 0 }; }");

    _zag_println("ncodegen6_test: all programs processed");
}
