// selfhost/native/ncodegen_test.zag — REAL end-to-end verification of the
// native x86-64 codegen. For each acceptance program we:
//   parse source → lower_program(decls) → encode(prog) → write_elf_exec(...)
// producing a genuine runnable Linux ELF (no cc/as/ld/LLVM). The proof is the
// process EXIT CODE, checked from bash after this runs.
//
//   Run:  ./zagc build selfhost/native/ncodegen_test.zag --run
//   Then: for each /tmp/zn_X, run it and check `echo $?`.
//
// Expected exit codes:
//   (a) /tmp/zn_a → 42
//   (b) /tmp/zn_b → 38
//   (c) /tmp/zn_c → 42
//   (d) /tmp/zn_d → 55
//   (e) /tmp/zn_e → 55

@import("x86.zag")
@import("elf.zag")
@import("ncodegen.zag")

fn build_one(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, ".");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let code: ArrayList[u8] = encode(prog);
    // These five integer programs use no string data, so the single-segment
    // writer is sufficient (and exercises the original ELF path unchanged).
    let rc: i32 = write_elf_exec(path, code, 0);
    _zag_print(tag);
    _zag_print(": decls=");
    _zag_print(_zag_i64_to_str(len[*Node](decls) as i64));
    _zag_print(" instrs=");
    _zag_print(_zag_i64_to_str(prog.len as i64));
    _zag_print(" bytes=");
    _zag_print(_zag_i64_to_str(code.len as i64));
    _zag_print(" wrote ");
    _zag_print(path);
    if (rc == 0) { _zag_println(" OK"); }
    else { _zag_println(" WRITE-FAILED"); }
}

fn main() void {
    // (a) constant return → 42
    build_one("a", "/tmp/zn_a",
        "fn main() i32 { return 42; }");

    // (b) locals + arithmetic precedence: 8*5 - 2 = 38
    build_one("b", "/tmp/zn_b",
        "fn main() i32 { let a: i32 = 8; let b: i32 = 5; return a * b - 2; }");

    // (c) a call with two args: add(40,2) = 42
    build_one("c", "/tmp/zn_c",
        "fn add(a: i32, b: i32) i32 { return a + b; } fn main() i32 { return add(40, 2); }");

    // (d) recursion: fib(10) = 55
    build_one("d", "/tmp/zn_d",
        "fn fib(n: i32) i32 { if (n < 2) { return n; } return fib(n - 1) + fib(n - 2); } fn main() i32 { return fib(10); }");

    // (e) while-loop sum 1..10 = 55
    build_one("e", "/tmp/zn_e",
        "fn main() i32 { let s: i32 = 0; let i: i32 = 1; while (i <= 10) { s = s + i; i = i + 1; } return s; }");

    _zag_println("ncodegen_test: all five ELF binaries written");
}
