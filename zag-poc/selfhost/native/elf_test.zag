// selfhost/native/elf_test.zag — proves the ELF64 writer produces real,
// runnable binaries. The machine code is hand-assembled freestanding code that
// invokes the Linux x86-64 `exit` syscall directly (no libc, no _start glue):
//
//     mov edi, 42      ; BF 2A 00 00 00   exit code -> rdi
//     mov eax, 60      ; B8 3C 00 00 00   syscall number 60 = exit
//     syscall          ; 0F 05
//
// Tests:
//   A) entry_off = 0   -> /tmp/zelf_a runs and returns 42
//   B) entry_off = 2   -> /tmp/zelf_b has two leading NOPs; entry skips them,
//                         still returns 42 (proves the entry_off math)
//   C) empty text      -> /tmp/zelf_c is a valid 120-byte (header-only) ELF
//
// Run:  ./zagc build selfhost/native/elf_test.zag --run
// Then validate the emitted files from bash (see the module's report).

@import("elf.zag")

// Append the freestanding `exit(42)` machine code to `buf`.
fn push_exit42(buf: *ArrayList[u8]) void {
    push[u8](buf, 191 as u8);   // 0xBF  mov edi, imm32
    push[u8](buf, 42 as u8);    // 0x2A  -> 42
    push[u8](buf, 0 as u8);     // 0x00
    push[u8](buf, 0 as u8);     // 0x00
    push[u8](buf, 0 as u8);     // 0x00
    push[u8](buf, 184 as u8);   // 0xB8  mov eax, imm32
    push[u8](buf, 60 as u8);    // 0x3C  -> 60 (sys_exit)
    push[u8](buf, 0 as u8);     // 0x00
    push[u8](buf, 0 as u8);     // 0x00
    push[u8](buf, 0 as u8);     // 0x00
    push[u8](buf, 15 as u8);    // 0x0F  syscall
    push[u8](buf, 5 as u8);     // 0x05
}

fn main() void {
    // ── A) entry_off = 0 ─────────────────────────────────────────────────────
    let text: ArrayList[u8] = make[u8](16);
    push_exit42(&text);
    let ra: i32 = write_elf_exec("/tmp/zelf_a", text, 0);
    _zag_print("A rc=");
    _zag_println(_zag_i64_to_str(ra as i64));
    _zag_print("A text.len=");
    _zag_println(_zag_i64_to_str(text.len as i64));   // expect 12

    // ── B) entry_off = 2 (two leading NOPs) ──────────────────────────────────
    let text2: ArrayList[u8] = make[u8](16);
    push[u8](&text2, 144 as u8);   // 0x90 nop
    push[u8](&text2, 144 as u8);   // 0x90 nop
    push_exit42(&text2);
    let rb: i32 = write_elf_exec("/tmp/zelf_b", text2, 2);
    _zag_print("B rc=");
    _zag_println(_zag_i64_to_str(rb as i64));
    _zag_print("B text.len=");
    _zag_println(_zag_i64_to_str(text2.len as i64));   // expect 14

    // ── C) empty text -> header-only 120-byte ELF ────────────────────────────
    let empty: ArrayList[u8] = make[u8](1);
    let rc: i32 = write_elf_exec("/tmp/zelf_c", empty, 0);
    _zag_print("C rc=");
    _zag_println(_zag_i64_to_str(rc as i64));
    _zag_print("C text.len=");
    _zag_println(_zag_i64_to_str(empty.len as i64));    // expect 0

    _zag_println("done");
}
