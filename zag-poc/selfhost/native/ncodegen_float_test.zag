// selfhost/native/ncodegen_float_test.zag — self-contained floating-point self
// test for the NATIVE x86-64 backend (SSE f64/f32). Compile + run with znc:
//
//     znc selfhost/native/ncodegen_float_test.zag -o /tmp/ft && /tmp/ft ; echo $?
//
// main() returns 0 iff every check passes, else the 1-based index of the FIRST
// failing check (so a nonzero exit pinpoints the regression). It also prints a
// handful of values whose exact %g formatting is asserted by tests/run_native.sh.
//
// Exercised: f64/f32 literals → IEEE-754 bits, + - * / , all six comparisons,
// int↔float casts (cvtsi2sd / cvttsd2si), unary float negation (sign-bit flip),
// f32 struct fields + by-value struct args/returns, nested-precedence arithmetic,
// and float function params/returns. All via SSE, no cc/as/ld/libc.

struct Vec3 { x: f32, y: f32, z: f32 }

fn dot(a: Vec3, b: Vec3) f32 { return a.x * b.x + a.y * b.y + a.z * b.z; }

fn scale(v: Vec3, s: f32) Vec3 {
    return Vec3{ .x = v.x * s, .y = v.y * s, .z = v.z * s };
}

fn sq(x: f64) f64 { return x * x; }

fn main() i32 {
    // 1: addition + exact equality
    let a: f64 = 1.5;
    let b: f64 = 2.5;
    if (a + b == 4.0) { } else { return 1; }

    // 2: subtraction
    if (5.5 - 2.0 == 3.5) { } else { return 2; }

    // 3: multiplication
    if (2.5 * 4.0 == 10.0) { } else { return 3; }

    // 4: division
    if (3.0 / 2.0 == 1.5) { } else { return 4; }

    // 5: comparisons (< <= > >= != ==)
    if (1.5 < 2.5 && 2.5 <= 2.5 && 3.0 > 2.0 && 2.0 >= 2.0 && 1.0 != 2.0 && 1.0 == 1.0) { } else { return 5; }

    // 6: a strictly-false comparison must be false
    if (2.5 < 1.5) { return 6; }

    // 7: int → f64 → int round trip
    let n: i32 = 7;
    let f: f64 = n as f64;
    if (f as i32 == 7) { } else { return 7; }

    // 8: float → int truncates toward zero
    let g: f64 = 9.9;
    if (g as i32 == 9) { } else { return 8; }

    // 9: unary float negation
    let h: f64 = 1.5;
    if (0.0 - h == 0.0 - 1.5 && (0.0 - h) < 0.0) { } else { return 9; }

    // 10: nested precedence (2 + 3*4 == 14)
    if (2.0 + 3.0 * 4.0 == 14.0) { } else { return 10; }

    // 11: float function param/return
    if (sq(3.0) == 9.0) { } else { return 11; }

    // 12: int → f64 widening in a `let`
    let w: f64 = 5;
    if (w == 5.0) { } else { return 12; }

    // 13: f32 struct fields + by-value struct arg (dot product)
    let p: Vec3 = Vec3{ .x = 1.0, .y = 2.0, .z = 3.0 };
    let q: Vec3 = Vec3{ .x = 4.0, .y = 5.0, .z = 6.0 };
    if (dot(p, q) == 32.0) { } else { return 13; }

    // 14: f32 struct returned by value, then summed
    let r: Vec3 = scale(p, 2.0);
    if (r.x + r.y + r.z == 12.0) { } else { return 14; }

    // 15: f64 accumulation in a while loop
    let s: f64 = 0.0;
    let i: i32 = 0;
    while (i < 4) {
        s = s + 0.25;
        i = i + 1;
    }
    if (s == 1.0) { } else { return 15; }

    // Asserted %g formatting (matches the C backend): 0.5, 1.5, -2.5, 440, 0.0001
    print_f64(0.5);
    print_f64(3.0 / 2.0);
    print_f64(0.0 - 2.5);
    print_f64(440.0);
    print_f32(0.0001);

    return 0;
}
