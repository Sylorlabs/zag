// selfhost/native/ncodegen2_test.zag — REAL end-to-end verification of the
// native x86-64 codegen's OUTPUT (print), STRINGS, and STRUCTS support.
//
// For each program we run the full from-scratch pipeline:
//   parse → lower_program(decls,&err,&data) → encode(prog)
//         → write_elf_exec[_data](path, code, 0, data)
// producing a genuine runnable Linux ELF (no cc/as/ld/LLVM). The proof is the
// process STDOUT and EXIT CODE, checked from bash after this runs.
//
//   Run:  ./zagc build selfhost/native/ncodegen2_test.zag --run
//   Then: run each /tmp/zn2_* and check its stdout + `echo $?`.
//
// Programs that emit STRING data go through write_elf_exec_data (2 PT_LOAD
// segments). Programs with no string data use write_elf_exec (1 segment).

@import("x86.zag")
@import("elf.zag")
@import("ncodegen.zag")

// Build with the 2-segment writer (code + read-only string data).
fn build_data(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, ".");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let code: ArrayList[u8] = encode(prog);
    let rc: i32 = write_elf_exec_data(path, code, 0, data);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    _zag_print(" instrs=");
    _zag_print(_zag_i64_to_str(prog.len as i64));
    _zag_print(" code=");
    _zag_print(_zag_i64_to_str(code.len as i64));
    _zag_print(" data=");
    _zag_print(_zag_i64_to_str(data.len as i64));
    _zag_print(" -> ");
    _zag_print(path);
    if (rc == 0) { _zag_println(" OK"); }
    else { _zag_println(" WRITE-FAILED"); }
}

// Build with the single-segment writer (no string data needed).
fn build_code(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, ".");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let code: ArrayList[u8] = encode(prog);
    let rc: i32 = write_elf_exec(path, code, 0);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    _zag_print(" instrs=");
    _zag_print(_zag_i64_to_str(prog.len as i64));
    _zag_print(" code=");
    _zag_print(_zag_i64_to_str(code.len as i64));
    _zag_print(" data=");
    _zag_print(_zag_i64_to_str(data.len as i64));
    _zag_print(" -> ");
    _zag_print(path);
    if (rc == 0) { _zag_println(" OK"); }
    else { _zag_println(" WRITE-FAILED"); }
}

// A program we EXPECT to be rejected loudly: confirm err > 0 (driver would
// abort). We still write the (intentionally bogus) binary so the harness can
// see it, but the proof is that nerr > 0 was reported.
fn build_reject(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, ".");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let _code: ArrayList[u8] = encode(prog);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    if (nerr > 0) { _zag_println("  REJECTED-LOUDLY (good)"); }
    else { _zag_println("  *** NOT REJECTED (BAD) ***"); }
}

fn main() void {
    // ── OUTPUT: print_int ────────────────────────────────────────────────────
    // (p1) print_int(12345) → prints "12345", exit 0
    build_code("p1_print12345", "/tmp/zn2_p1",
        "fn main() i32 { print_int(12345); return 0; }");

    // (p2) print_int(0) → "0"
    build_code("p2_print0", "/tmp/zn2_p2",
        "fn main() i32 { print_int(0); return 0; }");

    // (p3) print_int(0-42) → "-42"
    build_code("p3_printneg", "/tmp/zn2_p3",
        "fn main() i32 { print_int(0 - 42); return 0; }");

    // (p4) print_int(fib(10)) → "55"  (computed expression)
    build_code("p4_printfib", "/tmp/zn2_p4",
        "fn fib(n: i32) i32 { if (n < 2) { return n; } return fib(n - 1) + fib(n - 2); } fn main() i32 { print_int(fib(10)); return 0; }");

    // (p5) multiple print_int in a row → "1\n"? we test "10" then "20" → "1020"
    build_code("p5_multi", "/tmp/zn2_p5",
        "fn main() i32 { print_int(10); print_int(20); return 0; }");

    // (p6) print a large 64-bit value: 1000000007
    build_code("p6_big", "/tmp/zn2_p6",
        "fn main() i32 { print_int(1000000007); return 0; }");

    // ── OUTPUT: print_str (string data) ──────────────────────────────────────
    // (s1) print_str("hello\n") → "hello\n"
    build_data("s1_hello", "/tmp/zn2_s1",
        "fn main() i32 { print_str(\"hello\\n\"); return 0; }");

    // (s2) two literals, one with embedded newline in the middle
    build_data("s2_two", "/tmp/zn2_s2",
        "fn main() i32 { print_str(\"ab\\ncd\"); print_str(\"!\\n\"); return 0; }");

    // (s3) _zag_println appends its own newline → "world\n"
    build_data("s3_println", "/tmp/zn2_s3",
        "fn main() i32 { _zag_println(\"world\"); return 0; }");

    // (s4) empty string (len 0) then a marker → just "X\n"
    build_data("s4_empty", "/tmp/zn2_s4",
        "fn main() i32 { print_str(\"\"); print_str(\"X\\n\"); return 0; }");

    // (s5) print_int then print_str: "42" then "!\n"
    build_data("s5_mix", "/tmp/zn2_s5",
        "fn main() i32 { print_int(42); print_str(\"!\\n\"); return 0; }");

    // ── STRINGS: compile-time .len and literal indexing ──────────────────────
    // (t1) "hello".len == 5 → exit 5
    build_code("t1_len", "/tmp/zn2_t1",
        "fn main() i32 { return \"hello\".len; }");

    // (t2) "ABC"[1] == 'B' == 66 → exit 66
    build_data("t2_index", "/tmp/zn2_t2",
        "fn main() i32 { return \"ABC\"[1]; }");

    // ── STRUCTS: by value ────────────────────────────────────────────────────
    // (u1) P{ .x=30, .y=12 }; p.x + p.y == 42
    build_code("u1_struct", "/tmp/zn2_u1",
        "struct P { x: i32, y: i32 } fn main() i32 { let p: P = P{ .x = 30, .y = 12 }; return p.x + p.y; }");

    // (u2) field reassignment: p.x = 100; p.x + p.y == 112
    build_code("u2_fieldassign", "/tmp/zn2_u2",
        "struct P { x: i32, y: i32 } fn main() i32 { let p: P = P{ .x = 30, .y = 12 }; p.x = 100; return p.x + p.y; }");

    // (u3) struct via POINTER param: read p.*.x + p.*.y
    build_code("u3_ptr", "/tmp/zn2_u3",
        "struct P { x: i32, y: i32 } fn sum(p: *P) i32 { return p.*.x + p.*.y; } fn main() i32 { let q: P = P{ .x = 40, .y = 2 }; return sum(&q); }");

    // (u4) write through a pointer: p.*.x = 7; then read back
    build_code("u4_ptrwrite", "/tmp/zn2_u4",
        "struct P { x: i32, y: i32 } fn setx(p: *P) void { p.*.x = 7; } fn main() i32 { let q: P = P{ .x = 1, .y = 5 }; setx(&q); return q.x + q.y; }");

    // (u5) struct copy: let r = p (by value, N-word copy)
    build_code("u5_copy", "/tmp/zn2_u5",
        "struct P { x: i32, y: i32 } fn main() i32 { let p: P = P{ .x = 20, .y = 22 }; let r: P = p; return r.x + r.y; }");

    // (u6) three-field struct, mixed literal order
    build_code("u6_three", "/tmp/zn2_u6",
        "struct T { a: i32, b: i32, c: i32 } fn main() i32 { let t: T = T{ .c = 3, .a = 30, .b = 9 }; return t.a + t.b + t.c; }");

    // ── DELIBERATELY UNSUPPORTED → must be REJECTED LOUDLY (err > 0) ──────────
    // (r1) returning a struct BY VALUE is not implemented
    build_reject("r1_retstruct", "/tmp/zn2_r1",
        "struct P { x: i32, y: i32 } fn mk() P { return P{ .x = 1, .y = 2 }; } fn main() i32 { let p: P = mk(); return p.x; }");

    // (r2) passing a struct BY VALUE as an argument is not implemented
    build_reject("r2_structarg", "/tmp/zn2_r2",
        "struct P { x: i32, y: i32 } fn f(p: P) i32 { return p.x; } fn main() i32 { let q: P = P{ .x = 5, .y = 6 }; return f(q); }");

    // (r3) a bare []u8 slice value held in a variable is not implemented
    build_reject("r3_sliceval", "/tmp/zn2_r3",
        "fn main() i32 { let s: []u8 = \"hi\"; return s.len; }");

    // (r4) print_str of a non-literal (runtime []u8) is not implemented
    build_reject("r4_runtimestr", "/tmp/zn2_r4",
        "fn main() i32 { let s: []u8 = \"hi\"; print_str(s); return 0; }");

    _zag_println("ncodegen2_test: all programs processed");
}
