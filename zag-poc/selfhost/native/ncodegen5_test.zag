// selfhost/native/ncodegen5_test.zag — REAL end-to-end verification of ROUND-2
// of NATIVE SELF-HOSTING: (1) PROPER VARIABLE-SIZE LAYOUT, (2) NESTED struct/
// union literals as VALUES (new(Node{...})), (3) `&expr` on complex lvalues,
// (4) OPTIONALS (?T). Every feature is PROVEN by running the emitted native
// binary (no cc/as/ld/libc/LLVM) and checking its exit code / stdout.
//
//   parse → lower_program(decls,&err,&data) → encode → write_elf_exec_data → run
//
//   Run:  ./zagc build selfhost/native/ncodegen5_test.zag --run
//   Then: the bash driver runs each /tmp/n5_* and checks exit code / stdout.

@import("x86.zag")
@import("elf.zag")
@import("ncodegen.zag")

// Build a program we EXPECT to lower cleanly (err==0) into a runnable ELF.
fn build(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, "selfhost/native");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let code: ArrayList[u8] = encode(prog);
    let rc: i32 = write_elf_exec_data(path, code, 0, data);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    _zag_print(" instrs=");
    _zag_print(_zag_i64_to_str(prog.len as i64));
    _zag_print(" code=");
    _zag_print(_zag_i64_to_str(code.len as i64));
    _zag_print(" data=");
    _zag_print(_zag_i64_to_str(data.len as i64));
    _zag_print(" -> ");
    _zag_print(path);
    if (rc == 0) { _zag_println(" OK"); }
    else { _zag_println(" WRITE-FAILED"); }
}

// A program we EXPECT to be REJECTED loudly: confirm err > 0 (driver aborts).
fn build_reject(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, "selfhost/native");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let _code: ArrayList[u8] = encode(prog);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    if (nerr > 0) { _zag_println("  REJECTED-LOUDLY (good)"); }
    else { _zag_println("  *** NOT REJECTED (BAD) ***"); }
}

fn main() void {
    // ══ 1. PROPER VARIABLE-SIZE LAYOUT ═════════════════════════════════════════
    // struct S{a:i32, b:[]u8, c:i32} → 8 + 16 + 8 = 32.
    build("l1_sizeof32", "/tmp/n5_l1",
        "struct S{a:i32,b:[]u8,c:i32} fn main() i32 { return @sizeOf[S](); }");
    // build an S, set a=40,c=2, read a+c → 42 (proves field offsets account for
    // the 16-byte []u8 field b: c is at byte 24, not 16).
    build("l2_fields42", "/tmp/n5_l2",
        "struct S{a:i32,b:[]u8,c:i32} fn main() i32 { let s:S = S{.a=40,.b=\"hi\",.c=2}; return s.a + s.c; }");
    // confirm the []u8 field b round-trips: its .len is 5 ("hello").
    build("l3_slicefield_len", "/tmp/n5_l3",
        "struct S{a:i32,b:[]u8,c:i32} fn main() i32 { let s:S = S{.a=1,.b=\"hello\",.c=2}; return s.b.len; }");
    // nested struct field: Outer{ inner:Inner{x,y}, z } — Inner is 16 bytes, z at 16.
    build("l4_nested_layout", "/tmp/n5_l4",
        "struct Inner{x:i32,y:i32} struct Outer{inner:Inner,z:i32} fn main() i32 { return @sizeOf[Outer](); }");

    // ══ 2. NESTED struct/union LITERALS as VALUES ══════════════════════════════
    // the headline pattern: new(Node{ .ilit = IntLit{ .text = "5" } }) then read
    // the text back via a switch: text.len of "5" is 1, +41 = 42.
    build("n1_union_new_lit", "/tmp/n5_n1",
        "union Node { ilit: IntLit, bin: Bin } struct IntLit{ text: []u8 } struct Bin{ op: []u8, l: *Node, r: *Node } fn main() i32 { let p:*Node = new(Node{ .ilit = IntLit{ .text = \"5\" } }); switch (p.*) { .ilit => |c| { return c.*.text.len + 41; } .bin => |c| { return 0; } } return 0; }");
    // nested Bin variant: new(Node{ .bin = Bin{ .op="+", .l=lp, .r=rp } }); read
    // back l.*.ilit.text.len (1) via switch → +41 = 42.
    build("n2_union_nested_bin", "/tmp/n5_n2",
        "union Node { ilit: IntLit, bin: Bin } struct IntLit{ text: []u8 } struct Bin{ op: []u8, l: *Node, r: *Node } fn main() i32 { let lp:*Node = new(Node{ .ilit = IntLit{ .text = \"5\" } }); let rp:*Node = new(Node{ .ilit = IntLit{ .text = \"6\" } }); let b:*Node = new(Node{ .bin = Bin{ .op = \"+\", .l = lp, .r = rp } }); switch (b.*) { .bin => |c| { return c.*.op.len + 41; } .ilit => |c| { return 0; } } return 0; }");
    // nested struct literal as a `let` initializer (not just new): read inner.y.
    build("n3_nested_struct_let", "/tmp/n5_n3",
        "struct Inner{x:i32,y:i32} struct Outer{inner:Inner,z:i32} fn main() i32 { let o:Outer = Outer{ .inner = Inner{ .x=30, .y=10 }, .z=2 }; return o.inner.y + o.inner.x + o.z; }");
    // nested struct literal as a RETURN value, read back.
    build("n4_nested_struct_ret", "/tmp/n5_n4",
        "struct Inner{x:i32,y:i32} struct Outer{inner:Inner,z:i32} fn mk() Outer { return Outer{ .inner = Inner{ .x=40, .y=0 }, .z=2 }; } fn main() i32 { let o:Outer = mk(); return o.inner.x + o.z; }");
    // struct literal as a call ARGUMENT (by value), read a field inside callee.
    build("n5_struct_lit_arg", "/tmp/n5_n5",
        "struct P{x:i32,y:i32} fn sum(p:P) i32 { return p.x + p.y; } fn main() i32 { return sum(P{.x=40,.y=2}); }");
    // read an AGGREGATE field as a VALUE: let q = s.b ([]u8), then q.len → 5.
    build("n6_agg_field_value", "/tmp/n5_n6",
        "struct S{a:i32,b:[]u8} fn main() i32 { let s:S = S{.a=1,.b=\"hello\"}; let q:[]u8 = s.b; return q.len; }");
    // copy a nested struct field into a let, read it back: o.inner.x + o.inner.y.
    build("n7_nested_field_copy", "/tmp/n5_n7",
        "struct Inner{x:i32,y:i32} struct Outer{inner:Inner,z:i32} fn main() i32 { let o:Outer = Outer{ .inner = Inner{ .x=40, .y=2 }, .z=9 }; let q:Inner = o.inner; return q.x + q.y; }");

    // ══ 3. `&expr` ON COMPLEX LVALUES ══════════════════════════════════════════
    // &s.field → write through the pointer, read back the struct field changed.
    build("a1_addr_field", "/tmp/n5_a1",
        "struct P{x:i32,y:i32} fn main() i32 { let s:P = P{.x=1,.y=2}; let q:*i32 = &s.x; q.* = 40; return s.x + s.y; }");
    // &local scalar → write through, read back.
    build("a2_addr_local", "/tmp/n5_a2",
        "fn main() i32 { let a:i32 = 5; let p:*i32 = &a; p.* = 42; return a; }");
    // &p.*.field (pointer base) → write through.
    build("a3_addr_ptrfield", "/tmp/n5_a3",
        "struct P{x:i32,y:i32} fn main() i32 { let s:*P = new(P{.x=1,.y=2}); let q:*i32 = &s.*.x; q.* = 40; return s.*.x + s.*.y; }");
    // &xs.data[i] / &arr[i] via a *T pointer base → write through, read back.
    build("a4_addr_index", "/tmp/n5_a4",
        "@import(\"../../std/list.zag\") fn main() i32 { let xs:ArrayList[i32] = make[i32](4); push[i32](&xs,1); push[i32](&xs,2); let q:*i32 = &xs.data[0]; q.* = 40; return get[i32](xs,0) + get[i32](xs,1); }");

    // ══ 4. OPTIONALS (?T) ══════════════════════════════════════════════════════
    // fn returning ?i32: f(1) returns 42, f(0) returns null. f(1) orelse 7 → 42.
    build("o1_orelse_some", "/tmp/n5_o1",
        "fn f(b: i32) ?i32 { if (b == 1) { return 42; } return null; } fn main() i32 { return f(1) orelse 7; }");
    // f(0) orelse 7 → 7 (the null path takes the default).
    build("o2_orelse_none", "/tmp/n5_o2",
        "fn f(b: i32) ?i32 { if (b == 1) { return 42; } return null; } fn main() i32 { return f(0) orelse 7; }");
    // an optional LOCAL: let o:?i32 = 42; o orelse 7 → 42.
    build("o3_opt_local_some", "/tmp/n5_o3",
        "fn main() i32 { let o:?i32 = 42; return o orelse 7; }");
    // an optional LOCAL set to null: let o:?i32 = null; o orelse 7 → 7.
    build("o4_opt_local_null", "/tmp/n5_o4",
        "fn main() i32 { let o:?i32 = null; return o orelse 7; }");
    // CONSUME via the .has/.val fields directly (the if-let-equivalent in this
    // subset): if (o.has) use o.val. 40 + 2 = 42.
    build("o5_opt_consume", "/tmp/n5_o5",
        "fn f(b:i32) ?i32 { if (b==1) { return 40; } return null; } fn main() i32 { let o:?i32 = f(1); if (o.has) { return o.val + 2; } return 0; }");

    // ══ NON-REGRESSION (round-1 features must be unchanged) ════════════════════
    build("r_ret42", "/tmp/n5_r1", "fn main() i32 { return 42; }");
    build("r_fib10", "/tmp/n5_r2",
        "fn fib(n:i32) i32 { if (n < 2) { return n; } return fib(n-1) + fib(n-2); } fn main() i32 { return fib(10); }");
    build("r_list42", "/tmp/n5_r3",
        "@import(\"../../std/list.zag\") fn main() i32 { let xs: ArrayList[i32] = make[i32](4); push[i32](&xs, 30); push[i32](&xs, 12); return get[i32](xs,0) + get[i32](xs,1); }");
    build("r_union_switch42", "/tmp/n5_r4",
        "union U { a: i32, b: i32 } fn main() i32 { let u: U = U{ .a = 7 }; switch (u) { .a => |c| { return c.* + 35; } .b => |c| { return c.*; } } return 0; }");
    build("r_sizeof24", "/tmp/n5_r5",
        "struct P{a:i32,b:i32,c:i32} fn main() i32 { return @sizeOf[P](); }");
    build("r_struct42", "/tmp/n5_r6",
        "struct P{x:i32,y:i32} fn main() i32 { let p:P=P{.x=30,.y=12}; return p.x+p.y; }");
    build("r_byval_ret", "/tmp/n5_r7",
        "struct P{x:i32,y:i32} fn mk(a:i32,b:i32) P { return P{.x=a,.y=b}; } fn main() i32 { let p:P=mk(40,2); return p.x+p.y; }");
    build("r_new", "/tmp/n5_r8",
        "struct P{x:i32,y:i32} fn main() i32 { let p:*P = new(P{.x=40,.y=2}); return p.*.x + p.*.y; }");

    // ══ REJECTIONS (still-unsupported → must abort loudly) ═════════════════════
    build_reject("x1_bad_builtin", "/tmp/n5_x1",
        "fn main() i32 { return @bogus[i32](); }");
    build_reject("x2_unknown_fn", "/tmp/n5_x2",
        "fn main() i32 { return nope(1); }");

    _zag_println("ncodegen5_test: all programs processed");
}
