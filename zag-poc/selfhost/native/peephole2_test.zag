// selfhost/native/peephole2_test.zag — verifies the NEW peephole rules R4/R5.
//
// R4  store [b+d], rS ; load rD, [b+d]  (same b, same d)  → keep store ; mov rD, rS
// R5a mov_imm r, a ; mov_imm r, b   (same r)             → mov_imm r, b
// R5b mov_imm r, a ; mov_rr  r, x   (x != r)             → mov_rr  r, x
//
// Two layers of proof (same shape as peephole_test.zag):
//   (1) STRUCTURAL — hand-built Instr lists; assert the optimized output is
//       EXACTLY the expected reduced sequence (kind/dst/src/disp/imm per instr,
//       plus length). Includes the SAFETY NEGATIVES that MUST NOT fuse:
//         • store;load with DIFFERENT disp        → unchanged
//         • store; LABEL; load (not adjacent)     → unchanged
//         • mov_imm r,a; <reads r>; mov_imm r,b   → first NOT dropped (non-adj.)
//         • mov_imm r,a; mov_rr r,r (x==r)        → first NOT dropped (R5b guard)
//   (2) END-TO-END EQUIVALENCE — complete `_start` programs that each compute a
//       value via redundant store/reload and dead movs, exit with it, and some
//       also write to stdout. We encode BOTH the original and the optimized
//       program, write both as real ELF executables, RUN both, and assert the
//       exit codes are IDENTICAL, the stdout is byte-for-byte IDENTICAL, and the
//       optimized byte count is <= the original. ≥6 programs incl. exit-42,
//       exit-200, and one that prints.
//
// Run:  ./zagc build selfhost/native/peephole2_test.zag --run

@import("isa.zag")
@import("x86.zag")
@import("elf.zag")
@import("peephole.zag")

// ── tiny test bookkeeping ────────────────────────────────────────────────────
fn pp_pi(v: i32) void { _zag_print(_zag_i64_to_str(v as i64)); }

fn pp_check(tag: []u8, got: i32, want: i32, fails: *i32) void {
    if (got == want) {
        _zag_print("  ok   ");
        _zag_print(tag);
        _zag_print(" = ");
        pp_pi(got);
        _zag_println("");
    } else {
        _zag_print("  FAIL ");
        _zag_print(tag);
        _zag_print(" got ");
        pp_pi(got);
        _zag_print(" want ");
        pp_pi(want);
        _zag_println("");
        fails.* = fails.* + 1;
    }
}

// Print the full instruction stream (one line per instr).
fn pp_dump(label: []u8, prog: ArrayList[Instr]) void {
    _zag_print(label);
    _zag_print(" [");
    pp_pi(len[Instr](prog));
    _zag_println(" instrs]");
    let i: i32 = 0;
    while (i < len[Instr](prog)) {
        let ins: Instr = get[Instr](prog, i);
        _zag_print("    k=");
        pp_pi(ins.kind);
        _zag_print(" dst=");
        pp_pi(ins.dst);
        _zag_print(" src=");
        pp_pi(ins.src);
        _zag_print(" disp=");
        pp_pi(ins.disp);
        _zag_print(" imm=");
        pp_pi(ins.imm as i32);
        _zag_println("");
        i = i + 1;
    }
}

// Assert instruction at index i has the given kind/dst/src.
fn pp_assert_ins(tag: []u8, prog: ArrayList[Instr], i: i32, k: i32, d: i32, s: i32, fails: *i32) void {
    let ins: Instr = get[Instr](prog, i);
    pp_check(tag, ins.kind, k, fails);
    pp_check(tag, ins.dst,  d, fails);
    pp_check(tag, ins.src,  s, fails);
}

// ── (2) e2e helper: encode orig+opt, run both, compare exit codes AND stdout ──
fn pp_streq(a: []u8, b: []u8) i32 {
    if (a.len != b.len) { return 0; }
    let i: i32 = 0;
    let ok: i32 = 1;
    while (i < a.len) {
        if (a[i] != b[i]) { ok = 0; }
        i = i + 1;
    }
    return ok;
}

fn pp_e2e(tag: []u8, prog: ArrayList[Instr], want_code: i32, fails: *i32) void {
    let a: ArrayList[u8] = encode(prog);
    let opt: ArrayList[Instr] = peephole(prog);
    let b: ArrayList[u8] = encode(opt);

    // distinct /tmp paths per tag
    let pa: []u8 = _zag_str_concat("/tmp/pp2_", tag);
    let pa2: []u8 = _zag_str_concat(pa, "_orig");
    let pb: []u8 = _zag_str_concat(pa, "_opt");

    let rwa: i32 = write_elf_exec(pa2, a, 0);
    let rwb: i32 = write_elf_exec(pb, b, 0);

    // exit codes
    let ea: i32 = _zag_exec_cmd(pa2);
    let eb: i32 = _zag_exec_cmd(pb);
    // stdout
    let oa: []u8 = _zag_exec_capture(pa2);
    let ob: []u8 = _zag_exec_capture(pb);
    let same_out: i32 = pp_streq(oa, ob);

    _zag_print(tag);
    _zag_print(": instrs ");
    pp_pi(len[Instr](prog));
    _zag_print(" -> ");
    pp_pi(len[Instr](opt));
    _zag_print(" | bytes ");
    pp_pi(a.len);
    _zag_print(" -> ");
    pp_pi(b.len);
    _zag_print(" | exit ");
    pp_pi(ea);
    _zag_print(" -> ");
    pp_pi(eb);
    _zag_print(" | stdout-bytes ");
    pp_pi(oa.len);
    _zag_print(" -> ");
    pp_pi(ob.len);
    _zag_println("");

    pp_check("  write-orig rc", rwa, 0, fails);
    pp_check("  write-opt  rc", rwb, 0, fails);
    // original program actually produced the expected code (sanity)
    pp_check("  orig exit", ea, want_code, fails);
    // EQUIVALENCE: optimized exit code identical to original
    pp_check("  opt  exit (== orig)", eb, ea, fails);
    // EQUIVALENCE: optimized stdout byte-for-byte identical to original
    pp_check("  stdout (opt == orig)", same_out, 1, fails);
    // optimizer never grew the program
    if (b.len <= a.len) {
        pp_check("  bytes b<=a", 1, 1, fails);
    } else {
        pp_check("  bytes b<=a", 0, 1, fails);
    }
}

// ── e2e program builders ──────────────────────────────────────────────────────
// All use rsp-relative scratch: `sub rsp,64` up front, positive disps, then
// `add rsp,64` before exit. Stores/loads stay inside the reserved 64-byte frame.

// (A) STORE→RELOAD: compute the exit code by round-tripping it through memory.
//   sub rsp,64
//   mov rbx, code
//   store [rsp+0], rbx     ; mem = code
//   load  rdi, [rsp+0]     ; R4 → mov rdi, rbx ; rdi = code
//   add rsp,64
//   mov rax,60 ; syscall   ; exit(rdi)
fn pp_build_reload_prog(code: i32) ArrayList[Instr] {
    let p: ArrayList[Instr] = make[Instr](16);
    push[Instr](&p, i_sub_imm(R_RSP(), 64));
    push[Instr](&p, i_mov_imm(R_RBX(), code as i64));
    push[Instr](&p, i_store(R_RSP(), 0, R_RBX()));
    push[Instr](&p, i_load(R_RDI(), R_RSP(), 0));     // R4 target
    push[Instr](&p, i_add_imm(R_RSP(), 64));
    push[Instr](&p, i_mov_imm(R_RAX(), 60));
    push[Instr](&p, i_syscall());
    return p;
}

// (B) DEAD MOV-IMM (R5a): a wrong value written then immediately overwritten.
//   mov rdi, 222          ; DEAD (R5a drops it)
//   mov rdi, code         ; the real value
//   mov rax,60 ; syscall
fn pp_build_deadimm_prog(code: i32) ArrayList[Instr] {
    let p: ArrayList[Instr] = make[Instr](8);
    push[Instr](&p, i_mov_imm(R_RDI(), 222));         // dead
    push[Instr](&p, i_mov_imm(R_RDI(), code as i64)); // overwrites → R5a
    push[Instr](&p, i_mov_imm(R_RAX(), 60));
    push[Instr](&p, i_syscall());
    return p;
}

// (C) DEAD MOV-IMM before MOV-RR (R5b):
//   mov rsi, code
//   mov rdi, 222          ; DEAD (R5b drops it)
//   mov rdi, rsi          ; overwrites rdi from a DIFFERENT reg → R5b fires
//   mov rax,60 ; syscall
fn pp_build_deadimm_rr_prog(code: i32) ArrayList[Instr] {
    let p: ArrayList[Instr] = make[Instr](8);
    push[Instr](&p, i_mov_imm(R_RSI(), code as i64));
    push[Instr](&p, i_mov_imm(R_RDI(), 222));         // dead
    push[Instr](&p, i_mov_rr(R_RDI(), R_RSI()));      // R5b: src(rsi)!=dst(rdi)
    push[Instr](&p, i_mov_imm(R_RAX(), 60));
    push[Instr](&p, i_syscall());
    return p;
}

// (D) COMBINED: dead imm + store/reload feeding the exit code.
//   sub rsp,64
//   mov rdx, 333          ; DEAD (R5a)
//   mov rdx, code         ; real value
//   store [rsp+8], rdx
//   load  rdi, [rsp+8]    ; R4 → mov rdi, rdx
//   add rsp,64
//   mov rax,60 ; syscall
fn pp_build_combo_prog(code: i32) ArrayList[Instr] {
    let p: ArrayList[Instr] = make[Instr](16);
    push[Instr](&p, i_sub_imm(R_RSP(), 64));
    push[Instr](&p, i_mov_imm(R_RDX(), 333));         // dead
    push[Instr](&p, i_mov_imm(R_RDX(), code as i64)); // real → R5a drops the dead
    push[Instr](&p, i_store(R_RSP(), 8, R_RDX()));
    push[Instr](&p, i_load(R_RDI(), R_RSP(), 8));     // R4 target
    push[Instr](&p, i_add_imm(R_RSP(), 64));
    push[Instr](&p, i_mov_imm(R_RAX(), 60));
    push[Instr](&p, i_syscall());
    return p;
}

// (E) PRINTS to stdout AND exits 7, exercising R4 + R5a + R5b together.
//   "OK\n" packed little-endian = 0x000A4B4F = 674639 (O=79,K=75,\n=10).
//   sub rsp,16
//   mov rax, 674639       ; the packed bytes
//   store [rsp+0], rax    ; mem[rsp] = "OK\n\0..."
//   mov rdi, 1            ; fd = stdout
//   mov rsi, 4096         ; DEAD (R5b)
//   mov rsi, rsp          ; buf = rsp     → R5b drops the dead imm
//   mov rdx, 3            ; len = 3
//   mov rax, 1            ; write
//   syscall              ; write(1, rsp, 3) → "OK\n"
//   mov rbx, 9999         ; DEAD (R5a)
//   mov rbx, 7            ; exit code 7
//   store [rsp+8], rbx
//   load  rdi, [rsp+8]    ; R4 → mov rdi, rbx ; rdi = 7
//   add rsp,16
//   mov rax,60 ; syscall  ; exit(7)
fn pp_build_print_prog() ArrayList[Instr] {
    let p: ArrayList[Instr] = make[Instr](24);
    push[Instr](&p, i_sub_imm(R_RSP(), 16));
    push[Instr](&p, i_mov_imm(R_RAX(), 674639));      // "OK\n"
    push[Instr](&p, i_store(R_RSP(), 0, R_RAX()));    // mem[rsp]
    push[Instr](&p, i_mov_imm(R_RDI(), 1));           // fd
    push[Instr](&p, i_mov_imm(R_RSI(), 4096));        // dead
    push[Instr](&p, i_mov_rr(R_RSI(), R_RSP()));      // buf=rsp → R5b
    push[Instr](&p, i_mov_imm(R_RDX(), 3));           // len
    push[Instr](&p, i_mov_imm(R_RAX(), 1));           // write
    push[Instr](&p, i_syscall());
    push[Instr](&p, i_mov_imm(R_RBX(), 9999));        // dead
    push[Instr](&p, i_mov_imm(R_RBX(), 7));           // exit code → R5a
    push[Instr](&p, i_store(R_RSP(), 8, R_RBX()));
    push[Instr](&p, i_load(R_RDI(), R_RSP(), 8));     // R4 target
    push[Instr](&p, i_add_imm(R_RSP(), 16));
    push[Instr](&p, i_mov_imm(R_RAX(), 60));
    push[Instr](&p, i_syscall());
    return p;
}

fn main() void {
    let fails: i32 = 0;

    _zag_println("== peephole R4/R5: STRUCTURAL ==");

    // ── T1: R4 store;load (same base, same disp) → store ; mov rD, rS ─────────
    //   store [rbp-8], rsi ; load rdi, [rbp-8]  →  store [rbp-8], rsi ; mov rdi, rsi
    let t1: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t1, i_store(R_RBP(), 0 - 8, R_RSI()));   // base=rbp, disp=-8, src=rsi
    push[Instr](&t1, i_load(R_RDI(), R_RBP(), 0 - 8));    // dst=rdi, base=rbp, disp=-8
    let r1: ArrayList[Instr] = peephole(t1);
    pp_dump("T1 in ", t1);
    pp_dump("T1 out", r1);
    pp_check("T1 len == 2", len[Instr](r1), 2, &fails);
    // [0] the store, unchanged
    pp_check("T1 [0] kind STORE", get[Instr](r1, 0).kind, K_STORE(), &fails);
    pp_check("T1 [0] base rbp",   get[Instr](r1, 0).dst,  R_RBP(),   &fails);
    pp_check("T1 [0] disp -8",    get[Instr](r1, 0).disp, 0 - 8,     &fails);
    pp_check("T1 [0] src  rsi",   get[Instr](r1, 0).src,  R_RSI(),   &fails);
    // [1] mov rdi, rsi
    pp_assert_ins("T1 [1] mov rdi,rsi", r1, 1, K_MOV_RR(), R_RDI(), R_RSI(), &fails);

    // ── T2: R4 where rD == rS → mov r,r → R3 deletes it (just the store left) ─
    //   store [rbp-16], rdx ; load rdx, [rbp-16]  →  store [rbp-16], rdx
    let t2: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t2, i_store(R_RBP(), 0 - 16, R_RDX()));
    push[Instr](&t2, i_load(R_RDX(), R_RBP(), 0 - 16));
    let r2: ArrayList[Instr] = peephole(t2);
    pp_dump("T2 in ", t2);
    pp_dump("T2 out", r2);
    pp_check("T2 len == 1 (mov rdx,rdx removed by R3)", len[Instr](r2), 1, &fails);
    pp_check("T2 [0] kind STORE", get[Instr](r2, 0).kind, K_STORE(), &fails);

    // ── T3: SAFETY — store;load with DIFFERENT disp must NOT fuse ─────────────
    let t3: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t3, i_store(R_RBP(), 0 - 8,  R_RSI()));
    push[Instr](&t3, i_load(R_RDI(),  R_RBP(), 0 - 16));  // DIFFERENT disp (-16 != -8)
    let r3: ArrayList[Instr] = peephole(t3);
    pp_dump("T3 in ", t3);
    pp_dump("T3 out", r3);
    pp_check("T3 len == 2 (UNCHANGED)", len[Instr](r3), 2, &fails);
    pp_check("T3 [0] STORE", get[Instr](r3, 0).kind, K_STORE(), &fails);
    pp_check("T3 [1] LOAD",  get[Instr](r3, 1).kind, K_LOAD(),  &fails);

    // ── T3b: SAFETY — store;load with DIFFERENT base must NOT fuse ────────────
    let t3b: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t3b, i_store(R_RBP(), 0 - 8, R_RSI()));  // base=rbp
    push[Instr](&t3b, i_load(R_RDI(),  R_RSP(), 0 - 8));  // base=rsp (DIFFERENT)
    let r3b: ArrayList[Instr] = peephole(t3b);
    pp_dump("T3b in ", t3b);
    pp_dump("T3b out", r3b);
    pp_check("T3b len == 2 (UNCHANGED)", len[Instr](r3b), 2, &fails);
    pp_check("T3b [1] LOAD", get[Instr](r3b, 1).kind, K_LOAD(), &fails);

    // ── T4: SAFETY — store; LABEL; load must NOT fuse (label not adjacent) ────
    let t4: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t4, i_store(R_RBP(), 0 - 8, R_RSI()));
    push[Instr](&t4, i_label(3));
    push[Instr](&t4, i_load(R_RDI(), R_RBP(), 0 - 8));
    let r4: ArrayList[Instr] = peephole(t4);
    pp_dump("T4 in ", t4);
    pp_dump("T4 out", r4);
    pp_check("T4 len == 3 (UNCHANGED)", len[Instr](r4), 3, &fails);
    pp_check("T4 [0] STORE", get[Instr](r4, 0).kind, K_STORE(), &fails);
    pp_check("T4 [1] LABEL", get[Instr](r4, 1).kind, K_LABEL(), &fails);
    pp_check("T4 [2] LOAD",  get[Instr](r4, 2).kind, K_LOAD(),  &fails);

    // ── T5: R5a mov_imm r,a ; mov_imm r,b (same r) → drop first ───────────────
    //   mov rax,7 ; mov rax,9  →  mov rax,9
    let t5: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t5, i_mov_imm(R_RAX(), 7));   // dead
    push[Instr](&t5, i_mov_imm(R_RAX(), 9));   // overwrites
    let r5: ArrayList[Instr] = peephole(t5);
    pp_dump("T5 in ", t5);
    pp_dump("T5 out", r5);
    pp_check("T5 len == 1", len[Instr](r5), 1, &fails);
    pp_check("T5 [0] kind MOV_IMM", get[Instr](r5, 0).kind, K_MOV_IMM(), &fails);
    pp_check("T5 [0] dst rax",      get[Instr](r5, 0).dst,  R_RAX(),     &fails);
    pp_check("T5 [0] imm == 9 (the LIVE value)", get[Instr](r5, 0).imm as i32, 9, &fails);

    // ── T6: R5b mov_imm r,a ; mov_rr r,x (x!=r) → drop first ──────────────────
    //   mov rdi,5 ; mov rdi,rsi  →  mov rdi,rsi
    let t6: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t6, i_mov_imm(R_RDI(), 5));            // dead
    push[Instr](&t6, i_mov_rr(R_RDI(), R_RSI()));       // src(rsi) != dst(rdi)
    let r6: ArrayList[Instr] = peephole(t6);
    pp_dump("T6 in ", t6);
    pp_dump("T6 out", r6);
    pp_check("T6 len == 1", len[Instr](r6), 1, &fails);
    pp_assert_ins("T6 [0] mov rdi,rsi", r6, 0, K_MOV_RR(), R_RDI(), R_RSI(), &fails);

    // ── T7: SAFETY — R5b guard: mov_imm r,a ; mov_rr r,r (x==r) must NOT drop ─
    // `mov r,r` is a no-op (R3 will remove it) — the imm is the LIVE writer of r.
    //   mov rcx,42 ; mov rcx,rcx  →  mov rcx,42   (the mov r,r dropped by R3)
    let t7: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t7, i_mov_imm(R_RCX(), 42));
    push[Instr](&t7, i_mov_rr(R_RCX(), R_RCX()));       // x == r → R5b must NOT fire
    let r7: ArrayList[Instr] = peephole(t7);
    pp_dump("T7 in ", t7);
    pp_dump("T7 out", r7);
    pp_check("T7 len == 1 (imm KEPT, mov r,r removed by R3)", len[Instr](r7), 1, &fails);
    pp_check("T7 [0] kind MOV_IMM", get[Instr](r7, 0).kind, K_MOV_IMM(), &fails);
    pp_check("T7 [0] imm == 42 (PRESERVED)", get[Instr](r7, 0).imm as i32, 42, &fails);

    // ── T8: SAFETY — non-adjacent: mov_imm r,a ; <reads r> ; mov_imm r,b ──────
    // An instruction between the two imms READS r, so the first is NOT dead and
    // must be KEPT. Here `add rdx, rax` reads rax (and the second imm targets a
    // DIFFERENT reg, rdx-vs-rax doesn't even pair) — we model "value read between"
    // by inserting a consumer of rax. The first mov_imm must remain.
    //   mov rax,5 ; add rbx,rax ; mov rax,8
    let t8: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t8, i_mov_imm(R_RAX(), 5));
    push[Instr](&t8, i_add(R_RBX(), R_RAX()));         // reads rax (consumer)
    push[Instr](&t8, i_mov_imm(R_RAX(), 8));
    let r8: ArrayList[Instr] = peephole(t8);
    pp_dump("T8 in ", t8);
    pp_dump("T8 out", r8);
    pp_check("T8 len == 3 (UNCHANGED — first imm read before overwrite)", len[Instr](r8), 3, &fails);
    pp_check("T8 [0] MOV_IMM kept", get[Instr](r8, 0).kind, K_MOV_IMM(), &fails);
    pp_check("T8 [0] imm == 5",     get[Instr](r8, 0).imm as i32, 5, &fails);
    pp_check("T8 [1] ADD kept",     get[Instr](r8, 1).kind, K_ADD_RR(), &fails);
    pp_check("T8 [2] imm == 8",     get[Instr](r8, 2).imm as i32, 8, &fails);

    // ── T9: SAFETY — mov_imm r,a ; mov_imm r2,b (DIFFERENT dest) must NOT drop ─
    //   mov rax,5 ; mov rbx,8  →  unchanged (different dests, both live)
    let t9: ArrayList[Instr] = make[Instr](4);
    push[Instr](&t9, i_mov_imm(R_RAX(), 5));
    push[Instr](&t9, i_mov_imm(R_RBX(), 8));
    let r9: ArrayList[Instr] = peephole(t9);
    pp_dump("T9 in ", t9);
    pp_dump("T9 out", r9);
    pp_check("T9 len == 2 (UNCHANGED — different dests)", len[Instr](r9), 2, &fails);
    pp_check("T9 [0] imm == 5", get[Instr](r9, 0).imm as i32, 5, &fails);
    pp_check("T9 [1] imm == 8", get[Instr](r9, 1).imm as i32, 8, &fails);

    // ── (2) END-TO-END EQUIVALENCE ───────────────────────────────────────────
    _zag_println("");
    _zag_println("== peephole R4/R5: END-TO-END EQUIVALENCE ==");

    // store→reload programs (R4)
    pp_e2e("rl42",  pp_build_reload_prog(42),  42,  &fails);
    pp_e2e("rl200", pp_build_reload_prog(200), 200, &fails);
    pp_e2e("rl7",   pp_build_reload_prog(7),   7,   &fails);
    // dead mov-imm programs (R5a / R5b)
    pp_e2e("di99",  pp_build_deadimm_prog(99),     99,  &fails);
    pp_e2e("dirr123", pp_build_deadimm_rr_prog(123), 123, &fails);
    // combined R4 + R5a
    pp_e2e("cmb200", pp_build_combo_prog(200), 200, &fails);
    pp_e2e("cmb42",  pp_build_combo_prog(42),  42,  &fails);
    // prints to stdout + exits 7 (R4 + R5a + R5b)
    pp_e2e("print7", pp_build_print_prog(), 7, &fails);

    // ── summary ──────────────────────────────────────────────────────────────
    _zag_println("");
    if (fails == 0) {
        _zag_println("PEEPHOLE R4/R5: ALL CHECKS PASSED");
    } else {
        _zag_print("PEEPHOLE R4/R5: FAILURES = ");
        pp_pi(fails);
        _zag_println("");
    }
}
