// selfhost/native/elf_data_test.zag — proves the 2-segment ELF64 writer
// (`write_elf_exec_data`) produces a real, runnable binary that PRINTS from a
// read-only DATA segment mapped at DATA_VBASE() = 0x600000.
//
// The freestanding program does:
//   write(1, 0x600000, data.len)   ; print the data blob to stdout
//   exit(0)
//
// Built entirely from the i_* instruction constructors (isa.zag) and the
// assembler (x86.zag) — no hand-assembled byte arrays.
//
// Run:  ./zagc build selfhost/native/elf_data_test.zag --run
// Then validate from bash:
//   /tmp/zed                 → prints "hello from the data segment"
//   readelf -l /tmp/zed      → TWO LOAD segments (R E @0x400000, R @0x600000)

@import("isa.zag")
@import("x86.zag")
@import("elf.zag")

// Build the read-only data blob as an ArrayList[u8] from a string literal.
fn make_data() ArrayList[u8] {
    let s: []u8 = "hello from the data segment\n";
    let out: ArrayList[u8] = make[u8](s.len + 1);
    let i: i32 = 0;
    while (i < s.len) {
        push[u8](&out, s[i]);
        i = i + 1;
    }
    return out;
}

fn main() void {
    let data: ArrayList[u8] = make_data();
    let dlen: i64 = data.len as i64;

    // ── build the freestanding program ───────────────────────────────────────
    let prog: ArrayList[Instr] = make[Instr](16);

    // write(1, 0x600000, dlen)
    push[Instr](&prog, i_mov_imm(R_RAX(), 1));            // sys_write
    push[Instr](&prog, i_mov_imm(R_RDI(), 1));            // fd = stdout
    push[Instr](&prog, i_mov_imm(R_RSI(), DATA_VBASE())); // buf = 0x600000
    push[Instr](&prog, i_mov_imm(R_RDX(), dlen));         // count = data.len
    push[Instr](&prog, i_syscall());

    // exit(0)
    push[Instr](&prog, i_mov_imm(R_RAX(), 60));           // sys_exit
    push[Instr](&prog, i_mov_imm(R_RDI(), 0));            // status = 0
    push[Instr](&prog, i_syscall());

    // ── assemble + link into a 2-segment ELF ─────────────────────────────────
    let code: ArrayList[u8] = encode(prog);
    let rc: i32 = write_elf_exec_data("/tmp/zed", code, 0, data);

    _zag_print("rc=");
    _zag_println(_zag_i64_to_str(rc as i64));
    _zag_print("code.len=");
    _zag_println(_zag_i64_to_str(code.len as i64));
    _zag_print("data.len=");
    _zag_println(_zag_i64_to_str(dlen));
    _zag_println("wrote /tmp/zed");
}
