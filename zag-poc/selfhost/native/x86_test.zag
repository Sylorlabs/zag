// selfhost/native/x86_test.zag — exhaustive verification of the x86-64 encoder.
//
// Builds an Instr program covering EVERY K_* kind plus the hard edge cases
// (movabs, extended regs, negative disp, rsp/r12 SIB base, backward + forward
// jumps, call), encodes it, writes the raw bytes to /tmp/x86_test.bin, and
// prints diagnostics. Verified against objdump:
//   objdump -D -b binary -m i386:x86-64 -M intel /tmp/x86_test.bin

@import("x86.zag")

fn main() void {
    let prog: ArrayList[Instr] = make[Instr](64);

    // ── MOV_IMM: positive int32, NEGATIVE int32, value > 2^31 (movabs imm64) ──
    push[Instr](&prog, i_mov_imm(R_RAX(), 5));               // mov rax, 5
    push[Instr](&prog, i_mov_imm(R_RCX(), 0 - 1));           // mov rcx, -1
    push[Instr](&prog, i_mov_imm(R_RDX(), 4294967296));      // movabs rdx, 0x100000000
    push[Instr](&prog, i_mov_imm(R_R8(),  0 - 1));           // mov r8, -1  (extended reg, int32 form)

    // ── MOV_RR with extended regs as src AND dst ──────────────────────────────
    push[Instr](&prog, i_mov_rr(R_RBX(), R_RAX()));          // mov rbx, rax
    push[Instr](&prog, i_mov_rr(R_R8(),  R_R9()));           // mov r8, r9  (both extended)
    push[Instr](&prog, i_mov_rr(R_RSI(), R_R8()));           // mov rsi, r8 (extended src only)

    // ── reg-reg ALU ──────────────────────────────────────────────────────────
    push[Instr](&prog, i_add(R_RAX(), R_RBX()));             // add rax, rbx
    push[Instr](&prog, i_sub(R_RAX(), R_RCX()));             // sub rax, rcx
    push[Instr](&prog, i_imul(R_RAX(), R_RDX()));            // imul rax, rdx (reg/rm swap)
    push[Instr](&prog, i_imul(R_R8(),  R_RAX()));            // imul r8, rax  (extended dst)
    push[Instr](&prog, i_cmp(R_RAX(), R_RBX()));             // cmp rax, rbx
    push[Instr](&prog, i_and(R_RAX(), R_RBX()));             // and rax, rbx
    push[Instr](&prog, i_or(R_RAX(),  R_RBX()));             // or  rax, rbx
    push[Instr](&prog, i_xor(R_RAX(), R_RBX()));             // xor rax, rbx

    // ── reg-imm32 ALU ─────────────────────────────────────────────────────────
    push[Instr](&prog, i_add_imm(R_RAX(), 16));              // add rax, 16
    push[Instr](&prog, i_sub_imm(R_RAX(), 8));               // sub rax, 8
    push[Instr](&prog, i_cmp_imm(R_RAX(), 100));             // cmp rax, 100

    // ── push / pop, including extended reg ────────────────────────────────────
    push[Instr](&prog, i_push(R_RBP()));                     // push rbp
    push[Instr](&prog, i_push(R_R8()));                      // push r8
    push[Instr](&prog, i_pop(R_R8()));                       // pop r8
    push[Instr](&prog, i_pop(R_RBP()));                      // pop rbp

    // ── neg, idiv ─────────────────────────────────────────────────────────────
    push[Instr](&prog, i_neg(R_RAX()));                      // neg rax
    push[Instr](&prog, i_idiv(R_RCX()));                     // cqo ; idiv rcx
    push[Instr](&prog, i_idiv(R_R8()));                      // cqo ; idiv r8 (extended)

    // ── memory: rbp base with NEGATIVE disp; rsp base (SIB); r12 base (SIB+ext) ─
    push[Instr](&prog, i_load(R_RAX(), R_RBP(), 0 - 16));    // mov rax, [rbp-16]
    push[Instr](&prog, i_store(R_RBP(), 0 - 16, R_RAX()));   // mov [rbp-16], rax
    push[Instr](&prog, i_lea(R_RAX(), R_RBP(), 0 - 16));     // lea rax, [rbp-16]
    push[Instr](&prog, i_store(R_RSP(), 24, R_RBX()));       // mov [rsp+24], rbx  (SIB)
    push[Instr](&prog, i_load(R_RCX(), R_RSP(), 8));         // mov rcx, [rsp+8]   (SIB)
    push[Instr](&prog, i_load(R_R8(),  R_R8(),  0 - 8));     // mov r8, [r8-8]     (extended base+reg)

    // ── setcc for several condition codes ─────────────────────────────────────
    push[Instr](&prog, i_setcc(R_RAX(), CC_E()));            // sete  al  ; movzx rax
    push[Instr](&prog, i_setcc(R_RAX(), CC_NE()));           // setne al  ; movzx rax
    push[Instr](&prog, i_setcc(R_RAX(), CC_L()));            // setl  al  ; movzx rax
    push[Instr](&prog, i_setcc(R_RAX(), CC_G()));            // setg  al  ; movzx rax
    push[Instr](&prog, i_setcc(R_R8(),  CC_GE()));           // setge r8b ; movzx r8 (extended)

    // ── labels + control flow: backward jump (loop), forward jump, call ───────
    // layout: label 1 (loop top) ... jl 1 (backward) ; jmp 2 (forward over body)
    //         ... label 3 (call target) ... call 3 ... label 2 (forward dest)
    push[Instr](&prog, i_label(1));                          // .L1  (loop top)
    push[Instr](&prog, i_cmp(R_RAX(), R_RBX()));             // cmp rax, rbx
    push[Instr](&prog, i_jl(1));                             // jl .L1   (BACKWARD)
    push[Instr](&prog, i_jmp(2));                            // jmp .L2  (FORWARD)
    push[Instr](&prog, i_label(3));                          // .L3  (call target)
    push[Instr](&prog, i_mov_imm(R_RAX(), 0));              // body
    push[Instr](&prog, i_ret());                             // ret  (end of callee)
    push[Instr](&prog, i_call(3));                           // call .L3 (BACKWARD call)
    push[Instr](&prog, i_je(2));                             // je .L2 (forward jcc)
    push[Instr](&prog, i_label(2));                          // .L2  (forward dest)

    // ── terminators ──────────────────────────────────────────────────────────
    push[Instr](&prog, i_syscall());                         // syscall
    push[Instr](&prog, i_ret());                             // ret

    // ── encode ─────────────────────────────────────────────────────────────────
    let buf: ArrayList[u8] = encode(prog);

    _zag_print("zag-x86: encoded bytes = ");
    print_i32(buf.len);

    let wrc: i32 = _zag_write_file("/tmp/x86_test.bin", buf.data[0..buf.len]);
    if (wrc == 0) {
        _zag_println("zag-x86: wrote /tmp/x86_test.bin OK");
    } else {
        _zag_println("zag-x86: FAILED to write /tmp/x86_test.bin");
    }
}
