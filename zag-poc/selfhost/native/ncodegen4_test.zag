// selfhost/native/ncodegen4_test.zag — REAL end-to-end verification of ROUND-1
// of NATIVE SELF-HOSTING: GENERICS + @-BUILTINS + TYPE-TRACKING, then TAGGED
// UNIONS + switch + enums. Every feature is PROVEN by running the emitted native
// binary (no cc/as/ld/libc/LLVM) and checking its exit code / stdout.
//
//   parse → lower_program(decls,&err,&data) → encode → write_elf_exec_data → run
//
//   Run:  ./zagc build selfhost/native/ncodegen4_test.zag --run
//   Then: run each /tmp/n4_* and check exit code / stdout (the harness below
//         prints err/instr/code stats; the bash driver checks the binaries).

@import("x86.zag")
@import("elf.zag")
@import("ncodegen.zag")

// Build a program we EXPECT to lower cleanly (err==0) into a runnable ELF.
fn build(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, "selfhost/native");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let code: ArrayList[u8] = encode(prog);
    let rc: i32 = write_elf_exec_data(path, code, 0, data);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    _zag_print(" instrs=");
    _zag_print(_zag_i64_to_str(prog.len as i64));
    _zag_print(" code=");
    _zag_print(_zag_i64_to_str(code.len as i64));
    _zag_print(" data=");
    _zag_print(_zag_i64_to_str(data.len as i64));
    _zag_print(" -> ");
    _zag_print(path);
    if (rc == 0) { _zag_println(" OK"); }
    else { _zag_println(" WRITE-FAILED"); }
}

// A program we EXPECT to be REJECTED loudly: confirm err > 0 (driver aborts).
fn build_reject(tag: []u8, path: []u8, src: []u8) void {
    let decls: ArrayList[*Node] = parse_program_dir(src, "selfhost/native");
    let nerr: i32 = 0;
    let data: ArrayList[u8] = make[u8](16);
    let prog: ArrayList[Instr] = lower_program(decls, &nerr, &data);
    let _code: ArrayList[u8] = encode(prog);
    _zag_print(tag);
    _zag_print(": err=");
    _zag_print(_zag_i64_to_str(nerr as i64));
    if (nerr > 0) { _zag_println("  REJECTED-LOUDLY (good)"); }
    else { _zag_println("  *** NOT REJECTED (BAD) ***"); }
}

fn main() void {
    // ══ 1. @sizeOf ════════════════════════════════════════════════════════════
    // struct P{a,b,c} → 8*3 = 24.
    build("s1_sizeof_struct", "/tmp/n4_s1",
        "struct P{a:i32,b:i32,c:i32} fn main() i32 { return @sizeOf[P](); }");
    // scalar → 8 ; pointer → 8 ; []u8 → 16.
    build("s2_sizeof_scalar", "/tmp/n4_s2", "fn main() i32 { return @sizeOf[i32](); }");
    build("s3_sizeof_slice",  "/tmp/n4_s3", "fn main() i32 { return @sizeOf[[]u8](); }");

    // ══ 2. @strEq ═════════════════════════════════════════════════════════════
    build("e1_streq_eq", "/tmp/n4_e1",
        "fn main() i32 { if (@strEq(\"hi\",\"hi\")) { return 1; } return 0; }");
    build("e2_streq_ne", "/tmp/n4_e2",
        "fn main() i32 { if (@strEq(\"hi\",\"ho\")) { return 1; } return 0; }");
    // different lengths → not equal.
    build("e3_streq_len", "/tmp/n4_e3",
        "fn main() i32 { if (@strEq(\"hi\",\"hill\")) { return 1; } return 0; }");
    // @len of a slice variable.
    build("e4_len", "/tmp/n4_e4",
        "fn main() i32 { let s:[]u8=\"hello\"; return @len(s); }");

    // ══ 3. GENERIC FUNCTIONS (monomorphization) ═══════════════════════════════
    build("g1_genfn", "/tmp/n4_g1",
        "fn id[T](x: T) T { return x; } fn main() i32 { return id[i32](42); }");
    // a generic fn that calls another generic fn (transitive instantiation).
    build("g2_gen_chain", "/tmp/n4_g2",
        "fn id[T](x: T) T { return x; } fn dbl[T](x: T) T { return id[T](x) + id[T](x); } fn main() i32 { return dbl[i32](21); }");

    // ══ 4. GENERIC ArrayList — the real container test ════════════════════════
    build("g3_list", "/tmp/n4_g3",
        "@import(\"../../std/list.zag\") fn main() i32 { let xs: ArrayList[i32] = make[i32](4); push[i32](&xs, 30); push[i32](&xs, 12); return get[i32](xs,0) + get[i32](xs,1); }");
    build("g4_listlen", "/tmp/n4_g4",
        "@import(\"../../std/list.zag\") fn main() i32 { let xs: ArrayList[i32] = make[i32](4); push[i32](&xs, 30); push[i32](&xs, 12); return len[i32](xs); }");
    // grow past initial cap (exercises native realloc): 1+2+3+4+5 = 15.
    build("g5_listgrow", "/tmp/n4_g5",
        "@import(\"../../std/list.zag\") fn main() i32 { let xs: ArrayList[i32] = make[i32](1); push[i32](&xs,1); push[i32](&xs,2); push[i32](&xs,3); push[i32](&xs,4); push[i32](&xs,5); return get[i32](xs,0)+get[i32](xs,1)+get[i32](xs,2)+get[i32](xs,3)+get[i32](xs,4); }");

    // ══ 5. TAGGED UNIONS + switch ═════════════════════════════════════════════
    // active variant .a → c.* (7) + 35 = 42.
    build("u1_union_a", "/tmp/n4_u1",
        "union U { a: i32, b: i32 } fn main() i32 { let u: U = U{ .a = 7 }; switch (u) { .a => |c| { return c.* + 35; } .b => |c| { return c.*; } } return 0; }");
    // active variant .b → c.* (12) + 30 = 42 (proves the OTHER path is taken).
    build("u2_union_b", "/tmp/n4_u2",
        "union U { a: i32, b: i32 } fn main() i32 { let u: U = U{ .b = 12 }; switch (u) { .a => |c| { return c.* + 100; } .b => |c| { return c.* + 30; } } return 0; }");

    // ══ 6. ENUM switch returning per-variant values ═══════════════════════════
    build("u3_enum", "/tmp/n4_u3",
        "enum Color { Red, Green, Blue } fn main() i32 { let c: Color = Color.Green; switch (c) { .Red => { return 10; } .Green => { return 42; } .Blue => { return 99; } } return 0; }");
    // else fallback path.
    build("u4_enum_else", "/tmp/n4_u4",
        "enum Color { Red, Green, Blue } fn main() i32 { let c: Color = Color.Blue; switch (c) { .Red => { return 10; } else => { return 42; } } return 0; }");

    // ══ NON-REGRESSION (existing features must still work) ═════════════════════
    build("r_ret42", "/tmp/n4_r1", "fn main() i32 { return 42; }");
    build("r_fib10", "/tmp/n4_r2",
        "fn fib(n:i32) i32 { if (n < 2) { return n; } return fib(n-1) + fib(n-2); } fn main() i32 { return fib(10); }");
    build("r_printint", "/tmp/n4_r3", "fn main() i32 { print_int(12345); return 0; }");
    build("r_struct42", "/tmp/n4_r4",
        "struct P{x:i32,y:i32} fn main() i32 { let p:P=P{.x=30,.y=12}; return p.x+p.y; }");
    build("r_byval_ret", "/tmp/n4_r5",
        "struct P{x:i32,y:i32} fn mk(a:i32,b:i32) P { return P{.x=a,.y=b}; } fn main() i32 { let p:P=mk(40,2); return p.x+p.y; }");
    build("r_slice_len", "/tmp/n4_r6", "fn main() i32 { let s:[]u8=\"hello\"; return s.len; }");
    build("r_new", "/tmp/n4_r7",
        "struct P{x:i32,y:i32} fn main() i32 { let p:*P = new(P{.x=40,.y=2}); return p.*.x + p.*.y; }");

    // ══ REJECTIONS (still-unsupported → must abort loudly) ═════════════════════
    // unknown @-builtin.
    build_reject("x1_bad_builtin", "/tmp/n4_x1",
        "fn main() i32 { return @bogus[i32](); }");
    // address-of a plain scalar local (unchanged rejection).
    build_reject("x2_addr_scalar", "/tmp/n4_x2",
        "fn main() i32 { let a:i32=5; let p:*i32 = &a; return p.*; }");

    _zag_println("ncodegen4_test: all programs processed");
}
