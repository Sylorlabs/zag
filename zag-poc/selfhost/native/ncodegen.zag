// selfhost/native/ncodegen.zag — NATIVE CODEGEN for Zag's from-scratch x86-64
// backend. Lowers a parsed Zag AST (ArrayList[*Node] of top-level decls) into a
// flat ArrayList[Instr] (see isa.zag for the contract) that x86.zag can `encode`
// and elf.zag can `write_elf_exec` into a real, runnable Linux ELF — no
// cc/as/ld/LLVM anywhere in the pipeline.
//
//   AST ──lower_program──▶ ArrayList[Instr] ──encode──▶ bytes ──write_elf_exec──▶ ELF
//
// STRATEGY: a correct, unoptimized STACK MACHINE. Every expression leaves its
// result PUSHED on the CPU stack; binary ops pop two operands and push one. The
// separate optimizer is responsible for speed — here correctness is everything.
//
// CALLING CONVENTION: System V AMD64. Integer args in rdi,rsi,rdx,rcx,r8,r9;
// integer return in rax. rbp is the frame base for locals.
//
// ── 16-BYTE STACK ALIGNMENT (documented reasoning) ───────────────────────────
// At process entry the kernel hands us a 16-byte-aligned rsp, and our `_start`
// stub immediately `call`s main. A `call` pushes the 8-byte return address, so
// on entry to *any* function rsp ≡ 8 (mod 16). The prologue then does
// `push rbp` (another 8 bytes → rsp ≡ 0 mod 16) and `sub rsp, frame_size`. As
// long as frame_size is a MULTIPLE OF 16, rsp stays ≡ 0 (mod 16) after the
// prologue. From that aligned base, every inner `call` we emit is preceded by
// pushes that we always pop back off before the `call` (we pop the args into
// arg registers, restoring rsp to its post-prologue aligned value), so rsp ≡ 0
// (mod 16) at the inner `call` instruction — the ABI requirement. We therefore
// ALWAYS round frame_size up to a multiple of 16.
//
// LANGUAGE SUBSET: `;` after statements; no `<<`/`>>`/`|`/`||`-as-operator; no
// break/continue (flag-guarded while); `@strEq` for []u8 compare;
// `_zag_str_to_i64` to parse; deref pointer field as `p.*.field`; switch a union
// with `switch (n.*) { .tag => |x| {...} else => {...} }`. Helpers prefixed cg_.

@import("isa.zag")
@import("../parse.zag")   // AST (Node/Param/Bin/Call/FnDecl/...) + ArrayList + @strEq + _zag_str_to_i64

// ── decimal integer-literal parser ───────────────────────────────────────────
// We parse IntLit text ourselves (a small base-10 scanner) rather than calling
// the runtime's _zag_str_to_i64, whose ABI takes an extra out-pointer the Zag
// extern decl omits. The lexer hands us unsigned magnitudes; a leading '-' is a
// separate Un("-") node, but we tolerate one here for robustness. Underscores in
// numeric literals (e.g. 1_000) are skipped.
fn cg_parse_i64(s: []u8) i64 {
    let i: i32 = 0;
    let neg: i32 = 0;
    if (s.len > 0) {
        if (s[0] == '-') { neg = 1; i = 1; }
        else if (s[0] == '+') { i = 1; }
    }
    let acc: i64 = 0;
    while (i < s.len) {
        let c: u8 = s[i];
        if (c == '_') {
            i = i + 1;
        } else {
            let d: i64 = (c as i64) - 48;   // '0' = 48
            if (d >= 0 && d <= 9) {
                acc = acc * 10 + d;
            }
            i = i + 1;
        }
    }
    if (neg == 1) { return 0 - acc; }
    return acc;
}

// True only for a plain decimal integer literal (optional sign, digits, '_').
// Floats ("1.5"), hex, etc. -> 0, so codegen rejects them loudly instead of
// silently truncating (cg_parse_i64 would drop the '.' and mis-read the digits).
fn cg_is_int_text(s: []u8) i32 {
    let i: i32 = 0;
    if (s.len > 0) {
        if (s[0] == '-') { i = 1; }
        else if (s[0] == '+') { i = 1; }
    }
    if (i >= s.len) { return 0; }
    while (i < s.len) {
        let c: u8 = s[i];
        if (c == '_') { i = i + 1; }
        else {
            if (c < 48) { return 0; }
            if (c > 57) { return 0; }
            i = i + 1;
        }
    }
    return 1;
}

// ════════════════════════════════════════════════════════════════════════════
// FLOATING-POINT (f64 / f32) — decimal literal → IEEE-754 bit pattern, and the
// type predicates the SSE lowering keys on.
//
// REPRESENTATION CHOICE (documented): the native backend carries every float as
// a 64-bit DOUBLE bit pattern, flowing through ordinary integer registers / CPU
// stack words — so the integer stack machine is untouched; only the actual
// arithmetic/compare/convert hops into an xmm via MOVQ. f32 is PROMOTED to f64
// for storage and arithmetic (exact for f32-representable literals; full 4-byte
// []f32 packing + per-op f32 rounding is a later round). The compiler itself
// uses ONLY integer arithmetic here (cg_f64_bits is integer-only), so the native
// self-hosting fixpoint never depends on float codegen being correct.
// ════════════════════════════════════════════════════════════════════════════

// True iff `t` names a float type (f64 or f32 — treated identically internally).
fn cg_is_float_ty(t: []u8) i32 {
    if (@strEq(t, "f64")) { return 1; }
    if (@strEq(t, "f32")) { return 1; }
    return 0;
}

// True iff `s` is decimal FLOAT text: digits with exactly the float shape — at
// least one '.' OR an exponent marker, only digits / '.' / 'e' / 'E' / sign /
// '_'. Rejects hex ("0xff") and garbage so they are caught loudly (NOT parsed as
// a bogus float). A plain integer ("42") returns 0 (handled by the int path).
fn cg_is_float_text(s: []u8) i32 {
    let i: i32 = 0;
    if (s.len > 0) {
        if (s[0] == '-') { i = 1; }
        else if (s[0] == '+') { i = 1; }
    }
    if (i >= s.len) { return 0; }
    let dots: i32 = 0;
    let exps: i32 = 0;
    let digits: i32 = 0;
    while (i < s.len) {
        let c: u8 = s[i];
        if (c == '_') { i = i + 1; }
        else if (c == '.') { dots = dots + 1; i = i + 1; }
        else if (c == 'e' || c == 'E') {
            exps = exps + 1;
            i = i + 1;
            if (i < s.len) { if (s[i] == '-' || s[i] == '+') { i = i + 1; } }
        }
        else if (c >= 48 && c <= 57) { digits = digits + 1; i = i + 1; }
        else { return 0; }    // any other char → not a clean float
    }
    if (digits == 0) { return 0; }
    if (dots > 1) { return 0; }
    if (exps > 1) { return 0; }
    if (dots == 0 && exps == 0) { return 0; }   // an integer, not a float
    return 1;
}

// Largest positive i64 (used by the overflow guards below).
fn cg_i64_max() i64 { return 9223372036854775807; }

// 2^k as an i64 (k in 0..62). Built by doubling — no `<<` in the subset.
fn cg_pow2(k: i32) i64 {
    let v: i64 = 1;
    let i: i32 = 0;
    while (i < k) { v = v * 2; i = i + 1; }
    return v;
}

// IEEE-754 sign bit constant (0x8000000000000000) as an i64 bit pattern. We
// build it without a bare huge literal: it is i64-MIN, i.e. -(2^63).
fn cg_sign_bit() i64 { return (0 - cg_i64_max()) - 1; }

// ── decimal → IEEE-754 double, INTEGER-ONLY, correctly-rounded for the common
// range ──────────────────────────────────────────────────────────────────────
// Parses `s` (validated by cg_is_float_text) into the exact double bit pattern.
// Method: value = M × 10^decExp (M = up to 18 significant digits). We form the
// exact rational num/den, take its integer part's bits, then peel fractional
// bits by binary long division (remainder×2 / den — overflow-safe since the
// remainder stays < den ≤ 10^18 < 2^60), collect 54 bits (53 + round), and
// round-to-nearest-even. Magnitudes whose num/den would overflow i64 are
// REJECTED LOUDLY (cg_err) — never mis-encoded. Bit-exact vs strtod across a
// 32-value cross-check (0.5,1.5,3.14,0.0001,0.0219929,6.022e23,1e-10,…).
fn cg_f64_bits(s: []u8, cg: *Cg) i64 {
    let n: i32 = s.len;
    let i: i32 = 0;
    let neg: i32 = 0;
    if (i < n) {
        if (s[i] == '-') { neg = 1; i = 1; }
        else if (s[i] == '+') { i = 1; }
    }
    let m: i64 = 0;        // significand integer (≤18 sig digits)
    let sigcnt: i32 = 0;
    let fracdigits: i32 = 0;
    let seen_dot: i32 = 0;
    let expval: i32 = 0;
    let done: i32 = 0;
    while (i < n && done == 0) {
        let c: u8 = s[i];
        if (c == '.') { seen_dot = 1; i = i + 1; }
        else if (c == 'e' || c == 'E') {
            i = i + 1;
            let esign: i32 = 1;
            if (i < n) {
                if (s[i] == '-') { esign = 0 - 1; i = i + 1; }
                else if (s[i] == '+') { i = i + 1; }
            }
            let ev: i32 = 0;
            while (i < n) {
                let ec: u8 = s[i];
                if (ec >= 48 && ec <= 57) { ev = ev * 10 + ((ec as i32) - 48); i = i + 1; }
                else { i = i + 1; }
            }
            expval = esign * ev;
            done = 1;
        }
        else if (c == '_') { i = i + 1; }
        else if (c >= 48 && c <= 57) {
            let d: i32 = (c as i32) - 48;
            if (sigcnt < 18) {
                // skip leading INTEGER zeros (not significant); fractional zeros
                // ARE significant (they shift the value via fracdigits).
                let skip: i32 = 0;
                if (m == 0 && d == 0 && seen_dot == 0) { skip = 1; }
                if (skip == 0) {
                    m = m * 10 + (d as i64);
                    sigcnt = sigcnt + 1;
                    if (seen_dot == 1) { fracdigits = fracdigits + 1; }
                }
            } else {
                // beyond 18 sig digits: an extra INTEGER digit scales by 10.
                if (seen_dot == 0) { expval = expval + 1; }
            }
            i = i + 1;
        }
        else { i = i + 1; }
    }

    if (m == 0) {
        // ±0.0
        if (neg == 1) { return cg_sign_bit(); }
        return 0;
    }

    let dexp: i32 = expval - fracdigits;
    let imax: i64 = cg_i64_max();

    // form num/den (one of them is 1) with overflow guards.
    let num: i64 = m;
    let den: i64 = 1;
    if (dexp >= 0) {
        let k: i32 = 0;
        while (k < dexp) {
            if (num > imax / 10) { cg_err(cg, "native: float literal magnitude out of supported range"); return 0; }
            num = num * 10;
            k = k + 1;
        }
    } else {
        let k2: i32 = 0;
        let kk: i32 = 0 - dexp;
        while (k2 < kk) {
            if (den > imax / 10) { cg_err(cg, "native: float literal magnitude out of supported range"); return 0; }
            den = den * 10;
            k2 = k2 + 1;
        }
    }

    // binary long division → 54-bit significand (top bit set) + sticky.
    let intq: i64 = num / den;
    let rem: i64 = num - intq * den;
    let sig: i64 = 0;
    let e2: i32 = 0;
    let need: i32 = 54;
    let sticky: i32 = 0;

    if (intq > 0) {
        // bit length of intq
        let nb: i32 = 0;
        let t: i64 = intq;
        while (t > 0) { nb = nb + 1; t = t / 2; }
        e2 = nb - 1;
        if (nb <= need) {
            sig = intq;
            let bc: i32 = nb;
            while (bc < need) {
                rem = rem * 2;
                let bit: i64 = 0;
                if (rem >= den) { bit = 1; rem = rem - den; }
                sig = sig * 2 + bit;
                bc = bc + 1;
            }
        } else {
            let drop: i32 = nb - need;
            let p2: i64 = cg_pow2(drop);
            if ((intq - (intq / p2) * p2) != 0) { sticky = 1; }
            sig = intq / p2;
            if (rem != 0) { sticky = 1; }
        }
    } else {
        // value < 1: peel until the leading 1 bit (sets e2), then 53 more.
        let pos: i32 = 0;
        let found: i32 = 0;
        while (found == 0) {
            rem = rem * 2;
            let bit2: i64 = 0;
            if (rem >= den) { bit2 = 1; rem = rem - den; }
            pos = pos + 1;
            if (bit2 == 1) { found = 1; }
        }
        e2 = 0 - pos;
        sig = 1;
        let bc2: i32 = 1;
        while (bc2 < need) {
            rem = rem * 2;
            let bit3: i64 = 0;
            if (rem >= den) { bit3 = 1; rem = rem - den; }
            sig = sig * 2 + bit3;
            bc2 = bc2 + 1;
        }
    }

    if (rem != 0) { sticky = 1; }
    // round 54-bit sig to 53 bits, round-half-to-even.
    let roundbit: i64 = sig - (sig / 2) * 2;   // sig % 2
    let sig53: i64 = sig / 2;
    if (roundbit == 1) {
        let lsb: i64 = sig53 - (sig53 / 2) * 2;
        if (sticky == 1 || lsb == 1) {
            sig53 = sig53 + 1;
            if (sig53 == cg_pow2(53)) { sig53 = sig53 / 2; e2 = e2 + 1; }
        }
    }

    let expfield: i32 = e2 + 1023;
    if (expfield <= 0) {
        // subnormal/underflow — flush to ±0 (out of the supported normal range).
        if (neg == 1) { return cg_sign_bit(); }
        return 0;
    }
    if (expfield >= 2047) {
        // overflow → ±inf
        let inf: i64 = (2047 as i64) * cg_pow2(52);
        if (neg == 1) { return inf + cg_sign_bit(); }
        return inf;
    }
    let mant: i64 = sig53 - (sig53 / cg_pow2(52)) * cg_pow2(52);   // sig53 % 2^52
    let bits: i64 = (expfield as i64) * cg_pow2(52) + mant;
    if (neg == 1) { bits = bits + cg_sign_bit(); }
    return bits;
}

// ════════════════════════════════════════════════════════════════════════════
// GENERICS — monomorphization, ported from the mature C backend (codegen.zag).
//
// We expand the program BEFORE lowering: every distinct generic instantiation
// becomes a concrete, mangled decl appended to the decl list. A generic
// function `foo[T](..)` → a concrete `foo_T(..)` with its body cloned and every
// `T` substituted; a generic struct `Base[args]` → a concrete struct `Base_args`
// with substituted field types. The existing struct-layout / fn-symbol / type-
// tracking machinery then works unchanged: it only ever sees mangled, concrete
// names. Call sites and struct literals carrying type-args are resolved to their
// mangled names at lowering time (cg_call_mangled / cg_slit_sname).
//
// We mirror codegen.zag's logic exactly: subst_type, mangle, clone_*, and a
// fixpoint instance collection (a specialized body may instantiate more).
// ════════════════════════════════════════════════════════════════════════════

// Sanitize one type arg into an identifier fragment (* → p, [] → _, drop ]).
fn cg_mangle_targ(t: []u8) []u8 {
    let buf: ArrayList[u8] = make[u8](8);
    let i: i32 = 0;
    while (i < t.len) {
        let c: i32 = t[i] as i32;
        if (c == '*') { push[u8](&buf, 'p'); }
        else if (c == '[') { push[u8](&buf, '_'); }
        else if (c == ']') { }
        else if (c == ',') { push[u8](&buf, '_'); }
        else { push[u8](&buf, t[i]); }
        i = i + 1;
    }
    return buf.data[0..buf.len];
}

// name + "_" + each sanitized targ, e.g. ("id", ["i32"]) → "id_i32".
fn cg_mangle_generic(name: []u8, targs: ArrayList[[]u8]) []u8 {
    let s: []u8 = name;
    let i: i32 = 0;
    while (i < len[[]u8](targs)) {
        s = _zag_str_concat(s, "_");
        s = _zag_str_concat(s, cg_mangle_targ(get[[]u8](targs, i)));
        i = i + 1;
    }
    return s;
}

// Substitute generic type-params (names) with concrete args (vals) in a type
// string, honouring *, ?, !, [] prefixes and generic applications Base[args].
fn cg_subst_type(t: []u8, names: ArrayList[[]u8], vals: ArrayList[[]u8]) []u8 {
    let i: i32 = 0;
    while (i < len[[]u8](names)) {
        if (@strEq(t, get[[]u8](names, i))) { return get[[]u8](vals, i); }
        i = i + 1;
    }
    if (t.len > 1) {
        if (t[0] == '*') { return _zag_str_concat("*", cg_subst_type(t[1..], names, vals)); }
        if (t[0] == '?') { return _zag_str_concat("?", cg_subst_type(t[1..], names, vals)); }
        if (t[0] == '!') { return _zag_str_concat("!", cg_subst_type(t[1..], names, vals)); }
    }
    if (t.len > 2) {
        if (t[0] == '[' && t[1] == ']') { return _zag_str_concat("[]", cg_subst_type(t[2..], names, vals)); }
    }
    if (is_generic_app(t)) {
        let lb: i32 = index_of(t, '[');
        let base: []u8 = t[0..lb];
        let arglist: ArrayList[[]u8] = split_args(t[lb + 1..t.len - 1]);
        let s: []u8 = _zag_str_concat(base, "[");
        let k: i32 = 0;
        while (k < len[[]u8](arglist)) {
            if (k > 0) { s = _zag_str_concat(s, ","); }
            s = _zag_str_concat(s, cg_subst_type(get[[]u8](arglist, k), names, vals));
            k = k + 1;
        }
        return _zag_str_concat(s, "]");
    }
    return t;
}

// CANONICALIZE a type string for the native backend: a generic application
// Base[args] → its mangled concrete name Base_args (recursively normalising the
// args), and a `*Base[args]` → `*Base_args`, etc. After expansion every concrete
// struct instance is registered under this mangled name, so normalizing here lets
// the layout / type-tracking machinery key on it uniformly. Plain types (i32,
// "P", "[]u8", "*T") pass through unchanged.
fn cg_norm_type(t: []u8) []u8 {
    if (t.len > 1) {
        if (t[0] == '*') { return _zag_str_concat("*", cg_norm_type(t[1..])); }
    }
    if (is_generic_app(t)) {
        let lb: i32 = index_of(t, '[');
        let base: []u8 = t[0..lb];
        let arglist: ArrayList[[]u8] = split_args(t[lb + 1..t.len - 1]);
        // normalise each arg too (nested generic args), then mangle.
        let norm: ArrayList[[]u8] = make[[]u8](2);
        let k: i32 = 0;
        while (k < len[[]u8](arglist)) {
            push[[]u8](&norm, cg_norm_type(get[[]u8](arglist, k)));
            k = k + 1;
        }
        return cg_mangle_generic(base, norm);
    }
    return t;
}

// ── clone an AST subtree with type-param substitution (tp→ta) ────────────────
// Identical in spirit to codegen.zag's clone_*; we additionally clone switch
// statements (the native backend lowers them directly). Generic CALLS and struct
// LITERALS keep their (substituted) targs so the call/lit resolves to the right
// concrete mangled name after substitution.
fn cg_subst_targs(targs: ArrayList[[]u8], tp: ArrayList[[]u8], ta: ArrayList[[]u8]) ArrayList[[]u8] {
    let out: ArrayList[[]u8] = make[[]u8](2);
    let i: i32 = 0;
    while (i < len[[]u8](targs)) {
        push[[]u8](&out, cg_subst_type(get[[]u8](targs, i), tp, ta));
        i = i + 1;
    }
    return out;
}

fn cg_clone_call(c: Call, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    let args: ArrayList[*Node] = make[*Node](4);
    let i: i32 = 0;
    while (i < len[*Node](c.args)) {
        push[*Node](&args, cg_clone_expr(get[*Node](c.args, i), tp, ta));
        i = i + 1;
    }
    if (len[[]u8](c.targs) > 0) {
        return mk_gcall(cg_clone_expr(c.callee, tp, ta), args, cg_subst_targs(c.targs, tp, ta));
    }
    return mk_call(cg_clone_expr(c.callee, tp, ta), args);
}

fn cg_clone_slit(s: StructLit, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    let flds: ArrayList[FieldInit] = make[FieldInit](4);
    let i: i32 = 0;
    while (i < len[FieldInit](s.fields)) {
        let f: FieldInit = get[FieldInit](s.fields, i);
        push[FieldInit](&flds, FieldInit{ .name = f.name, .val = cg_clone_expr(f.val, tp, ta) });
        i = i + 1;
    }
    return new(Node{ .slit_ = StructLit{ .sname = s.sname, .fields = flds, .targs = cg_subst_targs(s.targs, tp, ta) } });
}

fn cg_clone_expr(n: *Node, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    return switch (n.*) {
        .ilit   => |x| mk_int(x.text),
        .slit   => |x| mk_str(x.text),
        .id     => |x| mk_ident(x.name),
        .bin    => |b| mk_bin(b.op, cg_clone_expr(b.l, tp, ta), cg_clone_expr(b.r, tp, ta)),
        .un     => |u| mk_un(u.op, cg_clone_expr(u.e, tp, ta)),
        .call   => |c| cg_clone_call(c, tp, ta),
        .fld    => |f| mk_field(cg_clone_expr(f.base, tp, ta), f.fname),
        .idx    => |x| mk_index(cg_clone_expr(x.base, tp, ta), cg_clone_expr(x.idx, tp, ta)),
        .slit_  => |s| cg_clone_slit(s, tp, ta),
        .cast_  => |c| mk_cast(cg_clone_expr(c.expr, tp, ta), cg_subst_type(c.target, tp, ta)),
        .slice_ => |s| mk_slice(cg_clone_expr(s.base, tp, ta), cg_clone_expr(s.lo, tp, ta), cg_clone_expr(s.hi, tp, ta), s.has_hi),
        else    => n,
    };
}

fn cg_clone_block(body: ArrayList[*Node], tp: ArrayList[[]u8], ta: ArrayList[[]u8]) ArrayList[*Node] {
    let out: ArrayList[*Node] = make[*Node](8);
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        push[*Node](&out, cg_clone_stmt(get[*Node](body, i), tp, ta));
        i = i + 1;
    }
    return out;
}

fn cg_clone_arm(a: SwitchArm, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) SwitchArm {
    return SwitchArm{ .tags = a.tags, .cap = a.cap, .has_cap = a.has_cap, .body = cg_clone_block(a.body, tp, ta) };
}

fn cg_clone_stmt(n: *Node, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    return switch (n.*) {
        .let_    => |l| mk_let(l.name, cg_subst_type(l.dty, tp, ta), l.has_dty, cg_clone_expr(l.expr, tp, ta)),
        .ret     => |r| mk_ret(r.has_expr, cg_clone_expr(r.expr, tp, ta)),
        .if_     => |x| mk_if(cg_clone_expr(x.cond, tp, ta), cg_clone_block(x.then_body, tp, ta), cg_clone_block(x.els_body, tp, ta), x.has_els),
        .while_  => |w| mk_while(cg_clone_expr(w.cond, tp, ta), cg_clone_block(w.body, tp, ta)),
        .assign  => |a| mk_assign(cg_clone_expr(a.target, tp, ta), cg_clone_expr(a.expr, tp, ta)),
        .estmt   => |e| mk_estmt(cg_clone_expr(e.expr, tp, ta)),
        .switch_ => |sw| cg_clone_switch(sw, tp, ta),
        else     => n,
    };
}

fn cg_clone_switch(sw: Switch, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    let arms: ArrayList[SwitchArm] = make[SwitchArm](4);
    let i: i32 = 0;
    while (i < len[SwitchArm](sw.arms)) {
        push[SwitchArm](&arms, cg_clone_arm(get[SwitchArm](sw.arms, i), tp, ta));
        i = i + 1;
    }
    return mk_switch(cg_clone_expr(sw.subject, tp, ta), arms, cg_clone_block(sw.els_body, tp, ta), sw.has_els);
}

// callee name of a call node ("" if not a plain ident).
fn cg_callee_name(n: *Node) []u8 {
    return switch (n.*) {
        .id  => |d| d.name,
        .fld => |f| f.fname,
        else => "",
    };
}

// ── instance collection (fixpoint) ───────────────────────────────────────────
// EXP holds the growing expanded decl list (originals + mangled instances) and a
// `seen` set of mangled instance names so we never duplicate one. `gnames` lists
// the names of mangled generic-fn instances we created (so their cloned bodies
// can be walked for further instantiation at the fixpoint).
struct Exp {
    decls:  ArrayList[*Node],   // original + appended instance decls
    seen:   ArrayList[[]u8],    // mangled names already emitted (fns AND structs)
}

fn cg_exp_seen(e: *Exp, m: []u8) i32 {
    let i: i32 = 0;
    while (i < len[[]u8](e.*.seen)) {
        if (@strEq(get[[]u8](e.*.seen, i), m)) { return 1; }
        i = i + 1;
    }
    return 0;
}

// Find the generic struct/fn template decl by (original) name; returns the *Node
// or a null sentinel via the has-flag pattern.
fn cg_find_generic_fn(decls: ArrayList[*Node], name: []u8, out: *FnDecl) i32 {
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        switch (get[*Node](decls, i).*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) > 0 && @strEq(f.name, name)) { out.* = f; return 1; }
            }
            else => { }
        }
        i = i + 1;
    }
    return 0;
}

fn cg_find_generic_struct(decls: ArrayList[*Node], name: []u8, out: *StructDecl) i32 {
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        switch (get[*Node](decls, i).*) {
            .struct_ => |s| {
                if (len[[]u8](s.tparams) > 0 && @strEq(s.name, name)) { out.* = s; return 1; }
            }
            else => { }
        }
        i = i + 1;
    }
    return 0;
}

// Register the generic STRUCT instance Base[targs] (and, transitively, any
// generic struct types its substituted fields reference) as concrete mangled
// StructDecls appended to e.decls. Dependencies are recorded first.
fn cg_inst_struct(e: *Exp, base: []u8, targs: ArrayList[[]u8], orig: ArrayList[*Node]) void {
    if (len[[]u8](targs) == 0) { return; }
    let mangled: []u8 = cg_mangle_generic(base, targs);
    if (cg_exp_seen(e, mangled) == 1) { return; }
    let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
    if (cg_find_generic_struct(orig, base, &sd) == 0) { return; }
    // mark seen up front (struct fields can be self-referential through a pointer)
    push[[]u8](&e.*.seen, mangled);
    // substitute field types, recording nested generic struct deps first.
    let newfields: ArrayList[Param] = make[Param](len[Param](sd.fields) + 1);
    let fi: i32 = 0;
    while (fi < len[Param](sd.fields)) {
        let p: Param = get[Param](sd.fields, fi);
        let st: []u8 = cg_subst_type(p.pty, sd.tparams, targs);
        cg_inst_type(e, st, orig);
        push[Param](&newfields, Param{ .name = p.name, .pty = cg_norm_type(st) });
        fi = fi + 1;
    }
    push[*Node](&e.*.decls, new(Node{ .struct_ = StructDecl{ .name = mangled, .fields = newfields, .tparams = make[[]u8](1) } }));
}

// Record a generic struct instantiation implied by a type string (e.g.
// "*ArrayList[i32]" → ArrayList[i32]). Strips *, ?, !, [] prefixes.
fn cg_inst_type(e: *Exp, t: []u8, orig: ArrayList[*Node]) void {
    let u: []u8 = t;
    let go: i32 = 1;
    while (go == 1) {
        if (u.len > 1 && (u[0] == '*' || u[0] == '?' || u[0] == '!')) { u = u[1..]; }
        else if (u.len > 2 && u[0] == '[' && u[1] == ']') { u = u[2..]; }
        else { go = 0; }
    }
    if (is_generic_app(u) == false) { return; }
    let lb: i32 = index_of(u, '[');
    let base: []u8 = u[0..lb];
    let arglist: ArrayList[[]u8] = split_args(u[lb + 1..u.len - 1]);
    cg_inst_struct(e, base, arglist, orig);
}

// Walk an expression, registering generic struct instances (struct lits, casts).
fn cg_inst_sinst_expr(e: *Exp, n: *Node, orig: ArrayList[*Node]) void {
    switch (n.*) {
        .slit_ => |s| {
            cg_inst_struct(e, s.sname, s.targs, orig);
            let i: i32 = 0;
            while (i < len[FieldInit](s.fields)) { cg_inst_sinst_expr(e, get[FieldInit](s.fields, i).val, orig); i = i + 1; }
        }
        .call  => |c| { let i: i32 = 0; while (i < len[*Node](c.args)) { cg_inst_sinst_expr(e, get[*Node](c.args, i), orig); i = i + 1; } }
        .bin   => |b| { cg_inst_sinst_expr(e, b.l, orig); cg_inst_sinst_expr(e, b.r, orig); }
        .un    => |u| { cg_inst_sinst_expr(e, u.e, orig); }
        .fld   => |f| { cg_inst_sinst_expr(e, f.base, orig); }
        .idx   => |x| { cg_inst_sinst_expr(e, x.base, orig); cg_inst_sinst_expr(e, x.idx, orig); }
        .cast_ => |c| { cg_inst_type(e, c.target, orig); cg_inst_sinst_expr(e, c.expr, orig); }
        .slice_=> |s| { cg_inst_sinst_expr(e, s.base, orig); cg_inst_sinst_expr(e, s.lo, orig); cg_inst_sinst_expr(e, s.hi, orig); }
        else => { }
    }
}

// Walk an expression, registering generic FN instances (foo[T](..) calls).
fn cg_inst_fn_expr(e: *Exp, n: *Node, orig: ArrayList[*Node]) void {
    switch (n.*) {
        .call => |c| {
            let i: i32 = 0;
            while (i < len[*Node](c.args)) { cg_inst_fn_expr(e, get[*Node](c.args, i), orig); i = i + 1; }
            if (len[[]u8](c.targs) > 0) {
                let cn: []u8 = cg_callee_name(c.callee);
                let mangled: []u8 = cg_mangle_generic(cn, c.targs);
                if (cg_exp_seen(e, mangled) == 0) {
                    let f: FnDecl = FnDecl{ .name = "", .tparams = make[[]u8](1), .params = make[Param](1), .ret = "", .annots = make[[]u8](1), .body = make[*Node](1), .is_extern = 0 };
                    if (cg_find_generic_fn(orig, cn, &f) == 1) {
                        push[[]u8](&e.*.seen, mangled);
                        // clone body with tp→targs; build concrete params/ret.
                        let cb: ArrayList[*Node] = cg_clone_block(f.body, f.tparams, c.targs);
                        let nps: ArrayList[Param] = make[Param](len[Param](f.params) + 1);
                        let pi: i32 = 0;
                        while (pi < len[Param](f.params)) {
                            let p: Param = get[Param](f.params, pi);
                            push[Param](&nps, Param{ .name = p.name, .pty = cg_norm_type(cg_subst_type(p.pty, f.tparams, c.targs)) });
                            pi = pi + 1;
                        }
                        let nret: []u8 = cg_norm_type(cg_subst_type(f.ret, f.tparams, c.targs));
                        push[*Node](&e.*.decls, new(Node{ .fn_decl = FnDecl{
                            .name = mangled, .tparams = make[[]u8](1), .params = nps,
                            .ret = nret, .annots = make[[]u8](1), .body = cb, .is_extern = 0 } }));
                    }
                }
            }
        }
        .bin   => |b| { cg_inst_fn_expr(e, b.l, orig); cg_inst_fn_expr(e, b.r, orig); }
        .un    => |u| { cg_inst_fn_expr(e, u.e, orig); }
        .fld   => |f| { cg_inst_fn_expr(e, f.base, orig); }
        .idx   => |x| { cg_inst_fn_expr(e, x.base, orig); cg_inst_fn_expr(e, x.idx, orig); }
        .cast_ => |c| { cg_inst_fn_expr(e, c.expr, orig); }
        .slice_=> |s| { cg_inst_fn_expr(e, s.base, orig); cg_inst_fn_expr(e, s.lo, orig); cg_inst_fn_expr(e, s.hi, orig); }
        .slit_ => |s| { let i: i32 = 0; while (i < len[FieldInit](s.fields)) { cg_inst_fn_expr(e, get[FieldInit](s.fields, i).val, orig); i = i + 1; } }
        else => { }
    }
}

// Walk a statement for BOTH fn and struct instances.
fn cg_inst_stmt(e: *Exp, n: *Node, orig: ArrayList[*Node]) void {
    switch (n.*) {
        .let_    => |l| { cg_inst_type(e, l.dty, orig); cg_inst_fn_expr(e, l.expr, orig); cg_inst_sinst_expr(e, l.expr, orig); }
        .ret     => |r| { if (r.has_expr == 1) { cg_inst_fn_expr(e, r.expr, orig); cg_inst_sinst_expr(e, r.expr, orig); } }
        .if_     => |x| { cg_inst_fn_expr(e, x.cond, orig); cg_inst_sinst_expr(e, x.cond, orig); cg_inst_body(e, x.then_body, orig); if (x.has_els == 1) { cg_inst_body(e, x.els_body, orig); } }
        .while_  => |w| { cg_inst_fn_expr(e, w.cond, orig); cg_inst_sinst_expr(e, w.cond, orig); cg_inst_body(e, w.body, orig); }
        .assign  => |a| { cg_inst_fn_expr(e, a.target, orig); cg_inst_fn_expr(e, a.expr, orig); cg_inst_sinst_expr(e, a.target, orig); cg_inst_sinst_expr(e, a.expr, orig); }
        .estmt   => |s| { cg_inst_fn_expr(e, s.expr, orig); cg_inst_sinst_expr(e, s.expr, orig); }
        .switch_ => |sw| {
            cg_inst_fn_expr(e, sw.subject, orig); cg_inst_sinst_expr(e, sw.subject, orig);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { cg_inst_body(e, get[SwitchArm](sw.arms, ai).body, orig); ai = ai + 1; }
            if (sw.has_els == 1) { cg_inst_body(e, sw.els_body, orig); }
        }
        else => { }
    }
}

fn cg_inst_body(e: *Exp, body: ArrayList[*Node], orig: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { cg_inst_stmt(e, get[*Node](body, i), orig); i = i + 1; }
}

// EXPAND the program: append a concrete mangled decl for every generic
// instantiation, to a fixpoint (a specialized body can instantiate more). The
// `orig` list (the unexpanded templates) is the search space for templates; new
// instance decls are appended to `e.decls` and ALSO walked (so transitive
// instances are discovered). Returns the expanded decl list.
fn cg_expand_generics(decls: ArrayList[*Node]) ArrayList[*Node] {
    let e: Exp = Exp{ .decls = make[*Node](len[*Node](decls) + 8), .seen = make[[]u8](8) };
    // seed with the originals.
    let i: i32 = 0;
    while (i < len[*Node](decls)) { push[*Node](&e.decls, get[*Node](decls, i)); i = i + 1; }
    // walk every NON-generic fn body for instances; also struct/fn signatures.
    let di: i32 = 0;
    while (di < len[*Node](decls)) {
        switch (get[*Node](decls, di).*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) == 0 && f.is_extern == 0) {
                    cg_inst_body(&e, f.body, decls);
                    let pj: i32 = 0;
                    while (pj < len[Param](f.params)) { cg_inst_type(&e, get[Param](f.params, pj).pty, decls); pj = pj + 1; }
                    cg_inst_type(&e, f.ret, decls);
                }
            }
            .struct_ => |s| {
                // A NON-generic struct whose FIELD is a generic-struct application
                // (e.g. `params: ArrayList[i32]`) must register that instance so the
                // field's true size (not the scalar default) is known when this
                // struct's layout is computed. Generic templates (tparams > 0) emit
                // no layout themselves — their concrete instances do.
                if (len[[]u8](s.tparams) == 0) {
                    let fj: i32 = 0;
                    while (fj < len[Param](s.fields)) { cg_inst_type(&e, get[Param](s.fields, fj).pty, decls); fj = fj + 1; }
                }
            }
            .union_ => |u| {
                // Likewise a non-generic union whose variant PAYLOAD is a generic
                // struct application (or contains one) registers that instance.
                let uj: i32 = 0;
                while (uj < len[Param](u.fields)) { cg_inst_type(&e, get[Param](u.fields, uj).pty, decls); uj = uj + 1; }
            }
            else => { }
        }
        di = di + 1;
    }
    // FIXPOINT: walk each appended instance fn body (cloned, concrete) for more
    // instances. New decls land at the end of e.decls; iterate until the cursor
    // catches the (growing) length. Instance struct decls have empty bodies, so
    // only fn_decl instances add work.
    let fp: i32 = len[*Node](decls);
    while (fp < len[*Node](e.decls)) {
        switch (get[*Node](e.decls, fp).*) {
            .fn_decl => |f2| {
                if (f2.is_extern == 0) {
                    cg_inst_body(&e, f2.body, decls);
                    let pj2: i32 = 0;
                    while (pj2 < len[Param](f2.params)) { cg_inst_type(&e, get[Param](f2.params, pj2).pty, decls); pj2 = pj2 + 1; }
                    cg_inst_type(&e, f2.ret, decls);
                }
            }
            .struct_ => |s2| {
                // a concrete instance struct's field types may reference further
                // generic struct instances; ensure those are registered.
                let sj: i32 = 0;
                while (sj < len[Param](s2.fields)) { cg_inst_type(&e, get[Param](s2.fields, sj).pty, decls); sj = sj + 1; }
            }
            else => { }
        }
        fp = fp + 1;
    }
    return e.decls;
}

// The concrete struct name a struct LITERAL denotes: generic → mangled, else the
// plain name. (StructLit.targs is empty for a non-generic literal.)
fn cg_slit_sname(s: StructLit) []u8 {
    if (len[[]u8](s.targs) > 0) { return cg_mangle_generic(s.sname, s.targs); }
    return s.sname;
}

// ── threaded codegen context ─────────────────────────────────────────────────
// Function ids are 1..num_fns. Control-flow labels are minted strictly above
// that range from `Cg.next`, so the two id spaces never collide.
//
// Extended for OUTPUT / STRINGS / STRUCTS:
//   data       — pointer to the string-constant DATA blob being accumulated.
//                A literal appended at offset `off` is referenced at the
//                absolute address DATA_VBASE()+off (movabs), so no relocation.
//   decls      — the whole top-level decl list, so we can resolve struct
//                layouts (struct-name → fields → field-index/offset) on demand.
//   pi_lbl     — label of the __print_int support routine.
//   ps_lbl     — label of the __print_str support routine.
//   al_lbl     — label of the __alloc (mmap) support routine.
//
// CONDITIONAL SUPPORT ROUTINES: a label is always MINTED for each support
// routine (so any `call` to it resolves), but its BODY is only emitted at the
// end of the program if the matching `use_*` flag was set during lowering. A
// program that never prints/allocs therefore contains NONE of those routine
// bodies — the binary is smaller and disassembly shows no dead code. The flags
// live behind a pointer hop (`cg.*`) so the threaded Cg sees the updates.
struct Cg {
    next:   i32,
    err:    i32,
    data:   *ArrayList[u8],
    decls:  ArrayList[*Node],
    pi_lbl: i32,
    ps_lbl: i32,
    al_lbl: i32,
    se_lbl: i32,    // label of the __streq support routine (@strEq)
    ml_lbl: i32,    // label of the __malloc support routine (_zag_malloc)
    rl_lbl: i32,    // label of the __realloc support routine (_zag_realloc)
    pf_lbl: i32,    // label of the __print_f64 support routine (print_f64/print_f32)
    use_pi: i32,    // 1 if __print_int is referenced
    use_pf: i32,    // 1 if __print_f64 is referenced
    use_ps: i32,    // 1 if __print_str is referenced
    use_al: i32,    // 1 if __alloc is referenced
    use_se: i32,    // 1 if __streq is referenced
    use_ml: i32,    // 1 if __malloc is referenced
    use_rl: i32,    // 1 if __realloc is referenced
    // ── NATIVE SYSCALL RUNTIME (the `_zag_*` externs) ────────────────────────
    // A contiguous block of `RT_COUNT()` labels minted at `rt_base`; routine k
    // has label rt_base+k (see the RT_* index constants). `rt_used[k] == 1` iff
    // routine k is referenced by some call site, so its body is emitted only then.
    rt_base: i32,
    rt_used: *ArrayList[i32],
}

// ── native-runtime routine indices (label = cg.*.rt_base + index) ────────────
// One per `_zag_*` extern we implement with raw syscalls. Bodies are emitted at
// the end of the program, conditionally on rt_used[k].
fn RT_WRITELN()  i32 { return 0; }   // __rt_writeln(rdi=&slice, rsi=fd, rdx=add_nl) — write(+'\n')
fn RT_CONCAT()   i32 { return 1; }   // _zag_str_concat(rdi=&a, rsi=&b) -> &{ptr,len}
fn RT_I2S()      i32 { return 2; }   // _zag_i64_to_str(rdi=v) -> &{ptr,len}
fn RT_U2S()      i32 { return 3; }   // _zag_u64_to_str(rdi=v) -> &{ptr,len}
fn RT_READF()    i32 { return 4; }   // _zag_read_file(rdi=&path) -> &{ptr,len} (len=-1 fail)
fn RT_WRITEF()   i32 { return 5; }   // _zag_write_file(rdi=&path, rsi=&content) -> 0/-1
fn RT_WRITEX()   i32 { return 6; }   // _zag_write_exec(rdi=&path, rsi=&content) -> 0/-1
fn RT_FEXISTS()  i32 { return 7; }   // _zag_file_exists(rdi=&path) -> 1/0
fn RT_ARG()      i32 { return 8; }   // _zag_arg(rdi=i) -> &{ptr,len}
fn RT_EXEC()     i32 { return 9; }   // _zag_exec_cmd(rdi=&cmd) -> exit status
fn RT_STRDUP()   i32 { return 10; }  // _zag_strdup(rdi=&s) -> &{ptr,len}
fn RT_STRCMPO()  i32 { return 11; }  // _zag_strcmp_ord(rdi=&a, rsi=&b) -> <0/0/>0
fn RT_IDXBYTE()  i32 { return 12; }  // _zag_str_index_of_byte(rdi=&s, rsi=b) -> idx/-1
fn RT_MEMCPY()   i32 { return 13; }  // _zag_memcpy(rdi=d, rsi=s, rdx=n)
fn RT_MEMCMP()   i32 { return 14; }  // _zag_memcmp(rdi=a, rsi=b, rdx=n) -> memcmp
fn RT_STR2I()    i32 { return 15; }  // _zag_str_to_i64(rdi=&s) -> i64
fn RT_PATHBUF()  i32 { return 16; }  // helper: __rt_pathbuf(rdi=&slice) -> rax=cstr (mmap'd, NUL-term)
fn RT_COUNT()    i32 { return 17; }  // number of runtime routines

// Record an unsupported-construct error: warn loudly AND bump the count so the
// driver ABORTS the build instead of ever emitting a silently-wrong binary.
fn cg_err(cg: *Cg, msg: []u8) void {
    _zag_eprintln(msg);
    cg.*.err = cg.*.err + 1;
}

fn cg_fresh(cg: *Cg) i32 {
    let id: i32 = cg.*.next;
    cg.*.next = cg.*.next + 1;
    return id;
}

// Label of native-runtime routine `k` (= rt_base + k).
fn cg_rt_lbl(cg: *Cg, k: i32) i32 { return cg.*.rt_base + k; }

// Mark native-runtime routine `k` as referenced so its body is emitted.
fn cg_rt_use(cg: *Cg, k: i32) void {
    set[i32](cg.*.rt_used, k, 1);
}

// True if native-runtime routine `k` is referenced.
fn cg_rt_is_used(cg: *Cg, k: i32) i32 {
    return get[i32](cg.*.rt_used.*, k);
}

// ── string-literal DECODING ──────────────────────────────────────────────────
// IMPORTANT: in THIS toolchain the lexer stores a string token's RAW lexeme —
// it INCLUDES the surrounding double-quotes and leaves escape sequences
// (\n \t \r \0 \\ \" \') UNDECODED (see selfhost/lex.zag). So StrLit.text for
// source "hi\n" is the 6 bytes  "  h i \ n  "  — NOT the decoded 3 bytes. We
// therefore decode it OURSELVES here: strip the outer quotes and resolve the
// standard escapes into their real bytes. Unknown escapes pass the escaped
// byte through verbatim (matching the lexer's char-literal behaviour). The
// result is the true byte sequence the program prints / measures / indexes.
fn cg_decode_str(text: []u8, out: *ArrayList[u8]) void {
    let n: i32 = text.len;
    let i: i32 = 0;
    let j: i32 = n;
    // Strip a single leading and trailing double-quote, if present (a well
    // formed Str token always has them; be defensive if not).
    if (n >= 2) {
        if (text[0] == 34) { i = 1; }                 // 34 = '"'
        if (text[n - 1] == 34) { j = n - 1; }
    }
    while (i < j) {
        let c: u8 = text[i];
        if (c == 92 && i + 1 < j) {                   // 92 = '\\'
            let e: u8 = text[i + 1];
            if (e == 'n') { push[u8](out, 10); }
            else if (e == 't') { push[u8](out, 9); }
            else if (e == 'r') { push[u8](out, 13); }
            else if (e == '0') { push[u8](out, 0); }
            else { push[u8](out, e); }                // \\, \", \', etc.
            i = i + 2;
        } else {
            push[u8](out, c);
            i = i + 1;
        }
    }
}

// Decoded byte LENGTH of a string literal token (post-quote-strip, post-escape).
fn cg_decoded_len(text: []u8) i32 {
    let tmp: ArrayList[u8] = make[u8](text.len + 1);
    cg_decode_str(text, &tmp);
    return len[u8](tmp);
}

// ── string-constant DATA blob ────────────────────────────────────────────────
// Decode the string literal `text` (strip quotes, resolve escapes) and append
// its real bytes to the data blob, returning the BYTE OFFSET at which they
// start. The emitted code references those bytes at the absolute virtual
// address DATA_VBASE()+off (computed at codegen time — no relocation). If
// `add_nl` is 1 a trailing '\n' is appended (for _zag_println). The returned
// off, together with the decoded length, is what the caller movabs's into
// rsi/rdx for __print_str.
fn cg_intern_str(cg: *Cg, text: []u8, add_nl: i32) i32 {
    let off: i32 = len[u8](cg.*.data.*);
    cg_decode_str(text, cg.*.data);
    if (add_nl == 1) { push[u8](cg.*.data, 10); }   // '\n'
    return off;
}

// ── struct / aggregate layout (PROPER variable-size, round-2) ────────────────
// LAYOUT CONTRACT (corrected from the old "8 bytes per field"):
//   • scalar / pointer / bool / enum         → 8 bytes
//   • []u8 (any slice)                        → 16 bytes  ({ptr@0, len@8})
//   • ?T optional                             → 8 + size(T)  ({has@0, val@8})
//   • struct                                  → SUM of its field sizes, each
//                                                field ROUNDED UP to a multiple
//                                                of 8 (so every offset is
//                                                8-aligned and the word-based
//                                                frame machinery still works).
//   • tagged union                            → 8 (tag@0) + max payload size
//                                                (payload stored INLINE @8).
//   A struct field's OFFSET is the cumulative 8-aligned sum of the field sizes
//   PRECEDING it (NOT 8*index). A struct's total size is that running sum.
//   For all-scalar structs this collapses to the old layout (offset 8*idx,
//   size 8*nfields) — backward compatible. A []u8 field is 16 bytes; a nested
//   struct/union field is its own size. Field byte sizes are always multiples
//   of 8, so aggregates remain a whole number of 8-byte words throughout.

// Find the StructDecl for `sname` among the top-level decls. Returns 1 and
// fills *out on success, 0 if there is no such struct.
fn cg_find_struct(cg: *Cg, sname: []u8, out: *StructDecl) i32 {
    let di: i32 = 0;
    while (di < len[*Node](cg.*.decls)) {
        let d: *Node = get[*Node](cg.*.decls, di);
        switch (d.*) {
            .struct_ => |s| {
                if (@strEq(s.name, sname)) { out.* = s; return 1; }
            }
            else => { }
        }
        di = di + 1;
    }
    return 0;
}

// Field index of `fname` within struct `sname`, or -1 if unknown. The byte
// offset is 8 * the returned index.
fn cg_field_index(cg: *Cg, sname: []u8, fname: []u8) i32 {
    let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
    if (cg_find_struct(cg, sname, &sd) == 0) { return 0 - 1; }
    let i: i32 = 0;
    while (i < len[Param](sd.fields)) {
        if (@strEq(get[Param](sd.fields, i).name, fname)) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

// Number of fields of struct `sname`, or -1 if unknown. (NOT size/8 anymore —
// a field can be >1 word; use cg_type_size / cg_agg_words for byte/word counts.)
fn cg_struct_nfields(cg: *Cg, sname: []u8) i32 {
    let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
    if (cg_find_struct(cg, sname, &sd) == 0) { return 0 - 1; }
    return len[Param](sd.fields);
}

// round n up to a multiple of 8 (field/payload alignment).
fn cg_round8(n: i32) i32 {
    let r: i32 = n % 8;
    if (r == 0) { return n; }
    return n + (8 - r);
}

// BYTE size of any type under the proper variable-size layout.
//   scalar/ptr/bool/enum → 8 ; []u8 → 16 ; ?T → 8 + round8(size(T)) ;
//   struct → sum of round8(field size) ; union → 8 + round8(max payload size).
// Recursion terminates because a struct/union field cannot (in this subset)
// contain itself by value — recursive types go through a pointer (*T → 8).
fn cg_type_size(cg: *Cg, ty0: []u8) i32 {
    let ty: []u8 = cg_norm_type(ty0);
    if (ty.len == 0) { return 8; }
    if (ty[0] == '*') { return 8; }                 // pointer = scalar
    if (cg_type_is_slice(cg, ty) == 1) { return 16; }  // []u8 = {ptr,len}
    if (ty[0] == '?') {                             // optional ?T = {has, val}
        return 8 + cg_round8(cg_type_size(cg, ty[1..]));
    }
    // struct: sum of 8-aligned field sizes.
    let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
    if (cg_find_struct(cg, ty, &sd) == 1) {
        let total: i32 = 0;
        let i: i32 = 0;
        while (i < len[Param](sd.fields)) {
            total = total + cg_round8(cg_type_size(cg, get[Param](sd.fields, i).pty));
            i = i + 1;
        }
        if (total == 0) { return 8; }   // empty struct: one word (defensive)
        return total;
    }
    // tagged union: 8 (tag) + max payload size, payload stored INLINE @8.
    let ud: UnionDecl = UnionDecl{ .name = "", .fields = make[Param](1) };
    if (cg_find_union(cg, ty, &ud) == 1) {
        let maxp: i32 = 0;
        let j: i32 = 0;
        while (j < len[Param](ud.fields)) {
            let ps: i32 = cg_round8(cg_type_size(cg, get[Param](ud.fields, j).pty));
            if (ps > maxp) { maxp = ps; }
            j = j + 1;
        }
        if (maxp == 0) { maxp = 8; }
        return 8 + maxp;
    }
    return 8;   // scalar / enum / unknown
}

// True if `ty` is a single-BYTE element type (u8 / i8). A `*u8`/`*i8` pointer
// array (e.g. an ArrayList[u8]'s `.data`, the ELF/string byte buffers) is packed
// at BYTE stride — unlike every other scalar, which our uniform layout pads to 8
// bytes. Byte-packing is mandatory: those buffers are handed to the `write`
// syscall verbatim, so a sparse 8-byte-stride layout would corrupt the output.
fn cg_elem_is_byte(ty: []u8) i32 {
    if (@strEq(ty, "u8")) { return 1; }
    if (@strEq(ty, "i8")) { return 1; }
    return 0;
}

// Pointer-arithmetic STRIDE (element byte size) for a `*T` array: 1 for a byte
// element (u8/i8), else the full type size (8 for scalars/pointers under our
// uniform layout, the aggregate size for a struct). This is what `p[i]` adds.
fn cg_elem_stride(cg: *Cg, ty: []u8) i32 {
    if (cg_elem_is_byte(ty) == 1) { return 1; }
    return cg_type_size(cg, ty);
}

// BYTE offset of field `fname` within struct `sname` = cumulative 8-aligned sum
// of the sizes of all PRECEDING fields. Returns -1 if the field/struct is unknown.
fn cg_field_offset(cg: *Cg, sname: []u8, fname: []u8) i32 {
    let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
    if (cg_find_struct(cg, sname, &sd) == 0) { return 0 - 1; }
    let off: i32 = 0;
    let i: i32 = 0;
    while (i < len[Param](sd.fields)) {
        let p: Param = get[Param](sd.fields, i);
        if (@strEq(p.name, fname)) { return off; }
        off = off + cg_round8(cg_type_size(cg, p.pty));
        i = i + 1;
    }
    return 0 - 1;
}

// True if `ty` names a user struct in this program (i.e. an aggregate held
// by-pointer, not a scalar). A leading '*' (pointer) is a SCALAR (the address),
// never a struct-by-value.
fn cg_type_is_struct(cg: *Cg, ty: []u8) i32 {
    if (ty.len == 0) { return 0; }
    if (ty[0] == '*') { return 0; }
    let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
    return cg_find_struct(cg, ty, &sd);
}

// True if `ty` is the []u8 slice type. We model a []u8 as a 2-word builtin
// aggregate {ptr@0, len@8} — 16 bytes — handled with the same by-pointer machinery
// as user structs. Only []u8 is supported (byte slices); other element types are
// not, and are NOT treated as aggregates here (they fall through to rejection).
fn cg_type_is_slice(cg: *Cg, ty: []u8) i32 {
    let _u: i32 = cg.*.err;   // keep the signature uniform (cg unused otherwise)
    return @strEq(ty, "[]u8");
}

// True if `ty` is an optional `?T` (held inline by-value as {has, val}).
fn cg_type_is_opt(cg: *Cg, ty: []u8) i32 {
    let _u: i32 = cg.*.err;
    if (ty.len > 1) { if (ty[0] == '?') { return 1; } }
    return 0;
}

// True if `ty` is ANY aggregate held INLINE by-value (addressed by a base
// pointer): a user struct, a []u8 slice, a tagged union {tag,payload}, or an
// optional `?T` {has,val}. A leading '*' is a scalar pointer (the address).
fn cg_type_is_agg(cg: *Cg, ty: []u8) i32 {
    if (cg_type_is_struct(cg, ty) == 1) { return 1; }
    if (cg_type_is_slice(cg, ty) == 1) { return 1; }
    if (ty.len > 0) {
        if (ty[0] != '*') { if (cg_type_is_union(cg, ty) == 1) { return 1; } }
    }
    if (cg_type_is_opt(cg, ty) == 1) { return 1; }
    return 0;
}

// WORD count (8-byte words) of an aggregate type = cg_type_size / 8. Every
// aggregate is a whole number of 8-byte words by construction (all field/payload
// sizes are 8-aligned). Callers gate this with cg_type_is_agg; returns 1
// defensively for a non-aggregate.
fn cg_agg_words(cg: *Cg, ty: []u8) i32 {
    if (cg_type_is_agg(cg, ty) == 0) { return 1; }
    let sz: i32 = cg_type_size(cg, ty);
    let w: i32 = sz / 8;
    if (w < 1) { return 1; }
    return w;
}

// ── tagged-union layout & lookups ────────────────────────────────────────────
// A tagged union U is laid out as: tag (i64) at offset 0, payload at offset 8.
// Total size = 8 + max-variant-payload (8-aligned). Every variant payload is
// treated as one 8-byte word in this subset (scalars and pointers fit; an
// aggregate variant payload is held by-pointer = 1 word). So every union is
// exactly 2 words: {tag@0, payload@8}. Construction stores the variant's INDEX
// (its position in the UnionDecl) as the tag; switch compares the loaded tag to
// each arm's variant index. Mirrors codegen.zag's tagged-union model.

// Find the UnionDecl named `uname`; fills *out, returns 1 on success.
fn cg_find_union(cg: *Cg, uname: []u8, out: *UnionDecl) i32 {
    let i: i32 = 0;
    while (i < len[*Node](cg.*.decls)) {
        switch (get[*Node](cg.*.decls, i).*) {
            .union_ => |u| { if (@strEq(u.name, uname)) { out.* = u; return 1; } }
            else => { }
        }
        i = i + 1;
    }
    return 0;
}

// True if `name` names a declared tagged union.
fn cg_type_is_union(cg: *Cg, name: []u8) i32 {
    let ud: UnionDecl = UnionDecl{ .name = "", .fields = make[Param](1) };
    return cg_find_union(cg, name, &ud);
}

// Index of variant `tag` within union `uname` (the stored tag value), or -1.
fn cg_union_variant_index(cg: *Cg, uname: []u8, tag: []u8) i32 {
    let ud: UnionDecl = UnionDecl{ .name = "", .fields = make[Param](1) };
    if (cg_find_union(cg, uname, &ud) == 0) { return 0 - 1; }
    let i: i32 = 0;
    while (i < len[Param](ud.fields)) {
        if (@strEq(get[Param](ud.fields, i).name, tag)) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

// Declared payload type of variant `tag` in union `uname` (or "" if unknown).
fn cg_union_payload_type(cg: *Cg, uname: []u8, tag: []u8) []u8 {
    let ud: UnionDecl = UnionDecl{ .name = "", .fields = make[Param](1) };
    if (cg_find_union(cg, uname, &ud) == 0) { return ""; }
    let i: i32 = 0;
    while (i < len[Param](ud.fields)) {
        if (@strEq(get[Param](ud.fields, i).name, tag)) { return get[Param](ud.fields, i).pty; }
        i = i + 1;
    }
    return "";
}

// Name of the union that declares variant `tag` (scans every union), or "".
fn cg_union_name_for_tag(cg: *Cg, tag: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](cg.*.decls)) {
        switch (get[*Node](cg.*.decls, i).*) {
            .union_ => |u| {
                let j: i32 = 0;
                while (j < len[Param](u.fields)) {
                    if (@strEq(get[Param](u.fields, j).name, tag)) { return u.name; }
                    j = j + 1;
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// ── enum layout & lookups ────────────────────────────────────────────────────
// An enum value is a plain integer = the member's index in the EnumDecl. Member
// access `Color.Green` evaluates to that index; switch compares an integer.
fn cg_find_enum(cg: *Cg, ename: []u8, out: *EnumDecl) i32 {
    let i: i32 = 0;
    while (i < len[*Node](cg.*.decls)) {
        switch (get[*Node](cg.*.decls, i).*) {
            .enum_ => |en| { if (@strEq(en.name, ename)) { out.* = en; return 1; } }
            else => { }
        }
        i = i + 1;
    }
    return 0;
}

// Integer value (member index) of `Ename.member`, or -1 if unknown.
fn cg_enum_member_index(cg: *Cg, ename: []u8, member: []u8) i32 {
    let ed: EnumDecl = EnumDecl{ .name = "", .members = make[[]u8](1) };
    if (cg_find_enum(cg, ename, &ed) == 0) { return 0 - 1; }
    let i: i32 = 0;
    while (i < len[[]u8](ed.members)) {
        if (@strEq(get[[]u8](ed.members, i), member)) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

// Name of the enum that declares member `m` (scans every enum), or "".
fn cg_enum_name_for_member(cg: *Cg, m: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](cg.*.decls)) {
        switch (get[*Node](cg.*.decls, i).*) {
            .enum_ => |en| {
                let j: i32 = 0;
                while (j < len[[]u8](en.members)) {
                    if (@strEq(get[[]u8](en.members, j), m)) { return en.name; }
                    j = j + 1;
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// ── global function symbol table (name → label id, return type) ──────────────
struct FnSym { name: []u8, lbl: i32, ret: []u8, nparams: i32 }

fn cg_find_fn(syms: ArrayList[FnSym], name: []u8) i32 {
    let i: i32 = 0;
    while (i < len[FnSym](syms)) {
        if (@strEq(get[FnSym](syms, i).name, name)) { return get[FnSym](syms, i).lbl; }
        i = i + 1;
    }
    return 0 - 1;
}

// ── per-function local environment (name → rbp displacement, coarse type) ────
// Each param and each `let` gets one or more 8-byte slots. A SCALAR local owns
// a single slot at disp = -8*(index+1) and its variable evaluates to that
// scalar value. A STRUCT-typed local owns N contiguous slots (N = field count)
// and the variable evaluates to the ADDRESS of the first slot (lea rbp+disp).
//
// `types` runs parallel to `names`/`disps`: types[i] is the coarse declared
// type string of names[i] (e.g. "i32", "P", "*P", "[]u8"). An empty string
// means "unknown scalar". `frame_words` is the next free 8-byte slot index;
// allocating an N-word local bumps it by N. The pre-scan in cg_lower_fn sizes
// the frame to hold the worst case, so growth here never overruns it.
// ── by-reference aggregates (params, sret) ───────────────────────────────────
// An aggregate (struct or []u8 slice) is held one of two ways:
//   • INLINE  — the local owns N contiguous 8-byte words; the variable evaluates
//               to lea(rbp+disp), the ADDRESS of that block. (`let p = P{..}`.)
//   • BY-REF  — the local owns a SINGLE word holding a POINTER to a block that
//               lives elsewhere (the caller's copy, for a by-value param/slice
//               param). The variable evaluates to load(rbp+disp), the pointer.
// `byref[i]` (parallel to names/disps/types) is 1 for BY-REF, 0 for INLINE.
// Field access and `.len`/indexing consult this to pick lea vs load when taking
// the aggregate's base address. This is how struct/slice by-value parameters get
// their own copy yet still expose `p.field` syntax.
struct Env {
    names:       ArrayList[[]u8],
    disps:       ArrayList[i32],
    types:       ArrayList[[]u8],
    byref:       ArrayList[i32],
    count:       i32,    // number of named locals
    frame_words: i32,    // next free 8-byte word index
    epilogue:    i32,
    sret_disp:   i32,    // rbp disp of the saved sret pointer (cg_not_found if none)
    sret_words:  i32,    // word count of the returned aggregate (0 if not sret)
    sret_type:   []u8,   // the aggregate return type string ("" if not sret)
}

fn cg_env_new(epilogue: i32) Env {
    return Env{
        .names = make[[]u8](8),
        .disps = make[i32](8),
        .types = make[[]u8](8),
        .byref = make[i32](8),
        .count = 0,
        .frame_words = 0,
        .epilogue = epilogue,
        .sret_disp = 0 - 2147483647,
        .sret_words = 0,
        .sret_type = "",
    };
}

// Is the named local a BY-REF aggregate (its slot holds a pointer to the block)?
fn cg_slot_byref(env: Env, name: []u8) i32 {
    let i: i32 = 0;
    while (i < len[[]u8](env.names)) {
        if (@strEq(get[[]u8](env.names, i), name)) { return get[i32](env.byref, i); }
        i = i + 1;
    }
    return 0;
}

// Type string recorded for a local (empty if none / unknown).
fn cg_slot_type(env: Env, name: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[[]u8](env.names)) {
        if (@strEq(get[[]u8](env.names, i), name)) { return get[[]u8](env.types, i); }
        i = i + 1;
    }
    return "";
}

// Allocate `words` contiguous 8-byte slots for `name` with coarse type `ty`,
// returning the rbp displacement of the FIRST (lowest-address) word. If the
// name already exists (shadowing) we reuse its slot AND refresh its type — but
// only when the existing slot is at least as large, which is the common case
// (same name re-let). The disp of a local is -8*(first_word_index + words):
// the first word lives at the most-negative address of the block so that, with
// our struct field offsets being POSITIVE (base + 8*idx), field accesses stay
// inside the block.
fn cg_slot_alloc_br(env: *Env, name: []u8, ty: []u8, words: i32, byref: i32) i32 {
    let i: i32 = 0;
    while (i < len[[]u8](env.*.names)) {
        if (@strEq(get[[]u8](env.*.names, i), name)) {
            set[[]u8](&env.*.types, i, ty);
            set[i32](&env.*.byref, i, byref);
            return get[i32](env.*.disps, i);
        }
        i = i + 1;
    }
    let first: i32 = env.*.frame_words;
    // Block occupies words [first .. first+words-1]; the first word sits at the
    // lowest address: disp = -(8*(first+words)). Field k is at disp + 8*k.
    let disp: i32 = 0 - (8 * (first + words));
    push[[]u8](&env.*.names, name);
    push[i32](&env.*.disps, disp);
    push[[]u8](&env.*.types, ty);
    push[i32](&env.*.byref, byref);
    env.*.count = env.*.count + 1;
    env.*.frame_words = env.*.frame_words + words;
    return disp;
}

// Allocate inline storage (byref=0) for `name`: a scalar (1 word) or an
// aggregate (N contiguous words). The variable evaluates to the block address.
fn cg_slot_alloc_typed(env: *Env, name: []u8, ty: []u8, words: i32) i32 {
    return cg_slot_alloc_br(env, name, ty, words, 0);
}

// Allocate a single anonymous scratch word (no name), returning its disp. Used
// for argument-copy temps and sret result blocks; the pre-scan reserves these.
fn cg_slot_scratch(env: *Env) i32 {
    let first: i32 = env.*.frame_words;
    let disp: i32 = 0 - (8 * (first + 1));
    env.*.frame_words = env.*.frame_words + 1;
    return disp;
}

// Reserve `words` contiguous anonymous scratch words; return the LOWEST disp
// (word 0). Field k sits at disp + 8*k, matching the struct layout contract.
fn cg_slot_scratch_n(env: *Env, words: i32) i32 {
    let first: i32 = env.*.frame_words;
    let disp: i32 = 0 - (8 * (first + words));
    env.*.frame_words = env.*.frame_words + words;
    return disp;
}

// Allocate a single scalar slot for `name` (unknown type), returning its disp.
fn cg_slot_alloc(env: *Env, name: []u8) i32 {
    return cg_slot_alloc_typed(env, name, "", 1);
}

// Look up an existing local's displacement; returns 1 (mod via has-flag) packed
// as: returns the disp, and -2147483647 sentinel means "not found".
fn cg_slot_find(env: Env, name: []u8) i32 {
    let i: i32 = 0;
    while (i < len[[]u8](env.names)) {
        if (@strEq(get[[]u8](env.names, i), name)) { return get[i32](env.disps, i); }
        i = i + 1;
    }
    return 0 - 2147483647;   // sentinel: undefined name
}

fn cg_not_found() i32 { return 0 - 2147483647; }

// ── slot pre-scan ────────────────────────────────────────────────────────────
// To fix frame_size before emitting the prologue we count the worst-case number
// of 8-byte WORDS the function's locals need: its params (1 word each) plus
// every distinct `let` (1 word for a scalar, N words for a struct-typed let,
// N = field count). Names are deduped so a re-`let` of a name shares its slot.
// `seen` collects distinct names; `words` accumulates the running word total.
fn cg_scan_seen(seen: *ArrayList[[]u8], name: []u8) i32 {
    let i: i32 = 0;
    while (i < len[[]u8](seen.*)) {
        if (@strEq(get[[]u8](seen.*, i), name)) { return 1; }   // already counted
        i = i + 1;
    }
    push[[]u8](seen, name);
    return 0;
}

// Word size of a declared type: an aggregate (struct → field count, []u8 → 2),
// else 1 (scalar).
fn cg_type_words(cg: *Cg, ty: []u8) i32 {
    if (cg_type_is_agg(cg, ty) == 1) { return cg_agg_words(cg, ty); }
    return 1;
}

// ── declared-type map for the pre-scan ───────────────────────────────────────
// The frame must reserve SCRATCH words for aggregate (struct / []u8) values that
// flow through CALLS: each by-value aggregate ARGUMENT needs an N-word caller
// copy, and each aggregate-by-value RETURN needs an N-word result block (sret).
// To know whether an argument or a call's result is an aggregate, the pre-scan
// needs the static types of names — which the env will hold later but isn't
// built yet. So we build a parallel, AST-only name→type map here (params + `let`
// declared/inferred types), mirroring exactly what cg_expr_type will report,
// plus a function name→return-type map (`fnames`/`frets`).
struct ScanCtx {
    seen:    *ArrayList[[]u8],   // distinct local names already sized
    words:   *i32,               // running frame word count
    names:   ArrayList[[]u8],    // local name → declared type (parallel)
    types:   ArrayList[[]u8],
    fnames:  ArrayList[[]u8],    // function name → return type (parallel)
    frets:   ArrayList[[]u8],
}

fn cg_scan_rectype(sc: *ScanCtx, name: []u8, ty: []u8) void {
    push[[]u8](&sc.*.names, name);
    push[[]u8](&sc.*.types, ty);
}

// Static type of an expression using ONLY the AST + the scan's name/fn maps
// (no env, but WITH cg for struct layouts). Conservative: returns "" (scalar)
// when it cannot tell. Mirrors the aggregate-relevant cases of cg_expr_type so
// the reserved scratch EXACTLY matches what lowering allocates — including field
// (`p.*.toks`), index, and slice bases, whose aggregate-ness must be seen by the
// scan or the per-call argument-copy reservation under-counts and the frame
// overruns (→ corruption when an aggregate field is passed by value).
fn cg_scan_typeof(sc: *ScanCtx, cg: *Cg, n: *Node) []u8 {
    switch (n.*) {
        .id => |x| {
            let i: i32 = 0;
            while (i < len[[]u8](sc.*.names)) {
                if (@strEq(get[[]u8](sc.*.names, i), x.name)) { return get[[]u8](sc.*.types, i); }
                i = i + 1;
            }
            return "";
        }
        .slit_ => |s| { return cg_norm_type(cg_slit_sname(s)); }
        .slit  => |_s| { return "[]u8"; }   // a string literal IS a []u8 slice value
        .cast_ => |c2| { return cg_norm_type(c2.target); }
        .slice_ => |sl| {
            let bt: []u8 = cg_scan_typeof(sc, cg, sl.base);
            if (cg_type_is_slice(cg, bt) == 1) { return "[]u8"; }
            switch (sl.base.*) { .slit => |_s| { return "[]u8"; } else => { } }
            if (@strEq(bt, "*u8") || @strEq(bt, "*i8")) { return "[]u8"; }
            return "";
        }
        .idx => |ix| {
            let bt: []u8 = cg_scan_typeof(sc, cg, ix.base);
            if (cg_type_is_slice(cg, bt) == 1) { return "u8"; }
            if (bt.len > 1) { if (bt[0] == '*') { return bt[1..]; } }
            return "";
        }
        .fld => |f| {
            // p.* — pointee type (strip leading '*').
            if (@strEq(f.fname, "*")) {
                let bt0: []u8 = cg_scan_typeof(sc, cg, f.base);
                if (bt0.len > 1 && bt0[0] == '*') { return bt0[1..]; }
                return "";
            }
            // optional .has/.val
            let obt0: []u8 = cg_scan_typeof(sc, cg, f.base);
            let obt1: []u8 = obt0;
            if (obt1.len > 1 && obt1[0] == '*') { obt1 = obt1[1..]; }
            if (cg_type_is_opt(cg, obt1) == 1) {
                if (@strEq(f.fname, "has")) { return "i32"; }
                if (@strEq(f.fname, "val")) { return cg_norm_type(obt1[1..]); }
                return "";
            }
            // struct field: peel a leading '*' (p.*.field collapses *S → S).
            let sname: []u8 = obt0;
            if (sname.len > 1) { if (sname[0] == '*') { sname = sname[1..]; } }
            let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
            if (cg_find_struct(cg, sname, &sd) == 1) {
                let i: i32 = 0;
                while (i < len[Param](sd.fields)) {
                    if (@strEq(get[Param](sd.fields, i).name, f.fname)) {
                        return cg_norm_type(get[Param](sd.fields, i).pty);
                    }
                    i = i + 1;
                }
            }
            return "";
        }
        .call  => |c| {
            switch (c.callee.*) {
                .id => |cid| {
                    // native-runtime externs (_zag_*) → their syscall return type.
                    if (cg_is_native_rt(cid.name) == 1) { return cg_native_rt_ret(cid.name); }
                    // generic call foo[T](..) → look up the mangled instance ret.
                    let fn2: []u8 = cid.name;
                    if (len[[]u8](c.targs) > 0) { fn2 = cg_mangle_generic(cid.name, c.targs); }
                    let i: i32 = 0;
                    while (i < len[[]u8](sc.*.fnames)) {
                        if (@strEq(get[[]u8](sc.*.fnames, i), fn2)) { return get[[]u8](sc.*.frets, i); }
                        i = i + 1;
                    }
                    return "";
                }
                else => { return ""; }
            }
        }
        else => { return ""; }
    }
}

// Reserve scratch words for one call expression: by-value aggregate ARGS each
// need an N-word caller copy, and an aggregate-by-value RETURN needs an N-word
// result block. `new(StructLit)` is NOT counted here (its block is the heap, not
// the frame). print builtins take no aggregate by-value args we copy. The same
// per-call worst case is reserved by lowering, so the frame never overruns.
fn cg_scan_call(cg: *Cg, sc: *ScanCtx, c: Call) void {
    // callee name
    let fname: []u8 = "";
    switch (c.callee.*) {
        .id => |x| { fname = x.name; }
        else => { }
    }
    // @-builtins reserve no aggregate scratch (no by-value agg args/returns here).
    if (fname.len > 0) {
        if (fname[0] == '@') { return; }
    }
    // Native-runtime externs (_zag_*) take slice args by their EXISTING block
    // pointer (no caller copy) and return a pointer in rax (no frame result
    // block), so they reserve no aggregate scratch here. The mem/heap trio
    // (_zag_malloc/_zag_realloc/_zag_free) likewise takes/returns scalars.
    if (cg_is_native_rt(fname) == 1) { return; }
    if (@strEq(fname, "_zag_malloc")) { return; }
    if (@strEq(fname, "_zag_realloc")) { return; }
    if (@strEq(fname, "_zag_free")) { return; }
    // generic call foo[T](..) → its mangled instance name for ret lookup below.
    if (len[[]u8](c.targs) > 0) { fname = cg_mangle_generic(fname, c.targs); }
    // `new(...)` allocates the STRUCT on the heap, but its lowering
    // (cg_lower_new) still consumes ONE frame word: the `pslot` scratch that
    // stashes the returned pointer across the per-field stores so the field
    // value-expressions can't clobber it. That word MUST be reserved here or the
    // frame overruns (two `new`s in one fn overran the aligned frame and
    // corrupted the saved rbp/return address → segfault). We also walk the
    // struct-literal's field VALUE expressions so any scratch THEY need (e.g. a
    // nested call) is reserved; cg_scan_expr's generic walk does not descend into
    // a `.slit_` node, so we descend explicitly here.
    if (@strEq(fname, "new")) {
        sc.*.words.* = sc.*.words.* + 1;   // pslot for the returned heap pointer
        if (len[*Node](c.args) == 1) {
            let narg: *Node = get[*Node](c.args, 0);
            switch (narg.*) {
                .slit_ => |s| {
                    let fi: i32 = 0;
                    while (fi < len[FieldInit](s.fields)) {
                        cg_scan_expr(cg, sc, get[FieldInit](s.fields, fi).val);
                        fi = fi + 1;
                    }
                }
                else => { }
            }
        }
        return;
    }
    // by-value aggregate arguments → one caller copy each. A string-LITERAL arg
    // is NOT counted here: its 2-word {ptr,len} block is materialized fresh per
    // use (counted by cg_scan_expr's `.slit` case) and passed directly, so no
    // separate copy block is allocated for it.
    let ai: i32 = 0;
    while (ai < len[*Node](c.args)) {
        let arg: *Node = get[*Node](c.args, ai);
        let is_slit: i32 = 0;
        switch (arg.*) { .slit => |_s| { is_slit = 1; } else => { } }
        if (is_slit == 0) {
            let at: []u8 = cg_scan_typeof(sc, cg, arg);
            if (cg_type_is_agg(cg, at) == 1) {
                sc.*.words.* = sc.*.words.* + cg_agg_words(cg, at);
            }
        }
        ai = ai + 1;
    }
    // ARGUMENT SPILL SLOTS: each call spills every arg's 8-byte payload into a
    // dedicated frame word first (so it can then be placed in a reg or pushed as
    // a stack arg for the System V >6-arg path). Reserve one word per arg.
    sc.*.words.* = sc.*.words.* + len[*Node](c.args);
    // aggregate-by-value return → one result block (sret).
    let rt: []u8 = "";
    let i: i32 = 0;
    while (i < len[[]u8](sc.*.fnames)) {
        if (@strEq(get[[]u8](sc.*.fnames, i), fname)) { rt = get[[]u8](sc.*.frets, i); }
        i = i + 1;
    }
    if (cg_type_is_agg(cg, rt) == 1) {
        sc.*.words.* = sc.*.words.* + cg_agg_words(cg, rt);
    }
}

// Word count to reserve for a switch SUBJECT scratch block (mirrors
// cg_switch_subject_words at lowering time). A union subject occupies its FULL
// size (tag + inline payload); we find the union via the first arm's first tag
// exactly like cg_switch_kind. Enum/scalar/value switches use 1 word; we return
// at least 2 (matching the old reservation) for safety.
fn cg_scan_switch_subject_words(cg: *Cg, sw: Switch) i32 {
    if (len[SwitchArm](sw.arms) == 0) { return 2; }
    let a0: SwitchArm = get[SwitchArm](sw.arms, 0);
    if (len[[]u8](a0.tags) == 0) { return 2; }
    let tag0: []u8 = get[[]u8](a0.tags, 0);
    let un: []u8 = cg_union_name_for_tag(cg, tag0);
    if (un.len > 0) {
        let w: i32 = cg_agg_words(cg, un);
        if (w < 2) { return 2; }
        return w;
    }
    return 2;
}

// Walk an expression, reserving call scratch for every nested call.
fn cg_scan_expr(cg: *Cg, sc: *ScanCtx, n: *Node) void {
    switch (n.*) {
        .call => |c| {
            cg_scan_call(cg, sc, c);
            let i: i32 = 0;
            while (i < len[*Node](c.args)) { cg_scan_expr(cg, sc, get[*Node](c.args, i)); i = i + 1; }
        }
        .slit => |_s| {
            // A bare string-literal VALUE materializes a fresh 2-word {ptr,len}
            // block in the frame (see the `.slit` case of cg_lower_expr). Reserve
            // those 2 words here so the frame never overruns. (A `.slit` consumed
            // by print_str(...) or a []u8 `let` initializer is handled WITHOUT a
            // scratch and is not walked here, so no over-reservation occurs.)
            sc.*.words.* = sc.*.words.* + 2;
        }
        .slit_ => |s| {
            // A struct/union literal used as a VALUE (call arg, nested value, …)
            // materializes a fresh block + a pslot in the frame (cg_lower_struct_lit).
            // Reserve block words + 1 pslot, then recurse into field VALUES (a
            // nested literal field is materialized inline, but reserving its own
            // block here is a safe OVER-reservation). The frame need only be big
            // enough, never exact, so over-reservation is always sound.
            let lty: []u8 = cg_norm_type(cg_slit_sname(s));
            let w: i32 = 1;
            if (cg_type_is_agg(cg, lty) == 1) { w = cg_agg_words(cg, lty); }
            sc.*.words.* = sc.*.words.* + w + 1;
            let fi: i32 = 0;
            while (fi < len[FieldInit](s.fields)) {
                cg_scan_expr(cg, sc, get[FieldInit](s.fields, fi).val);
                fi = fi + 1;
            }
        }
        .bin  => |b| {
            // `orelse` materializes the optional into a scratch block + pslot.
            if (@strEq(b.op, "orelse")) { sc.*.words.* = sc.*.words.* + 4; }
            cg_scan_expr(cg, sc, b.l); cg_scan_expr(cg, sc, b.r);
        }
        .un   => |u| { cg_scan_expr(cg, sc, u.e); }
        .fld  => |f| { cg_scan_expr(cg, sc, f.base); }
        .idx  => |x| { cg_scan_expr(cg, sc, x.base); cg_scan_expr(cg, sc, x.idx); }
        .cast_=> |c2| { cg_scan_expr(cg, sc, c2.expr); }
        .slice_ => |s2| {
            // base[lo..hi] materializes: src{ptr,len}=2 + lo=1 + hi=1 + res{ptr,len}=2.
            sc.*.words.* = sc.*.words.* + 6;
            cg_scan_expr(cg, sc, s2.base);
            cg_scan_expr(cg, sc, s2.lo);
            if (s2.has_hi == 1) { cg_scan_expr(cg, sc, s2.hi); }
        }
        .switch_ => |sw| {
            // expression switch: subject scratch (full union size) + 1-word result
            // slot + one capture word per capturing arm. Record union-arm capture
            // types so aggregate-of-capture args are sized correctly (see the
            // statement-switch scan for the rationale).
            let sw_uname2: []u8 = "";
            let sw_kind2: i32 = cg_switch_kind(cg, sw, &sw_uname2);
            sc.*.words.* = sc.*.words.* + cg_scan_switch_subject_words(cg, sw) + 1;
            cg_scan_expr(cg, sc, sw.subject);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) {
                let arm: SwitchArm = get[SwitchArm](sw.arms, ai);
                if (arm.has_cap == 1) {
                    sc.*.words.* = sc.*.words.* + 1;
                    if (sw_kind2 == 2 && len[[]u8](arm.tags) > 0) {
                        let payty2: []u8 = cg_union_payload_type(cg, sw_uname2, get[[]u8](arm.tags, 0));
                        cg_scan_rectype(sc, arm.cap, _zag_str_concat("*", cg_norm_type(payty2)));
                    }
                }
                cg_scan_body(cg, sc, arm.body);
                ai = ai + 1;
            }
            if (sw.has_els == 1) { cg_scan_body(cg, sc, sw.els_body); }
        }
        else => { }
    }
}

fn cg_scan_body(cg: *Cg, sc: *ScanCtx, body: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        let s: *Node = get[*Node](body, i);
        switch (s.*) {
            .let_   => |l| {
                // record the local's static type for later arg/return sizing.
                let lty: []u8 = "";
                if (l.has_dty == 1) { lty = cg_norm_type(l.dty); }
                else { lty = cg_scan_typeof(sc, cg, l.expr); }
                cg_scan_rectype(sc, l.name, lty);
                if (cg_scan_seen(sc.*.seen, l.name) == 0) {
                    sc.*.words.* = sc.*.words.* + cg_type_words(cg, lty);
                }
                // an aggregate/optional let materializes via a pslot (1 word).
                if (cg_type_is_agg(cg, lty) == 1) { sc.*.words.* = sc.*.words.* + 1; }
                cg_scan_expr(cg, sc, l.expr);
            }
            .assign => |a| {
                switch (a.target.*) {
                    .id => |x| {
                        if (cg_scan_seen(sc.*.seen, x.name) == 0) { sc.*.words.* = sc.*.words.* + 1; }
                    }
                    else => { }
                }
                cg_scan_expr(cg, sc, a.target);
                cg_scan_expr(cg, sc, a.expr);
            }
            .ret    => |r| { if (r.has_expr == 1) { cg_scan_expr(cg, sc, r.expr); } }
            .estmt  => |e| { cg_scan_expr(cg, sc, e.expr); }
            .if_    => |iff| {
                cg_scan_expr(cg, sc, iff.cond);
                cg_scan_body(cg, sc, iff.then_body);
                if (iff.has_els == 1) { cg_scan_body(cg, sc, iff.els_body); }
            }
            .while_ => |w2| {
                cg_scan_expr(cg, sc, w2.cond);
                cg_scan_body(cg, sc, w2.body);
            }
            .switch_ => |sw| {
                // A switch lowers the subject to a scratch block sized to the
                // subject (a UNION subject is its FULL {tag, inline payload} block;
                // a scalar/enum fits one word), plus ONE capture-pointer word per
                // capturing arm. Reserve those, then walk subject + arm bodies. For
                // a UNION arm with a `|cap|` capture we RECORD the capture's type
                // (`*<payload-type>`) in the scan's name map — exactly as
                // cg_bind_capture types it at lowering — so an aggregate field of
                // the capture (e.g. `len(f.*.params)` where params is an ArrayList)
                // is correctly sized as an aggregate arg. Without this the scan
                // under-reserves the arg-copy and the frame overruns.
                let sw_uname: []u8 = "";
                let sw_kind: i32 = cg_switch_kind(cg, sw, &sw_uname);
                sc.*.words.* = sc.*.words.* + cg_scan_switch_subject_words(cg, sw);
                cg_scan_expr(cg, sc, sw.subject);
                let ai: i32 = 0;
                while (ai < len[SwitchArm](sw.arms)) {
                    let arm: SwitchArm = get[SwitchArm](sw.arms, ai);
                    if (arm.has_cap == 1) {
                        sc.*.words.* = sc.*.words.* + 1;
                        if (sw_kind == 2 && len[[]u8](arm.tags) > 0) {
                            let payty: []u8 = cg_union_payload_type(cg, sw_uname, get[[]u8](arm.tags, 0));
                            cg_scan_rectype(sc, arm.cap, _zag_str_concat("*", cg_norm_type(payty)));
                        }
                    }
                    cg_scan_body(cg, sc, arm.body);
                    ai = ai + 1;
                }
                if (sw.has_els == 1) { cg_scan_body(cg, sc, sw.els_body); }
            }
            else => { }
        }
        i = i + 1;
    }
}

// round n up to a multiple of 16
fn cg_align16(n: i32) i32 {
    let r: i32 = n % 16;
    if (r == 0) { return n; }
    return n + (16 - r);
}

// ── operator dispatch helpers ────────────────────────────────────────────────
fn cg_is_cmp_op(op: []u8) i32 {
    if (@strEq(op, "<"))  { return 1; }
    if (@strEq(op, "<=")) { return 1; }
    if (@strEq(op, ">"))  { return 1; }
    if (@strEq(op, ">=")) { return 1; }
    if (@strEq(op, "==")) { return 1; }
    if (@strEq(op, "!=")) { return 1; }
    return 0;
}

fn cg_cmp_cc(op: []u8) i32 {
    if (@strEq(op, "<"))  { return CC_L(); }
    if (@strEq(op, "<=")) { return CC_LE(); }
    if (@strEq(op, ">"))  { return CC_G(); }
    if (@strEq(op, ">=")) { return CC_GE(); }
    if (@strEq(op, "==")) { return CC_E(); }
    return CC_NE();   // "!="
}

// ── native-runtime extern recognition ────────────────────────────────────────
// The `_zag_*` externs are implemented as native syscall support routines (see
// the RT_* section). For type-inference (let/arg/return aggregate handling), we
// need their RETURN type. Returns the type string for a recognized runtime
// extern, or "" if `name` is not one. A `[]u8`-returning runtime fn is an
// AGGREGATE — its result is a pointer to a fresh {ptr,len} block, treated exactly
// like any aggregate value downstream (so `let s: []u8 = _zag_str_concat(..)`
// binds that pointer). The mem/heap helpers (_zag_malloc/_zag_realloc/_zag_free)
// are intercepted by cg_lower_runtime and return scalars (*i8 ≈ "").
fn cg_native_rt_ret(name: []u8) []u8 {
    // []u8-returning (aggregate result = &{ptr,len}).
    if (@strEq(name, "_zag_str_concat"))      { return "[]u8"; }
    if (@strEq(name, "_zag_strdup"))          { return "[]u8"; }
    if (@strEq(name, "_zag_i64_to_str"))      { return "[]u8"; }
    if (@strEq(name, "_zag_u64_to_str"))      { return "[]u8"; }
    if (@strEq(name, "_zag_read_file"))       { return "[]u8"; }
    if (@strEq(name, "_zag_arg"))             { return "[]u8"; }
    // scalar-returning (i32/i64 in rax).
    if (@strEq(name, "_zag_strlen"))          { return "i32"; }
    if (@strEq(name, "_zag_str_len"))         { return "i32"; }
    if (@strEq(name, "_zag_strcmp"))          { return "i32"; }
    if (@strEq(name, "_zag_str_eq"))          { return "i32"; }
    if (@strEq(name, "_zag_strcmp_ord"))      { return "i32"; }
    if (@strEq(name, "_zag_str_index_of_byte")) { return "i32"; }
    if (@strEq(name, "_zag_str_to_i64"))      { return "i64"; }
    if (@strEq(name, "_zag_write_file"))      { return "i32"; }
    if (@strEq(name, "_zag_write_exec"))      { return "i32"; }
    if (@strEq(name, "_zag_file_exists"))     { return "i32"; }
    if (@strEq(name, "_zag_argc"))            { return "i32"; }
    if (@strEq(name, "_zag_exec_cmd"))        { return "i32"; }
    if (@strEq(name, "_zag_memcmp"))          { return "i32"; }
    if (@strEq(name, "_zag_print"))           { return ""; }
    if (@strEq(name, "_zag_println"))         { return ""; }
    if (@strEq(name, "_zag_eprintln"))        { return ""; }
    if (@strEq(name, "_zag_flush"))           { return ""; }
    if (@strEq(name, "_zag_exit"))            { return ""; }
    if (@strEq(name, "_zag_memcpy"))          { return ""; }
    return "";
}

// True if `name` is a native-runtime extern WE lower at the call site (so it is
// NOT looked up in the user-fn symbol table). Covers the syscall routines plus
// the void ones; the mem/heap trio is handled separately by cg_lower_runtime.
fn cg_is_native_rt(name: []u8) i32 {
    if (@strEq(name, "_zag_str_concat"))      { return 1; }
    if (@strEq(name, "_zag_strdup"))          { return 1; }
    if (@strEq(name, "_zag_i64_to_str"))      { return 1; }
    if (@strEq(name, "_zag_u64_to_str"))      { return 1; }
    if (@strEq(name, "_zag_read_file"))       { return 1; }
    if (@strEq(name, "_zag_arg"))             { return 1; }
    if (@strEq(name, "_zag_strlen"))          { return 1; }
    if (@strEq(name, "_zag_str_len"))         { return 1; }
    if (@strEq(name, "_zag_strcmp"))          { return 1; }
    if (@strEq(name, "_zag_str_eq"))          { return 1; }
    if (@strEq(name, "_zag_strcmp_ord"))      { return 1; }
    if (@strEq(name, "_zag_str_index_of_byte")) { return 1; }
    if (@strEq(name, "_zag_str_to_i64"))      { return 1; }
    if (@strEq(name, "_zag_write_file"))      { return 1; }
    if (@strEq(name, "_zag_write_exec"))      { return 1; }
    if (@strEq(name, "_zag_file_exists"))     { return 1; }
    if (@strEq(name, "_zag_argc"))            { return 1; }
    if (@strEq(name, "_zag_exec_cmd"))        { return 1; }
    if (@strEq(name, "_zag_memcmp"))          { return 1; }
    if (@strEq(name, "_zag_print"))           { return 1; }
    if (@strEq(name, "_zag_println"))         { return 1; }
    if (@strEq(name, "_zag_eprintln"))        { return 1; }
    if (@strEq(name, "_zag_flush"))           { return 1; }
    if (@strEq(name, "_zag_exit"))            { return 1; }
    if (@strEq(name, "_zag_memcpy"))          { return 1; }
    return 0;
}

// Return type string of a known function, or "" if not found.
fn cg_fn_ret(syms: ArrayList[FnSym], name: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[FnSym](syms)) {
        if (@strEq(get[FnSym](syms, i).name, name)) { return get[FnSym](syms, i).ret; }
        i = i + 1;
    }
    return "";
}

// ── coarse static type of an expression ──────────────────────────────────────
// Returns a type STRING: "" for an unknown/plain scalar, a struct name ("P")
// for a struct-by-value (an aggregate held by-pointer), "*T" for a pointer.
// Used to decide whether a `.field` access targets a struct base, and to size a
// struct-typed `let`'s slot. Conservative: anything not clearly aggregate is a
// scalar — and the lowering paths that genuinely need a struct re-derive its
// concrete name here, rejecting loudly when it cannot be determined.
fn cg_expr_type(n: *Node, env: *Env, syms: ArrayList[FnSym], cg: *Cg) []u8 {
    switch (n.*) {
        .id => |x| {
            return cg_slot_type(env.*, x.name);
        }
        .slit_ => |s| {
            // struct/union literal: its type is the (possibly mangled) name.
            return cg_norm_type(cg_slit_sname(s));
        }
        .call => |c| {
            switch (c.callee.*) {
                .id => |cid| {
                    // @-builtins: most yield a plain scalar (""). The float
                    // conversion builtins carry a float/int result type so the
                    // let/print/bin paths don't re-convert an already-converted
                    // value (and @floatCast preserves its float operand's type).
                    if (cid.name.len > 0) { if (cid.name[0] == '@') {
                        if (@strEq(cid.name, "@intToFloat")) { return "f64"; }
                        if (@strEq(cid.name, "@floatToInt")) { return "i32"; }
                        if (@strEq(cid.name, "@floatCast")) {
                            if (len[*Node](c.args) == 1) { return cg_expr_type(get[*Node](c.args, 0), env, syms, cg); }
                            return "f64";
                        }
                        return "";
                    } }
                    // native-runtime externs (_zag_*) → their syscall return type.
                    if (cg_is_native_rt(cid.name) == 1) { return cg_native_rt_ret(cid.name); }
                    // generic call foo[T](..) → mangled instance's return type.
                    let fn2: []u8 = cid.name;
                    if (len[[]u8](c.targs) > 0) { fn2 = cg_mangle_generic(cid.name, c.targs); }
                    return cg_fn_ret(syms, fn2);
                }
                else => { return ""; }
            }
        }
        .fld => |f| {
            // s.field — if `field` is a struct-typed member, its type is that
            // member's declared type. We need the base's struct name first.
            if (@strEq(f.fname, "*")) {
                // p.* — dereference of a pointer-to-T: the type is the pointee
                // (strip the leading '*').
                let bt: []u8 = cg_expr_type(f.base, env, syms, cg);
                if (bt.len > 1) {
                    if (bt[0] == '*') { return bt[1..]; }
                }
                return "";
            }
            // OPTIONAL field access: o.has → scalar (i32); o.val → T.
            let obt0: []u8 = cg_expr_type(f.base, env, syms, cg);
            let obt1: []u8 = obt0;
            if (obt1.len > 1 && obt1[0] == '*') { obt1 = obt1[1..]; }
            if (cg_type_is_opt(cg, obt1) == 1) {
                if (@strEq(f.fname, "has")) { return "i32"; }
                if (@strEq(f.fname, "val")) { return cg_norm_type(obt1[1..]); }
                return "";
            }
            // enum member access `Color.Green` → the value's type is the enum
            // (an int). Only when the base ident is NOT a local (a local `x.field`
            // is a struct-field access, handled below).
            switch (f.base.*) {
                .id => |bid| {
                    if (cg_slot_find(env.*, bid.name) == cg_not_found()) {
                        let em: i32 = cg_enum_member_index(cg, bid.name, f.fname);
                        if (em >= 0) { return bid.name; }
                    }
                }
                else => { }
            }
            let bt2: []u8 = cg_expr_type(f.base, env, syms, cg);
            // peel a single leading '*' (p.*.field collapses base type *P → P)
            let sname: []u8 = bt2;
            if (sname.len > 1) {
                if (sname[0] == '*') { sname = sname[1..]; }
            }
            let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
            if (cg_find_struct(cg, sname, &sd) == 1) {
                let i: i32 = 0;
                while (i < len[Param](sd.fields)) {
                    if (@strEq(get[Param](sd.fields, i).name, f.fname)) {
                        return cg_norm_type(get[Param](sd.fields, i).pty);
                    }
                    i = i + 1;
                }
            }
            return "";
        }
        .idx => |ix| {
            // x[i] element type: a *T pointer base → T; a []u8 slice → u8.
            let bt3: []u8 = cg_expr_type(ix.base, env, syms, cg);
            if (cg_type_is_slice(cg, bt3) == 1) { return "u8"; }
            if (bt3.len > 1) { if (bt3[0] == '*') { return bt3[1..]; } }
            return "";
        }
        .cast_ => |cst| { return cg_norm_type(cst.target); }
        .slit  => |_s| { return "[]u8"; }   // a string literal is a []u8 slice value
        .slice_ => |sl| {
            // base[lo..hi] : a sub-slice. A []u8 base (or a string literal, which
            // is a []u8 value) yields a []u8. A *u8 pointer base (e.g. an
            // ArrayList[u8]'s `.data` field) yields []u8 = {data+lo, hi-lo}. We
            // only model []u8; other element widths report "" (rejected at lowering).
            let bt: []u8 = cg_expr_type(sl.base, env, syms, cg);
            if (cg_type_is_slice(cg, bt) == 1) { return "[]u8"; }
            switch (sl.base.*) { .slit => |_s| { return "[]u8"; } else => { } }
            if (@strEq(bt, "*u8") || @strEq(bt, "*i8")) { return "[]u8"; }
            return "";
        }
        .ilit => |x| {
            // a float literal ("1.5") is f64; an int literal is an untyped scalar.
            if (cg_is_float_text(x.text) == 1) { return "f64"; }
            return "";
        }
        .un => |u| {
            // unary minus preserves the operand type (float stays float); '!' is
            // a bool (i32). '&' yields a pointer but is rarely type-queried here.
            if (@strEq(u.op, "-")) { return cg_expr_type(u.e, env, syms, cg); }
            return "";
        }
        .bin => |b| {
            // comparisons / logicals → bool (i32). Arithmetic inherits the float
            // type of whichever operand is float (so nested float math propagates).
            if (cg_is_cmp_op(b.op) == 1) { return "i32"; }
            if (@strEq(b.op, "&&") || @strEq(b.op, "||")) { return "i32"; }
            let lt: []u8 = cg_expr_type(b.l, env, syms, cg);
            if (cg_is_float_ty(lt) == 1) { return lt; }
            let rt: []u8 = cg_expr_type(b.r, env, syms, cg);
            if (cg_is_float_ty(rt) == 1) { return rt; }
            return lt;
        }
        else => { return ""; }
    }
}

// ── lvalue ADDRESS lowering (struct-aware, complex lvalues) ──────────────────
// Push the ADDRESS of an lvalue on the CPU stack. Used for struct field
// read/write AND `&expr`. Handles exactly the cases we can do correctly:
//   • an aggregate local         → its block base (inline lea, byref load)
//   • a pointer-typed local      → the pointer VALUE (already an address)
//   • a SCALAR local             → lea rbp+disp (address of its slot — `&local`)
//   • s.field / p.*.field        → base address + cumulative field byte offset
//   • p.*                        → the pointer VALUE
//   • p[i] (base *T)             → ptr + sizeof(T)*i
//   • s[i] / xs.data[i] ([]u8)   → load([base+0]) + i   (byte element)
// Anything else is rejected loudly (cg_err) — never silently mis-addressed.
//
// Push the BASE ADDRESS of an aggregate (struct / slice / union / ?T) local named
// `name`. INLINE locals own their block → lea(rbp+disp). BY-REF locals (by-value
// aggregate params) hold a POINTER to the block → load(rbp+disp). This single
// helper makes by-value params, slice values, and sret all addressable uniformly.
fn cg_push_agg_base(out: *ArrayList[Instr], env: *Env, name: []u8, disp: i32) void {
    if (cg_slot_byref(env.*, name) == 1) {
        push[Instr](out, i_load(R_RAX(), R_RBP(), disp));   // slot holds the pointer
    } else {
        push[Instr](out, i_lea(R_RAX(), R_RBP(), disp));    // slot IS the block
    }
    push[Instr](out, i_push(R_RAX()));
}

// True if `n` is an addressable LVALUE (has a stable storage location whose
// address we can take with cg_lower_addr). Locals, field/index/deref chains are
// lvalues. A CALL result, a slice/struct/string LITERAL, an arithmetic value,
// etc. are NOT lvalues — they are aggregate VALUES whose block address is what
// cg_lower_expr already leaves on the stack.
fn cg_is_lvalue(n: *Node) i32 {
    return switch (n.*) {
        .id  => |_x| 1,
        .fld => |_f| 1,
        .idx => |_x| 1,
        else => 0,
    };
}

// Push the BASE ADDRESS of `n` for a field/optional access: if `n` is an
// addressable lvalue, take its address (cg_lower_addr). Otherwise it must be an
// AGGREGATE VALUE (e.g. a call returning a struct/slice, a slice/struct literal),
// whose block address is precisely what cg_lower_expr pushes — so we lower it as
// an expression. This makes `someCall().field`, `Lit{..}.field`, and
// `sliceExpr.len` addressable uniformly. A non-aggregate non-lvalue base is a
// type error caught by the caller's struct/slice check.
fn cg_push_base_addr(out: *ArrayList[Instr], n: *Node, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    if (cg_is_lvalue(n) == 1) {
        cg_lower_addr(out, n, env, syms, cg);
    } else {
        cg_lower_expr(out, n, env, syms, cg);   // aggregate value → block address
    }
}

fn cg_lower_addr(out: *ArrayList[Instr], n: *Node, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    switch (n.*) {
        .id => |x| {
            let disp: i32 = cg_slot_find(env.*, x.name);
            if (disp == cg_not_found()) {
                cg_err(cg, "native: unknown identifier (address-of)");
                push[Instr](out, i_mov_imm(R_RAX(), 0));
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            let ty: []u8 = cg_slot_type(env.*, x.name);
            if (cg_type_is_agg(cg, ty) == 1) {
                // struct/slice/union/?T local: push its block base (lea/load).
                cg_push_agg_base(out, env, x.name, disp);
            } else if (ty.len > 0 && ty[0] == '*') {
                // pointer local: the address it denotes is its stored value.
                push[Instr](out, i_load(R_RAX(), R_RBP(), disp));
                push[Instr](out, i_push(R_RAX()));
            } else {
                // SCALAR local (or unknown-typed): &local is the slot's frame
                // address. A scalar local owns exactly one word at rbp+disp, so
                // its address is well-defined and writes through it persist.
                push[Instr](out, i_lea(R_RAX(), R_RBP(), disp));
                push[Instr](out, i_push(R_RAX()));
            }
        }
        .fld => |f| {
            if (@strEq(f.fname, "*")) {
                // p.* — the address is the pointer value itself.
                cg_lower_expr(out, f.base, env, syms, cg);   // pushes pointer value
                return;
            }
            // s.field / p.*.field : compute base address, add field byte offset.
            let bt: []u8 = cg_expr_type(f.base, env, syms, cg);
            // OPTIONAL field access: o.has → [block+0], o.val → [block+8]. A
            // pointer-to-optional base (*?T) is peeled to ?T first.
            let obt: []u8 = bt;
            if (obt.len > 1 && obt[0] == '*') { obt = obt[1..]; }
            if (cg_type_is_opt(cg, obt) == 1) {
                let ooff: i32 = 0 - 1;
                if (@strEq(f.fname, "has")) { ooff = 0; }
                else if (@strEq(f.fname, "val")) { ooff = 8; }
                if (ooff < 0) {
                    cg_err(cg, "native: optional has only .has / .val fields");
                    push[Instr](out, i_mov_imm(R_RAX(), 0));
                    push[Instr](out, i_push(R_RAX()));
                    return;
                }
                cg_push_base_addr(out, f.base, env, syms, cg);   // pushes block base
                push[Instr](out, i_pop(R_RAX()));
                if (ooff > 0) { push[Instr](out, i_add_imm(R_RAX(), ooff as i64)); }
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            let sname: []u8 = bt;
            if (sname.len > 1) {
                if (sname[0] == '*') { sname = sname[1..]; }
            }
            if (cg_type_is_struct(cg, sname) == 0) {
                cg_err(cg, "native: field access on non-struct value");
                push[Instr](out, i_mov_imm(R_RAX(), 0));
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            let foff: i32 = cg_field_offset(cg, sname, f.fname);
            if (foff < 0) {
                cg_err(cg, "native: unknown struct field");
                push[Instr](out, i_mov_imm(R_RAX(), 0));
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            cg_push_base_addr(out, f.base, env, syms, cg);   // pushes base address
            push[Instr](out, i_pop(R_RAX()));
            if (foff > 0) { push[Instr](out, i_add_imm(R_RAX(), foff as i64)); }
            push[Instr](out, i_push(R_RAX()));
        }
        .idx => |ix| {
            let ixt: []u8 = cg_expr_type(ix.base, env, syms, cg);
            // p[i] lvalue (base type *T): address = ptr + stride*i (stride = 1 for
            // a byte element, the type size otherwise). The pointer VALUE comes
            // from lowering the base expression.
            if (ixt.len > 1 && ixt[0] == '*') {
                let stride: i32 = cg_elem_stride(cg, cg_norm_type(ixt[1..]));
                cg_lower_expr(out, ix.base, env, syms, cg);   // pushes ptr value
                cg_lower_expr(out, ix.idx, env, syms, cg);    // pushes i
                push[Instr](out, i_pop(R_RCX()));             // rcx = i
                push[Instr](out, i_pop(R_RAX()));             // rax = ptr
                if (stride != 1) {
                    push[Instr](out, i_mov_imm(R_RDX(), stride as i64));
                    push[Instr](out, i_imul(R_RCX(), R_RDX()));
                }
                push[Instr](out, i_add(R_RAX(), R_RCX()));    // rax = ptr + stride*i
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            // s[i] / xs.data[i] lvalue (base []u8): address = load([base+0]) + i
            // (byte element). The base aggregate's data pointer lives at word 0.
            if (cg_type_is_slice(cg, ixt) == 1) {
                cg_push_base_addr(out, ix.base, env, syms, cg);   // pushes block base
                push[Instr](out, i_pop(R_RAX()));
                push[Instr](out, i_load(R_RAX(), R_RAX(), 0)); // rax = data ptr
                push[Instr](out, i_push(R_RAX()));
                cg_lower_expr(out, ix.idx, env, syms, cg);     // pushes i
                push[Instr](out, i_pop(R_RCX()));              // rcx = i
                push[Instr](out, i_pop(R_RAX()));              // rax = data ptr
                push[Instr](out, i_add(R_RAX(), R_RCX()));     // rax = ptr + i
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            cg_err(cg, "native: index-assign requires a *T pointer or []u8 slice base");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
        }
        else => {
            cg_err(cg, "native: unsupported address-of target");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
        }
    }
}

// ── expression lowering: result left PUSHED on the CPU stack ─────────────────
fn cg_lower_expr(out: *ArrayList[Instr], n: *Node, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    switch (n.*) {
        .ilit => |x| {
            if (cg_is_int_text(x.text) == 1) {
                push[Instr](out, i_mov_imm(R_RAX(), cg_parse_i64(x.text)));
                push[Instr](out, i_push(R_RAX()));
            } else if (cg_is_float_text(x.text) == 1) {
                // float literal → its IEEE-754 double bit pattern (loaded into a
                // gpr; it only enters an xmm when an SSE op consumes it).
                push[Instr](out, i_mov_imm(R_RAX(), cg_f64_bits(x.text, cg)));
                push[Instr](out, i_push(R_RAX()));
            } else {
                cg_err(cg, "native: unsupported numeric literal (hex/binary/malformed)");
                push[Instr](out, i_mov_imm(R_RAX(), 0));
                push[Instr](out, i_push(R_RAX()));
            }
        }
        .id => |x| {
            let disp: i32 = cg_slot_find(env.*, x.name);
            if (disp == cg_not_found()) {
                // boolean literals (the parser lowers true/false to plain Idents
                // that are not locals): true → 1, false → 0.
                if (@strEq(x.name, "true")) {
                    push[Instr](out, i_mov_imm(R_RAX(), 1));
                    push[Instr](out, i_push(R_RAX()));
                    return;
                }
                if (@strEq(x.name, "false")) {
                    push[Instr](out, i_mov_imm(R_RAX(), 0));
                    push[Instr](out, i_push(R_RAX()));
                    return;
                }
                cg_err(cg, "native: unknown identifier in expression");
                // emit a recognizable 0 so the program still assembles loudly
                push[Instr](out, i_mov_imm(R_RAX(), 0));
                push[Instr](out, i_push(R_RAX()));
            } else {
                let ty: []u8 = cg_slot_type(env.*, x.name);
                if (cg_type_is_agg(cg, ty) == 1) {
                    // a struct/slice VALUE evaluates to the ADDRESS of its block
                    // (inline → lea, by-ref param → load the held pointer).
                    cg_push_agg_base(out, env, x.name, disp);
                } else {
                    push[Instr](out, i_load(R_RAX(), R_RBP(), disp));
                    push[Instr](out, i_push(R_RAX()));
                }
            }
        }
        .un => |u| {
            if (@strEq(u.op, "-")) {
                cg_lower_expr(out, u.e, env, syms, cg);
                push[Instr](out, i_pop(R_RAX()));
                if (cg_is_float_ty(cg_expr_type(u.e, env, syms, cg)) == 1) {
                    // IEEE float negation = flip the sign bit (correct for ±0 and
                    // NaN, unlike 0.0-x which would turn -0.0 into +0.0).
                    push[Instr](out, i_mov_imm(R_RCX(), cg_sign_bit()));
                    push[Instr](out, i_xor(R_RAX(), R_RCX()));
                } else {
                    push[Instr](out, i_neg(R_RAX()));
                }
                push[Instr](out, i_push(R_RAX()));
            } else if (@strEq(u.op, "!")) {
                // logical not: (e == 0) ? 1 : 0
                cg_lower_expr(out, u.e, env, syms, cg);
                push[Instr](out, i_pop(R_RAX()));
                push[Instr](out, i_cmp_imm(R_RAX(), 0));
                push[Instr](out, i_setcc(R_RAX(), CC_E()));
                push[Instr](out, i_push(R_RAX()));
            } else if (@strEq(u.op, "&")) {
                // address-of: &s for a struct var is its slot address (already
                // what a struct var evaluates to); generally we lower the
                // lvalue's ADDRESS. Taking the address of a non-addressable
                // value is rejected loudly inside cg_lower_addr.
                cg_lower_addr(out, u.e, env, syms, cg);
            } else {
                cg_err(cg, "native: unsupported unary operator");
                cg_lower_expr(out, u.e, env, syms, cg);
            }
        }
        .bin => |bb| {
            cg_lower_bin(out, bb, env, syms, cg);
        }
        .call => |c| {
            cg_lower_call(out, c, env, syms, cg);
        }
        .cast_ => |cst| {
            // `expr as T`. Integer↔integer casts are no-ops at our 64-bit width.
            // int↔float casts use SSE: cvtsi2sd (i64→f64) / cvttsd2si (f64→i64,
            // truncating toward zero). f32↔f64 is a no-op internally (both held
            // as a double bit pattern).
            let stp: []u8 = cg_expr_type(cst.expr, env, syms, cg);
            let ttp: []u8 = cg_norm_type(cst.target);
            let sf: i32 = cg_is_float_ty(stp);
            let tf: i32 = cg_is_float_ty(ttp);
            cg_lower_expr(out, cst.expr, env, syms, cg);   // pushes source value
            if (tf == 1 && sf == 0) {
                // int → double
                push[Instr](out, i_pop(R_RAX()));
                push[Instr](out, i_fsi2sd(R_XMM0(), R_RAX()));
                push[Instr](out, i_fmovq_xg(R_RAX(), R_XMM0()));
                push[Instr](out, i_push(R_RAX()));
            } else if (tf == 0 && sf == 1) {
                // double → int (truncate toward zero)
                push[Instr](out, i_pop(R_RAX()));
                push[Instr](out, i_fmovq_gx(R_XMM0(), R_RAX()));
                push[Instr](out, i_ftsd2si(R_RAX(), R_XMM0()));
                push[Instr](out, i_push(R_RAX()));
            }
            // else: int→int or float→float — value already on the stack as-is.
        }
        .slit => |sl| {
            // A bare string literal used as a VALUE is a []u8 slice {ptr,len}.
            // Materialize the 2-word aggregate into a fresh frame scratch block
            // (the pre-scan reserved 2 words for this []u8 value) and push the
            // block's ADDRESS — exactly how a slice local/param is represented.
            let off: i32 = cg_intern_str(cg, sl.text, 0);
            let dlen: i32 = cg_decoded_len(sl.text);
            let base: i32 = cg_slot_scratch_n(env, 2);
            push[Instr](out, i_mov_imm(R_RAX(), DATA_VBASE() + (off as i64)));
            push[Instr](out, i_store(R_RBP(), base + 0, R_RAX()));     // [base+0] = ptr
            push[Instr](out, i_mov_imm(R_RAX(), dlen as i64));
            push[Instr](out, i_store(R_RBP(), base + 8, R_RAX()));     // [base+8] = len
            push[Instr](out, i_lea(R_RAX(), R_RBP(), base));
            push[Instr](out, i_push(R_RAX()));
        }
        .slit_ => |s| {
            cg_lower_struct_lit(out, s, env, syms, cg);
        }
        .fld => |f| {
            // "literal".len → compile-time constant DECODED length.
            if (@strEq(f.fname, "len")) {
                switch (f.base.*) {
                    .slit => |sl2| {
                        push[Instr](out, i_mov_imm(R_RAX(), cg_decoded_len(sl2.text) as i64));
                        push[Instr](out, i_push(R_RAX()));
                        return;
                    }
                    else => { }
                }
                // slice-VALUE .len → load word 1 ({ptr@0, len@8}) of its block.
                // The base may be a variable OR a value (call result, slice expr).
                let blt: []u8 = cg_expr_type(f.base, env, syms, cg);
                if (cg_type_is_slice(cg, blt) == 1) {
                    cg_push_base_addr(out, f.base, env, syms, cg);   // pushes block base
                    push[Instr](out, i_pop(R_RAX()));
                    push[Instr](out, i_load(R_RAX(), R_RAX(), 8));   // [base+8] = len
                    push[Instr](out, i_push(R_RAX()));
                    return;
                }
            }
            // p.* as an rvalue. If the pointee is an AGGREGATE (struct/union/
            // slice/?T), the VALUE of `p.*` is the BLOCK ADDRESS = the pointer
            // itself (so switch/field-access/copy all work on it). Otherwise it
            // is a scalar: load the pointed-to 8-byte word.
            if (@strEq(f.fname, "*")) {
                let pt: []u8 = cg_expr_type(f.base, env, syms, cg);
                let pet: []u8 = "";
                if (pt.len > 1 && pt[0] == '*') { pet = pt[1..]; }
                if (pet.len > 0 && cg_type_is_agg(cg, pet) == 1) {
                    cg_lower_expr(out, f.base, env, syms, cg);   // pushes pointer = block addr
                    return;
                }
                cg_lower_expr(out, f.base, env, syms, cg);   // pushes pointer value
                push[Instr](out, i_pop(R_RAX()));
                push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            // enum member access `Color.Green` → the member's integer index. The
            // base must be a plain ident naming a declared enum that has the member.
            switch (f.base.*) {
                .id => |bid| {
                    // only treat as enum access if it is NOT a known local var
                    // (a local `x.field` is a struct field, handled below).
                    if (cg_slot_find(env.*, bid.name) == cg_not_found()) {
                        let em: i32 = cg_enum_member_index(cg, bid.name, f.fname);
                        if (em >= 0) {
                            push[Instr](out, i_mov_imm(R_RAX(), em as i64));
                            push[Instr](out, i_push(R_RAX()));
                            return;
                        }
                    }
                }
                else => { }
            }
            // struct field read. If the FIELD's type is an aggregate (nested
            // struct/union/slice/?T), its VALUE is the field block's ADDRESS
            // (downstream copies/accesses it). Otherwise load the 8-byte scalar.
            let frt: []u8 = cg_expr_type(n, env, syms, cg);
            if (cg_type_is_agg(cg, frt) == 1) {
                cg_lower_addr(out, n, env, syms, cg);   // pushes &field = block base
                return;
            }
            cg_lower_addr(out, n, env, syms, cg);   // pushes &field
            push[Instr](out, i_pop(R_RAX()));
            push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
        }
        .idx => |ix| {
            // "literal"[i] → byte load from DATA_VBASE()+off+i (zero-extended).
            switch (ix.base.*) {
                .slit => |sl3| {
                    let off: i32 = cg_intern_str(cg, sl3.text, 0);
                    // rax = DATA_VBASE()+off ; rcx = i ; rax += rcx ; load byte.
                    push[Instr](out, i_mov_imm(R_RAX(), DATA_VBASE() + (off as i64)));
                    push[Instr](out, i_push(R_RAX()));
                    cg_lower_expr(out, ix.idx, env, syms, cg);   // pushes i
                    push[Instr](out, i_pop(R_RCX()));            // rcx = i
                    push[Instr](out, i_pop(R_RAX()));            // rax = base addr
                    push[Instr](out, i_add(R_RAX(), R_RCX()));   // rax = base+i
                    // 8-byte load then mask to one byte (data blob has >=7 slack
                    // because the whole read-only segment is page-padded, and we
                    // never index past the literal's length in valid programs).
                    push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
                    push[Instr](out, i_mov_imm(R_RCX(), 255));
                    push[Instr](out, i_and(R_RAX(), R_RCX()));
                    push[Instr](out, i_push(R_RAX()));
                    return;
                }
                else => { }
            }
            // slice-VALUE indexing s[i] → byte at [ load([base+0]) + i ]. The base
            // may be a variable OR a value (call result, slice expr).
            let ixt: []u8 = cg_expr_type(ix.base, env, syms, cg);
            if (cg_type_is_slice(cg, ixt) == 1) {
                cg_push_base_addr(out, ix.base, env, syms, cg);     // pushes block base
                push[Instr](out, i_pop(R_RAX()));
                push[Instr](out, i_load(R_RAX(), R_RAX(), 0));  // rax = data ptr
                push[Instr](out, i_push(R_RAX()));
                cg_lower_expr(out, ix.idx, env, syms, cg);      // pushes i
                push[Instr](out, i_pop(R_RCX()));               // rcx = i
                push[Instr](out, i_pop(R_RAX()));               // rax = data ptr
                push[Instr](out, i_add(R_RAX(), R_RCX()));      // rax = ptr + i
                push[Instr](out, i_load(R_RAX(), R_RAX(), 0));  // 8-byte load
                push[Instr](out, i_mov_imm(R_RCX(), 255));
                push[Instr](out, i_and(R_RAX(), R_RCX()));      // mask to one byte
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            // pointer-VARIABLE indexing p[i] (base type *T) → element at
            // [ ptr + stride*i ], stride = sizeof(T) under our uniform model. If T
            // is an AGGREGATE (struct / []u8 / union / ?T), the element VALUE is
            // its block ADDRESS (downstream copies/accesses it) — we must NOT load
            // a word; for a SCALAR T we load the 8-byte word at that address.
            if (ixt.len > 1) {
                if (ixt[0] == '*') {
                    let elemty: []u8 = cg_norm_type(ixt[1..]);
                    let stride: i32 = cg_elem_stride(cg, elemty);
                    cg_lower_expr(out, ix.base, env, syms, cg);     // pushes ptr value
                    cg_lower_expr(out, ix.idx, env, syms, cg);      // pushes i
                    push[Instr](out, i_pop(R_RCX()));               // rcx = i
                    push[Instr](out, i_pop(R_RAX()));               // rax = ptr
                    if (stride != 1) {
                        push[Instr](out, i_mov_imm(R_RDX(), stride as i64));
                        push[Instr](out, i_imul(R_RCX(), R_RDX()));
                    }
                    push[Instr](out, i_add(R_RAX(), R_RCX()));      // rax = ptr + stride*i
                    if (cg_type_is_agg(cg, elemty) == 1) {
                        // aggregate element: value = element ADDRESS.
                        push[Instr](out, i_push(R_RAX()));
                    } else if (cg_elem_is_byte(elemty) == 1) {
                        // byte element: 8-byte load then mask to one byte.
                        push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
                        push[Instr](out, i_mov_imm(R_RCX(), 255));
                        push[Instr](out, i_and(R_RAX(), R_RCX()));
                        push[Instr](out, i_push(R_RAX()));
                    } else {
                        push[Instr](out, i_load(R_RAX(), R_RAX(), 0));  // scalar word
                        push[Instr](out, i_push(R_RAX()));
                    }
                    return;
                }
            }
            cg_err(cg, "native: indexing unsupported (only \"literal\"[i], slice[i], or *T[i])");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
        }
        .switch_ => |sw| {
            cg_lower_switch_expr(out, sw, env, syms, cg);
        }
        .slice_ => |sl| {
            cg_lower_slice(out, sl, env, syms, cg);
        }
        else => {
            cg_err(cg, "native: unsupported expression kind");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
        }
    }
}

// ── slice expression: base[lo..hi] / base[lo..] → a new []u8 {ptr,len} ────────
// A sub-slice of a []u8: result.ptr = base.ptr + lo, result.len = (hi else
// base.len) - lo. We materialize the source {ptr,len} (a string literal interns
// its bytes; a slice value loads its block), compute the new ptr/len, store them
// in a fresh 2-word frame scratch block, and push that block's ADDRESS — exactly
// how every other []u8 value is represented. Only []u8 bases are supported.
fn cg_lower_slice(out: *ArrayList[Instr], sl: Slice, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    // 1. Get the source {ptr, len} into a fresh 2-word scratch `src`.
    let src: i32 = cg_slot_scratch_n(env, 2);
    let handled: i32 = 0;
    switch (sl.base.*) {
        .slit => |str| {
            // string literal base: ptr = DATA_VBASE()+off, len = decoded length.
            let off: i32 = cg_intern_str(cg, str.text, 0);
            let dlen: i32 = cg_decoded_len(str.text);
            push[Instr](out, i_mov_imm(R_RAX(), DATA_VBASE() + (off as i64)));
            push[Instr](out, i_store(R_RBP(), src + 0, R_RAX()));
            push[Instr](out, i_mov_imm(R_RAX(), dlen as i64));
            push[Instr](out, i_store(R_RBP(), src + 8, R_RAX()));
            handled = 1;
        }
        else => { }
    }
    if (handled == 0) {
        let bt: []u8 = cg_expr_type(sl.base, env, syms, cg);
        if (cg_type_is_slice(cg, bt) == 1) {
            // []u8 base: load its {ptr,len} block into `src`.
            cg_lower_expr(out, sl.base, env, syms, cg);        // pushes block base
            push[Instr](out, i_pop(R_RSI()));                  // rsi = src block base
            push[Instr](out, i_load(R_RAX(), R_RSI(), 0));     // ptr
            push[Instr](out, i_store(R_RBP(), src + 0, R_RAX()));
            push[Instr](out, i_load(R_RAX(), R_RSI(), 8));     // len
            push[Instr](out, i_store(R_RBP(), src + 8, R_RAX()));
        } else if (@strEq(bt, "*u8") || @strEq(bt, "*i8")) {
            // *u8 pointer base (e.g. ArrayList[u8].data): the pointer VALUE is the
            // data ptr; there is no length word, so src.ptr = base, src.len is
            // unknown — but an open-ended `data[lo..]` is invalid without a length,
            // so we require an explicit hi. src.len is set to hi here (used only
            // when has_hi); for an explicit hi the open-ended fallback is unused.
            if (sl.has_hi == 0) {
                cg_err(cg, "native: open-ended slice of a raw *u8 pointer needs an upper bound");
                push[Instr](out, i_mov_imm(R_RAX(), 0));
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            cg_lower_expr(out, sl.base, env, syms, cg);        // pushes the pointer value
            push[Instr](out, i_pop(R_RAX()));                  // rax = data ptr
            push[Instr](out, i_store(R_RBP(), src + 0, R_RAX()));
            push[Instr](out, i_mov_imm(R_RAX(), 0));           // len placeholder (unused: has_hi)
            push[Instr](out, i_store(R_RBP(), src + 8, R_RAX()));
        } else {
            cg_err(cg, "native: slice base must be a []u8, *u8, or string literal");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
            return;
        }
    }
    // 2. lo (into a scratch word so the hi/expr lowering can't clobber it).
    let loslot: i32 = cg_slot_scratch(env);
    cg_lower_expr(out, sl.lo, env, syms, cg);              // pushes lo
    push[Instr](out, i_pop(R_RAX()));
    push[Instr](out, i_store(R_RBP(), loslot, R_RAX()));
    // 3. hi: the explicit upper bound, or the source length when open-ended.
    let hislot: i32 = cg_slot_scratch(env);
    if (sl.has_hi == 1) {
        cg_lower_expr(out, sl.hi, env, syms, cg);          // pushes hi
        push[Instr](out, i_pop(R_RAX()));
    } else {
        push[Instr](out, i_load(R_RAX(), R_RBP(), src + 8));   // hi = source len
    }
    push[Instr](out, i_store(R_RBP(), hislot, R_RAX()));
    // 4. Build the result block: ptr = src.ptr + lo, len = hi - lo.
    let res: i32 = cg_slot_scratch_n(env, 2);
    push[Instr](out, i_load(R_RAX(), R_RBP(), src + 0));   // src.ptr
    push[Instr](out, i_load(R_RCX(), R_RBP(), loslot));    // lo
    push[Instr](out, i_add(R_RAX(), R_RCX()));             // ptr + lo
    push[Instr](out, i_store(R_RBP(), res + 0, R_RAX()));
    push[Instr](out, i_load(R_RAX(), R_RBP(), hislot));    // hi
    push[Instr](out, i_load(R_RCX(), R_RBP(), loslot));    // lo
    push[Instr](out, i_sub(R_RAX(), R_RCX()));             // hi - lo = len
    push[Instr](out, i_store(R_RBP(), res + 8, R_RAX()));
    // 5. value = result block address.
    push[Instr](out, i_lea(R_RAX(), R_RBP(), res));
    push[Instr](out, i_push(R_RAX()));
}

// ════════════════════════════════════════════════════════════════════════════
// UNIFIED AGGREGATE MATERIALIZATION (round-2) — nested struct/union literals as
// VALUES, into ANY destination (frame slot, heap block, sret block, or a nested
// field of any of those).
//
// The destination is described by a POINTER held in a frame slot (`pslot`) plus
// a byte OFFSET (`off`). The base pointer is reloaded from `pslot` immediately
// before each scalar store so the field-value expressions (which clobber
// rax/rcx/…) can never corrupt the destination address — the same robustness
// trick the heap `new(...)` path already used. A frame destination spills its
// `lea rbp+base` into a pslot up front (cg_pslot_for_frame); a heap/sret
// destination already has its pointer in a slot.
//
// cg_materialize_into places `val` (a value of declared type `fieldty`) at
// [*(rbp+pslot) + off], recursively materializing nested struct/union literals
// IN PLACE (their bytes land directly in the parent field — no boxing), storing
// a []u8 as its 16-byte {ptr,len}, and copying an aggregate VALUE expression
// word-by-word. A scalar lands as one word. Anything not expressible is rejected.
// ════════════════════════════════════════════════════════════════════════════

// Reserve a 1-word frame scratch slot, store `lea rbp+base` into it, and return
// the slot's disp. Used to turn an rbp-relative frame block into a pslot the
// materializer can reload per store.
fn cg_pslot_for_frame(out: *ArrayList[Instr], base: i32, env: *Env) i32 {
    let ps: i32 = cg_slot_scratch(env);
    push[Instr](out, i_lea(R_RAX(), R_RBP(), base));
    push[Instr](out, i_store(R_RBP(), ps, R_RAX()));
    return ps;
}

// Store the value currently in R_RAX to [*(rbp+pslot) + off]: reload the dest
// base pointer into rcx, then store. (Caller has already put the value in rax.)
fn cg_emit_store_at(out: *ArrayList[Instr], pslot: i32, off: i32) void {
    push[Instr](out, i_load(R_RCX(), R_RBP(), pslot));   // rcx = dest base
    push[Instr](out, i_store(R_RCX(), off, R_RAX()));
}

// Materialize `val` (declared type `fieldty`) at [*(rbp+pslot) + off].
fn cg_materialize_into(out: *ArrayList[Instr], pslot: i32, off: i32, val: *Node, fieldty: []u8, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let fty: []u8 = cg_norm_type(fieldty);

    // 1. NESTED struct/union literal whose type matches an aggregate field.
    let is_lit: i32 = 0;
    switch (val.*) { .slit_ => |_s| { is_lit = 1; } else => { } }
    if (is_lit == 1) {
        switch (val.*) {
            .slit_ => |s| {
                let litty: []u8 = cg_norm_type(cg_slit_sname(s));
                if (cg_type_is_union(cg, fty) == 1) {
                    cg_materialize_union_into(out, pslot, off, s, fty, env, syms, cg);
                    return;
                }
                if (cg_type_is_struct(cg, fty) == 1) {
                    if (@strEq(litty, fty) == 0) {
                        cg_err(cg, "native: nested struct literal type mismatch");
                    }
                    cg_materialize_struct_into(out, pslot, off, s, fty, env, syms, cg);
                    return;
                }
                // a literal in a non-aggregate field is a type error.
                cg_err(cg, "native: struct/union literal in non-aggregate field");
                return;
            }
            else => { }
        }
    }

    // 2. []u8 field → store the 16-byte {ptr,len} block (string lit or slice value).
    if (cg_type_is_slice(cg, fty) == 1) {
        let done: i32 = 0;
        switch (val.*) {
            .slit => |sl| {
                let soff: i32 = cg_intern_str(cg, sl.text, 0);
                let dlen: i32 = cg_decoded_len(sl.text);
                push[Instr](out, i_mov_imm(R_RAX(), DATA_VBASE() + (soff as i64)));
                cg_emit_store_at(out, pslot, off + 0);
                push[Instr](out, i_mov_imm(R_RAX(), dlen as i64));
                cg_emit_store_at(out, pslot, off + 8);
                done = 1;
            }
            else => { }
        }
        if (done == 0) {
            // slice VALUE expr → copy its 2 words from the source block.
            let st: []u8 = cg_expr_type(val, env, syms, cg);
            if (cg_type_is_slice(cg, st) == 0) {
                cg_err(cg, "native: []u8 field needs a string or slice value");
            } else {
                cg_lower_expr(out, val, env, syms, cg);   // pushes src base
                push[Instr](out, i_pop(R_RSI()));         // rsi = src base
                push[Instr](out, i_load(R_RAX(), R_RSI(), 0));
                cg_emit_store_at(out, pslot, off + 0);
                push[Instr](out, i_load(R_RAX(), R_RSI(), 8));
                cg_emit_store_at(out, pslot, off + 8);
            }
        }
        return;
    }

    // 3. struct/union FIELD whose value is an aggregate VALUE expression (not a
    // literal): copy its N words inline from the source block.
    if (cg_type_is_agg(cg, fty) == 1) {
        let nf: i32 = cg_agg_words(cg, fty);
        cg_lower_expr(out, val, env, syms, cg);          // pushes src base
        push[Instr](out, i_pop(R_RSI()));                // rsi = src base
        let k: i32 = 0;
        while (k < nf) {
            push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
            cg_emit_store_at(out, pslot, off + 8 * k);
            k = k + 1;
        }
        return;
    }

    // 4. SCALAR field → one word.
    cg_lower_expr(out, val, env, syms, cg);   // pushes scalar value
    push[Instr](out, i_pop(R_RAX()));
    cg_emit_store_at(out, pslot, off);
}

// Materialize a STRUCT literal `s` (type `sname`) at [*(rbp+pslot) + off]: write
// each FieldInit at its cumulative byte offset, recursing for nested aggregates.
fn cg_materialize_struct_into(out: *ArrayList[Instr], pslot: i32, off: i32, s: StructLit, sname: []u8, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let sn: []u8 = cg_slit_sname(s);   // generic literal → mangled concrete name
    if (@strEq(cg_norm_type(sn), cg_norm_type(sname)) == 0) {
        // sname is the field's declared struct type; sn the literal's — must match.
    }
    let i: i32 = 0;
    while (i < len[FieldInit](s.fields)) {
        let fi: FieldInit = get[FieldInit](s.fields, i);
        let foff: i32 = cg_field_offset(cg, sn, fi.name);
        if (foff < 0) {
            cg_err(cg, "native: struct literal sets unknown field");
        } else {
            let fty: []u8 = cg_field_type(cg, sn, fi.name);
            cg_materialize_into(out, pslot, off + foff, fi.val, fty, env, syms, cg);
        }
        i = i + 1;
    }
}

// Materialize a UNION literal `s` (type `uname`) at [*(rbp+pslot) + off]: write
// the variant index as the tag at off+0, then the payload INLINE at off+8 (sized
// to the payload's type, recursing for an aggregate payload literal).
fn cg_materialize_union_into(out: *ArrayList[Instr], pslot: i32, off: i32, s: StructLit, uname: []u8, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    if (len[FieldInit](s.fields) != 1) {
        cg_err(cg, "native: union literal must set exactly one variant");
        return;
    }
    let fi: FieldInit = get[FieldInit](s.fields, 0);
    let vidx: i32 = cg_union_variant_index(cg, uname, fi.name);
    if (vidx < 0) {
        cg_err(cg, "native: union literal sets unknown variant");
        return;
    }
    // tag = variant index, at off+0.
    push[Instr](out, i_mov_imm(R_RAX(), vidx as i64));
    cg_emit_store_at(out, pslot, off + 0);
    // payload INLINE at off+8, sized to the variant's declared payload type.
    let payty: []u8 = cg_union_payload_type(cg, uname, fi.name);
    cg_materialize_into(out, pslot, off + 8, fi.val, payty, env, syms, cg);
}

// Declared type of field `fname` in struct `sname` (normalised), or "" if unknown.
fn cg_field_type(cg: *Cg, sname: []u8, fname: []u8) []u8 {
    let sd: StructDecl = StructDecl{ .name = "", .fields = make[Param](1), .tparams = make[[]u8](1) };
    if (cg_find_struct(cg, sname, &sd) == 0) { return ""; }
    let i: i32 = 0;
    while (i < len[Param](sd.fields)) {
        let p: Param = get[Param](sd.fields, i);
        if (@strEq(p.name, fname)) { return cg_norm_type(p.pty); }
        i = i + 1;
    }
    return "";
}

// ── struct/union literal as a VALUE in an arbitrary expression position ───────
// A struct/union literal used as a value (call arg, nested value, etc.) is
// materialized into a FRESH frame scratch block (reserved by the pre-scan) and
// evaluates to that block's ADDRESS — exactly how an aggregate local/param is
// represented downstream. This lets `new(Node{...})`, `f(Lit)`, `return Lit`,
// and nested `Lit{ .f = Lit2{...} }` all work uniformly.
fn cg_lower_struct_lit(out: *ArrayList[Instr], s: StructLit, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let sn: []u8 = cg_norm_type(cg_slit_sname(s));
    let nf: i32 = cg_agg_words(cg, sn);
    if (cg_type_is_agg(cg, sn) == 0) {
        cg_err(cg, "native: struct/union literal of unknown type");
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    let base: i32 = cg_slot_scratch_n(env, nf);
    let ps: i32 = cg_pslot_for_frame(out, base, env);
    if (cg_type_is_union(cg, sn) == 1) {
        cg_materialize_union_into(out, ps, 0, s, sn, env, syms, cg);
    } else {
        cg_materialize_struct_into(out, ps, 0, s, sn, env, syms, cg);
    }
    push[Instr](out, i_lea(R_RAX(), R_RBP(), base));   // value = block address
    push[Instr](out, i_push(R_RAX()));
}

// Store each FieldInit of a struct literal into the block at rbp+base (a frame
// slot). Thin wrapper over the unified materializer (spills base → pslot).
fn cg_store_struct_fields(out: *ArrayList[Instr], s: StructLit, base: i32, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let sn: []u8 = cg_norm_type(cg_slit_sname(s));
    let ps: i32 = cg_pslot_for_frame(out, base, env);
    cg_materialize_struct_into(out, ps, 0, s, sn, env, syms, cg);
}

// Store a union literal into the frame block at rbp+base (thin wrapper).
fn cg_store_union_lit(out: *ArrayList[Instr], s: StructLit, uname: []u8, base: i32, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let ps: i32 = cg_pslot_for_frame(out, base, env);
    cg_materialize_union_into(out, ps, 0, s, uname, env, syms, cg);
}

// ════════════════════════════════════════════════════════════════════════════
// OPTIONALS (`?T`), ported from codegen.zag's model.
//
//   ?T  is a 2+-word block { has:i64 @0, val:T @8 }  (size = 8 + size(T)).
//   null              → { has = 0 }   (val region left undefined — never read).
//   a bare value `x`  → { has = 1, val = x }.
//   an existing ?T    → copied verbatim (a call returning ?T, or null).
//   a orelse b        → if a.has then a.val else b (b is the non-optional default).
// `if (opt) |v| {..}` if-let is NOT representable in this parser/AST (the If node
// carries no capture), so it is not implemented; the optional is consumed via
// `orelse` (and, where the program writes it, the .has/.val fields directly).
// ════════════════════════════════════════════════════════════════════════════

// True if expression `n` is the `null` literal (the parser lowers null to an
// Ident named "null" that is not a known local).
fn cg_is_null_expr(n: *Node, env: *Env) i32 {
    switch (n.*) {
        .id => |x| {
            if (@strEq(x.name, "null")) {
                if (cg_slot_find(env.*, x.name) == cg_not_found()) { return 1; }
            }
        }
        else => { }
    }
    return 0;
}

// True if expression `n` already evaluates to an OPTIONAL value (so we copy its
// block rather than wrap it): the `null` literal, or a call/expr whose static
// type is ?T.
fn cg_expr_is_opt(n: *Node, env: *Env, syms: ArrayList[FnSym], cg: *Cg) i32 {
    if (cg_is_null_expr(n, env) == 1) { return 1; }
    let t: []u8 = cg_expr_type(n, env, syms, cg);
    return cg_type_is_opt(cg, t);
}

// Write the optional value `val` (declared type `optty` = "?T") into the block at
// [*(rbp+pslot) + off].
fn cg_store_opt_into(out: *ArrayList[Instr], pslot: i32, off: i32, optty: []u8, val: *Node, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let inner: []u8 = "";
    if (optty.len > 1) { inner = cg_norm_type(optty[1..]); }
    let onf: i32 = cg_agg_words(cg, optty);
    // null → has = 0 (and zero the val words for cleanliness/determinism).
    if (cg_is_null_expr(val, env) == 1) {
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        cg_emit_store_at(out, pslot, off + 0);
        let z: i32 = 1;
        while (z < onf) {
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            cg_emit_store_at(out, pslot, off + 8 * z);
            z = z + 1;
        }
        return;
    }
    // an existing optional value → copy its block verbatim (has + val words).
    if (cg_expr_is_opt(val, env, syms, cg) == 1) {
        cg_lower_expr(out, val, env, syms, cg);   // pushes src block base
        push[Instr](out, i_pop(R_RSI()));         // rsi = src base
        let k: i32 = 0;
        while (k < onf) {
            push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
            cg_emit_store_at(out, pslot, off + 8 * k);
            k = k + 1;
        }
        return;
    }
    // a bare value x → has = 1, then materialize x (sized to T) at off+8.
    push[Instr](out, i_mov_imm(R_RAX(), 1));
    cg_emit_store_at(out, pslot, off + 0);
    cg_materialize_into(out, pslot, off + 8, val, inner, env, syms, cg);
}

// `a orelse b` → if a.has then a.val else b. We materialize the optional `a`
// into a fresh 2-word scratch block, test its has-word, and select. The result
// pushed is a SCALAR (T) — `orelse` unwraps. (T must be a scalar/pointer in this
// subset; an aggregate-typed orelse would need block selection — rejected.)
fn cg_lower_orelse(out: *ArrayList[Instr], bb: Bin, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    // Determine the optional's type (for sizing) and its inner T.
    let aty: []u8 = cg_expr_type(bb.l, env, syms, cg);
    let inner: []u8 = "";
    if (aty.len > 1 && aty[0] == '?') { inner = cg_norm_type(aty[1..]); }
    if (inner.len > 0 && cg_type_is_agg(cg, inner) == 1) {
        cg_err(cg, "native: orelse on an aggregate optional unsupported");
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    let l_else: i32 = cg_fresh(cg);
    let l_end: i32 = cg_fresh(cg);
    // Materialize `a` into a scratch optional block, then load its has + val.
    let onf: i32 = 2;
    if (aty.len > 1 && aty[0] == '?') { onf = cg_agg_words(cg, aty); }
    let blk: i32 = cg_slot_scratch_n(env, onf);
    let ps: i32 = cg_pslot_for_frame(out, blk, env);
    if (aty.len > 1 && aty[0] == '?') {
        cg_store_opt_into(out, ps, 0, aty, bb.l, env, syms, cg);
    } else {
        // `a` isn't statically optional (e.g. a literal value) — treat as present.
        cg_store_opt_into(out, ps, 0, "?i64", bb.l, env, syms, cg);
    }
    // if has == 0 → take default; else value = a.val.
    push[Instr](out, i_load(R_RAX(), R_RBP(), blk + 0));   // has
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_else));
    push[Instr](out, i_load(R_RAX(), R_RBP(), blk + 8));   // a.val
    push[Instr](out, i_push(R_RAX()));
    push[Instr](out, i_jmp(l_end));
    push[Instr](out, i_label(l_else));
    cg_lower_expr(out, bb.r, env, syms, cg);               // default (pushed)
    push[Instr](out, i_label(l_end));
}

// setcc condition code for a FLOAT comparison (ucomisd sets CF/ZF/PF like an
// UNSIGNED compare, so float </<=/>/>= map to below/below-eq/above/above-eq).
// NaN is unordered (sets ZF=PF=CF=1); we do not special-case it (==/!= on a NaN
// is mildly wrong) — documented; the supported programs contain no NaNs.
fn cg_float_cmp_cc(op: []u8) i32 {
    if (@strEq(op, "<"))  { return CC_B(); }
    if (@strEq(op, "<=")) { return CC_BE(); }
    if (@strEq(op, ">"))  { return CC_A(); }
    if (@strEq(op, ">=")) { return CC_AE(); }
    if (@strEq(op, "==")) { return CC_E(); }
    return CC_NE();   // "!="
}

// Lower a binary op whose operands are FLOAT. Both must be float (f32/f64 may
// mix — both are doubles internally); an int/float mix is rejected loudly so a
// stray integer is never reinterpreted as a double bit pattern. The two operand
// bit patterns are popped into gprs, moved into xmm0/xmm1, the SSE op runs, and
// the result's bits are pushed back as an ordinary 8-byte stack word.
fn cg_lower_bin_float(out: *ArrayList[Instr], bb: Bin, lf: i32, rf: i32, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    if (lf == 0 || rf == 0) {
        cg_err(cg, "native: mixed int/float arithmetic — add an explicit `as f64`/`as f32` cast");
        cg_lower_expr(out, bb.l, env, syms, cg);   // leave something on the stack
        return;
    }
    cg_lower_expr(out, bb.l, env, syms, cg);        // pushes l bits
    cg_lower_expr(out, bb.r, env, syms, cg);        // pushes r bits
    push[Instr](out, i_pop(R_RCX()));               // rcx = r
    push[Instr](out, i_pop(R_RAX()));               // rax = l
    push[Instr](out, i_fmovq_gx(R_XMM0(), R_RAX())); // xmm0 = l
    push[Instr](out, i_fmovq_gx(R_XMM1(), R_RCX())); // xmm1 = r
    if (cg_is_cmp_op(bb.op) == 1) {
        push[Instr](out, i_fucomi(R_XMM0(), R_XMM1()));        // sets EFLAGS (l ? r)
        push[Instr](out, i_setcc(R_RAX(), cg_float_cmp_cc(bb.op)));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    if (@strEq(bb.op, "+")) { push[Instr](out, i_fadd(R_XMM0(), R_XMM1())); }
    else if (@strEq(bb.op, "-")) { push[Instr](out, i_fsub(R_XMM0(), R_XMM1())); }
    else if (@strEq(bb.op, "*")) { push[Instr](out, i_fmul(R_XMM0(), R_XMM1())); }
    else if (@strEq(bb.op, "/")) { push[Instr](out, i_fdiv(R_XMM0(), R_XMM1())); }
    else {
        cg_err(cg, "native: operator not supported on floats (only + - * / and comparisons)");
    }
    push[Instr](out, i_fmovq_xg(R_RAX(), R_XMM0()));
    push[Instr](out, i_push(R_RAX()));
}

// ── binary operators (incl. short-circuit && / ||, optional orelse) ──────────
fn cg_lower_bin(out: *ArrayList[Instr], bb: Bin, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    // `opt orelse default` — unwrap the optional or take the default.
    if (@strEq(bb.op, "orelse")) {
        cg_lower_orelse(out, bb, env, syms, cg);
        return;
    }
    // SHORT-CIRCUIT logical && / ||. We evaluate the left operand and branch
    // before touching the right, so side effects / division-by-zero in the
    // right operand are correctly skipped — matching real `&&`/`||` semantics.
    if (@strEq(bb.op, "&&")) {
        let lfalse: i32 = cg_fresh(cg);
        let lend: i32 = cg_fresh(cg);
        cg_lower_expr(out, bb.l, env, syms, cg);
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_cmp_imm(R_RAX(), 0));
        push[Instr](out, i_je(lfalse));            // left false → whole expr false
        cg_lower_expr(out, bb.r, env, syms, cg);
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_cmp_imm(R_RAX(), 0));
        push[Instr](out, i_je(lfalse));            // right false → false
        push[Instr](out, i_mov_imm(R_RAX(), 1));
        push[Instr](out, i_jmp(lend));
        push[Instr](out, i_label(lfalse));
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_label(lend));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    if (@strEq(bb.op, "||")) {
        let ltrue: i32 = cg_fresh(cg);
        let lend: i32 = cg_fresh(cg);
        cg_lower_expr(out, bb.l, env, syms, cg);
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_cmp_imm(R_RAX(), 0));
        push[Instr](out, i_jne(ltrue));            // left true → whole expr true
        cg_lower_expr(out, bb.r, env, syms, cg);
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_cmp_imm(R_RAX(), 0));
        push[Instr](out, i_jne(ltrue));            // right true → true
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_jmp(lend));
        push[Instr](out, i_label(ltrue));
        push[Instr](out, i_mov_imm(R_RAX(), 1));
        push[Instr](out, i_label(lend));
        push[Instr](out, i_push(R_RAX()));
        return;
    }

    // ── FLOAT detection: if either operand is float-typed, take the SSE path. ──
    // f32 and f64 are both carried as a double bit pattern, so an f32/f64 mix is
    // fine; an int/float MIX (no operand-specific cast) is rejected loudly.
    let lty: []u8 = cg_expr_type(bb.l, env, syms, cg);
    let rty: []u8 = cg_expr_type(bb.r, env, syms, cg);
    let lf: i32 = cg_is_float_ty(lty);
    let rf: i32 = cg_is_float_ty(rty);
    if (lf == 1 || rf == 1) {
        cg_lower_bin_float(out, bb, lf, rf, env, syms, cg);
        return;
    }

    // ── strict binary ops: lower both, pop r=rcx, l=rax ──────────────────────
    cg_lower_expr(out, bb.l, env, syms, cg);   // pushes l
    cg_lower_expr(out, bb.r, env, syms, cg);   // pushes r
    push[Instr](out, i_pop(R_RCX()));          // rcx = r
    push[Instr](out, i_pop(R_RAX()));          // rax = l

    if (cg_is_cmp_op(bb.op) == 1) {
        push[Instr](out, i_cmp(R_RAX(), R_RCX()));
        push[Instr](out, i_setcc(R_RAX(), cg_cmp_cc(bb.op)));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    if (@strEq(bb.op, "+")) {
        push[Instr](out, i_add(R_RAX(), R_RCX()));
    } else if (@strEq(bb.op, "-")) {
        push[Instr](out, i_sub(R_RAX(), R_RCX()));
    } else if (@strEq(bb.op, "*")) {
        push[Instr](out, i_imul(R_RAX(), R_RCX()));
    } else if (@strEq(bb.op, "/")) {
        push[Instr](out, i_idiv(R_RCX()));                 // cqo+idiv; quotient → rax
    } else if (@strEq(bb.op, "%")) {
        push[Instr](out, i_idiv(R_RCX()));                 // remainder → rdx
        push[Instr](out, i_mov_rr(R_RAX(), R_RDX()));
    } else if (@strEq(bb.op, "&")) {
        push[Instr](out, i_and(R_RAX(), R_RCX()));
    } else if (@strEq(bb.op, "^")) {
        push[Instr](out, i_xor(R_RAX(), R_RCX()));
    } else if (@strEq(bb.op, "|")) {
        push[Instr](out, i_or(R_RAX(), R_RCX()));
    } else {
        cg_err(cg, "native: unsupported binary operator");
        // leave rax = l so we still push something recognizable
    }
    push[Instr](out, i_push(R_RAX()));
}

// ── print builtins ───────────────────────────────────────────────────────────
// Recognize the OUTPUT builtins and lower them to a `call` of the appropriate
// support routine. print_int(x) / _zag_print_i32(x): lower the arg into rdi and
// `call __print_int`. print_str("lit") / _zag_print("lit") / _zag_println("lit"):
// intern the literal bytes, set rsi=DATA_VBASE()+off, rdx=len, `call __print_str`
// (_zag_println appends a trailing '\n'). A print call yields no useful value,
// so we push a 0 placeholder (the caller of an estmt discards it; in an
// expression position the builtins are not meant to be used). Returns 1 if it
// recognized & handled a builtin, 0 otherwise.
fn cg_is_print_int(name: []u8) i32 {
    if (@strEq(name, "print_int"))     { return 1; }
    if (@strEq(name, "_zag_print_i32")) { return 1; }
    return 0;
}
fn cg_is_print_str(name: []u8) i32 {
    if (@strEq(name, "print_str")) { return 1; }
    if (@strEq(name, "_zag_print")) { return 1; }
    return 0;
}
fn cg_is_println_str(name: []u8) i32 {
    if (@strEq(name, "_zag_println")) { return 1; }
    return 0;
}
// print a float (f64 or f32) — both routed through __print_f64 (f32 is held as a
// double internally). `print_float` is accepted as an alias.
fn cg_is_print_float(name: []u8) i32 {
    if (@strEq(name, "print_f64"))      { return 1; }
    if (@strEq(name, "print_f32"))      { return 1; }
    if (@strEq(name, "print_float"))    { return 1; }
    if (@strEq(name, "_zag_print_f64")) { return 1; }
    if (@strEq(name, "_zag_print_f32")) { return 1; }
    return 0;
}

fn cg_lower_print(out: *ArrayList[Instr], fname: []u8, c: Call, env: *Env, syms: ArrayList[FnSym], cg: *Cg) i32 {
    let nargs: i32 = len[*Node](c.args);

    if (cg_is_print_int(fname) == 1) {
        if (nargs != 1) {
            cg_err(cg, "native: print_int expects exactly one argument");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
            return 1;
        }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);  // pushes value
        push[Instr](out, i_pop(R_RDI()));                          // rdi = value
        cg.*.use_pi = 1;                                           // __print_int referenced
        push[Instr](out, i_call(cg.*.pi_lbl));
        push[Instr](out, i_mov_imm(R_RAX(), 0));                   // no value
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    if (cg_is_print_float(fname) == 1) {
        if (nargs != 1) {
            cg_err(cg, "native: print_f64/print_f32 expects exactly one argument");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
            return 1;
        }
        let parg: *Node = get[*Node](c.args, 0);
        cg_lower_expr(out, parg, env, syms, cg);                   // pushes value
        push[Instr](out, i_pop(R_RDI()));                          // rdi = double bits
        // a stray int arg (`print_f64(3)`) is widened so we never print the raw
        // integer bit pattern as a denormal double.
        if (cg_is_float_ty(cg_expr_type(parg, env, syms, cg)) == 0) {
            push[Instr](out, i_fsi2sd(R_XMM0(), R_RDI()));
            push[Instr](out, i_fmovq_xg(R_RDI(), R_XMM0()));
        }
        cg.*.use_pf = 1;                                           // __print_f64 referenced
        push[Instr](out, i_call(cg.*.pf_lbl));
        push[Instr](out, i_mov_imm(R_RAX(), 0));                   // no value
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    let is_ps: i32 = cg_is_print_str(fname);
    let is_pl: i32 = cg_is_println_str(fname);
    if (is_ps == 1 || is_pl == 1) {
        if (nargs != 1) {
            cg_err(cg, "native: print_str/println expects exactly one argument");
            push[Instr](out, i_mov_imm(R_RAX(), 0));
            push[Instr](out, i_push(R_RAX()));
            return 1;
        }
        // Argument is either a STRING LITERAL (intern its bytes) or a []u8 SLICE
        // VALUE (a variable/param/call result) — for the latter we load {ptr,len}
        // from its block and feed those to __print_str. _zag_println appends '\n'
        // (only meaningful for a literal; for a slice we keep its exact bytes).
        let arg: *Node = get[*Node](c.args, 0);
        let handled: i32 = 0;
        switch (arg.*) {
            .slit => |sl| {
                let add_nl: i32 = 0;
                if (is_pl == 1) { add_nl = 1; }
                let total: i32 = cg_decoded_len(sl.text) + add_nl;
                let off: i32 = cg_intern_str(cg, sl.text, add_nl);
                // rsi = DATA_VBASE()+off ; rdx = total ; call __print_str
                push[Instr](out, i_mov_imm(R_RSI(), DATA_VBASE() + (off as i64)));
                push[Instr](out, i_mov_imm(R_RDX(), total as i64));
                cg.*.use_ps = 1;
                push[Instr](out, i_call(cg.*.ps_lbl));
                handled = 1;
            }
            else => { }
        }
        if (handled == 0) {
            // []u8 slice value: load its {ptr@0, len@8} block and write it.
            let at: []u8 = cg_expr_type(arg, env, syms, cg);
            if (cg_type_is_slice(cg, at) == 1) {
                cg_lower_expr(out, arg, env, syms, cg);          // pushes block base
                push[Instr](out, i_pop(R_RAX()));                // rax = block base
                push[Instr](out, i_load(R_RSI(), R_RAX(), 0));   // rsi = ptr
                push[Instr](out, i_load(R_RDX(), R_RAX(), 8));   // rdx = len
                cg.*.use_ps = 1;
                push[Instr](out, i_call(cg.*.ps_lbl));
                handled = 1;
            }
        }
        if (handled == 0) {
            cg_err(cg, "native: print_str/println argument must be a string literal or []u8 slice");
        }
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }
    return 0;
}

// new(T{..}) heap allocation. Lowered to: rdi = sizeof(T); call __alloc (one
// mmap → rax = ptr); stash ptr in a frame pslot; materialize the (struct OR
// union) literal's fields INLINE into the heap block via the unified
// materializer (so NESTED aggregate fields — e.g. new(Node{ .bin = Bin{...} })
// — work). The value is the returned pointer; `p.*.field` reads it back.
fn cg_lower_new(out: *ArrayList[Instr], c: Call, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    if (len[*Node](c.args) != 1) {
        cg_err(cg, "native: new(...) expects exactly one struct-literal argument");
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    let arg: *Node = get[*Node](c.args, 0);
    let handled: i32 = 0;
    switch (arg.*) {
        .slit_ => |s| {
            let sn: []u8 = cg_norm_type(cg_slit_sname(s));   // generic → mangled
            let sz: i32 = cg_type_size(cg, sn);
            if (cg_type_is_agg(cg, sn) == 0) {
                cg_err(cg, "native: new(...) on unknown struct/union type");
            }
            // rdi = sizeof(T) ; call __alloc → rax = ptr.
            push[Instr](out, i_mov_imm(R_RDI(), sz as i64));
            cg.*.use_al = 1;
            push[Instr](out, i_call(cg.*.al_lbl));
            // Stash ptr in a scratch pslot so field-value expressions can't
            // clobber it; the materializer reloads it per store.
            let pslot: i32 = cg_slot_scratch(env);
            push[Instr](out, i_store(R_RBP(), pslot, R_RAX()));
            if (cg_type_is_union(cg, sn) == 1) {
                cg_materialize_union_into(out, pslot, 0, s, sn, env, syms, cg);
            } else {
                cg_materialize_struct_into(out, pslot, 0, s, sn, env, syms, cg);
            }
            push[Instr](out, i_load(R_RAX(), R_RBP(), pslot));   // value = ptr
            push[Instr](out, i_push(R_RAX()));
            handled = 1;
        }
        else => { }
    }
    if (handled == 0) {
        cg_err(cg, "native: new(...) argument must be a struct literal");
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
    }
}

// ── @-builtins ───────────────────────────────────────────────────────────────
// Compile-time SIZE of a type in bytes, under the PROPER variable-size layout
// (cg_type_size): struct → sum of 8-aligned field sizes; union → 8 + max payload;
// []u8 → 16; ?T → 8 + size(T); scalar/pointer/enum → 8. Generic-app types are
// normalised to their concrete mangled name first (handled inside cg_type_size).
fn cg_sizeof_type(cg: *Cg, t0: []u8) i32 {
    return cg_type_size(cg, t0);
}

// Lower an @-builtin call. `fname` includes the leading '@'. Result is PUSHED.
fn cg_lower_builtin(out: *ArrayList[Instr], fname: []u8, c: Call, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let b: []u8 = fname[1..];   // strip '@'
    let nargs: i32 = len[*Node](c.args);

    // @sizeOf[T]() → compile-time constant byte size.
    if (@strEq(b, "sizeOf")) {
        let t: []u8 = "i32";
        if (len[[]u8](c.targs) > 0) { t = get[[]u8](c.targs, 0); }
        push[Instr](out, i_mov_imm(R_RAX(), cg_sizeof_type(cg, t) as i64));
        push[Instr](out, i_push(R_RAX()));
        return;
    }

    // @len(x) / @strLen(x) → the slice length word [block+8]. x must be a slice
    // value (a []u8); a string literal's length is a compile-time constant.
    if (@strEq(b, "len") || @strEq(b, "strLen")) {
        if (nargs != 1) { cg_err(cg, "native: @len/@strLen expects one argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return; }
        let arg: *Node = get[*Node](c.args, 0);
        switch (arg.*) {
            .slit => |sl| {
                push[Instr](out, i_mov_imm(R_RAX(), cg_decoded_len(sl.text) as i64));
                push[Instr](out, i_push(R_RAX()));
                return;
            }
            else => { }
        }
        let at: []u8 = cg_expr_type(arg, env, syms, cg);
        if (cg_type_is_slice(cg, at) == 1) {
            cg_lower_expr(out, arg, env, syms, cg);          // pushes block base
            push[Instr](out, i_pop(R_RAX()));
            push[Instr](out, i_load(R_RAX(), R_RAX(), 8));   // [base+8] = len
            push[Instr](out, i_push(R_RAX()));
            return;
        }
        cg_err(cg, "native: @len/@strLen argument must be a []u8 slice");
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return;
    }

    // @strEq(a, b) → 1 if the two []u8 slices have equal length AND bytes, else 0.
    if (@strEq(b, "strEq")) {
        if (nargs != 2) { cg_err(cg, "native: @strEq expects two arguments"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return; }
        // Lower both slice operands to their block base addresses, pop into the
        // first two arg registers, and call __streq(rdi=&a, rsi=&b).
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);   // pushes &a
        cg_lower_expr(out, get[*Node](c.args, 1), env, syms, cg);   // pushes &b
        push[Instr](out, i_pop(R_RSI()));   // rsi = &b
        push[Instr](out, i_pop(R_RDI()));   // rdi = &a
        cg.*.use_se = 1;
        push[Instr](out, i_call(cg.*.se_lbl));
        push[Instr](out, i_push(R_RAX()));  // 0/1
        return;
    }

    // @intCast(x) / @truncate(x) / @floatCast(x) → no-op at 64-bit width (f32↔f64
    // share the internal double representation, so @floatCast is also a no-op).
    if (@strEq(b, "intCast") || @strEq(b, "truncate") || @strEq(b, "floatCast")) {
        if (nargs != 1) { cg_err(cg, "native: @intCast/@truncate/@floatCast expects one argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);   // value passes through
        return;
    }

    // @intToFloat(x) → cvtsi2sd ; @floatToInt(x) → cvttsd2si (truncate). Mirrors
    // the `x as f64` / `x as i32` cast paths (kept for source that spells the
    // conversion as a builtin).
    if (@strEq(b, "intToFloat")) {
        if (nargs != 1) { cg_err(cg, "native: @intToFloat expects one argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_fsi2sd(R_XMM0(), R_RAX()));
        push[Instr](out, i_fmovq_xg(R_RAX(), R_XMM0()));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    if (@strEq(b, "floatToInt")) {
        if (nargs != 1) { cg_err(cg, "native: @floatToInt expects one argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_fmovq_gx(R_XMM0(), R_RAX()));
        push[Instr](out, i_ftsd2si(R_RAX(), R_XMM0()));
        push[Instr](out, i_push(R_RAX()));
        return;
    }

    cg_err(cg, "native: unsupported @-builtin");
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_push(R_RAX()));
}

// ── runtime heap externs (native, mmap-backed) ───────────────────────────────
// std/list.zag (the generic ArrayList) is implemented over _zag_malloc /
// _zag_realloc / _zag_free. The native backend has no libc, so we provide these
// directly: __malloc / __realloc are mmap-backed with an 8-byte size HEADER (the
// allocation length lives at ptr-8) so realloc can copy exactly min(old,new)
// bytes; __free is a no-op (we never unmap — documented small leak, fine for the
// short-lived programs this subset compiles). Returns 1 if it handled `fname`.
fn cg_lower_runtime(out: *ArrayList[Instr], fname: []u8, c: Call, env: *Env, syms: ArrayList[FnSym], cg: *Cg) i32 {
    let nargs: i32 = len[*Node](c.args);
    if (@strEq(fname, "_zag_malloc")) {
        if (nargs != 1) { cg_err(cg, "native: _zag_malloc expects one argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);   // pushes n
        push[Instr](out, i_pop(R_RDI()));                          // rdi = n
        cg.*.use_ml = 1;
        push[Instr](out, i_call(cg.*.ml_lbl));
        push[Instr](out, i_push(R_RAX()));                         // ptr
        return 1;
    }
    if (@strEq(fname, "_zag_realloc")) {
        if (nargs != 2) { cg_err(cg, "native: _zag_realloc expects two arguments"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);   // pushes oldptr
        cg_lower_expr(out, get[*Node](c.args, 1), env, syms, cg);   // pushes newsize
        push[Instr](out, i_pop(R_RSI()));                          // rsi = newsize
        push[Instr](out, i_pop(R_RDI()));                          // rdi = oldptr
        cg.*.use_rl = 1;
        push[Instr](out, i_call(cg.*.rl_lbl));
        push[Instr](out, i_push(R_RAX()));                         // newptr
        return 1;
    }
    if (@strEq(fname, "_zag_free")) {
        // evaluate the argument for side effects, then discard; no unmap.
        if (nargs == 1) {
            cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);
            push[Instr](out, i_pop(R_RAX()));
        }
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }
    return 0;
}

// ── native syscall runtime (the `_zag_*` externs) — call-site lowering ────────
// Each `_zag_*` extern is implemented as a native support routine (RT_* index,
// label rt_base+index, body emitted only if referenced). At the call site we
// lower the args (a []u8 arg is its existing {ptr,len} BLOCK POINTER, a scalar
// is its value), pop them into System V arg registers rdi,rsi,rdx,…, `call` the
// routine, and push rax (a scalar result, or a pointer to a fresh {ptr,len}
// block for a []u8 result — treated as an aggregate value downstream).
//
// Lower the c.args left→right (each leaves one 8-byte value on the CPU stack),
// then pop them in REVERSE into the arg registers, leaving rsp balanced.
fn cg_rt_lower_args(out: *ArrayList[Instr], c: Call, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let nargs: i32 = len[*Node](c.args);
    let i: i32 = 0;
    while (i < nargs) {
        cg_lower_expr(out, get[*Node](c.args, i), env, syms, cg);
        i = i + 1;
    }
    let j: i32 = nargs - 1;
    while (j >= 0) {
        push[Instr](out, i_pop(arg_reg(j)));
        j = j - 1;
    }
}

// Lower a recognized native-runtime call. Returns 1 if handled, 0 otherwise.
fn cg_lower_native_rt(out: *ArrayList[Instr], fname: []u8, c: Call, env: *Env, syms: ArrayList[FnSym], cg: *Cg) i32 {
    let nargs: i32 = len[*Node](c.args);

    // ── I/O: eprintln → __rt_writeln(rdi=&s, rsi=fd=2, rdx=nl=1) ──────────────
    // (_zag_print / _zag_println are handled by cg_lower_print via __print_str,
    // which writes to fd=1 — eprintln needs fd=2 so it routes through here.)
    let is_print: i32 = 0; let pfd: i32 = 1; let pnl: i32 = 0;
    if (@strEq(fname, "_zag_eprintln")) { is_print = 1; pfd = 2; pnl = 1; }
    if (is_print == 1) {
        if (nargs != 1) { cg_err(cg, "native: _zag_print* expects one []u8 argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        let arg: *Node = get[*Node](c.args, 0);
        // a string LITERAL has no block: materialize it as a []u8 value first.
        cg_lower_expr(out, arg, env, syms, cg);    // pushes &{ptr,len}
        push[Instr](out, i_pop(R_RDI()));          // rdi = &slice
        push[Instr](out, i_mov_imm(R_RSI(), pfd as i64));   // rsi = fd
        push[Instr](out, i_mov_imm(R_RDX(), pnl as i64));   // rdx = add_nl
        cg_rt_use(cg, RT_WRITELN());
        push[Instr](out, i_call(cg_rt_lbl(cg, RT_WRITELN())));
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    // ── flush → no-op (we use unbuffered write(2), nothing to flush) ──────────
    if (@strEq(fname, "_zag_flush")) {
        let k: i32 = 0;
        while (k < nargs) { cg_lower_expr(out, get[*Node](c.args, k), env, syms, cg); push[Instr](out, i_pop(R_RAX())); k = k + 1; }
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    // ── exit(code) → exit syscall (60); never returns ────────────────────────
    if (@strEq(fname, "_zag_exit")) {
        if (nargs != 1) { cg_err(cg, "native: _zag_exit expects one argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);
        push[Instr](out, i_pop(R_RDI()));              // rdi = exit code
        push[Instr](out, i_mov_imm(R_RAX(), 60));      // sys_exit
        push[Instr](out, i_syscall());
        push[Instr](out, i_mov_imm(R_RAX(), 0));       // unreachable; keep stack model
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    // ── _zag_argc() → load argc from [r15] ───────────────────────────────────
    if (@strEq(fname, "_zag_argc")) {
        if (nargs != 0) { cg_err(cg, "native: _zag_argc expects no arguments"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        push[Instr](out, i_load(R_RAX(), 15, 0));      // rax = [r15] = argc
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    // ── the routine-backed runtime fns (RT_* index, expected arg count) ──────
    let idx: i32 = 0 - 1; let want: i32 = 0; let found: i32 = 0;
    if (@strEq(fname, "_zag_str_concat"))       { idx = RT_CONCAT();  want = 2; found = 1; }
    if (@strEq(fname, "_zag_strdup"))           { idx = RT_STRDUP();  want = 1; found = 1; }
    if (@strEq(fname, "_zag_i64_to_str"))       { idx = RT_I2S();     want = 1; found = 1; }
    if (@strEq(fname, "_zag_u64_to_str"))       { idx = RT_U2S();     want = 1; found = 1; }
    if (@strEq(fname, "_zag_read_file"))        { idx = RT_READF();   want = 1; found = 1; }
    if (@strEq(fname, "_zag_write_file"))       { idx = RT_WRITEF();  want = 2; found = 1; }
    if (@strEq(fname, "_zag_write_exec"))       { idx = RT_WRITEX();  want = 2; found = 1; }
    if (@strEq(fname, "_zag_file_exists"))      { idx = RT_FEXISTS(); want = 1; found = 1; }
    if (@strEq(fname, "_zag_arg"))              { idx = RT_ARG();     want = 1; found = 1; }
    if (@strEq(fname, "_zag_exec_cmd"))         { idx = RT_EXEC();    want = 1; found = 1; }
    if (@strEq(fname, "_zag_strcmp_ord"))       { idx = RT_STRCMPO(); want = 2; found = 1; }
    if (@strEq(fname, "_zag_str_index_of_byte")){ idx = RT_IDXBYTE(); want = 2; found = 1; }
    if (@strEq(fname, "_zag_memcpy"))           { idx = RT_MEMCPY();  want = 3; found = 1; }
    if (@strEq(fname, "_zag_memcmp"))           { idx = RT_MEMCMP();  want = 3; found = 1; }
    if (@strEq(fname, "_zag_str_to_i64"))       { idx = RT_STR2I();   want = 1; found = 1; }
    if (found == 1) {
        if (nargs != want) { cg_err(cg, _zag_str_concat("native: wrong arg count for ", fname)); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        cg_rt_lower_args(out, c, env, syms, cg);
        cg_rt_use(cg, idx);
        push[Instr](out, i_call(cg_rt_lbl(cg, idx)));
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    // ── strlen / str_len → the slice's len word; str_eq/strcmp → __streq ──────
    if (@strEq(fname, "_zag_strlen") || @strEq(fname, "_zag_str_len")) {
        if (nargs != 1) { cg_err(cg, "native: _zag_strlen expects one argument"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);   // pushes &slice
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_load(R_RAX(), R_RAX(), 8));              // [&slice+8] = len
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }
    if (@strEq(fname, "_zag_strcmp") || @strEq(fname, "_zag_str_eq")) {
        if (nargs != 2) { cg_err(cg, "native: _zag_strcmp expects two arguments"); push[Instr](out, i_mov_imm(R_RAX(), 0)); push[Instr](out, i_push(R_RAX())); return 1; }
        cg_lower_expr(out, get[*Node](c.args, 0), env, syms, cg);   // &a
        cg_lower_expr(out, get[*Node](c.args, 1), env, syms, cg);   // &b
        push[Instr](out, i_pop(R_RSI()));   // rsi = &b
        push[Instr](out, i_pop(R_RDI()));   // rdi = &a
        cg.*.use_se = 1;
        push[Instr](out, i_call(cg.*.se_lbl));   // __streq → 0/1
        push[Instr](out, i_push(R_RAX()));
        return 1;
    }

    return 0;
}

// ── calls ────────────────────────────────────────────────────────────────────
fn cg_lower_call(out: *ArrayList[Instr], c: Call, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let nargs: i32 = len[*Node](c.args);
    // callee must be a plain Ident naming a known function or a print builtin
    let fname: []u8 = "";
    let ok: i32 = 0;
    switch (c.callee.*) {
        .id => |x| { fname = x.name; ok = 1; }
        else => { ok = 0; }
    }
    if (ok == 0) {
        cg_err(cg, "native: only direct function calls supported");
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    // @-builtins (@sizeOf, @len, @strEq, @intCast, ...) are intercepted first.
    if (fname.len > 0) {
        if (fname[0] == '@') { cg_lower_builtin(out, fname, c, env, syms, cg); return; }
    }
    // OUTPUT builtins are intercepted before the user-function lookup.
    if (cg_lower_print(out, fname, c, env, syms, cg) == 1) { return; }
    // new(T{..}) heap allocation.
    if (@strEq(fname, "new")) { cg_lower_new(out, c, env, syms, cg); return; }
    // RUNTIME heap externs (the std/list.zag backing): _zag_malloc/_zag_realloc/
    // _zag_free — provided natively (mmap-backed) so generic containers run with
    // NO libc. (Defined here, not as extern fns, hence intercepted before lookup.)
    if (cg_lower_runtime(out, fname, c, env, syms, cg) == 1) { return; }
    // NATIVE SYSCALL RUNTIME externs (_zag_str_concat, _zag_read_file, _zag_arg,
    // _zag_i64_to_str, _zag_eprintln, _zag_write_exec, _zag_exec_cmd, …) — every
    // `_zag_*` primitive implemented with raw syscalls, NO C runtime.
    if (cg_lower_native_rt(out, fname, c, env, syms, cg) == 1) { return; }

    // A GENERIC call foo[T](..) resolves to the mangled concrete instance name
    // foo_T (registered by monomorphization). Non-generic calls keep their name.
    if (len[[]u8](c.targs) > 0) { fname = cg_mangle_generic(fname, c.targs); }

    let lbl: i32 = cg_find_fn(syms, fname);
    if (lbl < 0) {
        cg_err(cg, "native: call to unknown function");
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return;
    }

    // ── argument lowering, with by-value AGGREGATE copy ──────────────────────
    // Evaluate args left→right, each leaving an 8-byte value (the arg-register
    // payload) on the CPU stack. For a SCALAR arg that payload is its value. For
    // an AGGREGATE arg (struct / []u8 slice passed by value) we give the callee
    // its OWN copy: allocate a fresh N-word scratch block in OUR frame (reserved
    // by the pre-scan), copy the source aggregate's N words into it, and the
    // payload is the COPY's address. Mutating the callee's param therefore can
    // never touch the caller's original — MUTATION ISOLATION holds by copy.
    // STEP 1: spill every arg's 8-byte PAYLOAD into a dedicated frame slot
    // aslot[i] (reserved by the scan). For a SCALAR arg the payload is its value;
    // for a by-value AGGREGATE arg (struct/slice) the payload is the address of a
    // fresh private COPY (so the callee mutating its param can't touch the
    // caller's original — mutation isolation by copy); a string-LITERAL arg's
    // materialized {ptr,len} block address is already private, so it is passed
    // directly. Spilling first lets us then place args in registers OR push them
    // as System V stack args (for the 7th+ argument) without clobbering.
    let aslot: ArrayList[i32] = make[i32](nargs + 1);
    let i: i32 = 0;
    while (i < nargs) {
        let arg: *Node = get[*Node](c.args, i);
        let at: []u8 = cg_expr_type(arg, env, syms, cg);
        let is_slit: i32 = 0;
        switch (arg.*) { .slit => |_s| { is_slit = 1; } else => { } }
        let sl: i32 = cg_slot_scratch(env);
        push[i32](&aslot, sl);
        if (cg_type_is_agg(cg, at) == 1 && is_slit == 0) {
            let nf: i32 = cg_agg_words(cg, at);
            let cpy: i32 = cg_slot_scratch_n(env, nf);
            cg_lower_expr(out, arg, env, syms, cg);          // pushes src base addr
            push[Instr](out, i_pop(R_RSI()));                // rsi = src base
            let k: i32 = 0;
            while (k < nf) {
                push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
                push[Instr](out, i_store(R_RBP(), cpy + 8 * k, R_RAX()));
                k = k + 1;
            }
            push[Instr](out, i_lea(R_RAX(), R_RBP(), cpy));  // payload = copy addr
        } else {
            cg_lower_expr(out, arg, env, syms, cg);          // pushes scalar/lit-addr
            push[Instr](out, i_pop(R_RAX()));
        }
        push[Instr](out, i_store(R_RBP(), sl, R_RAX()));     // aslot[i] = payload
        i = i + 1;
    }

    // STEP 2: System V argument placement. Args 0..5 go in rdi,rsi,rdx,rcx,r8,r9;
    // args 6.. are PUSHED on the CPU stack in REVERSE (so arg6 ends lowest, at
    // [rsp] when the callee reads it). To keep rsp 16-aligned at the `call` (the
    // ABI requirement — our frame is 16-aligned after the prologue), if the number
    // of stack args is ODD we push one padding word first.
    let nstack: i32 = 0;
    if (nargs > 6) { nstack = nargs - 6; }
    let pushed: i32 = nstack;
    if (nstack % 2 == 1) {
        push[Instr](out, i_mov_imm(R_RAX(), 0));   // alignment padding
        push[Instr](out, i_push(R_RAX()));
        pushed = pushed + 1;
    }
    // push stack args in reverse: arg n-1 first … arg 6 last (→ arg6 at [rsp]).
    let s: i32 = nargs - 1;
    while (s >= 6) {
        push[Instr](out, i_load(R_RAX(), R_RBP(), get[i32](aslot, s)));
        push[Instr](out, i_push(R_RAX()));
        s = s - 1;
    }
    // load args 0..min(nargs,6)-1 into their registers.
    let r: i32 = 0;
    let nreg: i32 = nargs;
    if (nreg > 6) { nreg = 6; }
    while (r < nreg) {
        push[Instr](out, i_load(arg_reg(r), R_RBP(), get[i32](aslot, r)));
        r = r + 1;
    }

    // ── sret: aggregate-by-value RETURN ──────────────────────────────────────
    // If the callee returns a struct/slice by value, reserve an N-word result
    // block in OUR frame and pass its address in R_R10() (the sret pointer — NOT
    // an arg reg, set LAST after the arg-reg loads so it isn't clobbered). The
    // callee writes its return aggregate there and returns that pointer in rax;
    // the call result we push is that block's address, treated exactly like any
    // other aggregate base downstream.
    let rt: []u8 = cg_fn_ret(syms, fname);
    let ret_agg: i32 = cg_type_is_agg(cg, rt);
    if (ret_agg == 1) {
        let rnf: i32 = cg_agg_words(cg, rt);
        let res: i32 = cg_slot_scratch_n(env, rnf);
        push[Instr](out, i_lea(R_R10(), R_RBP(), res));   // r10 = sret dest
    }
    push[Instr](out, i_call(lbl));
    // reclaim the stack args + padding we pushed (rsp += 8*pushed).
    if (pushed > 0) {
        push[Instr](out, i_add_imm(R_RSP(), (8 * pushed) as i64));
    }
    push[Instr](out, i_push(R_RAX()));   // result (scalar value, or sret block addr)
}

// ════════════════════════════════════════════════════════════════════════════
// SWITCH — tagged-union / enum / value switch, ported from codegen.zag.
//
// A switch dispatches on a DISCRIMINANT integer:
//   • UNION subject  → the tag word at [block+0] (the active variant's index).
//                      A `|cap|` capture binds cap = pointer to the payload at
//                      [block+8], typed as that variant's declared payload type.
//   • ENUM subject   → the member-index integer value.
//   • plain VALUE    → the integer value itself (arms match integer literals).
//
// We materialize the subject into a 2-word frame scratch block once, load the
// discriminant, then for each arm compare it to the arm's tag value(s) and
// branch to that arm's body; an `else` arm is the fallback. This mirrors the C
// backend's `switch (__sw.tag)` lowering but with explicit compares + jumps.
// ════════════════════════════════════════════════════════════════════════════

// Classify a switch by its first arm's first tag:
//   2 = union (tag matches a union variant), 1 = enum (matches an enum member),
//   0 = plain value switch. The union name / enum name is returned via *uname.
fn cg_switch_kind(cg: *Cg, sw: Switch, uname: *[]u8) i32 {
    if (len[SwitchArm](sw.arms) == 0) { uname.* = ""; return 0; }
    let a0: SwitchArm = get[SwitchArm](sw.arms, 0);
    if (len[[]u8](a0.tags) == 0) { uname.* = ""; return 0; }
    let tag0: []u8 = get[[]u8](a0.tags, 0);
    let un: []u8 = cg_union_name_for_tag(cg, tag0);
    if (un.len > 0) { uname.* = un; return 2; }
    let en: []u8 = cg_enum_name_for_member(cg, tag0);
    if (en.len > 0) { uname.* = en; return 1; }
    uname.* = "";
    return 0;
}

// The integer discriminant value an arm tag matches, given the switch kind and
// the union/enum name. For a value switch the tag is parsed as an integer.
fn cg_arm_tag_value(cg: *Cg, kind: i32, uname: []u8, tag: []u8) i32 {
    if (kind == 2) { return cg_union_variant_index(cg, uname, tag); }
    if (kind == 1) { return cg_enum_member_index(cg, uname, tag); }
    return cg_parse_i64(tag) as i32;
}

// Number of words a switch subject occupies in its scratch block: a union →
// its FULL size (8 tag + max payload, so an inline aggregate payload is fully
// captured); an enum/scalar → 1 (just the discriminant word).
fn cg_switch_subject_words(cg: *Cg, kind: i32, uname: []u8) i32 {
    if (kind == 2) {
        let w: i32 = cg_agg_words(cg, uname);
        if (w < 2) { return 2; }
        return w;
    }
    return 1;
}

// Materialize the switch subject into a fresh scratch block sized to the subject,
// returning the block's rbp displacement. A UNION subject has its FULL block
// copied (tag + inline payload, however large), so a `|cap|` capture pointing at
// blk+8 reaches every payload word. An enum/scalar value is stored at [block+0].
// The discriminant is always [block+0]; a union payload starts at block+8.
fn cg_switch_materialize(out: *ArrayList[Instr], sw: Switch, kind: i32, uname: []u8, env: *Env, syms: ArrayList[FnSym], cg: *Cg) i32 {
    let words: i32 = cg_switch_subject_words(cg, kind, uname);
    let blk: i32 = cg_slot_scratch_n(env, words);
    if (kind == 2) {
        // union: subject evaluates to its block address → copy ALL its words so
        // an inline aggregate payload (e.g. a struct with a []u8) is preserved.
        cg_lower_expr(out, sw.subject, env, syms, cg);     // pushes src block base
        push[Instr](out, i_pop(R_RSI()));                  // rsi = src base
        let k: i32 = 0;
        while (k < words) {
            push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
            push[Instr](out, i_store(R_RBP(), blk + 8 * k, R_RAX()));
            k = k + 1;
        }
    } else {
        // enum/scalar: the value IS the discriminant; store it at [blk+0].
        cg_lower_expr(out, sw.subject, env, syms, cg);     // pushes value
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_store(R_RBP(), blk + 0, R_RAX()));
    }
    return blk;
}

// Bind a union arm's `|cap|` capture: store a POINTER to the payload (blk+8) into
// a fresh local slot named `cap`, typed as the variant's declared payload type
// reachable via deref. We type the capture slot as a POINTER-to-payload so that
// `cap.*` / `cap.*.field` work; if the payload is itself a struct/union, the
// capture is a pointer to its block. Returns nothing.
fn cg_bind_capture(out: *ArrayList[Instr], cap: []u8, payty: []u8, blk: i32, env: *Env, cg: *Cg) void {
    // capture holds &payload; its type is *<payload-type> so deref reads it.
    let capty: []u8 = _zag_str_concat("*", cg_norm_type(payty));
    let cdisp: i32 = cg_slot_alloc_typed(env, cap, capty, 1);
    push[Instr](out, i_lea(R_RAX(), R_RBP(), blk + 8));   // rax = &payload
    push[Instr](out, i_store(R_RBP(), cdisp, R_RAX()));   // cap = &payload
}

// Lower a switch STATEMENT: dispatch to per-arm bodies, with an else fallback.
fn cg_lower_switch_stmt(out: *ArrayList[Instr], sw: Switch, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let uname: []u8 = "";
    let kind: i32 = cg_switch_kind(cg, sw, &uname);
    let blk: i32 = cg_switch_materialize(out, sw, kind, uname, env, syms, cg);
    let end_lbl: i32 = cg_fresh(cg);

    let na: i32 = len[SwitchArm](sw.arms);
    let ai: i32 = 0;
    while (ai < na) {
        let arm: SwitchArm = get[SwitchArm](sw.arms, ai);
        let body_lbl: i32 = cg_fresh(cg);
        let next_lbl: i32 = cg_fresh(cg);
        // if discriminant matches ANY of this arm's tags → jump to body.
        let ti: i32 = 0;
        while (ti < len[[]u8](arm.tags)) {
            let tv: i32 = cg_arm_tag_value(cg, kind, uname, get[[]u8](arm.tags, ti));
            push[Instr](out, i_load(R_RAX(), R_RBP(), blk + 0));   // discriminant
            push[Instr](out, i_cmp_imm(R_RAX(), tv as i64));
            push[Instr](out, i_je(body_lbl));
            ti = ti + 1;
        }
        push[Instr](out, i_jmp(next_lbl));        // no tag matched → next arm
        // body
        push[Instr](out, i_label(body_lbl));
        if (kind == 2 && arm.has_cap == 1) {
            let payty: []u8 = cg_union_payload_type(cg, uname, get[[]u8](arm.tags, 0));
            cg_bind_capture(out, arm.cap, payty, blk, env, cg);
        }
        cg_lower_block(out, arm.body, env, syms, cg);
        push[Instr](out, i_jmp(end_lbl));
        push[Instr](out, i_label(next_lbl));
        ai = ai + 1;
    }
    if (sw.has_els == 1) {
        cg_lower_block(out, sw.els_body, env, syms, cg);
    }
    push[Instr](out, i_label(end_lbl));
}

// Lower a switch EXPRESSION: each arm's body yields a value (its last/only expr);
// the chosen value is left PUSHED. Implemented as branch chain into a result slot.
fn cg_lower_switch_expr(out: *ArrayList[Instr], sw: Switch, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let uname: []u8 = "";
    let kind: i32 = cg_switch_kind(cg, sw, &uname);
    let blk: i32 = cg_switch_materialize(out, sw, kind, uname, env, syms, cg);
    let res: i32 = cg_slot_scratch(env);   // result slot
    let end_lbl: i32 = cg_fresh(cg);

    let na: i32 = len[SwitchArm](sw.arms);
    let ai: i32 = 0;
    while (ai < na) {
        let arm: SwitchArm = get[SwitchArm](sw.arms, ai);
        let body_lbl: i32 = cg_fresh(cg);
        let next_lbl: i32 = cg_fresh(cg);
        let ti: i32 = 0;
        while (ti < len[[]u8](arm.tags)) {
            let tv: i32 = cg_arm_tag_value(cg, kind, uname, get[[]u8](arm.tags, ti));
            push[Instr](out, i_load(R_RAX(), R_RBP(), blk + 0));
            push[Instr](out, i_cmp_imm(R_RAX(), tv as i64));
            push[Instr](out, i_je(body_lbl));
            ti = ti + 1;
        }
        push[Instr](out, i_jmp(next_lbl));
        push[Instr](out, i_label(body_lbl));
        if (kind == 2 && arm.has_cap == 1) {
            let payty: []u8 = cg_union_payload_type(cg, uname, get[[]u8](arm.tags, 0));
            cg_bind_capture(out, arm.cap, payty, blk, env, cg);
        }
        cg_lower_arm_value(out, arm.body, env, syms, cg);   // pushes arm value
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_store(R_RBP(), res, R_RAX()));
        push[Instr](out, i_jmp(end_lbl));
        push[Instr](out, i_label(next_lbl));
        ai = ai + 1;
    }
    if (sw.has_els == 1) {
        cg_lower_arm_value(out, sw.els_body, env, syms, cg);
        push[Instr](out, i_pop(R_RAX()));
        push[Instr](out, i_store(R_RBP(), res, R_RAX()));
    } else {
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_store(R_RBP(), res, R_RAX()));
    }
    push[Instr](out, i_label(end_lbl));
    push[Instr](out, i_load(R_RAX(), R_RBP(), res));
    push[Instr](out, i_push(R_RAX()));
}

// The VALUE of a switch-expression arm body: the body is a single value
// expression (an estmt holding it, or a bare expr). We lower that expression,
// leaving its result PUSHED. Statements other than a trailing value-expr in an
// arm body are not supported in expression position (rejected loudly).
fn cg_lower_arm_value(out: *ArrayList[Instr], body: ArrayList[*Node], env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    if (len[*Node](body) == 0) {
        push[Instr](out, i_mov_imm(R_RAX(), 0));
        push[Instr](out, i_push(R_RAX()));
        return;
    }
    let last: *Node = get[*Node](body, len[*Node](body) - 1);
    switch (last.*) {
        .estmt => |e| { cg_lower_expr(out, e.expr, env, syms, cg); }
        else => { cg_lower_expr(out, last, env, syms, cg); }
    }
}

// ── statement lowering ───────────────────────────────────────────────────────
fn cg_lower_stmt(out: *ArrayList[Instr], n: *Node, env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    switch (n.*) {
        .let_ => |l| {
            // Determine the local's coarse type: prefer the declared type, else
            // infer from the initializer (so `let p = P{..}` is struct-typed).
            let lty: []u8 = "";
            if (l.has_dty == 1) { lty = cg_norm_type(l.dty); }
            else { lty = cg_expr_type(l.expr, env, syms, cg); }

            if (cg_type_is_opt(cg, lty) == 1) {
                // OPTIONAL-typed let `let o: ?T = <null | value | optional>`.
                // Reserve the {has,val} block and write the optional INTO it.
                let onf: i32 = cg_agg_words(cg, lty);
                let obase: i32 = cg_slot_alloc_typed(env, l.name, lty, onf);
                let ops: i32 = cg_pslot_for_frame(out, obase, env);
                cg_store_opt_into(out, ops, 0, lty, l.expr, env, syms, cg);
            } else if (cg_type_is_agg(cg, lty) == 1) {
                // AGGREGATE-typed let (struct or []u8 slice). Reserve the N-word
                // INLINE block, then materialize the initializer DIRECTLY into it.
                let nf: i32 = cg_agg_words(cg, lty);
                let base: i32 = cg_slot_alloc_typed(env, l.name, lty, nf);
                let done: i32 = 0;
                switch (l.expr.*) {
                    .slit_ => |s| {
                        // struct OR union literal → write into the let block.
                        if (cg_type_is_slice(cg, lty) == 1) {
                            cg_err(cg, "native: []u8 let cannot take a struct literal");
                            done = 1;
                        } else if (cg_type_is_union(cg, lty) == 1) {
                            cg_store_union_lit(out, s, lty, base, env, syms, cg);
                            done = 1;
                        } else {
                            if (@strEq(cg_norm_type(cg_slit_sname(s)), lty) == 0) {
                                cg_err(cg, "native: struct let initializer type mismatch");
                            }
                            cg_store_struct_fields(out, s, base, env, syms, cg);
                            done = 1;
                        }
                    }
                    .slit => |sl| {
                        // string literal → write {ptr,len} of a []u8 DIRECTLY into
                        // the let block (no scratch). Rejected for a struct-typed let.
                        if (cg_type_is_slice(cg, lty) == 0) {
                            cg_err(cg, "native: struct let cannot take a string literal");
                        }
                        let off: i32 = cg_intern_str(cg, sl.text, 0);
                        let dlen: i32 = cg_decoded_len(sl.text);
                        push[Instr](out, i_mov_imm(R_RAX(), DATA_VBASE() + (off as i64)));
                        push[Instr](out, i_store(R_RBP(), base + 0, R_RAX()));
                        push[Instr](out, i_mov_imm(R_RAX(), dlen as i64));
                        push[Instr](out, i_store(R_RBP(), base + 8, R_RAX()));
                        done = 1;
                    }
                    else => { }
                }
                if (done == 0) {
                    // `let q: P = p;` / `let t: []u8 = s;` / `let p = mk();` —
                    // copy another aggregate VALUE (by address): lower the rvalue
                    // to its block base, then copy N words into the let block.
                    let rt: []u8 = cg_expr_type(l.expr, env, syms, cg);
                    if (cg_type_is_agg(cg, rt) == 0) {
                        cg_err(cg, "native: aggregate let needs an aggregate initializer");
                    } else {
                        cg_lower_expr(out, l.expr, env, syms, cg);   // pushes src base
                        push[Instr](out, i_pop(R_RSI()));            // rsi = src base
                        // copy nf words: dst = rbp+base+8*k, src = [rsi+8*k]
                        let k: i32 = 0;
                        while (k < nf) {
                            push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
                            push[Instr](out, i_store(R_RBP(), base + 8 * k, R_RAX()));
                            k = k + 1;
                        }
                    }
                }
            } else {
                // SCALAR let.
                cg_lower_expr(out, l.expr, env, syms, cg);
                push[Instr](out, i_pop(R_RAX()));
                // int → float widening: `let f: f64 = <int>` converts the integer
                // to a double (matches the C backend's implicit widening) so the
                // slot holds the value's bit pattern, not a raw integer bit pattern.
                if (cg_is_float_ty(lty) == 1) {
                    if (cg_is_float_ty(cg_expr_type(l.expr, env, syms, cg)) == 0) {
                        push[Instr](out, i_fsi2sd(R_XMM0(), R_RAX()));
                        push[Instr](out, i_fmovq_xg(R_RAX(), R_XMM0()));
                    }
                }
                let disp: i32 = cg_slot_alloc_typed(env, l.name, lty, 1);
                push[Instr](out, i_store(R_RBP(), disp, R_RAX()));
            }
        }
        .assign => |a| {
            // A field, pointer-field, or index assignment stores through a
            // computed address: `s.field = v` / `p.*.field = v` / `p.* = v` /
            // `p[i] = v` / `xs.*.data[i] = v`.
            let is_lval: i32 = 0;
            switch (a.target.*) {
                .fld => |_f| { is_lval = 1; }
                .idx => |_x| { is_lval = 1; }
                else => { }
            }
            if (is_lval == 1) {
                // If the assigned lvalue is an AGGREGATE (struct / []u8 / union /
                // ?T — e.g. `xs.data[i] = tok` for ArrayList[Tok]), the value is a
                // block ADDRESS and we must COPY its N words into the destination
                // block, not store a single word. A scalar lvalue stores one word.
                let tty: []u8 = cg_expr_type(a.target, env, syms, cg);
                if (cg_type_is_agg(cg, tty) == 1) {
                    let nf: i32 = cg_agg_words(cg, tty);
                    cg_lower_addr(out, a.target, env, syms, cg);   // pushes &target
                    cg_lower_expr(out, a.expr, env, syms, cg);     // pushes src base
                    push[Instr](out, i_pop(R_RSI()));              // rsi = src base
                    push[Instr](out, i_pop(R_RCX()));              // rcx = &target
                    let k: i32 = 0;
                    while (k < nf) {
                        push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
                        push[Instr](out, i_store(R_RCX(), 8 * k, R_RAX()));
                        k = k + 1;
                    }
                    return;
                }
                // BYTE-element lvalue (`xs.data[i] = b` for a *u8/*i8 array, or a
                // u8/i8 field): a full 8-byte store would clobber the 7 following
                // bytes of a packed buffer, so do a byte read-modify-write that
                // touches only the target byte.
                if (cg_elem_is_byte(tty) == 1) {
                    cg_lower_addr(out, a.target, env, syms, cg);   // pushes &target
                    cg_lower_expr(out, a.expr, env, syms, cg);     // pushes value
                    push[Instr](out, i_pop(R_RAX()));              // rax = new byte
                    push[Instr](out, i_pop(R_RSI()));              // rsi = &target byte
                    cg_rt_emit_store_byte(out, cg);                // [rsi].byte = rax(low)
                    return;
                }
                cg_lower_addr(out, a.target, env, syms, cg);   // pushes &target
                cg_lower_expr(out, a.expr, env, syms, cg);     // pushes value
                push[Instr](out, i_pop(R_RAX()));              // rax = value
                push[Instr](out, i_pop(R_RCX()));              // rcx = &target
                push[Instr](out, i_store(R_RCX(), 0, R_RAX()));
                return;
            }
            // target must be a plain Ident
            let tname: []u8 = "";
            let ok: i32 = 0;
            switch (a.target.*) {
                .id => |x| { tname = x.name; ok = 1; }
                else => { ok = 0; }
            }
            if (ok == 0) {
                cg_err(cg, "native: only simple identifier assignment supported");
                cg_lower_expr(out, a.expr, env, syms, cg);
                push[Instr](out, i_pop(R_RAX()));
            } else {
                // AGGREGATE target (`cur = next` where cur is a struct/[]u8/union/
                // ?T local): the value is a block ADDRESS. An INLINE local owns its
                // block → COPY the N words into it. A BY-REF local's slot holds a
                // pointer → re-point it at the new block (store the address). A
                // scalar target stores one word.
                let tty: []u8 = cg_slot_type(env.*, tname);
                if (cg_type_is_agg(cg, tty) == 1) {
                    let disp: i32 = cg_slot_find(env.*, tname);
                    if (disp == cg_not_found()) { disp = cg_slot_alloc_typed(env, tname, tty, cg_agg_words(cg, tty)); }
                    if (cg_slot_byref(env.*, tname) == 1) {
                        // by-ref: the slot aliases a block — re-point it.
                        cg_lower_expr(out, a.expr, env, syms, cg);   // pushes src block addr
                        push[Instr](out, i_pop(R_RAX()));
                        push[Instr](out, i_store(R_RBP(), disp, R_RAX()));
                    } else {
                        // inline: copy the N words into the local's own block.
                        let nf: i32 = cg_agg_words(cg, tty);
                        cg_lower_expr(out, a.expr, env, syms, cg);   // pushes src block addr
                        push[Instr](out, i_pop(R_RSI()));            // rsi = src base
                        let k: i32 = 0;
                        while (k < nf) {
                            push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
                            push[Instr](out, i_store(R_RBP(), disp + 8 * k, R_RAX()));
                            k = k + 1;
                        }
                    }
                    return;
                }
                cg_lower_expr(out, a.expr, env, syms, cg);
                push[Instr](out, i_pop(R_RAX()));
                let disp: i32 = cg_slot_find(env.*, tname);
                if (disp == cg_not_found()) {
                    // assignment to an as-yet-unseen name: allocate it
                    disp = cg_slot_alloc(env, tname);
                }
                push[Instr](out, i_store(R_RBP(), disp, R_RAX()));
            }
        }
        .ret => |r| {
            if (env.*.sret_disp != cg_not_found()) {
                // sret: this function returns an aggregate BY VALUE. The caller's
                // result-block pointer is saved at sret_disp (a pslot); write the
                // returned value directly into it via the unified machinery, then
                // return that pointer in rax. Handles struct/union literals (incl.
                // NESTED aggregate fields), string literals, optionals (?T), and
                // an aggregate VALUE expression (copied word-by-word).
                if (r.has_expr == 0) {
                    cg_err(cg, "native: aggregate-returning fn must return a value");
                    push[Instr](out, i_jmp(env.*.epilogue));
                    return;
                }
                let rty: []u8 = cg_norm_type(env.*.sret_type);
                let sps: i32 = env.*.sret_disp;
                if (cg_type_is_opt(cg, rty) == 1) {
                    // wrap into the ?T result block (null / value / optional).
                    cg_store_opt_into(out, sps, 0, rty, r.expr, env, syms, cg);
                } else {
                    let is_lit: i32 = 0;
                    switch (r.expr.*) { .slit_ => |_s| { is_lit = 1; } .slit => |_t| { is_lit = 1; } else => { } }
                    if (is_lit == 1) {
                        // a struct/union/string literal of the return type →
                        // materialize directly into the result block.
                        cg_materialize_into(out, sps, 0, r.expr, rty, env, syms, cg);
                    } else {
                        // aggregate VALUE expression → copy its N words.
                        let nf: i32 = env.*.sret_words;
                        cg_lower_expr(out, r.expr, env, syms, cg);   // pushes src base
                        push[Instr](out, i_pop(R_RSI()));            // rsi = src base
                        let k: i32 = 0;
                        while (k < nf) {
                            push[Instr](out, i_load(R_RAX(), R_RSI(), 8 * k));
                            cg_emit_store_at(out, sps, 8 * k);
                            k = k + 1;
                        }
                    }
                }
                push[Instr](out, i_load(R_RAX(), R_RBP(), env.*.sret_disp));  // rax = dest
                push[Instr](out, i_jmp(env.*.epilogue));
                return;
            }
            if (r.has_expr == 1) {
                cg_lower_expr(out, r.expr, env, syms, cg);
                push[Instr](out, i_pop(R_RAX()));
            } else {
                push[Instr](out, i_mov_imm(R_RAX(), 0));
            }
            push[Instr](out, i_jmp(env.*.epilogue));
        }
        .if_ => |iff| {
            let else_lbl: i32 = cg_fresh(cg);
            let end_lbl: i32 = cg_fresh(cg);
            cg_lower_expr(out, iff.cond, env, syms, cg);
            push[Instr](out, i_pop(R_RAX()));
            push[Instr](out, i_cmp_imm(R_RAX(), 0));
            push[Instr](out, i_je(else_lbl));
            cg_lower_block(out, iff.then_body, env, syms, cg);
            push[Instr](out, i_jmp(end_lbl));
            push[Instr](out, i_label(else_lbl));
            if (iff.has_els == 1) {
                cg_lower_block(out, iff.els_body, env, syms, cg);
            }
            push[Instr](out, i_label(end_lbl));
        }
        .while_ => |w| {
            let top: i32 = cg_fresh(cg);
            let end: i32 = cg_fresh(cg);
            push[Instr](out, i_label(top));
            cg_lower_expr(out, w.cond, env, syms, cg);
            push[Instr](out, i_pop(R_RAX()));
            push[Instr](out, i_cmp_imm(R_RAX(), 0));
            push[Instr](out, i_je(end));
            cg_lower_block(out, w.body, env, syms, cg);
            push[Instr](out, i_jmp(top));
            push[Instr](out, i_label(end));
        }
        .estmt => |e| {
            cg_lower_expr(out, e.expr, env, syms, cg);
            push[Instr](out, i_pop(R_RAX()));   // discard
        }
        .switch_ => |sw| {
            cg_lower_switch_stmt(out, sw, env, syms, cg);
        }
        else => {
            cg_err(cg, "native: unsupported statement kind");
        }
    }
}

fn cg_lower_block(out: *ArrayList[Instr], body: ArrayList[*Node], env: *Env, syms: ArrayList[FnSym], cg: *Cg) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        cg_lower_stmt(out, get[*Node](body, i), env, syms, cg);
        i = i + 1;
    }
}

// ── per-function lowering ────────────────────────────────────────────────────
fn cg_lower_fn(out: *ArrayList[Instr], f: FnDecl, lbl: i32, syms: ArrayList[FnSym], cg: *Cg) void {
    // Compute worst-case frame WORDS. Each param needs ONE word (a by-value
    // aggregate param holds the incoming POINTER, a scalar holds its value), plus
    // every distinct `let`/assign target sized by type (scalar 1, aggregate N),
    // plus SCRATCH for by-value aggregate call args / sret result blocks / string
    // literal {ptr,len} materializations (reserved by the scan). One extra word
    // is reserved up front for saving the incoming sret pointer if this function
    // itself returns an aggregate by value. The scan dedupes names and pre-counts
    // param names as "seen" so a `let` shadowing a param shares its slot.
    let seen: ArrayList[[]u8] = make[[]u8](8);
    let words: i32 = 0;
    let fret: []u8 = cg_norm_type(f.ret);
    let fn_ret_agg: i32 = cg_type_is_agg(cg, fret);
    if (fn_ret_agg == 1) { words = words + 1; }   // saved-sret-pointer slot

    // Build the scan's name→type and fn→ret maps so it can size aggregate flow.
    let sc: ScanCtx = ScanCtx{
        .seen = &seen, .words = &words,
        .names = make[[]u8](8), .types = make[[]u8](8),
        .fnames = make[[]u8](8), .frets = make[[]u8](8),
    };
    let si: i32 = 0;
    while (si < len[FnSym](syms)) {
        push[[]u8](&sc.fnames, get[FnSym](syms, si).name);
        push[[]u8](&sc.frets, get[FnSym](syms, si).ret);
        si = si + 1;
    }
    let pi: i32 = 0;
    while (pi < len[Param](f.params)) {
        let prm: Param = get[Param](f.params, pi);
        cg_scan_rectype(&sc, prm.name, cg_norm_type(prm.pty));   // param static type
        let _dup: i32 = cg_scan_seen(&seen, prm.name);
        words = words + 1;
        pi = pi + 1;
    }
    cg_scan_body(cg, &sc, f.body);
    let frame_size: i32 = cg_align16(8 * words);

    let epilogue: i32 = cg_fresh(cg);
    let env: Env = cg_env_new(epilogue);

    // ── prologue ──
    push[Instr](out, i_label(lbl));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), frame_size as i64));

    // ── save the incoming sret pointer (R_R10) for an aggregate-returning fn ──
    // The caller passed the result block's address in r10. r10 is clobberable by
    // the body, so spill it to a dedicated frame slot now; `return <agg>` reloads
    // it to write the result. (Allocated FIRST so its disp is stable.)
    if (fn_ret_agg == 1) {
        let sd: i32 = cg_slot_scratch(&env);
        env.sret_disp = sd;
        env.sret_words = cg_agg_words(cg, fret);
        env.sret_type = fret;
        push[Instr](out, i_store(R_RBP(), sd, R_R10()));
    }

    // ── spill incoming args (arg_reg(i)) into their local slots ──
    // Each param is recorded with its declared type. A by-value AGGREGATE param
    // (struct or []u8 slice) is BY-REF: the arg register holds a POINTER to the
    // caller's private copy, which we store as the param's single-word slot value
    // (byref=1) so `p.field`/`s.len`/`s[i]` dereference it. A `*P` pointer param
    // is an ordinary scalar (the address). MUTATION ISOLATION is guaranteed by
    // the caller having copied the aggregate before the call.
    let i: i32 = 0;
    while (i < len[Param](f.params)) {
        let p: Param = get[Param](f.params, i);
        let pty: []u8 = cg_norm_type(p.pty);
        let pdisp: i32 = 0;
        if (cg_type_is_agg(cg, pty) == 1) {
            pdisp = cg_slot_alloc_br(&env, p.name, pty, 1, 1);   // byref pointer
        } else {
            pdisp = cg_slot_alloc_typed(&env, p.name, pty, 1);
        }
        if (i < 6) {
            // args 0..5 arrive in registers rdi,rsi,rdx,rcx,r8,r9.
            push[Instr](out, i_store(R_RBP(), pdisp, arg_reg(i)));
        } else {
            // args 6+ arrive on the stack: at the `call`, arg6 was at [rsp], so
            // after `push rbp` the callee reads arg i at [rbp + 16 + 8*(i-6)]
            // ([rbp]=saved rbp, [rbp+8]=return addr, [rbp+16]=arg6, …).
            push[Instr](out, i_load(R_RAX(), R_RBP(), 16 + 8 * (i - 6)));
            push[Instr](out, i_store(R_RBP(), pdisp, R_RAX()));
        }
        i = i + 1;
    }

    // ── body ──
    cg_lower_block(out, f.body, &env, syms, cg);

    // ── epilogue ──
    // A void/no-explicit-return function falls through here with rax = whatever;
    // for an i32 main without a final return that's still well-defined (callers
    // of our acceptance set always return explicitly).
    push[Instr](out, i_label(epilogue));
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── OUTPUT support routine: __print_str(rsi=ptr, rdx=len) ────────────────────
// A leaf routine: write(1, rsi, rdx) via syscall, then ret. rsi/rdx already
// hold ptr/len (set by the caller). No prologue — it touches no stack memory.
//   mov rax, 1 (sys_write) ; mov rdi, 1 (fd=stdout) ; syscall ; ret
fn cg_emit_print_str(out: *ArrayList[Instr], lbl: i32) void {
    push[Instr](out, i_label(lbl));
    push[Instr](out, i_mov_imm(R_RAX(), 1));    // sys_write
    push[Instr](out, i_mov_imm(R_RDI(), 1));    // fd = stdout
    push[Instr](out, i_syscall());              // write(1, rsi, rdx)
    push[Instr](out, i_ret());
}

// ── OUTPUT support routine: __print_int(rdi=n) ───────────────────────────────
// Convert the SIGNED 64-bit n to decimal ASCII and write(1, buf, len).
//
// APPROACH (handles 0, negatives, and INT64_MIN with no overflow):
//   • Record sign (r10 = 1 if n<0).
//   • Peel digits least-significant-first: rem = n % 10 (signed; may be < 0 for
//     negative n), n = n / 10, digit = abs(rem) + '0'. PUSH each digit byte on
//     the CPU stack (so they accumulate most-significant-on-top), counting in
//     r9. n==0 is special-cased to push a single '0'.
//   • If negative, PUSH '-' last (so it pops first → leftmost char).
//   • POP r9 chars in order into a stack buffer at [rbp-64..], writing each as a
//     64-bit store at INCREASING addresses. A 64-bit store writes 8 bytes, but
//     because we write low→high addresses, every position's low byte (the real
//     digit) survives; only 7 garbage bytes trail PAST the last char, beyond
//     `len`, never emitted. The 64-byte buffer easily covers 20 digits + sign +
//     7 slack.
//   • write(1, buf, r9).
// We never negate the full magnitude (we abs each remainder instead), so
// INT64_MIN prints correctly. Uses callee-clobberable regs only; restores rsp
// via mov rsp,rbp so the pushed-digit scratch is reclaimed.
fn cg_emit_print_int(out: *ArrayList[Instr], lbl: i32, cg: *Cg) void {
    let l_pos:   i32 = cg_fresh(cg);   // skip neg-flag set when n >= 0
    let l_loop:  i32 = cg_fresh(cg);   // digit-peel loop top
    let l_zero:  i32 = cg_fresh(cg);   // n == 0 special case
    let l_after: i32 = cg_fresh(cg);   // after digit collection
    let l_nosign:i32 = cg_fresh(cg);   // skip '-' when non-negative
    let l_wtop:  i32 = cg_fresh(cg);   // pop+store loop top
    let l_wdone: i32 = cg_fresh(cg);   // pop+store loop done

    push[Instr](out, i_label(lbl));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 64));        // 64-byte digit buffer

    push[Instr](out, i_mov_rr(R_RAX(), R_RDI()));    // rax = working value n
    push[Instr](out, i_mov_imm(R_R10(), 0));         // r10 = sign flag (0)
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jge(l_pos));
    push[Instr](out, i_mov_imm(R_R10(), 1));         // n < 0 → sign = 1
    push[Instr](out, i_label(l_pos));

    push[Instr](out, i_mov_imm(R_R9(), 0));          // r9 = digit count
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_zero));                  // n == 0 → push '0'

    // digit-peel loop: while rax != 0 { rcx=10; cqo/idiv → rax=quot rdx=rem;
    //                                   r8 = abs(rem)+'0'; push r8; r9++ }
    push[Instr](out, i_label(l_loop));
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_after));
    push[Instr](out, i_mov_imm(R_RCX(), 10));
    push[Instr](out, i_idiv(R_RCX()));               // rax=quotient, rdx=remainder
    push[Instr](out, i_mov_rr(R_R8(), R_RDX()));     // r8 = remainder
    let l_pdig: i32 = cg_fresh(cg);
    push[Instr](out, i_cmp_imm(R_R8(), 0));
    push[Instr](out, i_jge(l_pdig));
    push[Instr](out, i_neg(R_R8()));                 // abs(remainder)
    push[Instr](out, i_label(l_pdig));
    push[Instr](out, i_add_imm(R_R8(), 48));         // + '0'
    push[Instr](out, i_push(R_R8()));                // push digit char
    push[Instr](out, i_add_imm(R_R9(), 1));          // r9++
    push[Instr](out, i_jmp(l_loop));

    push[Instr](out, i_label(l_zero));
    push[Instr](out, i_mov_imm(R_R8(), 48));         // '0'
    push[Instr](out, i_push(R_R8()));
    push[Instr](out, i_mov_imm(R_R9(), 1));

    push[Instr](out, i_label(l_after));
    // if negative, push '-' (45) LAST so it pops FIRST (leftmost char)
    push[Instr](out, i_cmp_imm(R_R10(), 0));
    push[Instr](out, i_je(l_nosign));
    push[Instr](out, i_mov_imm(R_R8(), 45));         // '-'
    push[Instr](out, i_push(R_R8()));
    push[Instr](out, i_add_imm(R_R9(), 1));
    push[Instr](out, i_label(l_nosign));

    // pop r9 chars into buffer at [rbp-64], increasing addresses. The buffer
    // start is the fixed displacement -64, so we re-`lea` it for the syscall
    // rather than tying up an extra register (the ISA exposes no r11).
    push[Instr](out, i_lea(R_RSI(), R_RBP(), 0 - 64));   // rsi = write ptr
    push[Instr](out, i_mov_rr(R_RCX(), R_R9()));         // rcx = remaining count
    push[Instr](out, i_label(l_wtop));
    push[Instr](out, i_cmp_imm(R_RCX(), 0));
    push[Instr](out, i_je(l_wdone));
    push[Instr](out, i_pop(R_RAX()));                    // next char (MS-first)
    push[Instr](out, i_store(R_RSI(), 0, R_RAX()));      // [rsi] = char (low byte)
    push[Instr](out, i_add_imm(R_RSI(), 1));             // ptr++
    push[Instr](out, i_sub_imm(R_RCX(), 1));             // count--
    push[Instr](out, i_jmp(l_wtop));
    push[Instr](out, i_label(l_wdone));

    // write(1, buf, r9). r9 still holds len; re-lea the buffer start.
    push[Instr](out, i_mov_imm(R_RAX(), 1));             // sys_write
    push[Instr](out, i_mov_imm(R_RDI(), 1));             // fd = stdout
    push[Instr](out, i_lea(R_RSI(), R_RBP(), 0 - 64));   // buf
    push[Instr](out, i_mov_rr(R_RDX(), R_R9()));         // len
    push[Instr](out, i_syscall());

    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── OUTPUT support routine: __print_f64(rdi = double bit pattern) ─────────────
// Converts a 64-bit IEEE-754 double to a decimal string in the SAME format the C
// backend uses (printf "%g", 6 significant digits) and write(1,..)s it with a
// trailing '\n'. Used for both print_f64 and print_f32 (f32 is held as a double
// internally). Algorithm (all in SSE scalar double + integer ops, no libc):
//   • split sign; abs the bit pattern; emit '-' / handle ±0.
//   • normalise |V| into [1,10) by repeated /10 or *10, tracking exp10.
//   • D = trunc(V*1e5 + 0.5)  → exactly 6 significant digits (carry-fix if 1e6).
//   • peel the 6 digits into per-slot frame bytes; find the last nonzero.
//   • print FIXED for exp10 ∈ [-4,5], else SCIENTIFIC (d.ddddde±NN) — matching
//     %g's threshold and trailing-zero stripping.
// Cross-checked bit-for-bit against glibc %g on 44 values (see report). The FP
// normalisation can perturb the last sig digit for extreme exponents — an
// acceptable, documented round-1 limit (the C backend stays available).
fn PF_TEN()  i64 { return 4621819117588971520; }   // 10.0
fn PF_ONE()  i64 { return 4607182418800017408; }   //  1.0
fn PF_HALF() i64 { return 4602678819172646912; }   //  0.5
fn PF_E5()   i64 { return 4681608360884174848; }   //  100000.0

// append the literal byte `c` to [rsi], advancing the write pointer rsi.
fn pf_putc(out: *ArrayList[Instr], c: i32) void {
    push[Instr](out, i_mov_imm(R_RAX(), c as i64));
    push[Instr](out, i_store(R_RSI(), 0, R_RAX()));   // low byte → buffer
    push[Instr](out, i_add_imm(R_RSI(), 1));
}
// append the digit byte at [r10] (a clean 0..9 value in its own 8-byte slot) as
// ASCII; advances rsi only. Touches ONLY rax (the loop counter rcx / pointer r10
// must survive), so no masking — the slot holds exactly the digit.
fn pf_put_ds(out: *ArrayList[Instr]) void {
    push[Instr](out, i_load(R_RAX(), R_R10(), 0));
    push[Instr](out, i_add_imm(R_RAX(), 48));         // + '0'
    push[Instr](out, i_store(R_RSI(), 0, R_RAX()));
    push[Instr](out, i_add_imm(R_RSI(), 1));
}

fn cg_emit_print_f64(out: *ArrayList[Instr], lbl: i32, cg: *Cg) void {
    let l_nosign:   i32 = cg_fresh(cg);
    let l_nonzero:  i32 = cg_fresh(cg);
    let l_finish:   i32 = cg_fresh(cg);
    let l_nhi:      i32 = cg_fresh(cg);
    let l_nhi_done: i32 = cg_fresh(cg);
    let l_nlo:      i32 = cg_fresh(cg);
    let l_nlo_done: i32 = cg_fresh(cg);
    let l_dok:      i32 = cg_fresh(cg);
    let l_last:     i32 = cg_fresh(cg);
    let l_last_done:i32 = cg_fresh(cg);
    let l_sci:      i32 = cg_fresh(cg);
    let l_fixed_neg:i32 = cg_fresh(cg);
    let l_fi_int:   i32 = cg_fresh(cg);
    let l_fi_int_d: i32 = cg_fresh(cg);
    let l_fi_frac:  i32 = cg_fresh(cg);
    let l_fixdone:  i32 = cg_fresh(cg);
    let l_nz:       i32 = cg_fresh(cg);
    let l_nz_done:  i32 = cg_fresh(cg);
    let l_ndig:     i32 = cg_fresh(cg);
    let l_scifrac:  i32 = cg_fresh(cg);
    let l_sci_e:    i32 = cg_fresh(cg);
    let l_sci_eneg: i32 = cg_fresh(cg);
    let l_sci_emit: i32 = cg_fresh(cg);
    let l_sci_ebig: i32 = cg_fresh(cg);
    let l_sci_peel: i32 = cg_fresh(cg);
    let l_sci_peeld:i32 = cg_fresh(cg);
    let l_sci_pop:  i32 = cg_fresh(cg);

    push[Instr](out, i_label(lbl));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 128));

    // write pointer rsi = &OUTBUF (rbp-128). DS digit slots live at rbp-64+8*i.
    push[Instr](out, i_lea(R_RSI(), R_RBP(), 0 - 128));

    // sign: if bits < 0 (bit63 set) emit '-'. Keep the bit pattern in rdi across
    // the '-' emit (pf_putc clobbers rax), then abs it into rax.
    push[Instr](out, i_cmp_imm(R_RDI(), 0));
    push[Instr](out, i_jge(l_nosign));
    pf_putc(out, 45);                                   // '-'
    push[Instr](out, i_label(l_nosign));
    // abs bits = bits & 0x7FFFFFFFFFFFFFFF
    push[Instr](out, i_mov_rr(R_RAX(), R_RDI()));
    push[Instr](out, i_mov_imm(R_RCX(), cg_i64_max()));
    push[Instr](out, i_and(R_RAX(), R_RCX()));
    // zero?
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jne(l_nonzero));
    pf_putc(out, 48);                                   // '0'
    push[Instr](out, i_jmp(l_finish));

    push[Instr](out, i_label(l_nonzero));
    push[Instr](out, i_fmovq_gx(R_XMM0(), R_RAX()));    // xmm0 = |V|
    push[Instr](out, i_mov_imm(R_R8(), 0));             // r8 = exp10
    push[Instr](out, i_mov_imm(R_RAX(), PF_TEN()));
    push[Instr](out, i_fmovq_gx(R_XMM1(), R_RAX()));    // xmm1 = 10.0
    // while V >= 10: V/=10; exp10++
    push[Instr](out, i_label(l_nhi));
    push[Instr](out, i_fucomi(R_XMM0(), R_XMM1()));
    push[Instr](out, i_setcc(R_RAX(), CC_AE()));        // V>=10 ?
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_nhi_done));
    push[Instr](out, i_fdiv(R_XMM0(), R_XMM1()));
    push[Instr](out, i_add_imm(R_R8(), 1));
    push[Instr](out, i_jmp(l_nhi));
    push[Instr](out, i_label(l_nhi_done));
    push[Instr](out, i_mov_imm(R_RAX(), PF_ONE()));
    push[Instr](out, i_fmovq_gx(R_XMM2(), R_RAX()));    // xmm2 = 1.0
    // while V < 1: V*=10; exp10--
    push[Instr](out, i_label(l_nlo));
    push[Instr](out, i_fucomi(R_XMM0(), R_XMM2()));
    push[Instr](out, i_setcc(R_RAX(), CC_B()));         // V<1 ?
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_nlo_done));
    push[Instr](out, i_fmul(R_XMM0(), R_XMM1()));
    push[Instr](out, i_sub_imm(R_R8(), 1));
    push[Instr](out, i_jmp(l_nlo));
    push[Instr](out, i_label(l_nlo_done));

    // D = trunc(V*1e5 + 0.5)
    push[Instr](out, i_mov_imm(R_RAX(), PF_E5()));
    push[Instr](out, i_fmovq_gx(R_XMM3(), R_RAX()));
    push[Instr](out, i_fmul(R_XMM0(), R_XMM3()));
    push[Instr](out, i_mov_imm(R_RAX(), PF_HALF()));
    push[Instr](out, i_fmovq_gx(R_XMM3(), R_RAX()));
    push[Instr](out, i_fadd(R_XMM0(), R_XMM3()));
    push[Instr](out, i_ftsd2si(R_RAX(), R_XMM0()));     // rax = D
    // carry fix: if D >= 1000000 → D/=10; exp10++
    push[Instr](out, i_cmp_imm(R_RAX(), 1000000));
    push[Instr](out, i_jl(l_dok));
    push[Instr](out, i_mov_imm(R_RCX(), 10));
    push[Instr](out, i_idiv(R_RCX()));                  // rax = D/10
    push[Instr](out, i_add_imm(R_R8(), 1));
    push[Instr](out, i_label(l_dok));

    // peel the 6 digits MSB-last into DS slots ds[5..0] (8-byte slots, no overlap).
    push[Instr](out, i_mov_imm(R_RCX(), 10));
    push[Instr](out, i_idiv(R_RCX())); push[Instr](out, i_store(R_RBP(), 0 - 64 + 40, R_RDX()));  // ds[5]
    push[Instr](out, i_idiv(R_RCX())); push[Instr](out, i_store(R_RBP(), 0 - 64 + 32, R_RDX()));  // ds[4]
    push[Instr](out, i_idiv(R_RCX())); push[Instr](out, i_store(R_RBP(), 0 - 64 + 24, R_RDX()));  // ds[3]
    push[Instr](out, i_idiv(R_RCX())); push[Instr](out, i_store(R_RBP(), 0 - 64 + 16, R_RDX()));  // ds[2]
    push[Instr](out, i_idiv(R_RCX())); push[Instr](out, i_store(R_RBP(), 0 - 64 + 8,  R_RDX()));  // ds[1]
    push[Instr](out, i_idiv(R_RCX())); push[Instr](out, i_store(R_RBP(), 0 - 64 + 0,  R_RDX()));  // ds[0]

    // last = highest index 0..5 with ds[i] != 0 (ds[0] is always nonzero).
    push[Instr](out, i_mov_imm(R_RCX(), 5));
    push[Instr](out, i_lea(R_R10(), R_RBP(), 0 - 64 + 40));   // &ds[5]
    push[Instr](out, i_label(l_last));
    push[Instr](out, i_cmp_imm(R_RCX(), 0));
    push[Instr](out, i_jle(l_last_done));
    push[Instr](out, i_load(R_RAX(), R_R10(), 0));
    push[Instr](out, i_mov_imm(R_RDX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RDX()));
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jne(l_last_done));
    push[Instr](out, i_sub_imm(R_RCX(), 1));
    push[Instr](out, i_sub_imm(R_R10(), 8));
    push[Instr](out, i_jmp(l_last));
    push[Instr](out, i_label(l_last_done));
    push[Instr](out, i_mov_rr(R_RDI(), R_RCX()));            // rdi = last

    // branch: scientific if exp10 < -4 or exp10 >= 6, else fixed.
    push[Instr](out, i_cmp_imm(R_R8(), 0 - 4));
    push[Instr](out, i_jl(l_sci));
    push[Instr](out, i_cmp_imm(R_R8(), 6));
    push[Instr](out, i_jge(l_sci));
    // FIXED notation.
    push[Instr](out, i_cmp_imm(R_R8(), 0));
    push[Instr](out, i_jl(l_fixed_neg));
    // exp10 >= 0: integer part ds[0..exp10]
    push[Instr](out, i_lea(R_R10(), R_RBP(), 0 - 64));       // &ds[0]
    push[Instr](out, i_mov_imm(R_RCX(), 0));
    push[Instr](out, i_label(l_fi_int));
    push[Instr](out, i_cmp(R_RCX(), R_R8()));
    push[Instr](out, i_jg(l_fi_int_d));
    pf_put_ds(out);
    push[Instr](out, i_add_imm(R_R10(), 8));
    push[Instr](out, i_add_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_fi_int));
    push[Instr](out, i_label(l_fi_int_d));
    // fractional ds[exp10+1..last] iff last > exp10
    push[Instr](out, i_cmp(R_RDI(), R_R8()));
    push[Instr](out, i_jle(l_fixdone));
    pf_putc(out, 46);                                       // '.'
    push[Instr](out, i_mov_rr(R_RCX(), R_R8()));
    push[Instr](out, i_add_imm(R_RCX(), 1));                // rcx = exp10+1 (r10 already there)
    push[Instr](out, i_label(l_fi_frac));
    push[Instr](out, i_cmp(R_RCX(), R_RDI()));
    push[Instr](out, i_jg(l_fixdone));
    pf_put_ds(out);
    push[Instr](out, i_add_imm(R_R10(), 8));
    push[Instr](out, i_add_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_fi_frac));
    push[Instr](out, i_label(l_fixdone));
    push[Instr](out, i_jmp(l_finish));

    // FIXED, exp10 < 0: "0." + (-exp10-1) zeros + ds[0..last]
    push[Instr](out, i_label(l_fixed_neg));
    pf_putc(out, 48);                                       // '0'
    pf_putc(out, 46);                                       // '.'
    push[Instr](out, i_mov_imm(R_RCX(), 0));
    push[Instr](out, i_sub(R_RCX(), R_R8()));               // rcx = -exp10
    push[Instr](out, i_sub_imm(R_RCX(), 1));                // rcx = -exp10-1
    push[Instr](out, i_label(l_nz));
    push[Instr](out, i_cmp_imm(R_RCX(), 0));
    push[Instr](out, i_jle(l_nz_done));
    pf_putc(out, 48);                                       // leading '0'
    push[Instr](out, i_sub_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_nz));
    push[Instr](out, i_label(l_nz_done));
    push[Instr](out, i_lea(R_R10(), R_RBP(), 0 - 64));      // &ds[0]
    push[Instr](out, i_mov_imm(R_RCX(), 0));
    push[Instr](out, i_label(l_ndig));
    push[Instr](out, i_cmp(R_RCX(), R_RDI()));
    push[Instr](out, i_jg(l_finish));
    pf_put_ds(out);
    push[Instr](out, i_add_imm(R_R10(), 8));
    push[Instr](out, i_add_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_ndig));

    // SCIENTIFIC: ds[0] '.' ds[1..last] 'e' sign exp(min 2 digits)
    push[Instr](out, i_label(l_sci));
    push[Instr](out, i_lea(R_R10(), R_RBP(), 0 - 64));      // &ds[0]
    pf_put_ds(out);
    push[Instr](out, i_add_imm(R_R10(), 8));                // &ds[1]
    push[Instr](out, i_cmp_imm(R_RDI(), 1));
    push[Instr](out, i_jl(l_sci_e));
    pf_putc(out, 46);                                       // '.'
    push[Instr](out, i_mov_imm(R_RCX(), 1));
    push[Instr](out, i_label(l_scifrac));
    push[Instr](out, i_cmp(R_RCX(), R_RDI()));
    push[Instr](out, i_jg(l_sci_e));
    pf_put_ds(out);
    push[Instr](out, i_add_imm(R_R10(), 8));
    push[Instr](out, i_add_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_scifrac));
    push[Instr](out, i_label(l_sci_e));
    pf_putc(out, 101);                                      // 'e'
    push[Instr](out, i_cmp_imm(R_R8(), 0));
    push[Instr](out, i_jl(l_sci_eneg));
    pf_putc(out, 43);                                       // '+'
    push[Instr](out, i_mov_rr(R_RAX(), R_R8()));            // e = exp10
    push[Instr](out, i_jmp(l_sci_emit));
    push[Instr](out, i_label(l_sci_eneg));
    pf_putc(out, 45);                                       // '-'
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_sub(R_RAX(), R_R8()));               // e = -exp10
    push[Instr](out, i_label(l_sci_emit));
    push[Instr](out, i_cmp_imm(R_RAX(), 10));
    push[Instr](out, i_jge(l_sci_ebig));
    // e in [0,9]: "0" + digit.  Save e in rdx (pf_putc clobbers rax).
    push[Instr](out, i_mov_rr(R_RDX(), R_RAX()));
    pf_putc(out, 48);                                   // '0'
    push[Instr](out, i_mov_rr(R_RAX(), R_RDX()));
    push[Instr](out, i_add_imm(R_RAX(), 48));
    push[Instr](out, i_store(R_RSI(), 0, R_RAX()));
    push[Instr](out, i_add_imm(R_RSI(), 1));
    push[Instr](out, i_jmp(l_finish));
    // e >= 10: peel onto the CPU stack, then pop MSB-first.
    push[Instr](out, i_label(l_sci_ebig));
    push[Instr](out, i_mov_imm(R_RCX(), 0));               // count
    push[Instr](out, i_label(l_sci_peel));
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_sci_peeld));
    push[Instr](out, i_push(R_RCX()));                     // save count (idiv uses rdx:rax)
    push[Instr](out, i_mov_imm(R_R10(), 10));
    push[Instr](out, i_idiv(R_R10()));                    // rax=q rdx=rem
    push[Instr](out, i_add_imm(R_RDX(), 48));
    push[Instr](out, i_pop(R_RCX()));
    push[Instr](out, i_push(R_RDX()));                    // push digit char
    push[Instr](out, i_add_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_sci_peel));
    push[Instr](out, i_label(l_sci_peeld));
    push[Instr](out, i_label(l_sci_pop));
    push[Instr](out, i_cmp_imm(R_RCX(), 0));
    push[Instr](out, i_je(l_finish));
    push[Instr](out, i_pop(R_RAX()));
    push[Instr](out, i_store(R_RSI(), 0, R_RAX()));
    push[Instr](out, i_add_imm(R_RSI(), 1));
    push[Instr](out, i_sub_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_sci_pop));

    // FINISH: append '\n', write(1, OUTBUF, len), return.
    push[Instr](out, i_label(l_finish));
    pf_putc(out, 10);                                      // '\n'
    push[Instr](out, i_mov_rr(R_RDX(), R_RSI()));
    push[Instr](out, i_lea(R_RAX(), R_RBP(), 0 - 128));
    push[Instr](out, i_sub(R_RDX(), R_RAX()));             // len = rsi - bufstart
    push[Instr](out, i_mov_imm(R_RAX(), 1));               // sys_write
    push[Instr](out, i_mov_imm(R_RDI(), 1));               // fd = stdout
    push[Instr](out, i_lea(R_RSI(), R_RBP(), 0 - 128));    // buf
    push[Instr](out, i_syscall());
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── HEAP support routine: __alloc(rdi = size in bytes) -> rax = ptr ───────────
// Allocates a fresh region via the mmap(2) syscall — one mmap per allocation,
// no shared writable segment, no libc. The kernel rounds the length up to a page
// (4 KiB), so each allocation wastes up to a page; a bump allocator would amortize
// this but needs a writable data segment we don't carve here, so we keep the
// simple, 100%-correct one-mmap-per-alloc model (documented page waste). On
// failure mmap returns a small negative errno in rax; we do NOT mask it (callers
// in this subset allocate tiny structs that never fail in practice) — the value
// is propagated verbatim, never silently turned into a bogus pointer.
//
// x86-64 mmap ABI:  rax=9 ; rdi=0 (addr=NULL, kernel chooses) ;
//   rsi=length (our requested size) ; rdx=3 (PROT_READ|PROT_WRITE) ;
//   r10=0x22 (MAP_PRIVATE|MAP_ANONYMOUS) ; r8=-1 (fd) ; r9=0 (offset) ; syscall.
// NOTE the kernel uses r10 for arg4 (NOT rcx). Leaf routine, no stack frame.
fn cg_emit_alloc(out: *ArrayList[Instr], lbl: i32) void {
    push[Instr](out, i_label(lbl));
    push[Instr](out, i_mov_rr(R_RSI(), R_RDI()));     // rsi = length (requested size)
    push[Instr](out, i_mov_imm(R_RAX(), 9));          // sys_mmap
    push[Instr](out, i_mov_imm(R_RDI(), 0));          // addr = NULL
    push[Instr](out, i_mov_imm(R_RDX(), 3));          // PROT_READ|PROT_WRITE
    push[Instr](out, i_mov_imm(R_R10(), 34));         // MAP_PRIVATE|MAP_ANONYMOUS (0x22)
    push[Instr](out, i_mov_imm(R_R8(), 0 - 1));       // fd = -1
    push[Instr](out, i_mov_imm(R_R9(), 0));           // offset = 0
    push[Instr](out, i_syscall());                    // rax = mapped ptr
    push[Instr](out, i_ret());
}

// ── support routine: __streq(rdi=&a, rsi=&b) -> rax = 1 if equal else 0 ───────
// a and b are []u8 slice blocks { ptr@0, len@8 }. Equal iff lengths match AND
// every byte matches. Leaf routine; uses only clobberable regs (rax,rcx,rdx,r8,
// r9,r10). Algorithm:
//   r8  = a.len = [rdi+8] ; r9 = b.len = [rsi+8]
//   if r8 != r9 → return 0
//   rdi = a.ptr = [rdi+0] ; rsi = b.ptr = [rsi+0] ; rcx = 0 (index)
//   loop: if rcx >= r8 → return 1
//         r10 = byte a.ptr[rcx] (8-byte load masked to 1 byte)
//         rdx = byte b.ptr[rcx]
//         if r10 != rdx → return 0 ; rcx++ ; loop
fn cg_emit_streq(out: *ArrayList[Instr], lbl: i32, cg: *Cg) void {
    let l_loop:  i32 = cg_fresh(cg);
    let l_eq:    i32 = cg_fresh(cg);
    let l_ne:    i32 = cg_fresh(cg);
    let l_body:  i32 = cg_fresh(cg);

    push[Instr](out, i_label(lbl));
    push[Instr](out, i_load(R_R8(), R_RDI(), 8));     // r8 = a.len
    push[Instr](out, i_load(R_R9(), R_RSI(), 8));     // r9 = b.len
    push[Instr](out, i_cmp(R_R8(), R_R9()));
    push[Instr](out, i_jne(l_ne));                    // lengths differ → not equal
    push[Instr](out, i_load(R_RDI(), R_RDI(), 0));    // rdi = a.ptr
    push[Instr](out, i_load(R_RSI(), R_RSI(), 0));    // rsi = b.ptr
    push[Instr](out, i_mov_imm(R_RCX(), 0));          // rcx = i = 0

    push[Instr](out, i_label(l_loop));
    push[Instr](out, i_cmp(R_RCX(), R_R8()));
    push[Instr](out, i_jge(l_eq));                    // i >= len → all matched
    // r10 = a.ptr + i ; load byte
    push[Instr](out, i_mov_rr(R_R10(), R_RDI()));
    push[Instr](out, i_add(R_R10(), R_RCX()));
    push[Instr](out, i_load(R_R10(), R_R10(), 0));
    push[Instr](out, i_mov_imm(R_RDX(), 255));
    push[Instr](out, i_and(R_R10(), R_RDX()));        // r10 = a byte
    // rdx = b.ptr + i ; load byte
    push[Instr](out, i_mov_rr(R_RDX(), R_RSI()));
    push[Instr](out, i_add(R_RDX(), R_RCX()));
    push[Instr](out, i_load(R_RDX(), R_RDX(), 0));
    push[Instr](out, i_push(R_R9()));                 // (free a scratch reg via stack)
    push[Instr](out, i_mov_imm(R_R9(), 255));
    push[Instr](out, i_and(R_RDX(), R_R9()));         // rdx = b byte
    push[Instr](out, i_pop(R_R9()));
    push[Instr](out, i_cmp(R_R10(), R_RDX()));
    push[Instr](out, i_jne(l_ne));                    // bytes differ → not equal
    push[Instr](out, i_add_imm(R_RCX(), 1));          // i++
    push[Instr](out, i_jmp(l_loop));
    let _unused: i32 = l_body;

    push[Instr](out, i_label(l_eq));
    push[Instr](out, i_mov_imm(R_RAX(), 1));
    push[Instr](out, i_ret());
    push[Instr](out, i_label(l_ne));
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_ret());
}

// ── support routine: __malloc(rdi=n) -> rax = ptr (with size header) ──────────
// mmap(n+8); store n at [base+0]; return base+8. The 8-byte header lets
// __realloc know the old size. Calls __alloc; the pushed n survives the call
// (mmap touches no caller stack).
fn cg_emit_malloc(out: *ArrayList[Instr], lbl: i32, cg: *Cg) void {
    push[Instr](out, i_label(lbl));
    push[Instr](out, i_push(R_RDI()));               // save n
    push[Instr](out, i_add_imm(R_RDI(), 8));         // request n + 8 (header)
    push[Instr](out, i_call(cg.*.al_lbl));           // rax = mmap base
    push[Instr](out, i_pop(R_RCX()));                // rcx = n
    push[Instr](out, i_store(R_RAX(), 0, R_RCX()));  // [base] = n
    push[Instr](out, i_add_imm(R_RAX(), 8));         // ptr = base + 8
    push[Instr](out, i_ret());
}

// ── support routine: __realloc(rdi=oldptr, rsi=newsize) -> rax = newptr ───────
// Allocate a fresh header'd region of `newsize`, copy min(oldsize, newsize)
// bytes (rounded UP to 8-byte words; both regions are page-rounded mmaps so the
// ≤7-byte over-copy stays in-bounds), and return the new user pointer. The old
// region is left mapped (no unmap — documented small leak). oldsize is read from
// the header at [oldptr-8].
fn cg_emit_realloc(out: *ArrayList[Instr], lbl: i32, cg: *Cg) void {
    let l_min:  i32 = cg_fresh(cg);
    let l_loop: i32 = cg_fresh(cg);
    let l_done: i32 = cg_fresh(cg);

    push[Instr](out, i_label(lbl));
    push[Instr](out, i_push(R_RDI()));               // save oldptr
    push[Instr](out, i_push(R_RSI()));               // save newsize
    push[Instr](out, i_mov_rr(R_RDI(), R_RSI()));    // rdi = newsize
    push[Instr](out, i_add_imm(R_RDI(), 8));         // + header
    push[Instr](out, i_call(cg.*.al_lbl));           // rax = new mmap base
    push[Instr](out, i_pop(R_RSI()));                // rsi = newsize
    push[Instr](out, i_store(R_RAX(), 0, R_RSI()));  // [newbase] = newsize
    push[Instr](out, i_add_imm(R_RAX(), 8));         // rax = newptr (past header)
    push[Instr](out, i_pop(R_RDI()));                // rdi = oldptr
    push[Instr](out, i_load(R_R8(), R_RDI(), 0 - 8));// r8 = oldsize = [oldptr-8]
    // rcx = min(oldsize, newsize)
    push[Instr](out, i_mov_rr(R_RCX(), R_R8()));     // rcx = oldsize
    push[Instr](out, i_cmp(R_RCX(), R_RSI()));
    push[Instr](out, i_jle(l_min));                  // oldsize <= newsize → keep
    push[Instr](out, i_mov_rr(R_RCX(), R_RSI()));    // else rcx = newsize
    push[Instr](out, i_label(l_min));
    // copy rcx bytes as 8-byte words: r9 = byte offset, step 8.
    push[Instr](out, i_mov_imm(R_R9(), 0));
    push[Instr](out, i_label(l_loop));
    push[Instr](out, i_cmp(R_R9(), R_RCX()));
    push[Instr](out, i_jge(l_done));                 // r9 >= count → done
    // r10 = [oldptr + r9] (8 bytes)
    push[Instr](out, i_mov_rr(R_R10(), R_RDI()));
    push[Instr](out, i_add(R_R10(), R_R9()));
    push[Instr](out, i_load(R_R10(), R_R10(), 0));
    // [newptr + r9] = r10  — newptr is rax; use rdx as the dest base scratch
    push[Instr](out, i_mov_rr(R_RDX(), R_RAX()));
    push[Instr](out, i_add(R_RDX(), R_R9()));
    push[Instr](out, i_store(R_RDX(), 0, R_R10()));
    push[Instr](out, i_add_imm(R_R9(), 8));          // next word
    push[Instr](out, i_jmp(l_loop));
    push[Instr](out, i_label(l_done));
    push[Instr](out, i_ret());                        // rax = newptr
}

// ════════════════════════════════════════════════════════════════════════════
// NATIVE SYSCALL RUNTIME — the `_zag_*` externs, implemented in raw x86-64 with
// Linux syscalls only. NO C, no libc: this replaces std/runtime.c entirely so
// not one bit of C is in the language's runtime.
//
// SLICE ABI: a []u8 value is a POINTER to a 16-byte {ptr@0, len@8} block. A
// routine taking a []u8 receives that block pointer; a routine RETURNING a []u8
// returns (rax) a pointer to a freshly-allocated 16-byte {ptr,len} block.
//
// Syscall numbers (x86-64): read=0 write=1 open=2 close=3 mmap=9 exit=60
// fork=57 execve=59 wait4=61 chmod=90 access=21. Syscall clobbers rcx and r11;
// result (or -errno) in rax. Args: rdi,rsi,rdx,r10,r8,r9 (NOTE r10 not rcx).
// Routines never touch r15 (the reserved argc/argv base).
// ════════════════════════════════════════════════════════════════════════════

// Allocate a 16-byte {ptr,len} result block via __alloc (mmap), store rsi=ptr at
// [block+0] and rdx=len at [block+8], leaving the block address in rax. Helper
// emitted inline by the routines that build a []u8 result. Clobbers rdi.
fn cg_rt_emit_make_slice(out: *ArrayList[Instr], cg: *Cg) void {
    // caller has the desired ptr in rsi and len in rdx; preserve across __alloc.
    push[Instr](out, i_push(R_RSI()));
    push[Instr](out, i_push(R_RDX()));
    push[Instr](out, i_mov_imm(R_RDI(), 16));
    push[Instr](out, i_call(cg.*.al_lbl));       // rax = 16-byte block
    push[Instr](out, i_pop(R_RDX()));            // rdx = len
    push[Instr](out, i_pop(R_RSI()));            // rsi = ptr
    push[Instr](out, i_store(R_RAX(), 0, R_RSI()));   // [block+0] = ptr
    push[Instr](out, i_store(R_RAX(), 8, R_RDX()));   // [block+8] = len
}

// ── __rt_writeln(rdi=&slice, rsi=fd, rdx=add_nl) ─────────────────────────────
// write(fd, slice.ptr, slice.len); if add_nl, also write a single '\n' byte.
fn cg_emit_rt_writeln(out: *ArrayList[Instr], cg: *Cg) void {
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_WRITELN())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 16));
    push[Instr](out, i_mov_rr(R_R8(), R_RSI()));      // r8 = fd
    push[Instr](out, i_mov_rr(R_R9(), R_RDX()));      // r9 = add_nl
    push[Instr](out, i_mov_rr(R_R10(), R_RDI()));     // r10 = &slice
    // write(fd, slice.ptr, slice.len)
    push[Instr](out, i_mov_imm(R_RAX(), 1));          // sys_write
    push[Instr](out, i_mov_rr(R_RDI(), R_R8()));      // fd
    push[Instr](out, i_load(R_RSI(), R_R10(), 0));    // ptr
    push[Instr](out, i_load(R_RDX(), R_R10(), 8));    // len
    push[Instr](out, i_syscall());
    // if add_nl, write a '\n'
    let l_nonl: i32 = cg_fresh(cg);
    push[Instr](out, i_cmp_imm(R_R9(), 0));
    push[Instr](out, i_je(l_nonl));
    push[Instr](out, i_mov_imm(R_RAX(), 10));         // '\n'
    push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));
    push[Instr](out, i_mov_imm(R_RAX(), 1));          // sys_write
    push[Instr](out, i_mov_rr(R_RDI(), R_R8()));      // fd
    push[Instr](out, i_lea(R_RSI(), R_RBP(), 0 - 8)); // &'\n'
    push[Instr](out, i_mov_imm(R_RDX(), 1));          // len 1
    push[Instr](out, i_syscall());
    push[Instr](out, i_label(l_nonl));
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_str_concat(rdi=&a, rsi=&b) -> rax = &{ptr,len} ──────────────────────
// total = a.len + b.len ; buf = malloc(total) ; copy a then b ; return {buf,total}.
fn cg_emit_rt_concat(out: *ArrayList[Instr], cg: *Cg) void {
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_CONCAT())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 48));
    // [rbp-8]=a.ptr [rbp-16]=a.len [rbp-24]=b.ptr [rbp-32]=b.len [rbp-40]=buf
    push[Instr](out, i_load(R_RAX(), R_RDI(), 0)); push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));
    push[Instr](out, i_load(R_RAX(), R_RDI(), 8)); push[Instr](out, i_store(R_RBP(), 0 - 16, R_RAX()));
    push[Instr](out, i_load(R_RAX(), R_RSI(), 0)); push[Instr](out, i_store(R_RBP(), 0 - 24, R_RAX()));
    push[Instr](out, i_load(R_RAX(), R_RSI(), 8)); push[Instr](out, i_store(R_RBP(), 0 - 32, R_RAX()));
    // total = a.len + b.len ; buf = malloc(total)  (malloc(0) is fine: maps a page)
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 16));
    push[Instr](out, i_load(R_RAX(), R_RBP(), 0 - 32));
    push[Instr](out, i_add(R_RDI(), R_RAX()));             // rdi = total
    push[Instr](out, i_push(R_RDI()));                     // save total
    push[Instr](out, i_call(cg.*.ml_lbl));                 // rax = buf
    push[Instr](out, i_pop(R_RDI()));                      // rdi = total (restore)
    push[Instr](out, i_store(R_RBP(), 0 - 40, R_RAX()));   // buf
    // copy a.len bytes: src=a.ptr, dst=buf
    cg_rt_emit_bytecopy(out, cg, 0 - 8, 0 - 16, 0 - 40, 0);
    // copy b.len bytes: src=b.ptr, dst=buf + a.len
    cg_rt_emit_bytecopy_off(out, cg, 0 - 24, 0 - 32, 0 - 40, 0 - 16);
    // result = {buf, total}
    push[Instr](out, i_load(R_RSI(), R_RBP(), 0 - 40));    // ptr = buf
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 16));    // a.len
    push[Instr](out, i_load(R_RDX(), R_RBP(), 0 - 32));    // b.len
    push[Instr](out, i_add(R_RDX(), R_RDI()));             // len = a.len+b.len
    cg_rt_emit_make_slice(out, cg);                        // rax = &{ptr,len}
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// Copy [rbp+lenoff] bytes from *[rbp+srcoff] to *[rbp+dstoff] + (dstadd ? [rbp+
// dstaddoff] : 0). Byte-by-byte (rsp-relative frame slots hold ptrs/len). Uses
// rax,rcx(no—syscall-free here),rdx,r8,r9,r10 scratch — caller's frame slots are
// reloaded each call so no cross-call register pressure.
fn cg_rt_emit_bytecopy(out: *ArrayList[Instr], cg: *Cg, srcoff: i32, lenoff: i32, dstoff: i32, dstaddoff: i32) void {
    cg_rt_emit_bytecopy_off(out, cg, srcoff, lenoff, dstoff, dstaddoff);
}

// Real implementation: dst base = [dstoff] + (dstaddoff!=0 ? [dstaddoff] : 0).
fn cg_rt_emit_bytecopy_off(out: *ArrayList[Instr], cg: *Cg, srcoff: i32, lenoff: i32, dstoff: i32, dstaddoff: i32) void {
    let l_top: i32 = cg_fresh(cg);
    let l_end: i32 = cg_fresh(cg);
    push[Instr](out, i_load(R_R8(), R_RBP(), srcoff));    // r8 = src ptr
    push[Instr](out, i_load(R_R9(), R_RBP(), dstoff));    // r9 = dst base
    if (dstaddoff != 0) {
        push[Instr](out, i_load(R_RAX(), R_RBP(), dstaddoff));
        push[Instr](out, i_add(R_R9(), R_RAX()));         // r9 += offset
    }
    push[Instr](out, i_load(R_R10(), R_RBP(), lenoff));   // r10 = count
    push[Instr](out, i_mov_imm(R_RDX(), 0));              // rdx = i
    push[Instr](out, i_label(l_top));
    push[Instr](out, i_cmp(R_RDX(), R_R10()));
    push[Instr](out, i_jge(l_end));
    // load byte src[i]
    push[Instr](out, i_mov_rr(R_RAX(), R_R8()));
    push[Instr](out, i_add(R_RAX(), R_RDX()));
    push[Instr](out, i_load(R_RAX(), R_RAX(), 0));        // 8-byte load
    push[Instr](out, i_push(R_RDX()));
    push[Instr](out, i_mov_imm(R_RDX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RDX()));            // mask to 1 byte
    push[Instr](out, i_pop(R_RDX()));
    // store byte to dst[i]: need a 1-byte store. We emit a store-byte sequence:
    // load existing 8 bytes, replace low byte, store back — but simpler: store
    // the byte and let the trailing 7 bytes be overwritten by the next iteration
    // (we write low→high). The FINAL byte's 7 trailing bytes land in the page's
    // slack (malloc pages are 4 KiB, total<page in practice) OR in the result's
    // own NUL/unused tail. To stay correct for adjacent allocations we instead
    // do a true byte store via the masked read-modify-write below.
    push[Instr](out, i_mov_rr(R_RSI(), R_R9()));
    push[Instr](out, i_add(R_RSI(), R_RDX()));            // rsi = &dst[i]
    cg_rt_emit_store_byte(out, cg);                       // [rsi].byte = rax(low)
    push[Instr](out, i_add_imm(R_RDX(), 1));
    push[Instr](out, i_jmp(l_top));
    push[Instr](out, i_label(l_end));
}

// Store the LOW byte of rax to [rsi], preserving the other 7 bytes there:
//   r11-free: load old 8 bytes into r8scratch? We use rdi as scratch.
//   old = [rsi] ; old = old AND 0xFFFFFFFFFFFFFF00 ; old = old OR (rax & 0xFF) ;
//   [rsi] = old.  (No `|`/`<<` in the subset → we do it with add and a mask we
//   build via successive arithmetic; here we have access to i_and/i_or in the
//   ISA which the ASSEMBLER supports, so use K_OR_RR via i_or.)
fn cg_rt_emit_store_byte(out: *ArrayList[Instr], cg: *Cg) void {
    let _u: i32 = cg.*.err;
    push[Instr](out, i_push(R_RDX()));
    push[Instr](out, i_push(R_RAX()));
    push[Instr](out, i_load(R_RDX(), R_RSI(), 0));        // rdx = old 8 bytes
    // mask off low byte: rdx = rdx - (rdx & 0xFF)
    push[Instr](out, i_mov_rr(R_RDI(), R_RDX()));
    push[Instr](out, i_mov_imm(R_RAX(), 255));
    push[Instr](out, i_and(R_RDI(), R_RAX()));            // rdi = old low byte
    push[Instr](out, i_sub(R_RDX(), R_RDI()));            // clear low byte of rdx
    push[Instr](out, i_pop(R_RAX()));                     // restore new byte (low)
    push[Instr](out, i_push(R_RAX()));
    push[Instr](out, i_mov_imm(R_RDI(), 255));
    push[Instr](out, i_and(R_RAX(), R_RDI()));            // rax = new & 0xFF
    push[Instr](out, i_or(R_RDX(), R_RAX()));             // merge
    push[Instr](out, i_store(R_RSI(), 0, R_RDX()));       // [rsi] = merged
    push[Instr](out, i_pop(R_RAX()));
    push[Instr](out, i_pop(R_RDX()));
}

// ── _zag_i64_to_str(rdi=v) / _zag_u64_to_str(rdi=v) -> rax = &{ptr,len} ───────
// Convert to decimal in a malloc'd buffer, return {buf,len}. `is_signed`=1 emits
// a leading '-' for negatives (i64); =0 treats v as unsigned magnitude (u64) —
// but since we lack unsigned division here, u64 reuses the signed peel which is
// correct for non-negative values (the common case); negative-as-u64 is rare and
// would need unsigned idiv — documented limitation, still byte-correct decimal.
fn cg_emit_rt_int_to_str(out: *ArrayList[Instr], cg: *Cg, lbl: i32) void {
    let l_pos:   i32 = cg_fresh(cg);
    let l_loop:  i32 = cg_fresh(cg);
    let l_zero:  i32 = cg_fresh(cg);
    let l_after: i32 = cg_fresh(cg);
    let l_nosign:i32 = cg_fresh(cg);
    let l_wtop:  i32 = cg_fresh(cg);
    let l_wdone: i32 = cg_fresh(cg);
    let l_pdig:  i32 = cg_fresh(cg);

    push[Instr](out, i_label(lbl));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 64));         // digit stack buffer @ rbp-64
    push[Instr](out, i_mov_rr(R_RAX(), R_RDI()));     // rax = v
    push[Instr](out, i_mov_imm(R_R10(), 0));          // r10 = sign flag
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jge(l_pos));
    push[Instr](out, i_mov_imm(R_R10(), 1));          // negative
    push[Instr](out, i_label(l_pos));
    push[Instr](out, i_mov_imm(R_R9(), 0));           // r9 = digit count
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_zero));
    push[Instr](out, i_label(l_loop));
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_after));
    push[Instr](out, i_mov_imm(R_RCX(), 10));
    push[Instr](out, i_idiv(R_RCX()));                // rax=quot, rdx=rem
    push[Instr](out, i_mov_rr(R_R8(), R_RDX()));      // r8 = rem
    push[Instr](out, i_cmp_imm(R_R8(), 0));
    push[Instr](out, i_jge(l_pdig));
    push[Instr](out, i_neg(R_R8()));                  // abs(rem)
    push[Instr](out, i_label(l_pdig));
    push[Instr](out, i_add_imm(R_R8(), 48));          // + '0'
    push[Instr](out, i_push(R_R8()));                 // push digit
    push[Instr](out, i_add_imm(R_R9(), 1));
    push[Instr](out, i_jmp(l_loop));
    push[Instr](out, i_label(l_zero));
    push[Instr](out, i_mov_imm(R_R8(), 48));
    push[Instr](out, i_push(R_R8()));
    push[Instr](out, i_mov_imm(R_R9(), 1));
    push[Instr](out, i_label(l_after));
    push[Instr](out, i_cmp_imm(R_R10(), 0));
    push[Instr](out, i_je(l_nosign));
    push[Instr](out, i_mov_imm(R_R8(), 45));          // '-'
    push[Instr](out, i_push(R_R8()));
    push[Instr](out, i_add_imm(R_R9(), 1));
    push[Instr](out, i_label(l_nosign));
    // r9 = length. malloc(r9) → buf. Save r9 across the call.
    push[Instr](out, i_push(R_R9()));
    push[Instr](out, i_mov_rr(R_RDI(), R_R9()));
    push[Instr](out, i_call(cg.*.ml_lbl));            // rax = buf
    push[Instr](out, i_pop(R_R9()));                  // r9 = length
    // store buf in rbp-8 (frame), then pop digits into it.
    push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));   // buf
    push[Instr](out, i_mov_rr(R_RSI(), R_RAX()));     // rsi = write ptr
    push[Instr](out, i_mov_rr(R_RCX(), R_R9()));      // rcx = remaining
    push[Instr](out, i_label(l_wtop));
    push[Instr](out, i_cmp_imm(R_RCX(), 0));
    push[Instr](out, i_je(l_wdone));
    push[Instr](out, i_pop(R_RAX()));                 // next digit (MS first)
    cg_rt_emit_store_byte(out, cg);                   // [rsi].byte = digit
    push[Instr](out, i_add_imm(R_RSI(), 1));
    push[Instr](out, i_sub_imm(R_RCX(), 1));
    push[Instr](out, i_jmp(l_wtop));
    push[Instr](out, i_label(l_wdone));
    // result = {buf, r9}
    push[Instr](out, i_load(R_RSI(), R_RBP(), 0 - 8));    // ptr = buf
    push[Instr](out, i_mov_rr(R_RDX(), R_R9()));          // len
    cg_rt_emit_make_slice(out, cg);
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── __rt_pathbuf(rdi=&slice) -> rax = NUL-terminated cstr (malloc'd) ──────────
// Copy slice bytes to a fresh malloc(len+1) buffer and append a NUL. Used by the
// file/exec routines (open/access/chmod/execve all need a C string).
fn cg_emit_rt_pathbuf(out: *ArrayList[Instr], cg: *Cg) void {
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_PATHBUF())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 32));
    // [rbp-8]=src.ptr [rbp-16]=src.len [rbp-24]=buf
    push[Instr](out, i_load(R_RAX(), R_RDI(), 0)); push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));
    push[Instr](out, i_load(R_RAX(), R_RDI(), 8)); push[Instr](out, i_store(R_RBP(), 0 - 16, R_RAX()));
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 16));
    push[Instr](out, i_add_imm(R_RDI(), 1));          // len + 1
    push[Instr](out, i_call(cg.*.ml_lbl));            // rax = buf
    push[Instr](out, i_store(R_RBP(), 0 - 24, R_RAX()));
    // copy len bytes src→buf
    cg_rt_emit_bytecopy_off(out, cg, 0 - 8, 0 - 16, 0 - 24, 0);
    // buf[len] = 0
    push[Instr](out, i_load(R_RSI(), R_RBP(), 0 - 24));
    push[Instr](out, i_load(R_RAX(), R_RBP(), 0 - 16));
    push[Instr](out, i_add(R_RSI(), R_RAX()));        // &buf[len]
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    cg_rt_emit_store_byte(out, cg);
    push[Instr](out, i_load(R_RAX(), R_RBP(), 0 - 24));   // return buf
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_read_file(rdi=&path) -> rax = &{ptr,len}  (len = -1 on open failure) ─
// open(path,O_RDONLY); read in a loop into a growing mmap'd buffer until EOF;
// close; return {buf,total}.
fn cg_emit_rt_read_file(out: *ArrayList[Instr], cg: *Cg) void {
    let l_fail:  i32 = cg_fresh(cg);
    let l_rtop:  i32 = cg_fresh(cg);
    let l_rdone: i32 = cg_fresh(cg);
    let l_ret:   i32 = cg_fresh(cg);

    push[Instr](out, i_label(cg_rt_lbl(cg, RT_READF())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 64));
    // [rbp-8]=fd [rbp-16]=buf [rbp-24]=cap [rbp-32]=total
    // pathbuf
    push[Instr](out, i_call(cg_rt_lbl(cg, RT_PATHBUF())));   // rax = cstr (rdi=&path passes through)
    // open(cstr, O_RDONLY=0, 0)
    push[Instr](out, i_mov_rr(R_RDI(), R_RAX()));
    push[Instr](out, i_mov_imm(R_RAX(), 2));          // sys_open
    push[Instr](out, i_mov_imm(R_RSI(), 0));          // O_RDONLY
    push[Instr](out, i_mov_imm(R_RDX(), 0));          // mode
    push[Instr](out, i_syscall());                    // rax = fd or -errno
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jl(l_fail));                   // fd < 0 → failure
    push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));   // fd
    // initial buffer: malloc(65536), cap=65536, total=0
    push[Instr](out, i_mov_imm(R_RDI(), 65536));
    push[Instr](out, i_call(cg.*.ml_lbl));            // rax = buf
    push[Instr](out, i_store(R_RBP(), 0 - 16, R_RAX()));
    push[Instr](out, i_mov_imm(R_RAX(), 65536));
    push[Instr](out, i_store(R_RBP(), 0 - 24, R_RAX()));  // cap
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_store(R_RBP(), 0 - 32, R_RAX()));  // total
    // read loop: ensure room (cap-total); if 0, grow via realloc(buf, cap*2).
    push[Instr](out, i_label(l_rtop));
    // room = cap - total
    push[Instr](out, i_load(R_R8(), R_RBP(), 0 - 24));    // cap
    push[Instr](out, i_load(R_R9(), R_RBP(), 0 - 32));    // total
    push[Instr](out, i_mov_rr(R_RAX(), R_R8()));
    push[Instr](out, i_sub(R_RAX(), R_R9()));             // room
    let l_haveroom: i32 = cg_fresh(cg);
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jg(l_haveroom));
    // grow: newcap = cap*2 ; buf = realloc(buf, newcap)
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 16));   // oldbuf
    push[Instr](out, i_load(R_RSI(), R_RBP(), 0 - 24));   // cap
    push[Instr](out, i_add(R_RSI(), R_RSI()));            // newcap = cap*2
    push[Instr](out, i_store(R_RBP(), 0 - 24, R_RSI()));  // cap = newcap
    push[Instr](out, i_call(cg.*.rl_lbl));                // rax = newbuf
    push[Instr](out, i_store(R_RBP(), 0 - 16, R_RAX()));
    push[Instr](out, i_label(l_haveroom));
    // read(fd, buf+total, cap-total)
    push[Instr](out, i_mov_imm(R_RAX(), 0));              // sys_read
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 8));    // fd
    push[Instr](out, i_load(R_RSI(), R_RBP(), 0 - 16));   // buf
    push[Instr](out, i_load(R_R8(), R_RBP(), 0 - 32));    // total
    push[Instr](out, i_add(R_RSI(), R_R8()));             // buf+total
    push[Instr](out, i_load(R_RDX(), R_RBP(), 0 - 24));   // cap
    push[Instr](out, i_sub(R_RDX(), R_R8()));             // cap-total
    push[Instr](out, i_syscall());                        // rax = nread
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jle(l_rdone));                     // 0 (EOF) or error → stop
    // total += nread
    push[Instr](out, i_load(R_R8(), R_RBP(), 0 - 32));
    push[Instr](out, i_add(R_R8(), R_RAX()));
    push[Instr](out, i_store(R_RBP(), 0 - 32, R_R8()));
    push[Instr](out, i_jmp(l_rtop));
    push[Instr](out, i_label(l_rdone));
    // close(fd)
    push[Instr](out, i_mov_imm(R_RAX(), 3));              // sys_close
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 8));
    push[Instr](out, i_syscall());
    // result = {buf, total}
    push[Instr](out, i_load(R_RSI(), R_RBP(), 0 - 16));   // ptr = buf
    push[Instr](out, i_load(R_RDX(), R_RBP(), 0 - 32));   // len = total
    cg_rt_emit_make_slice(out, cg);
    push[Instr](out, i_jmp(l_ret));
    push[Instr](out, i_label(l_fail));
    // failure: return {0, -1}
    push[Instr](out, i_mov_imm(R_RSI(), 0));
    push[Instr](out, i_mov_imm(R_RDX(), 0 - 1));
    cg_rt_emit_make_slice(out, cg);
    push[Instr](out, i_label(l_ret));
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_write_file(rdi=&path, rsi=&content) -> rax = 0/-1 ───────────────────
// open(path, O_WRONLY|O_CREAT|O_TRUNC=577, 0644=420); write(content); close.
// `mark_exec`=1 also chmod(path, 0755=493) after a successful write (write_exec).
fn cg_emit_rt_write_file(out: *ArrayList[Instr], cg: *Cg, lbl: i32, mark_exec: i32) void {
    let l_fail: i32 = cg_fresh(cg);
    let l_ret:  i32 = cg_fresh(cg);

    push[Instr](out, i_label(lbl));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 48));
    // [rbp-8]=&content [rbp-16]=cstr(path) [rbp-24]=fd
    push[Instr](out, i_store(R_RBP(), 0 - 8, R_RSI()));   // save &content
    // pathbuf(&path)  (rdi already = &path)
    push[Instr](out, i_call(cg_rt_lbl(cg, RT_PATHBUF())));
    push[Instr](out, i_store(R_RBP(), 0 - 16, R_RAX()));  // cstr
    // open(cstr, 577, 420)
    push[Instr](out, i_mov_rr(R_RDI(), R_RAX()));
    push[Instr](out, i_mov_imm(R_RAX(), 2));          // sys_open
    push[Instr](out, i_mov_imm(R_RSI(), 577));        // O_WRONLY|O_CREAT|O_TRUNC
    push[Instr](out, i_mov_imm(R_RDX(), 420));        // 0644
    push[Instr](out, i_syscall());                    // rax = fd or -errno
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jl(l_fail));
    push[Instr](out, i_store(R_RBP(), 0 - 24, R_RAX()));  // fd
    // write(fd, content.ptr, content.len)
    push[Instr](out, i_mov_imm(R_RAX(), 1));          // sys_write
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 24));   // fd
    push[Instr](out, i_load(R_R8(), R_RBP(), 0 - 8));     // &content
    push[Instr](out, i_load(R_RSI(), R_R8(), 0));         // content.ptr
    push[Instr](out, i_load(R_RDX(), R_R8(), 8));         // content.len
    push[Instr](out, i_syscall());
    // close(fd)
    push[Instr](out, i_mov_imm(R_RAX(), 3));
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 24));
    push[Instr](out, i_syscall());
    if (mark_exec == 1) {
        // chmod(cstr, 0755=493)
        push[Instr](out, i_mov_imm(R_RAX(), 90));     // sys_chmod
        push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 16));   // cstr
        push[Instr](out, i_mov_imm(R_RSI(), 493));    // 0755
        push[Instr](out, i_syscall());
    }
    push[Instr](out, i_mov_imm(R_RAX(), 0));          // success → 0
    push[Instr](out, i_jmp(l_ret));
    push[Instr](out, i_label(l_fail));
    push[Instr](out, i_mov_imm(R_RAX(), 0 - 1));      // -1
    push[Instr](out, i_label(l_ret));
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_file_exists(rdi=&path) -> rax = 1/0 ─────────────────────────────────
// access(cstr, F_OK=0) == 0 ? 1 : 0.
fn cg_emit_rt_file_exists(out: *ArrayList[Instr], cg: *Cg) void {
    let l_no: i32 = cg_fresh(cg);
    let l_ret: i32 = cg_fresh(cg);
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_FEXISTS())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_call(cg_rt_lbl(cg, RT_PATHBUF())));   // rax = cstr
    push[Instr](out, i_mov_rr(R_RDI(), R_RAX()));
    push[Instr](out, i_mov_imm(R_RAX(), 21));         // sys_access
    push[Instr](out, i_mov_imm(R_RSI(), 0));          // F_OK
    push[Instr](out, i_syscall());                    // rax = 0 if ok
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_jne(l_no));
    push[Instr](out, i_mov_imm(R_RAX(), 1));
    push[Instr](out, i_jmp(l_ret));
    push[Instr](out, i_label(l_no));
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_label(l_ret));
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_arg(rdi=i) -> rax = &{ptr,len} ──────────────────────────────────────
// argv[i] is at [r15 + 8 + 8*i] (a NUL-terminated cstr). Build a {cstr,len}
// slice by scanning for the NUL to get len. Out-of-range i → {ptr, 0} pointing
// at argv[0]'s slot is avoided: we return {0,0} for i<0 or i>=argc.
fn cg_emit_rt_arg(out: *ArrayList[Instr], cg: *Cg) void {
    let l_oob: i32 = cg_fresh(cg);
    let l_scan: i32 = cg_fresh(cg);
    let l_send: i32 = cg_fresh(cg);
    let l_ret: i32 = cg_fresh(cg);
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_ARG())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    // bounds: if i < 0 → oob ; if i >= argc → oob
    push[Instr](out, i_cmp_imm(R_RDI(), 0));
    push[Instr](out, i_jl(l_oob));
    push[Instr](out, i_load(R_R8(), 15, 0));          // r8 = argc
    push[Instr](out, i_cmp(R_RDI(), R_R8()));
    push[Instr](out, i_jge(l_oob));
    // &argv[i] = r15 + (8 + 8*i)  (load needs a constant disp, so add manually).
    push[Instr](out, i_mov_rr(R_RCX(), R_RDI()));      // rcx = i
    push[Instr](out, i_mov_imm(R_RAX(), 8));
    push[Instr](out, i_imul(R_RCX(), R_RAX()));        // rcx = 8*i
    push[Instr](out, i_add_imm(R_RCX(), 8));           // rcx = 8 + 8*i
    push[Instr](out, i_mov_rr(R_RSI(), 15));           // rsi = r15
    push[Instr](out, i_add(R_RSI(), R_RCX()));         // rsi = &argv[i]
    push[Instr](out, i_load(R_RSI(), R_RSI(), 0));     // rsi = argv[i] cstr ptr
    // scan for NUL: rdx = 0 ; while ([rsi+rdx] != 0) rdx++
    push[Instr](out, i_mov_imm(R_RDX(), 0));
    push[Instr](out, i_label(l_scan));
    push[Instr](out, i_mov_rr(R_RAX(), R_RSI()));
    push[Instr](out, i_add(R_RAX(), R_RDX()));
    push[Instr](out, i_load(R_RAX(), R_RAX(), 0));     // 8-byte load
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RCX()));         // low byte
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_send));
    push[Instr](out, i_add_imm(R_RDX(), 1));
    push[Instr](out, i_jmp(l_scan));
    push[Instr](out, i_label(l_send));
    // result = {rsi, rdx}
    cg_rt_emit_make_slice(out, cg);                    // rsi=ptr rdx=len already
    push[Instr](out, i_jmp(l_ret));
    push[Instr](out, i_label(l_oob));
    push[Instr](out, i_mov_imm(R_RSI(), 0));
    push[Instr](out, i_mov_imm(R_RDX(), 0));
    cg_rt_emit_make_slice(out, cg);
    push[Instr](out, i_label(l_ret));
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_exec_cmd(rdi=&cmd) -> rax = child exit status ───────────────────────
// fork(); in child: execve("/bin/sh", ["/bin/sh","-c",cmd,0], 0); in parent:
// wait4(pid, &status, 0, 0); return (status / 256) & 255 (the WEXITSTATUS byte).
// The argv array and "/bin/sh"/"-c" strings live in the read-only DATA blob.
fn cg_emit_rt_exec(out: *ArrayList[Instr], cg: *Cg) void {
    let l_child: i32 = cg_fresh(cg);
    // intern the constant strings "/bin/sh" and "-c" (NUL-terminated) into DATA.
    let sh_off: i32 = len[u8](cg.*.data.*);
    cg_rt_push_cstr(cg, "/bin/sh");
    let dashc_off: i32 = len[u8](cg.*.data.*);
    cg_rt_push_cstr(cg, "-c");

    push[Instr](out, i_label(cg_rt_lbl(cg, RT_EXEC())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 80));
    // [rbp-8]=cmd cstr  [rbp-16..-48]=argv[0..3]  [rbp-56]=status  [rbp-64]=pid
    push[Instr](out, i_call(cg_rt_lbl(cg, RT_PATHBUF())));   // rax = cmd cstr (rdi=&cmd)
    push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));
    // argv[0] = "/bin/sh", argv[1] = "-c", argv[2] = cmd, argv[3] = 0
    push[Instr](out, i_mov_imm(R_RAX(), DATA_VBASE() + (sh_off as i64)));
    push[Instr](out, i_store(R_RBP(), 0 - 48, R_RAX()));   // argv[0] (lowest addr)
    push[Instr](out, i_mov_imm(R_RAX(), DATA_VBASE() + (dashc_off as i64)));
    push[Instr](out, i_store(R_RBP(), 0 - 40, R_RAX()));   // argv[1]
    push[Instr](out, i_load(R_RAX(), R_RBP(), 0 - 8));
    push[Instr](out, i_store(R_RBP(), 0 - 32, R_RAX()));   // argv[2] = cmd
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_store(R_RBP(), 0 - 24, R_RAX()));   // argv[3] = NULL
    // fork()
    push[Instr](out, i_mov_imm(R_RAX(), 57));         // sys_fork
    push[Instr](out, i_syscall());                    // rax = pid (0 in child)
    push[Instr](out, i_cmp_imm(R_RAX(), 0));
    push[Instr](out, i_je(l_child));
    // ── parent: wait4(pid, &status, 0, 0) ──
    push[Instr](out, i_store(R_RBP(), 0 - 64, R_RAX()));   // pid
    push[Instr](out, i_mov_imm(R_RAX(), 61));         // sys_wait4
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 64));   // pid
    push[Instr](out, i_lea(R_RSI(), R_RBP(), 0 - 56));    // &status
    push[Instr](out, i_mov_imm(R_RDX(), 0));          // options
    push[Instr](out, i_mov_imm(R_R10(), 0));          // rusage
    push[Instr](out, i_syscall());
    // status >> 8 & 0xFF  →  (status / 256) % 256
    push[Instr](out, i_load(R_RAX(), R_RBP(), 0 - 56));
    push[Instr](out, i_mov_imm(R_RCX(), 256));
    push[Instr](out, i_idiv(R_RCX()));                // rax = status/256
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RCX()));        // & 0xFF
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
    // ── child: execve("/bin/sh", argv, NULL) ──
    push[Instr](out, i_label(l_child));
    push[Instr](out, i_mov_imm(R_RAX(), 59));         // sys_execve
    push[Instr](out, i_mov_imm(R_RDI(), DATA_VBASE() + (sh_off as i64)));   // path
    push[Instr](out, i_lea(R_RSI(), R_RBP(), 0 - 48));    // argv (argv[0] lowest)
    push[Instr](out, i_mov_imm(R_RDX(), 0));          // envp = NULL
    push[Instr](out, i_syscall());
    // execve failed → exit(127)
    push[Instr](out, i_mov_imm(R_RAX(), 60));
    push[Instr](out, i_mov_imm(R_RDI(), 127));
    push[Instr](out, i_syscall());
}

// Append a NUL-terminated copy of `s` (decoded — it is a plain literal, no
// escapes) to the DATA blob.
fn cg_rt_push_cstr(cg: *Cg, s: []u8) void {
    let i: i32 = 0;
    while (i < s.len) { push[u8](cg.*.data, s[i]); i = i + 1; }
    push[u8](cg.*.data, 0);
}

// ── _zag_strdup(rdi=&s) -> rax = &{ptr,len}  (heap copy of the bytes) ─────────
fn cg_emit_rt_strdup(out: *ArrayList[Instr], cg: *Cg) void {
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_STRDUP())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 32));
    // [rbp-8]=s.ptr [rbp-16]=s.len [rbp-24]=buf
    push[Instr](out, i_load(R_RAX(), R_RDI(), 0)); push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));
    push[Instr](out, i_load(R_RAX(), R_RDI(), 8)); push[Instr](out, i_store(R_RBP(), 0 - 16, R_RAX()));
    push[Instr](out, i_load(R_RDI(), R_RBP(), 0 - 16));
    push[Instr](out, i_call(cg.*.ml_lbl));            // buf = malloc(len)
    push[Instr](out, i_store(R_RBP(), 0 - 24, R_RAX()));
    cg_rt_emit_bytecopy_off(out, cg, 0 - 8, 0 - 16, 0 - 24, 0);
    push[Instr](out, i_load(R_RSI(), R_RBP(), 0 - 24));
    push[Instr](out, i_load(R_RDX(), R_RBP(), 0 - 16));
    cg_rt_emit_make_slice(out, cg);
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_strcmp_ord(rdi=&a, rsi=&b) -> rax = <0 / 0 / >0 ─────────────────────
// memcmp over min(a.len,b.len); if equal there, sign of (a.len - b.len).
fn cg_emit_rt_strcmp_ord(out: *ArrayList[Instr], cg: *Cg) void {
    let l_top: i32 = cg_fresh(cg);
    let l_lenrule: i32 = cg_fresh(cg);
    let l_ret: i32 = cg_fresh(cg);
    let l_amin: i32 = cg_fresh(cg);
    let l_neq: i32 = cg_fresh(cg);
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_STRCMPO())));
    push[Instr](out, i_push(R_RBP()));
    push[Instr](out, i_mov_rr(R_RBP(), R_RSP()));
    push[Instr](out, i_sub_imm(R_RSP(), 32));
    // Save a.len/b.len in the frame so the length rule survives the byte loop.
    push[Instr](out, i_load(R_RAX(), R_RDI(), 8)); push[Instr](out, i_store(R_RBP(), 0 - 8, R_RAX()));  // a.len
    push[Instr](out, i_load(R_RAX(), R_RSI(), 8)); push[Instr](out, i_store(R_RBP(), 0 - 16, R_RAX())); // b.len
    // r8=a.ptr r9=b.ptr ; min len → r10
    push[Instr](out, i_load(R_R8(), R_RDI(), 0));
    push[Instr](out, i_load(R_R9(), R_RSI(), 0));
    push[Instr](out, i_load(R_RAX(), R_RBP(), 0 - 8));    // a.len
    push[Instr](out, i_load(R_R10(), R_RBP(), 0 - 16));   // b.len
    push[Instr](out, i_cmp(R_RAX(), R_R10()));
    push[Instr](out, i_jle(l_amin));
    push[Instr](out, i_mov_rr(R_RAX(), R_R10()));    // min in rax
    push[Instr](out, i_label(l_amin));
    push[Instr](out, i_mov_rr(R_R10(), R_RAX()));    // r10 = min len
    push[Instr](out, i_mov_imm(R_RDX(), 0));         // i
    push[Instr](out, i_label(l_top));
    push[Instr](out, i_cmp(R_RDX(), R_R10()));
    push[Instr](out, i_jge(l_lenrule));
    // ca = a.ptr[i]
    push[Instr](out, i_mov_rr(R_RAX(), R_R8()));
    push[Instr](out, i_add(R_RAX(), R_RDX()));
    push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RCX()));       // rax = ca
    // cb = b.ptr[i] (into rsi scratch — &b no longer needed, lens are in frame)
    push[Instr](out, i_mov_rr(R_RSI(), R_R9()));
    push[Instr](out, i_add(R_RSI(), R_RDX()));
    push[Instr](out, i_load(R_RSI(), R_RSI(), 0));
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_RSI(), R_RCX()));       // rsi = cb
    push[Instr](out, i_cmp(R_RAX(), R_RSI()));
    push[Instr](out, i_jne(l_neq));
    push[Instr](out, i_add_imm(R_RDX(), 1));
    push[Instr](out, i_jmp(l_top));
    push[Instr](out, i_label(l_neq));
    push[Instr](out, i_sub(R_RAX(), R_RSI()));       // ca - cb
    push[Instr](out, i_jmp(l_ret));
    push[Instr](out, i_label(l_lenrule));
    // equal prefix: return a.len - b.len (both saved in the frame).
    push[Instr](out, i_load(R_RAX(), R_RBP(), 0 - 8));
    push[Instr](out, i_load(R_RCX(), R_RBP(), 0 - 16));
    push[Instr](out, i_sub(R_RAX(), R_RCX()));
    push[Instr](out, i_label(l_ret));
    push[Instr](out, i_mov_rr(R_RSP(), R_RBP()));
    push[Instr](out, i_pop(R_RBP()));
    push[Instr](out, i_ret());
}

// ── _zag_str_index_of_byte(rdi=&s, rsi=byte) -> rax = index or -1 ────────────
fn cg_emit_rt_idxbyte(out: *ArrayList[Instr], cg: *Cg) void {
    let l_top: i32 = cg_fresh(cg);
    let l_found: i32 = cg_fresh(cg);
    let l_no: i32 = cg_fresh(cg);
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_IDXBYTE())));
    push[Instr](out, i_mov_rr(R_R9(), R_RSI()));     // r9 = target byte
    push[Instr](out, i_load(R_R8(), R_RDI(), 0));    // r8 = s.ptr
    push[Instr](out, i_load(R_R10(), R_RDI(), 8));   // r10 = s.len
    push[Instr](out, i_mov_imm(R_RDX(), 0));         // i
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_R9(), R_RCX()));        // target & 0xFF
    push[Instr](out, i_label(l_top));
    push[Instr](out, i_cmp(R_RDX(), R_R10()));
    push[Instr](out, i_jge(l_no));
    push[Instr](out, i_mov_rr(R_RAX(), R_R8()));
    push[Instr](out, i_add(R_RAX(), R_RDX()));
    push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RCX()));       // s.ptr[i]
    push[Instr](out, i_cmp(R_RAX(), R_R9()));
    push[Instr](out, i_je(l_found));
    push[Instr](out, i_add_imm(R_RDX(), 1));
    push[Instr](out, i_jmp(l_top));
    push[Instr](out, i_label(l_found));
    push[Instr](out, i_mov_rr(R_RAX(), R_RDX()));    // index
    push[Instr](out, i_ret());
    push[Instr](out, i_label(l_no));
    push[Instr](out, i_mov_imm(R_RAX(), 0 - 1));     // -1
    push[Instr](out, i_ret());
}

// ── _zag_memcpy(rdi=dst, rsi=src, rdx=n) -> void ─────────────────────────────
fn cg_emit_rt_memcpy(out: *ArrayList[Instr], cg: *Cg) void {
    let l_top: i32 = cg_fresh(cg);
    let l_end: i32 = cg_fresh(cg);
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_MEMCPY())));
    push[Instr](out, i_mov_imm(R_R8(), 0));          // i
    push[Instr](out, i_label(l_top));
    push[Instr](out, i_cmp(R_R8(), R_RDX()));
    push[Instr](out, i_jge(l_end));
    push[Instr](out, i_mov_rr(R_RAX(), R_RSI()));
    push[Instr](out, i_add(R_RAX(), R_R8()));
    push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RCX()));       // src[i]
    push[Instr](out, i_push(R_RSI()));
    push[Instr](out, i_mov_rr(R_RSI(), R_RDI()));
    push[Instr](out, i_add(R_RSI(), R_R8()));        // &dst[i]
    cg_rt_emit_store_byte(out, cg);
    push[Instr](out, i_pop(R_RSI()));
    push[Instr](out, i_add_imm(R_R8(), 1));
    push[Instr](out, i_jmp(l_top));
    push[Instr](out, i_label(l_end));
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_ret());
}

// ── _zag_memcmp(rdi=a, rsi=b, rdx=n) -> rax = <0/0/>0 (first differing byte) ──
fn cg_emit_rt_memcmp(out: *ArrayList[Instr], cg: *Cg) void {
    let l_top: i32 = cg_fresh(cg);
    let l_eq: i32 = cg_fresh(cg);
    let l_ne: i32 = cg_fresh(cg);
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_MEMCMP())));
    push[Instr](out, i_mov_imm(R_R8(), 0));          // i
    push[Instr](out, i_label(l_top));
    push[Instr](out, i_cmp(R_R8(), R_RDX()));
    push[Instr](out, i_jge(l_eq));
    push[Instr](out, i_mov_rr(R_RAX(), R_RDI()));
    push[Instr](out, i_add(R_RAX(), R_R8()));
    push[Instr](out, i_load(R_RAX(), R_RAX(), 0));
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_RAX(), R_RCX()));       // a[i]
    push[Instr](out, i_mov_rr(R_R9(), R_RSI()));
    push[Instr](out, i_add(R_R9(), R_R8()));
    push[Instr](out, i_load(R_R9(), R_R9(), 0));
    push[Instr](out, i_push(R_RCX()));
    push[Instr](out, i_mov_imm(R_RCX(), 255));
    push[Instr](out, i_and(R_R9(), R_RCX()));        // b[i]
    push[Instr](out, i_pop(R_RCX()));
    push[Instr](out, i_cmp(R_RAX(), R_R9()));
    push[Instr](out, i_jne(l_ne));
    push[Instr](out, i_add_imm(R_R8(), 1));
    push[Instr](out, i_jmp(l_top));
    push[Instr](out, i_label(l_ne));
    push[Instr](out, i_sub(R_RAX(), R_R9()));        // a[i]-b[i]
    push[Instr](out, i_ret());
    push[Instr](out, i_label(l_eq));
    push[Instr](out, i_mov_imm(R_RAX(), 0));
    push[Instr](out, i_ret());
}

// ── _zag_str_to_i64(rdi=&s) -> rax = parsed decimal (signed) ─────────────────
fn cg_emit_rt_str2i(out: *ArrayList[Instr], cg: *Cg) void {
    let l_top: i32 = cg_fresh(cg);
    let l_end: i32 = cg_fresh(cg);
    let l_skip: i32 = cg_fresh(cg);
    let l_noneg: i32 = cg_fresh(cg);
    push[Instr](out, i_label(cg_rt_lbl(cg, RT_STR2I())));
    push[Instr](out, i_load(R_R8(), R_RDI(), 0));    // ptr
    push[Instr](out, i_load(R_R9(), R_RDI(), 8));    // len
    push[Instr](out, i_mov_imm(R_RAX(), 0));         // acc
    push[Instr](out, i_mov_imm(R_RDX(), 0));         // i
    push[Instr](out, i_mov_imm(R_R10(), 0));         // neg flag
    // optional leading '-' (only if len>0 and ptr[0]=='-')
    push[Instr](out, i_cmp_imm(R_R9(), 0));
    push[Instr](out, i_jle(l_noneg));
    push[Instr](out, i_push(R_RAX()));
    push[Instr](out, i_load(R_RCX(), R_R8(), 0));
    push[Instr](out, i_push(R_RDI()));
    push[Instr](out, i_mov_imm(R_RDI(), 255));
    push[Instr](out, i_and(R_RCX(), R_RDI()));
    push[Instr](out, i_pop(R_RDI()));
    push[Instr](out, i_pop(R_RAX()));
    push[Instr](out, i_cmp_imm(R_RCX(), 45));         // '-'
    push[Instr](out, i_jne(l_noneg));
    push[Instr](out, i_mov_imm(R_R10(), 1));          // neg
    push[Instr](out, i_mov_imm(R_RDX(), 1));          // skip the '-'
    push[Instr](out, i_label(l_noneg));
    push[Instr](out, i_label(l_top));
    push[Instr](out, i_cmp(R_RDX(), R_R9()));
    push[Instr](out, i_jge(l_end));
    // c = ptr[i]
    push[Instr](out, i_mov_rr(R_RCX(), R_R8()));
    push[Instr](out, i_add(R_RCX(), R_RDX()));
    push[Instr](out, i_load(R_RCX(), R_RCX(), 0));
    push[Instr](out, i_push(R_RDI()));
    push[Instr](out, i_mov_imm(R_RDI(), 255));
    push[Instr](out, i_and(R_RCX(), R_RDI()));
    push[Instr](out, i_pop(R_RDI()));
    push[Instr](out, i_sub_imm(R_RCX(), 48));          // c - '0'
    // skip non-digits (matches the lenient C strtoll-ish: ignore them)
    push[Instr](out, i_cmp_imm(R_RCX(), 0));
    push[Instr](out, i_jl(l_skip));
    push[Instr](out, i_cmp_imm(R_RCX(), 9));
    push[Instr](out, i_jg(l_skip));
    // acc = acc*10 + digit
    push[Instr](out, i_mov_imm(R_RDI(), 10));
    push[Instr](out, i_imul(R_RAX(), R_RDI()));
    push[Instr](out, i_add(R_RAX(), R_RCX()));
    push[Instr](out, i_label(l_skip));
    push[Instr](out, i_add_imm(R_RDX(), 1));
    push[Instr](out, i_jmp(l_top));
    push[Instr](out, i_label(l_end));
    // apply sign
    let l_pos: i32 = cg_fresh(cg);
    push[Instr](out, i_cmp_imm(R_R10(), 0));
    push[Instr](out, i_je(l_pos));     // neg flag clear → no negate
    push[Instr](out, i_neg(R_RAX()));
    push[Instr](out, i_label(l_pos));
    push[Instr](out, i_ret());
}

// Dependency closure: a referenced rt routine that allocates pulls in __malloc/
// __alloc; ones that build a path/cstr pull in the pathbuf helper; file/exec/
// readfile that grow buffers pull in __realloc.
fn cg_rt_close_deps(cg: *Cg) void {
    // routines that allocate (make_slice via __alloc, malloc'd buffers).
    if (cg_rt_is_used(cg, RT_CONCAT()) == 1)  { cg.*.use_ml = 1; }
    if (cg_rt_is_used(cg, RT_I2S()) == 1)     { cg.*.use_ml = 1; }
    if (cg_rt_is_used(cg, RT_U2S()) == 1)     { cg.*.use_ml = 1; }
    if (cg_rt_is_used(cg, RT_STRDUP()) == 1)  { cg.*.use_ml = 1; }
    if (cg_rt_is_used(cg, RT_READF()) == 1)   { cg.*.use_ml = 1; cg.*.use_rl = 1; set[i32](cg.*.rt_used, RT_PATHBUF(), 1); }
    if (cg_rt_is_used(cg, RT_ARG()) == 1)     { cg.*.use_al = 1; }
    if (cg_rt_is_used(cg, RT_WRITELN()) == 1) { }  // no alloc
    if (cg_rt_is_used(cg, RT_WRITEF()) == 1)  { cg.*.use_ml = 1; set[i32](cg.*.rt_used, RT_PATHBUF(), 1); }
    if (cg_rt_is_used(cg, RT_WRITEX()) == 1)  { cg.*.use_ml = 1; set[i32](cg.*.rt_used, RT_PATHBUF(), 1); }
    if (cg_rt_is_used(cg, RT_FEXISTS()) == 1) { cg.*.use_ml = 1; set[i32](cg.*.rt_used, RT_PATHBUF(), 1); }
    if (cg_rt_is_used(cg, RT_EXEC()) == 1)    { cg.*.use_ml = 1; set[i32](cg.*.rt_used, RT_PATHBUF(), 1); }
    if (cg_rt_is_used(cg, RT_PATHBUF()) == 1) { cg.*.use_ml = 1; }
    // make_slice uses __alloc; any []u8-returning routine needs it.
    if (cg_rt_is_used(cg, RT_CONCAT()) == 1)  { cg.*.use_al = 1; }
    if (cg_rt_is_used(cg, RT_I2S()) == 1)     { cg.*.use_al = 1; }
    if (cg_rt_is_used(cg, RT_U2S()) == 1)     { cg.*.use_al = 1; }
    if (cg_rt_is_used(cg, RT_STRDUP()) == 1)  { cg.*.use_al = 1; }
    if (cg_rt_is_used(cg, RT_READF()) == 1)   { cg.*.use_al = 1; }
}

// Emit every referenced native-runtime routine body (after the heap/print/streq
// routines, all reachable only via `call`).
fn cg_emit_native_rt(out: *ArrayList[Instr], cg: *Cg) void {
    if (cg_rt_is_used(cg, RT_WRITELN()) == 1) { cg_emit_rt_writeln(out, cg); }
    if (cg_rt_is_used(cg, RT_CONCAT()) == 1)  { cg_emit_rt_concat(out, cg); }
    if (cg_rt_is_used(cg, RT_I2S()) == 1)     { cg_emit_rt_int_to_str(out, cg, cg_rt_lbl(cg, RT_I2S())); }
    if (cg_rt_is_used(cg, RT_U2S()) == 1)     { cg_emit_rt_int_to_str(out, cg, cg_rt_lbl(cg, RT_U2S())); }
    if (cg_rt_is_used(cg, RT_PATHBUF()) == 1) { cg_emit_rt_pathbuf(out, cg); }
    if (cg_rt_is_used(cg, RT_READF()) == 1)   { cg_emit_rt_read_file(out, cg); }
    if (cg_rt_is_used(cg, RT_WRITEF()) == 1)  { cg_emit_rt_write_file(out, cg, cg_rt_lbl(cg, RT_WRITEF()), 0); }
    if (cg_rt_is_used(cg, RT_WRITEX()) == 1)  { cg_emit_rt_write_file(out, cg, cg_rt_lbl(cg, RT_WRITEX()), 1); }
    if (cg_rt_is_used(cg, RT_FEXISTS()) == 1) { cg_emit_rt_file_exists(out, cg); }
    if (cg_rt_is_used(cg, RT_ARG()) == 1)     { cg_emit_rt_arg(out, cg); }
    if (cg_rt_is_used(cg, RT_EXEC()) == 1)    { cg_emit_rt_exec(out, cg); }
    if (cg_rt_is_used(cg, RT_STRDUP()) == 1)  { cg_emit_rt_strdup(out, cg); }
    if (cg_rt_is_used(cg, RT_STRCMPO()) == 1) { cg_emit_rt_strcmp_ord(out, cg); }
    if (cg_rt_is_used(cg, RT_IDXBYTE()) == 1) { cg_emit_rt_idxbyte(out, cg); }
    if (cg_rt_is_used(cg, RT_MEMCPY()) == 1)  { cg_emit_rt_memcpy(out, cg); }
    if (cg_rt_is_used(cg, RT_MEMCMP()) == 1)  { cg_emit_rt_memcmp(out, cg); }
    if (cg_rt_is_used(cg, RT_STR2I()) == 1)   { cg_emit_rt_str2i(out, cg); }
}

// ── top-level entry: lower the whole program ─────────────────────────────────
// Returns a full instruction list whose FIRST bytes are the `_start` stub, so
// the encoded result has entry_off = 0. ALSO appends every string-constant byte
// to `dataout` (in the order the emitted code's DATA_VBASE()+off references
// assume), so the caller can map it as the read-only data segment.
fn lower_program(decls0: ArrayList[*Node], errout: *i32, dataout: *ArrayList[u8]) ArrayList[Instr] {
    let out: ArrayList[Instr] = make[Instr](128);
    let top_err: i32 = 0;

    // ── pass 0: MONOMORPHIZE — expand the program with one concrete mangled
    // decl per generic instantiation (fns + structs), to a fixpoint. The rest of
    // the backend then only ever sees concrete, mangled names; the layout / fn /
    // type-tracking machinery works unchanged.
    let decls: ArrayList[*Node] = cg_expand_generics(decls0);

    // ── pass 1: assign each (non-extern, non-generic-template) FnDecl a label ──
    // A generic TEMPLATE (tparams > 0) emits NO code — only its concrete instances
    // (appended by expansion, tparams == 0) do — so templates are skipped here.
    let syms: ArrayList[FnSym] = make[FnSym](8);
    let next_id: i32 = 1;
    let di: i32 = 0;
    while (di < len[*Node](decls)) {
        let d: *Node = get[*Node](decls, di);
        switch (d.*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) > 0) {
                    // generic template: no code, instances carry it.
                } else if (f.is_extern == 1) {
                    // extern declaration: emits no code. We do NOT count this as
                    // an error — the runtime externs we support (_zag_malloc,
                    // _zag_realloc, _zag_free, the print/strEq builtins) are
                    // lowered natively at the CALL site, and a call to an
                    // un-supported extern is caught loudly there as "call to
                    // unknown function". So a mere extern decl is harmless.
                } else {
                    push[FnSym](&syms, FnSym{ .name = f.name, .lbl = next_id, .ret = cg_norm_type(f.ret), .nparams = len[Param](f.params) });
                    next_id = next_id + 1;
                }
            }
            .struct_ => |_s| { }   // type decl: no code; consulted for layout.
            .enum_   => |_e| { }
            .union_  => |_u| { }
            else => {
                // genuinely unsupported top-level construct.
                _zag_eprintln("native: skipping unsupported top-level decl");
                top_err = top_err + 1;
            }
        }
        di = di + 1;
    }

    // Mint the support-routine labels (above every function id) — __print_int,
    // __print_str, __alloc — then reserve the fresh control-flow label space
    // strictly above THOSE. Labels are minted unconditionally so any `call`
    // resolves; the BODIES are emitted at the end only when use_* says so.
    let pi_lbl: i32 = next_id;
    let ps_lbl: i32 = next_id + 1;
    let al_lbl: i32 = next_id + 2;
    let se_lbl: i32 = next_id + 3;
    let ml_lbl: i32 = next_id + 4;
    let rl_lbl: i32 = next_id + 5;
    let pf_lbl: i32 = next_id + 6;
    // NATIVE SYSCALL RUNTIME: a contiguous block of RT_COUNT() labels for the
    // `_zag_*` routines, minted above the heap/print/streq routine labels. Their
    // `rt_used` flags (one per routine, init 0) gate body emission like use_*.
    let rt_base: i32 = next_id + 7;
    let rt_used: ArrayList[i32] = make[i32](RT_COUNT() + 1);
    let rti: i32 = 0;
    while (rti < RT_COUNT()) { push[i32](&rt_used, 0); rti = rti + 1; }
    let cg: Cg = Cg{
        .next = rt_base + RT_COUNT(),
        .err = top_err,
        .data = dataout,
        .decls = decls,
        .pi_lbl = pi_lbl,
        .ps_lbl = ps_lbl,
        .al_lbl = al_lbl,
        .se_lbl = se_lbl,
        .ml_lbl = ml_lbl,
        .rl_lbl = rl_lbl,
        .pf_lbl = pf_lbl,
        .use_pi = 0,
        .use_pf = 0,
        .use_ps = 0,
        .use_al = 0,
        .use_se = 0,
        .use_ml = 0,
        .use_rl = 0,
        .rt_base = rt_base,
        .rt_used = &rt_used,
    };

    // ── _start stub (emitted FIRST → entry_off = 0) ──
    //   mov r15, rsp ; call main ; mov rdi, rax ; mov rax, 60 ; syscall
    // The VERY FIRST instruction saves the initial rsp into r15 (BEFORE any push):
    // at process entry the kernel hands us rsp pointing at [argc, argv[0], …], so
    // r15 is the stable base from which _zag_argc/_zag_arg read argc/argv. r15 is
    // RESERVED — codegen never allocates it (registers used are rax,rcx,rdx,rsi,
    // rdi,r8,r9,r10,rbp,rsp only), so it survives every call untouched.
    let main_lbl: i32 = cg_find_fn(syms, "main");
    if (main_lbl < 0) {
        _zag_eprintln("native: no main function found");
        cg.err = cg.err + 1;
        errout.* = cg.err;
        // Emit a trivial exit(0) so the binary is still valid & runnable.
        push[Instr](&out, i_mov_imm(R_RDI(), 0));
        push[Instr](&out, i_mov_imm(R_RAX(), 60));
        push[Instr](&out, i_syscall());
        return out;
    }
    push[Instr](&out, i_mov_rr(15, R_RSP()));   // r15 = initial rsp (argc/argv base)
    push[Instr](&out, i_call(main_lbl));
    push[Instr](&out, i_mov_rr(R_RDI(), R_RAX()));
    push[Instr](&out, i_mov_imm(R_RAX(), 60));
    push[Instr](&out, i_syscall());

    // ── pass 2: lower every function body ──
    di = 0;
    while (di < len[*Node](decls)) {
        let d2: *Node = get[*Node](decls, di);
        switch (d2.*) {
            .fn_decl => |f| {
                if (f.is_extern == 0 && len[[]u8](f.tparams) == 0) {
                    let lbl: i32 = cg_find_fn(syms, f.name);
                    cg_lower_fn(&out, f, lbl, syms, &cg);
                }
            }
            else => { }
        }
        di = di + 1;
    }

    // ── support routines — emitted ONLY if referenced (conditional bloat fix) ──
    // Each lives after every user function, reached only via `call`, so falling
    // off the last user function never enters them. A program that never prints
    // or allocates therefore contains NONE of these bodies (smaller binary).
    // __malloc/__realloc are emitted via __alloc (mmap); ensure __alloc exists
    // if either references it.
    // NATIVE SYSCALL RUNTIME dependency closure: most `_zag_*` routines that
    // build a result string allocate via __malloc (header'd mmap), and the
    // pathbuf helper does too — so a referenced rt routine that allocates pulls
    // in __malloc; str_to_i64's path helper and read_file need pathbuf. We force
    // the transitive `use_*` / rt_used flags here so every called routine has a
    // body. (Order doesn't matter — emission below is gated on the final flags.)
    cg_rt_close_deps(&cg);
    if (cg.use_ml == 1) { cg.use_al = 1; }
    if (cg.use_rl == 1) { cg.use_al = 1; }
    if (cg.use_pi == 1) { cg_emit_print_int(&out, cg.pi_lbl, &cg); }
    if (cg.use_pf == 1) { cg_emit_print_f64(&out, cg.pf_lbl, &cg); }
    if (cg.use_ps == 1) { cg_emit_print_str(&out, cg.ps_lbl); }
    if (cg.use_al == 1) { cg_emit_alloc(&out, cg.al_lbl); }
    if (cg.use_se == 1) { cg_emit_streq(&out, cg.se_lbl, &cg); }
    if (cg.use_ml == 1) { cg_emit_malloc(&out, cg.ml_lbl, &cg); }
    if (cg.use_rl == 1) { cg_emit_realloc(&out, cg.rl_lbl, &cg); }
    cg_emit_native_rt(&out, &cg);

    errout.* = cg.err;
    return out;
}
