// selfhost/std/time.zag — monotonic time for the native Zag runtime.
//
// The value has an unspecified epoch and is intended for elapsed-time
// measurement. It is supplied by Linux clock_gettime(CLOCK_MONOTONIC) through
// a syscall emitted by Zag's native backend. Returns -1 if the syscall fails.

fn time_monotonic_ms() i64 {
    return _zag_clock_monotonic_ms();
}

fn time_elapsed_ms(start_ms: i64) i64 {
    return time_monotonic_ms() - start_ms;
}
