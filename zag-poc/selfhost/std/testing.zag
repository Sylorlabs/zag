// selfhost/std/testing.zag — minimal allocation-free test support.

struct TestState {
    passed: i32,
    failed: i32,
}

fn test_state() TestState {
    return TestState{ .passed = 0, .failed = 0 };
}

fn test_expect(state: *TestState, condition: i32, name: []u8) void {
    if (condition != 0) {
        state.*.passed = state.*.passed + 1;
        _zag_print("ok  ");
        _zag_println(name);
    } else {
        state.*.failed = state.*.failed + 1;
        _zag_print("FAIL ");
        _zag_println(name);
    }
}

fn test_expect_eq_i32(state: *TestState, actual: i32, expected: i32, name: []u8) void {
    test_expect(state, actual == expected, name);
}

fn test_expect_eq_i64(state: *TestState, actual: i64, expected: i64, name: []u8) void {
    test_expect(state, actual == expected, name);
}

fn test_expect_str(state: *TestState, actual: []u8, expected: []u8, name: []u8) void {
    test_expect(state, _zag_strcmp(actual, expected), name);
}

fn test_exit_code(state: *TestState) i32 {
    if (state.*.failed == 0) { return 0; }
    return 1;
}
