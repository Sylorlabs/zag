// selfhost/codegen.zag — C backend, written in Zag.
//
// Walks the ast.zag Node tree and emits C source into a byte buffer
// (ArrayList[u8]). Covers the subset the parser produces: fn decls, params,
// let/return/if/while/assign/expr statements, and expressions (int/ident/bin/
// un/call/field/index). Emits a small prelude with print_i32.

@import("parse.zag")

// ── output buffer ────────────────────────────────────────────────────────────
fn emit(buf: *ArrayList[u8], s: []u8) void {
    let i: i32 = 0;
    while (i < s.len) {
        push[u8](buf, s[i]);
        i = i + 1;
    }
}

// ── type-string helpers (index_of / split_args / is_generic_app live in
//    parse.zag so both the parser and codegen can use them) ─────────────────

// True if `s` starts with prefix `p`.
fn cg_starts_with(s: []u8, p: []u8) i32 {
    if (s.len < p.len) { return 0; }
    let i: i32 = 0;
    while (i < p.len) {
        if (s[i] != p[i]) { return 0; }
        i = i + 1;
    }
    return 1;
}

// Parse a run of ASCII digits at [from..to) into an i64 (no sign, no overflow check).
fn cg_parse_uint(s: []u8, from: i32, to: i32) i64 {
    let v: i64 = 0;
    let i: i32 = from;
    while (i < to) {
        let c: i32 = s[i] as i32;
        if (c < '0' || c > '9') { return v; }
        v = v * 10 + ((c - '0') as i64);
        i = i + 1;
    }
    return v;
}

// True iff every byte of s in [from..to) is an ASCII digit (and the range is non-empty).
fn cg_all_digits(s: []u8, from: i32, to: i32) i32 {
    if (to <= from) { return 0; }
    let i: i32 = from;
    while (i < to) {
        let c: i32 = s[i] as i32;
        if (c < '0' || c > '9') { return 0; }
        i = i + 1;
    }
    return 1;
}

// ── heterogeneous numeric type predicates (mirror src/types.zig) ─────────────
fn cg_is_posit(t: []u8) i32 {
    if (@strEq(t, "p8") || @strEq(t, "p16") || @strEq(t, "p32") || @strEq(t, "p64")) { return 1; }
    return 0;
}

// Saturating: sat_i8/16/32/64, sat_u8/16/32/64. Returns 1 if t is one of them.
fn is_sat_ty(t: []u8) i32 {
    if (cg_starts_with(t, "sat_") == 0) { return 0; }
    let b: []u8 = t[4..];
    if (@strEq(b, "i8") || @strEq(b, "i16") || @strEq(b, "i32") || @strEq(b, "i64")) { return 1; }
    if (@strEq(b, "u8") || @strEq(b, "u16") || @strEq(b, "u32") || @strEq(b, "u64")) { return 1; }
    return 0;
}

// "sat_i16" → "i16" (the prelude function suffix).
fn sat_base(t: []u8) []u8 { return t[4..]; }

fn is_bignum_ty(t: []u8) i32 {
    if (@strEq(t, "u_any") || @strEq(t, "i_any")) { return 1; }
    return 0;
}

// RNS: rns_<N>, 2 <= N <= 8.
fn is_rns_ty(t: []u8) i32 {
    if (cg_starts_with(t, "rns_") == 0) { return 0; }
    if (cg_all_digits(t, 4, t.len) == 0) { return 0; }
    let n: i64 = cg_parse_uint(t, 4, t.len);
    if (n >= 2 && n <= 8) { return 1; }
    return 0;
}

// Fixed-point: fixed_<I>_<F> with I,F runs of digits.
fn is_fixed_ty(t: []u8) i32 {
    if (cg_starts_with(t, "fixed_") == 0) { return 0; }
    let us: i32 = 6;                       // first underscore after "fixed_" → I/F split
    while (us < t.len) {
        if ((t[us] as i32) == '_') {
            if (cg_all_digits(t, 6, us) == 0) { return 0; }
            if (cg_all_digits(t, us + 1, t.len) == 0) { return 0; }
            return 1;
        }
        us = us + 1;
    }
    return 0;
}

// Fractional bit count F of fixed_<I>_<F>.
fn fixed_frac_bits(t: []u8) i64 {
    let us: i32 = 6;
    while (us < t.len) {
        if ((t[us] as i32) == '_') { return cg_parse_uint(t, us + 1, t.len); }
        us = us + 1;
    }
    return 0;
}

// Arbitrary-width int uN/iN, 1<=N<=127, EXCLUDING the standard widths 8/16/32/64.
fn is_arb_int_ty(t: []u8) i32 {
    if (t.len < 2) { return 0; }
    let c0: i32 = t[0] as i32;
    if (c0 != 'u' && c0 != 'i') { return 0; }
    if (cg_all_digits(t, 1, t.len) == 0) { return 0; }
    let n: i64 = cg_parse_uint(t, 1, t.len);
    if (n < 1 || n > 127) { return 0; }
    if (n == 8 || n == 16 || n == 32 || n == 64) { return 0; }
    return 1;
}

fn arb_int_bits(t: []u8) i64 { return cg_parse_uint(t, 1, t.len); }
fn arb_int_signed(t: []u8) i32 { if ((t[0] as i32) == 'i') { return 1; } return 0; }

// 1 iff t is any heterogeneous numeric type that needs the numeric runtime / a
// special slice typedef.
fn is_numeric_ty(t: []u8) i32 {
    if (cg_is_posit(t) == 1) { return 1; }
    if (@strEq(t, "quire")) { return 1; }
    if (is_sat_ty(t) == 1) { return 1; }
    if (is_rns_ty(t) == 1) { return 1; }
    if (is_fixed_ty(t) == 1) { return 1; }
    if (is_arb_int_ty(t) == 1) { return 1; }
    if (is_bignum_ty(t) == 1) { return 1; }
    return 0;
}

// 2^bits - 1 as a decimal string, computed without << (forbidden in the dialect).
fn arb_mask_str(bits: i64) []u8 {
    let m: i64 = 0;
    let i: i64 = 0;
    while (i < bits) { m = m * 2 + 1; i = i + 1; }
    return _zag_i64_to_str(m);
}

// ── Zag type → C type ────────────────────────────────────────────────────────
fn ctype(t: []u8) []u8 {
    // function-pointer type → its ZagFn_ typedef name
    if (is_fn_type(t) == 1) { return mangle_fn(t); }
    // Heterogeneous numeric scalars → their prelude C representation.
    if (@strEq(t, "p8"))    { return "uint8_t"; }
    if (@strEq(t, "p16"))   { return "uint16_t"; }
    if (@strEq(t, "p32"))   { return "uint32_t"; }
    if (@strEq(t, "p64"))   { return "uint64_t"; }
    if (@strEq(t, "quire")) { return "ZagQuire"; }
    if (@strEq(t, "u_any")) { return "unsigned __int128"; }
    if (@strEq(t, "i_any")) { return "__int128"; }
    if (is_sat_ty(t) == 1) {
        let b: []u8 = sat_base(t);
        if (@strEq(b, "i8"))  { return "int8_t"; }
        if (@strEq(b, "i16")) { return "int16_t"; }
        if (@strEq(b, "i32")) { return "int32_t"; }
        if (@strEq(b, "i64")) { return "int64_t"; }
        if (@strEq(b, "u8"))  { return "uint8_t"; }
        if (@strEq(b, "u16")) { return "uint16_t"; }
        if (@strEq(b, "u32")) { return "uint32_t"; }
        if (@strEq(b, "u64")) { return "uint64_t"; }
    }
    if (is_rns_ty(t) == 1)   { return "ZagRns"; }
    if (is_fixed_ty(t) == 1) { return "int32_t"; }   // fixed_I_F stored as int32_t (Q-format)
    if (is_arb_int_ty(t) == 1) {
        let n: i64 = arb_int_bits(t);
        let is_sgn: i32 = arb_int_signed(t);
        if (is_sgn == 1) {
            if (n <= 8)  { return "int8_t"; }
            if (n <= 16) { return "int16_t"; }
            if (n <= 32) { return "int32_t"; }
            return "int64_t";
        }
        if (n <= 8)  { return "uint8_t"; }
        if (n <= 16) { return "uint16_t"; }
        if (n <= 32) { return "uint32_t"; }
        return "uint64_t";
    }
    // general slice []T → ZagSlice_<mangled T>  ([]u8 keeps the prelude name)
    if (@strEq(t, "[]u8")) { return "ZagSliceU8"; }
    if (t.len > 2) {
        if (t[0] == '[' && t[1] == ']') {
            return _zag_str_concat("ZagSlice_", mangle_targ(t[2..]));
        }
    }
    return ctype_core(t);
}

fn ctype_core(t: []u8) []u8 {
    if (@strEq(t, "i8"))   { return "int8_t"; }
    if (@strEq(t, "i16"))  { return "int16_t"; }
    if (@strEq(t, "i32"))  { return "int32_t"; }
    if (@strEq(t, "i64"))  { return "int64_t"; }
    if (@strEq(t, "u8"))   { return "uint8_t"; }
    if (@strEq(t, "u16"))  { return "uint16_t"; }
    if (@strEq(t, "u32"))  { return "uint32_t"; }
    if (@strEq(t, "u64"))  { return "uint64_t"; }
    if (@strEq(t, "f32"))  { return "float"; }
    if (@strEq(t, "f64"))  { return "double"; }
    if (@strEq(t, "bool")) { return "int32_t"; }
    if (@strEq(t, "void")) { return "void"; }
    if (@strEq(t, ""))     { return "int32_t"; }
    if (@strEq(t, "[]u8")) { return "ZagSliceU8"; }
    // ?T → ZagOpt_<mangled T> (an optional struct { _has; _val; })
    if (t.len > 1) {
        if (t[0] == '?') { return _zag_str_concat("ZagOpt_", mangle_targ(t[1..])); }
    }
    // !T → ZagErr_<mangled T> (an error-union struct { _err; _val; })
    if (t.len > 1) {
        if (t[0] == '!') { return _zag_str_concat("ZagErr_", mangle_targ(t[1..])); }
    }
    // *T → "<ctype(T)>*"
    if (t.len > 1) {
        if (t[0] == '*') { return _zag_str_concat(ctype(t[1..]), "*"); }
    }
    // generic application Base[args] → Base_arg1_arg2 (monomorphized C name)
    if (is_generic_app(t)) {
        let lb: i32 = index_of(t, '[');
        let base: []u8 = t[0..lb];
        let arglist: ArrayList[[]u8] = split_args(t[lb + 1..t.len - 1]);
        return mangle_generic(base, arglist);
    }
    // named type (struct/enum/union) — emit verbatim
    return t;
}

// ── function-pointer types ("fn(P1,P2)Ret") ──────────────────────────────────
fn is_fn_type(t: []u8) i32 {
    if (t.len < 4) { return 0; }
    if (t[0] == 'f' && t[1] == 'n' && t[2] == '(') { return 1; }
    return 0;
}

// Index of the ')' matching the '(' at position 2 (depth-aware over nested fns).
fn fn_type_close(t: []u8) i32 {
    let depth: i32 = 0;
    let i: i32 = 2;
    while (i < t.len) {
        let c: i32 = t[i] as i32;
        if (c == '(') { depth = depth + 1; }
        else if (c == ')') { depth = depth - 1; if (depth == 0) { return i; } }
        i = i + 1;
    }
    return 0 - 1;
}

fn fn_type_params(t: []u8) []u8 {
    let c: i32 = fn_type_close(t);
    if (c < 3) { return ""; }
    return t[3..c];
}

fn fn_type_ret(t: []u8) []u8 {
    let c: i32 = fn_type_close(t);
    if (c < 0) { return "void"; }
    return t[c + 1..t.len];
}

// "fn(f32)f32" → "ZagFn_f32_f32" (return mangle, then each param).
fn mangle_fn(t: []u8) []u8 {
    let s: []u8 = _zag_str_concat("ZagFn_", mangle_targ(fn_type_ret(t)));
    let ps: []u8 = fn_type_params(t);
    if (ps.len > 0) {
        let args: ArrayList[[]u8] = split_args(ps);
        let i: i32 = 0;
        while (i < len[[]u8](args)) {
            s = _zag_str_concat(_zag_str_concat(s, "_"), mangle_targ(get[[]u8](args, i)));
            i = i + 1;
        }
    }
    return s;
}

// ── generics: monomorphization ───────────────────────────────────────────────
// One concrete instantiation of a generic fn, e.g. id[i32] → "id_i32".
struct Inst {
    mangled: []u8,
    f:       FnDecl,             // the generic fn template (for the substituted signature)
    targs:   ArrayList[[]u8],
    cbody:   ArrayList[*Node],   // body cloned with type-params substituted to concrete types
}

fn cg_callee_name(n: *Node) []u8 {
    return switch (n.*) {
        .id  => |d| d.name,
        .fld => |f| f.fname,
        else => "",
    };
}

// Sanitize one type arg into a C-identifier fragment (*→p, []→_, drop ]).
fn mangle_targ(t: []u8) []u8 {
    let buf: ArrayList[u8] = make[u8](8);
    let i: i32 = 0;
    while (i < t.len) {
        let c: i32 = t[i] as i32;
        if (c == '*') { push[u8](&buf, 'p'); }
        else if (c == '[') { push[u8](&buf, '_'); }
        else if (c == ']') { }
        else { push[u8](&buf, t[i]); }
        i = i + 1;
    }
    return buf.data[0..buf.len];
}

// name + "_" + each sanitized targ, e.g. ("id", ["i32"]) → "id_i32".
fn mangle_generic(name: []u8, targs: ArrayList[[]u8]) []u8 {
    let s: []u8 = name;
    let i: i32 = 0;
    while (i < len[[]u8](targs)) {
        s = _zag_str_concat(s, "_");
        s = _zag_str_concat(s, mangle_targ(get[[]u8](targs, i)));
        i = i + 1;
    }
    return s;
}

// Substitute generic type-params (names) with concrete args (vals) in a type
// string, honouring * and [] prefixes.
fn subst_type(t: []u8, names: ArrayList[[]u8], vals: ArrayList[[]u8]) []u8 {
    let i: i32 = 0;
    while (i < len[[]u8](names)) {
        if (@strEq(t, get[[]u8](names, i))) { return get[[]u8](vals, i); }
        i = i + 1;
    }
    if (t.len > 1) {
        if (t[0] == '*') { return _zag_str_concat("*", subst_type(t[1..], names, vals)); }
        if (t[0] == '?') { return _zag_str_concat("?", subst_type(t[1..], names, vals)); }
        if (t[0] == '!') { return _zag_str_concat("!", subst_type(t[1..], names, vals)); }
    }
    if (t.len > 2) {
        if (t[0] == '[' && t[1] == ']') { return _zag_str_concat("[]", subst_type(t[2..], names, vals)); }
    }
    // function type fn(P..)R → fn(subst(P)..)subst(R)
    if (is_fn_type(t) == 1) {
        let s: []u8 = "fn(";
        let ps: []u8 = fn_type_params(t);
        if (ps.len > 0) {
            let args: ArrayList[[]u8] = split_args(ps);
            let i: i32 = 0;
            while (i < len[[]u8](args)) {
                if (i > 0) { s = _zag_str_concat(s, ","); }
                s = _zag_str_concat(s, subst_type(get[[]u8](args, i), names, vals));
                i = i + 1;
            }
        }
        return _zag_str_concat(_zag_str_concat(s, ")"), subst_type(fn_type_ret(t), names, vals));
    }
    // generic application Base[args] → Base[subst(args)...]
    if (is_generic_app(t)) {
        let lb: i32 = index_of(t, '[');
        let base: []u8 = t[0..lb];
        let arglist: ArrayList[[]u8] = split_args(t[lb + 1..t.len - 1]);
        let s: []u8 = _zag_str_concat(base, "[");
        let i: i32 = 0;
        while (i < len[[]u8](arglist)) {
            if (i > 0) { s = _zag_str_concat(s, ","); }
            s = _zag_str_concat(s, subst_type(get[[]u8](arglist, i), names, vals));
            i = i + 1;
        }
        return _zag_str_concat(s, "]");
    }
    return t;
}

fn inst_seen(insts: ArrayList[Inst], mangled: []u8) bool {
    let i: i32 = 0;
    while (i < len[Inst](insts)) {
        if (@strEq(get[Inst](insts, i).mangled, mangled)) { return true; }
        i = i + 1;
    }
    return false;
}

// ── clone AST with type-param substitution (for monomorphizing fn bodies) ─────
fn subst_targs(targs: ArrayList[[]u8], tp: ArrayList[[]u8], ta: ArrayList[[]u8]) ArrayList[[]u8] {
    let out: ArrayList[[]u8] = make[[]u8](2);
    let i: i32 = 0;
    while (i < len[[]u8](targs)) {
        push[[]u8](&out, subst_type(get[[]u8](targs, i), tp, ta));
        i = i + 1;
    }
    return out;
}

fn clone_call(c: Call, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    let args: ArrayList[*Node] = make[*Node](4);
    let i: i32 = 0;
    while (i < len[*Node](c.args)) {
        push[*Node](&args, clone_expr(get[*Node](c.args, i), tp, ta));
        i = i + 1;
    }
    if (len[[]u8](c.targs) > 0) {
        return mk_gcall(clone_expr(c.callee, tp, ta), args, subst_targs(c.targs, tp, ta));
    }
    return mk_call(clone_expr(c.callee, tp, ta), args);
}

fn clone_slit(s: StructLit, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    let flds: ArrayList[FieldInit] = make[FieldInit](4);
    let i: i32 = 0;
    while (i < len[FieldInit](s.fields)) {
        let f: FieldInit = get[FieldInit](s.fields, i);
        push[FieldInit](&flds, FieldInit{ .name = f.name, .val = clone_expr(f.val, tp, ta) });
        i = i + 1;
    }
    return new(Node{ .slit_ = StructLit{ .sname = s.sname, .fields = flds, .targs = subst_targs(s.targs, tp, ta) } });
}

fn clone_expr(n: *Node, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    return switch (n.*) {
        .ilit  => |x| mk_int(x.text),
        .slit  => |x| mk_str(x.text),
        .id    => |x| mk_ident(x.name),
        .bin   => |b| mk_bin(b.op, clone_expr(b.l, tp, ta), clone_expr(b.r, tp, ta)),
        .un    => |u| mk_un(u.op, clone_expr(u.e, tp, ta)),
        .call  => |c| clone_call(c, tp, ta),
        .fld   => |f| mk_field(clone_expr(f.base, tp, ta), f.fname),
        .idx   => |x| mk_index(clone_expr(x.base, tp, ta), clone_expr(x.idx, tp, ta)),
        .slit_ => |s| clone_slit(s, tp, ta),
        .cast_ => |c| mk_cast(clone_expr(c.expr, tp, ta), subst_type(c.target, tp, ta)),
        .slice_ => |s| mk_slice(clone_expr(s.base, tp, ta), clone_expr(s.lo, tp, ta), clone_expr(s.hi, tp, ta), s.has_hi),
        else   => n,
    };
}

fn clone_block(body: ArrayList[*Node], tp: ArrayList[[]u8], ta: ArrayList[[]u8]) ArrayList[*Node] {
    let out: ArrayList[*Node] = make[*Node](8);
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        push[*Node](&out, clone_stmt(get[*Node](body, i), tp, ta));
        i = i + 1;
    }
    return out;
}

fn clone_stmt(n: *Node, tp: ArrayList[[]u8], ta: ArrayList[[]u8]) *Node {
    return switch (n.*) {
        .let_   => |l| mk_let(l.name, subst_type(l.dty, tp, ta), l.has_dty, l.has_init, clone_expr(l.expr, tp, ta)),
        .ret    => |r| mk_ret(r.has_expr, clone_expr(r.expr, tp, ta)),
        .if_    => |x| mk_if(clone_expr(x.cond, tp, ta), clone_block(x.then_body, tp, ta), clone_block(x.els_body, tp, ta), x.has_els),
        .while_ => |w| mk_while(clone_expr(w.cond, tp, ta), clone_block(w.body, tp, ta)),
        .assign => |a| mk_assign(clone_expr(a.target, tp, ta), clone_expr(a.expr, tp, ta)),
        .estmt  => |e| mk_estmt(clone_expr(e.expr, tp, ta)),
        else    => n,
    };
}

// ── expressions ──────────────────────────────────────────────────────────────
fn first_is_upper(s: []u8) bool {
    if (s.len == 0) { return false; }
    return s[0] >= 'A' && s[0] <= 'Z';
}

fn is_ident(n: *Node) bool {
    return switch (n.*) {
        .id  => |_x| true,
        else => false,
    };
}

fn is_int_literal(n: *Node) i32 {
    return switch (n.*) {
        .ilit => |_x| 1,
        else  => 0,
    };
}

// ── union / enum lookups (the codegen is otherwise type-unaware) ─────────────
// True if `name` is a declared tagged union.
fn is_union(dl: ArrayList[*Node], name: []u8) bool {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .union_ => |u| { if (@strEq(u.name, name)) { return true; } }
            else => { }
        }
        i = i + 1;
    }
    return false;
}

// Name of the union whose field set contains `tag`, or "" if none.
fn union_name_for_tag(dl: ArrayList[*Node], tag: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .union_ => |u| {
                let j: i32 = 0;
                while (j < len[Param](u.fields)) {
                    if (@strEq(get[Param](u.fields, j).name, tag)) { return u.name; }
                    j = j + 1;
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// Name of the enum whose members contain `tag`, or "" if none.
fn enum_name_for_tag(dl: ArrayList[*Node], tag: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .enum_ => |e| {
                let j: i32 = 0;
                while (j < len[[]u8](e.members)) {
                    if (@strEq(get[[]u8](e.members, j), tag)) { return e.name; }
                    j = j + 1;
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// Emit a @-builtin call. `name` includes the leading '@'.
fn gen_builtin(buf: *ArrayList[u8], name: []u8, c: Call, dl: ArrayList[*Node]) void {
    let b: []u8 = name[1..];   // strip '@'
    if (@strEq(b, "sizeOf")) {
        emit(buf, "((int32_t)sizeof(");
        if (len[[]u8](c.targs) > 0) { emit(buf, ctype(get[[]u8](c.targs, 0))); }
        else { emit(buf, "int32_t"); }
        emit(buf, "))");
    } else if (@strEq(b, "len")) {
        emit(buf, "(");
        gen_expr(buf, get[*Node](c.args, 0), dl);
        emit(buf, ").len");
    } else if (@strEq(b, "intCast") || @strEq(b, "floatCast") || @strEq(b, "truncate")) {
        // value-preserving in C — emit the argument directly
        gen_expr(buf, get[*Node](c.args, 0), dl);
    } else if (@strEq(b, "strEq")) {
        emit(buf, "_zag_str_eq(");
        gen_args(buf, c.args, dl);
        emit(buf, ")");
    } else if (@strEq(b, "strLen")) {
        emit(buf, "_zag_str_len(");
        gen_args(buf, c.args, dl);
        emit(buf, ")");
    } else if (@strEq(b, "prefetch")) {
        // software-pipelining hint: warm L1 for the slice's data (portable C)
        emit(buf, "__builtin_prefetch((");
        gen_expr(buf, get[*Node](c.args, 0), dl);
        emit(buf, ").ptr)");
    } else if (@strEq(b, "cacheLineSize")) {
        emit(buf, "((int32_t)ZAG_CACHE_LINE)");
    } else if (@strEq(b, "cacheAlignedAlloc")) {
        emit(buf, "zag_cache_aligned_alloc(");
        gen_args(buf, c.args, dl);
        emit(buf, ")");
    } else if (@strEq(b, "cacheAlignedFree")) {
        emit(buf, "zag_cache_aligned_free(");
        gen_args(buf, c.args, dl);
        emit(buf, ")");
    } else if (numeric_builtin_cname(b).len > 0) {
        // posit / quire conversion + accumulator builtins → numeric runtime fns
        emit(buf, numeric_builtin_cname(b));
        emit(buf, "(");
        gen_args(buf, c.args, dl);
        emit(buf, ")");
    } else {
        // fall back to the bare runtime symbol name
        emit(buf, b);
        emit(buf, "(");
        gen_args(buf, c.args, dl);
        emit(buf, ")");
    }
}

// Map a numeric @-builtin (without the leading '@') to its runtime C function.
// Mirrors src/codegen.zig's builtin → zag_* dispatch. "" if not a numeric builtin.
fn numeric_builtin_cname(b: []u8) []u8 {
    if (@strEq(b, "intToPosit"))   { return "zag_p32_from_i64"; }
    if (@strEq(b, "floatToPosit")) { return "zag_f64_to_p32"; }
    if (@strEq(b, "positToFloat")) { return "zag_p32_to_f64"; }
    if (@strEq(b, "positToBits"))  { return "zag_p32_bits"; }
    if (@strEq(b, "intToP8"))      { return "zag_p8_from_i64"; }
    if (@strEq(b, "intToP16"))     { return "zag_p16_from_i64"; }
    if (@strEq(b, "intToP64"))     { return "zag_p64_from_i64"; }
    if (@strEq(b, "floatToP8"))    { return "zag_f64_to_p8"; }
    if (@strEq(b, "floatToP16"))   { return "zag_f64_to_p16"; }
    if (@strEq(b, "floatToP64"))   { return "zag_ld_to_p64"; }
    if (@strEq(b, "p8ToFloat"))    { return "zag_p8_to_f64"; }
    if (@strEq(b, "p16ToFloat"))   { return "zag_p16_to_f64"; }
    if (@strEq(b, "p64ToFloat"))   { return "zag_p64_to_f64"; }
    if (@strEq(b, "p8ToBits"))     { return "zag_p8_bits"; }
    if (@strEq(b, "p16ToBits"))    { return "zag_p16_bits"; }
    if (@strEq(b, "p64ToBits"))    { return "zag_p64_bits"; }
    if (@strEq(b, "quireZero"))    { return "zag_quire_zero"; }
    if (@strEq(b, "quireFMA"))     { return "zag_quire_fma"; }
    if (@strEq(b, "quireToPosit")) { return "zag_quire_to_p32"; }
    return "";
}

// Logical byte length of a string literal token (quotes stripped, each \X = 1).
fn str_lit_len(text: []u8) i32 {
    if (text.len < 2) { return 0; }
    let n: i32 = 0;
    let i: i32 = 1;                 // skip opening quote
    let last: i32 = text.len - 1;   // index of closing quote (exclusive bound)
    while (i < last) {
        if (text[i] == '\\' && i + 1 < last) { i = i + 2; } else { i = i + 1; }
        n = n + 1;
    }
    return n;
}

fn gen_args(buf: *ArrayList[u8], args: ArrayList[*Node], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](args)) {
        if (i > 0) { emit(buf, ", "); }
        gen_expr(buf, get[*Node](args, i), dl);
        i = i + 1;
    }
}

// Declared type of param #idx of the (non-generic) fn named `cn`, or "".
fn callee_param_type(cn: []u8, idx: i32, dl: ArrayList[*Node]) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| {
                if (@strEq(f.name, cn) && len[[]u8](f.tparams) == 0) {
                    if (idx < len[Param](f.params)) { return get[Param](f.params, idx).pty; }
                    return "";
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

fn gen_args_typed(buf: *ArrayList[u8], cn: []u8, args: ArrayList[*Node], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](args)) {
        if (i > 0) { emit(buf, ", "); }
        let pt: []u8 = callee_param_type(cn, i, dl);
        let a: *Node = get[*Node](args, i);
        if (is_opt_type(pt)) {
            gen_opt_value(buf, pt, a, dl);
        } else {
            gen_expr(buf, a, dl);
        }
        i = i + 1;
    }
}

// ── expression switch (switch as a value) → C ternary chain ──────────────────
// Value expression of an arm/else body (expr arms hold a single estmt).
fn body_expr(body: ArrayList[*Node]) *Node {
    if (len[*Node](body) == 0) { return mk_int("0"); }
    let s: *Node = get[*Node](body, 0);
    return switch (s.*) {
        .estmt => |e| e.expr,
        else   => s,
    };
}

// Build a fat closure value `(ZagFn..){ code_ptr, env_ptr }` from a bare fn /
// hoisted-closure id. A capturing closure stores its captures in a stack env
// struct; a named fn (or empty closure) carries a null env (a thunk ignores it).
fn gen_clomake(buf: *ArrayList[u8], idn: *Node, dl: ArrayList[*Node]) void {
    let name: []u8 = id_name_of(idn);
    let zfn: []u8 = mangle_fn(cg_fn_type_of(dl, name));
    if (cg_starts_with(name, "__clos_") == 1) {
        emit(buf, "(");
        emit(buf, zfn);
        emit(buf, "){ &");
        emit(buf, name);
        emit(buf, ", ");
        let caps: []u8 = clos_cap_names(dl, name);
        if (caps.len > 0) {
            // heap-allocate env so the closure can safely escape the creator's frame
            emit(buf, "_zag_heap_dup(&(");
            emit(buf, name);
            emit(buf, "_env){ ");
            let names: ArrayList[[]u8] = split_args(caps);
            let i: i32 = 0;
            while (i < len[[]u8](names)) {
                if (i > 0) { emit(buf, ", "); }
                emit(buf, ".");
                emit(buf, get[[]u8](names, i));
                emit(buf, " = ");
                emit(buf, get[[]u8](names, i));
                i = i + 1;
            }
            emit(buf, " }, sizeof(");
            emit(buf, name);
            emit(buf, "_env))");
        } else {
            emit(buf, "(void*)0");
        }
        emit(buf, " }");
    } else {
        // named fn → thunk that ignores the env
        emit(buf, "(");
        emit(buf, zfn);
        emit(buf, "){ &__thunk_");
        emit(buf, name);
        emit(buf, ", (void*)0 }");
    }
}

// Comma-joined capture names of a hoisted closure (""=none).
fn clos_cap_names(dl: ArrayList[*Node], name: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| { if (@strEq(f.name, name)) { return f.cap_names; } }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// new(T{..}) → ({ T* __n = malloc(sizeof(T)); *__n = T{..}; __n; })
fn gen_new(buf: *ArrayList[u8], arg: *Node, dl: ArrayList[*Node]) void {
    let ty: []u8 = "int32_t";
    switch (arg.*) {
        .slit_ => |s| {
            if (len[[]u8](s.targs) > 0) { ty = mangle_generic(s.sname, s.targs); }
            else { ty = s.sname; }
        }
        else => { }
    }
    let ct: []u8 = ctype(ty);
    emit(buf, "({ "); emit(buf, ct); emit(buf, "* __n = (");
    emit(buf, ct); emit(buf, "*)malloc(sizeof("); emit(buf, ct); emit(buf, ")); *__n = ");
    gen_expr(buf, arg, dl);
    emit(buf, "; __n; })");
}

// OR of the arm's tag tests against the fixed `__sw` temp.
fn gen_arm_cond(buf: *ArrayList[u8], arm: SwitchArm, prefix: []u8, is_u: i32) void {
    emit(buf, "(");
    let ti: i32 = 0;
    while (ti < len[[]u8](arm.tags)) {
        if (ti > 0) { emit(buf, " || "); }
        if (is_u == 1) { emit(buf, "__sw.tag == "); } else { emit(buf, "__sw == "); }
        // integer/value switch (no enum/union prefix) → emit the literal verbatim
        if (prefix.len > 0) { emit(buf, prefix); emit(buf, "_"); }
        emit(buf, get[[]u8](arm.tags, ti));
        ti = ti + 1;
    }
    emit(buf, ")");
}

// The arm's value, with the payload bound via __auto_type for union captures.
fn gen_arm_value(buf: *ArrayList[u8], arm: SwitchArm, is_u: i32, dl: ArrayList[*Node]) void {
    if (is_u == 1 && arm.has_cap == 1) {
        emit(buf, "({ __auto_type ");
        emit(buf, arm.cap);
        emit(buf, " = __sw.u.");
        emit(buf, get[[]u8](arm.tags, 0));
        emit(buf, "; (");
        gen_expr(buf, body_expr(arm.body), dl);
        emit(buf, "); })");
    } else {
        emit(buf, "(");
        gen_expr(buf, body_expr(arm.body), dl);
        emit(buf, ")");
    }
}

fn gen_expr(buf: *ArrayList[u8], n: *Node, dl: ArrayList[*Node]) void {
    switch (n.*) {
        .ilit => |x| { emit(buf, x.text); }
        .slit => |x| {
            // string literal → ZagSliceU8{ ptr, len }
            emit(buf, "(ZagSliceU8){(const uint8_t*)");
            emit(buf, x.text);
            emit(buf, ", ");
            emit(buf, _zag_i64_to_str(str_lit_len(x.text) as i64));
            emit(buf, "}");
        }
        .id   => |x| {
            if (@strEq(x.name, "null")) { emit(buf, "0"); }
            else { emit(buf, x.name); }
        }
        .cast_ => |c| {
            // expr as Type → ((CType)(expr))
            emit(buf, "((");
            emit(buf, ctype(c.target));
            emit(buf, ")(");
            gen_expr(buf, c.expr, dl);
            emit(buf, "))");
        }
        .bin  => |b| {
            if (@strEq(b.op, "orelse")) {
                // opt orelse default → ({ __auto_type __o = opt; __o._has ? __o._val : default; })
                emit(buf, "({ __auto_type __o = ");
                gen_expr(buf, b.l, dl);
                emit(buf, "; __o._has ? __o._val : (");
                gen_expr(buf, b.r, dl);
                emit(buf, "); })");
            } else {
                emit(buf, "(");
                gen_expr(buf, b.l, dl);
                emit(buf, " ");
                emit(buf, b.op);
                emit(buf, " ");
                gen_expr(buf, b.r, dl);
                emit(buf, ")");
            }
        }
        .un   => |u| {
            emit(buf, "(");
            emit(buf, u.op);
            gen_expr(buf, u.e, dl);
            emit(buf, ")");
        }
        .call => |c| {
            let cn: []u8 = cg_callee_name(c.callee);
            if (cn.len > 0 && cn[0] == '@') {
                // @-builtin: @sizeOf[T](), @strEq(..), @len(..), @intCast(..), ...
                gen_builtin(buf, cn, c, dl);
            } else if (cg_starts_with(cn, "__icrc_") == 1) {
                // Interface coercion: __icrc_IfaceName_ConcreteName(arg)
                // Decode: strip "__icrc_", then split on last '_' (which may be inside a type name)
                // The encoding is: __icrc_<iface>_<concrete> where iface+concrete were joined.
                // We stored it as __icrc_<pt>_<argty> — so scan cn[7..] to find the split:
                // actually we just need iface (pt) and concrete (argty).
                // Approach: find the second separator by looking for a known iface name.
                // Simpler: the iface name is the part after "__icrc_" up to the point where
                // `iface_method_count(dl, prefix) > 0`. Try prefixes from left.
                let tail: []u8 = cn[7..];  // strip "__icrc_"
                let iname: []u8 = "";
                let cname: []u8 = "";
                let ti: i32 = 1;
                while (ti <= tail.len) {
                    let candidate: []u8 = tail[0..ti];
                    if (iface_method_count(dl, candidate) > 0) {
                        iname = candidate;
                        // cname is the rest after the '_' separator
                        if (ti + 1 < tail.len) { cname = tail[ti+1..]; }
                        ti = tail.len + 1;  // break
                    } else {
                        ti = ti + 1;
                    }
                }
                // Emit: ({ ConcreteName __zit = <arg>; (IfaceName){.vtbl=&__vtbl_C_I,.data=(void*)&__zit}; })
                emit(buf, "({ ");
                emit(buf, cname);
                emit(buf, " __zit = ");
                gen_expr(buf, get[*Node](c.args, 0), dl);
                emit(buf, "; (");
                emit(buf, iname);
                emit(buf, "){.vtbl=&__vtbl_");
                emit(buf, cname);
                emit(buf, "_");
                emit(buf, iname);
                emit(buf, ",.data=(void*)&__zit}; })");
            } else if (@strEq(cn, "__catch")) {
                // `e catch fb` → ({ __auto_type __t = e; __t._err ? (fb) : __t._val; })
                emit(buf, "({ __auto_type __t = ");
                gen_expr(buf, get[*Node](c.args, 0), dl);
                emit(buf, "; __t._err ? (");
                gen_expr(buf, get[*Node](c.args, 1), dl);
                emit(buf, ") : __t._val; })");
            } else if (@strEq(cn, "__catchc")) {
                // `e catch |err| fb` → bind err to the error code in the fallback
                emit(buf, "({ __auto_type __t = ");
                gen_expr(buf, get[*Node](c.args, 0), dl);
                emit(buf, "; __t._err ? ({ int32_t ");
                emit(buf, cg_callee_name(get[*Node](c.args, 1)));
                emit(buf, " = __t._err; (");
                gen_expr(buf, get[*Node](c.args, 2), dl);
                emit(buf, "); }) : __t._val; })");
            } else if (@strEq(cn, "__clocall")) {
                // call through a fn value: (v).fn((v).env, args...)
                emit(buf, "(");
                gen_expr(buf, get[*Node](c.args, 0), dl);
                emit(buf, ").fn((");
                gen_expr(buf, get[*Node](c.args, 0), dl);
                emit(buf, ").env");
                let ci: i32 = 1;
                while (ci < len[*Node](c.args)) {
                    emit(buf, ", ");
                    gen_expr(buf, get[*Node](c.args, ci), dl);
                    ci = ci + 1;
                }
                emit(buf, ")");
            } else if (@strEq(cn, "__clomake")) {
                // wrap a top-level fn / hoisted closure as a fat closure value
                gen_clomake(buf, get[*Node](c.args, 0), dl);
            } else if (@strEq(cn, "new") && len[*Node](c.args) == 1) {
                // new(T{..}) → heap-allocate T, store, return *T
                gen_new(buf, get[*Node](c.args, 0), dl);
            } else if (@strEq(cn, "delete") && len[*Node](c.args) == 1) {
                emit(buf, "free(");
                gen_expr(buf, get[*Node](c.args, 0), dl);
                emit(buf, ")");
            } else if (len[[]u8](c.targs) > 0) {
                // generic call foo[T](...) → mangled monomorphized name foo_T(...)
                emit(buf, mangle_generic(cn, c.targs));
                emit(buf, "(");
                gen_args(buf, c.args, dl);
                emit(buf, ")");
            } else {
                gen_expr(buf, c.callee, dl);
                emit(buf, "(");
                gen_args_typed(buf, cn, c.args, dl);
                emit(buf, ")");
            }
        }
        .fld  => |f| {
            // pointer deref `x.*` → `(*x)`
            if (@strEq(f.fname, "*")) {
                emit(buf, "(*");
                gen_expr(buf, f.base, dl);
                emit(buf, ")");
            } else if (@strEq(f.fname, "?")) {
                // force-unwrap `opt.?` → ({ __auto_type __fu = opt; __fu._val; })
                emit(buf, "({ __auto_type __fu = ");
                gen_expr(buf, f.base, dl);
                emit(buf, "; __fu._val; })");
            } else if (is_ident(f.base) && @strEq(id_name_of(f.base), "error")) {
                // bare error constant `error.X` → ZAG_ERR_X (the integer code)
                emit(buf, "ZAG_ERR_");
                emit(buf, f.fname);
            } else if (is_ident(f.base) && first_is_upper(f.fname)) {
                // enum member access `Color.Green` → `Color_Green`
                // (convention: enum members capitalized, struct fields lowercase)
                gen_expr(buf, f.base, dl);
                emit(buf, "_");
                emit(buf, f.fname);
            } else {
                gen_expr(buf, f.base, dl);
                emit(buf, ".");
                emit(buf, f.fname);
            }
        }
        .idx  => |x| {
            // slice base ([]T) indexes through .ptr; pointer/array base is direct
            if (x.ptr_base == 0) {
                emit(buf, "(");
                gen_expr(buf, x.base, dl);
                emit(buf, ").ptr[");
            } else {
                gen_expr(buf, x.base, dl);
                emit(buf, "[");
            }
            gen_expr(buf, x.idx, dl);
            emit(buf, "]");
        }
        .slice_ => |s| {
            // (ZagSliceU8){ <ptr> + lo, (hi | base.len) - lo }
            // s.ptr_base (stamped by the type pass) is 1 for a *T pointer base
            // (slice it directly) and 0 for a []T slice value (use .ptr/.len).
            emit(buf, "(ZagSliceU8){ (");
            gen_expr(buf, s.base, dl);
            if (s.ptr_base == 1) { emit(buf, ") + ("); } else { emit(buf, ").ptr + ("); }
            gen_expr(buf, s.lo, dl);
            emit(buf, "), (");
            if (s.has_hi == 1) {
                gen_expr(buf, s.hi, dl);
            } else {
                // open-ended is only meaningful for slice bases (a pointer has no len)
                emit(buf, "(");
                gen_expr(buf, s.base, dl);
                emit(buf, ").len");
            }
            emit(buf, ") - (");
            gen_expr(buf, s.lo, dl);
            emit(buf, ") }");
        }
        .slit_ => |s| {
            if (is_union(dl, s.sname)) {
                // tagged-union construction: (U){ .tag = U_field, .u = { .field = v } }
                let f0: FieldInit = get[FieldInit](s.fields, 0);
                emit(buf, "(");
                emit(buf, s.sname);
                emit(buf, "){ .tag = ");
                emit(buf, s.sname); emit(buf, "_"); emit(buf, f0.name);
                emit(buf, ", .u = { .");
                emit(buf, f0.name); emit(buf, " = ");
                gen_expr(buf, f0.val, dl);
                emit(buf, " } }");
            } else {
                // struct literal: (Name){ .field = val, ... }; generic → (Name_T){ ... }
                emit(buf, "(");
                if (len[[]u8](s.targs) > 0) {
                    emit(buf, mangle_generic(s.sname, s.targs));
                } else {
                    emit(buf, s.sname);
                }
                emit(buf, "){ ");
                let i: i32 = 0;
                while (i < len[FieldInit](s.fields)) {
                    if (i > 0) { emit(buf, ", "); }
                    let f: FieldInit = get[FieldInit](s.fields, i);
                    emit(buf, ".");
                    emit(buf, f.name);
                    emit(buf, " = ");
                    gen_expr(buf, f.val, dl);
                    i = i + 1;
                }
                emit(buf, " }");
            }
        }
        .switch_ => |sw| {
            // expression switch → ({ __auto_type __sw = subj; cond?val:cond?val:final; })
            let tag0: []u8 = switch_first_tag(sw);
            let uname: []u8 = union_name_for_tag(dl, tag0);
            let is_u: i32 = 0;
            let prefix: []u8 = "";
            if (uname.len > 0) { is_u = 1; prefix = uname; }
            else { prefix = enum_name_for_tag(dl, tag0); }
            emit(buf, "({ __auto_type __sw = ");
            gen_expr(buf, sw.subject, dl);
            emit(buf, "; ");
            let nn: i32 = len[SwitchArm](sw.arms);
            let last_uncond: i32 = 0;
            if (sw.has_els == 0) { last_uncond = 1; }   // exhaustive: last arm is the tail
            let ai: i32 = 0;
            while (ai < nn) {
                let arm: SwitchArm = get[SwitchArm](sw.arms, ai);
                if (last_uncond == 1 && ai == nn - 1) {
                    gen_arm_value(buf, arm, is_u, dl);
                } else {
                    gen_arm_cond(buf, arm, prefix, is_u);
                    emit(buf, " ? ");
                    gen_arm_value(buf, arm, is_u, dl);
                    emit(buf, " : ");
                }
                ai = ai + 1;
            }
            if (sw.has_els == 1) {
                emit(buf, "(");
                gen_expr(buf, body_expr(sw.els_body), dl);
                emit(buf, ")");
            }
            emit(buf, "; })");
        }
        else => { emit(buf, "0"); }
    }
}

fn is_opt_type(t: []u8) bool { return t.len > 1 && t[0] == '?'; }
fn is_err_type(t: []u8) bool { return t.len > 1 && t[0] == '!'; }

// `error.X` literal detection (parsed as Field(ident "error", X)).
fn is_error_lit(n: *Node) bool {
    return switch (n.*) {
        .fld => |f| is_ident(f.base) && @strEq(id_name_of(f.base), "error"),
        else => false,
    };
}
fn error_lit_name(n: *Node) []u8 {
    return switch (n.*) {
        .fld => |f| f.fname,
        else => "",
    };
}

// Is `n` a `try expr` node (Un("try", expr))?
fn is_try_expr(n: *Node) bool {
    return switch (n.*) {
        .un => |u| @strEq(u.op, "try"),
        else => false,
    };
}
fn un_inner(n: *Node) *Node {
    return switch (n.*) {
        .un => |u| u.e,
        else => n,
    };
}

// Emit `e` coerced to error-union type `errty` (!T): error.X → error struct;
// an already-error value → passthrough; a bare value → success { 0, e }.
fn gen_err_value(buf: *ArrayList[u8], errty: []u8, e: *Node, dl: ArrayList[*Node]) void {
    if (is_error_lit(e)) {
        emit(buf, "("); emit(buf, ctype(errty)); emit(buf, "){ ._err = ZAG_ERR_");
        emit(buf, error_lit_name(e));
        emit(buf, " }");
    } else {
        emit(buf, "("); emit(buf, ctype(errty)); emit(buf, "){ ._err = 0, ._val = ");
        gen_expr(buf, e, dl);
        emit(buf, " }");
    }
}

// Lower `try inner`: unwrap on success, else propagate (if the enclosing fn
// returns !T) or abort (if it can't).
fn gen_try(buf: *ArrayList[u8], fnret: []u8, inner: *Node, dl: ArrayList[*Node]) void {
    emit(buf, "({ __auto_type __t = ");
    gen_expr(buf, inner, dl);
    emit(buf, "; ");
    if (is_err_type(fnret)) {
        emit(buf, "if (__t._err) return (");
        emit(buf, ctype(fnret));
        emit(buf, "){ ._err = __t._err }; ");
    } else {
        emit(buf, "if (__t._err) { fprintf(stderr, \"zag: unhandled error\\n\"); exit(1); } ");
    }
    emit(buf, "__t._val; })");
}

// Emit `e` coerced to the optional type `optty` (?T): null → {0}; an existing
// optional → passthrough; a bare value → { _has=1, _val=e }.
fn gen_opt_value(buf: *ArrayList[u8], optty: []u8, e: *Node, dl: ArrayList[*Node]) void {
    if (is_null_expr(e)) {
        emit(buf, "("); emit(buf, ctype(optty)); emit(buf, "){0}");
    } else if (expr_is_optional(e, dl)) {
        gen_expr(buf, e, dl);
    } else {
        emit(buf, "("); emit(buf, ctype(optty)); emit(buf, "){1, ");
        gen_expr(buf, e, dl);
        emit(buf, "}");
    }
}

// ── statements ───────────────────────────────────────────────────────────────
// `fnret` is the enclosing function's return type, needed to wrap `return v;`
// when the function returns ?T.
fn gen_block(buf: *ArrayList[u8], body: ArrayList[*Node], dl: ArrayList[*Node], fnret: []u8) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        gen_stmt(buf, get[*Node](body, i), dl, fnret);
        i = i + 1;
    }
}

// First pattern tag of a switch (used to identify the subject's union/enum).
fn switch_first_tag(sw: Switch) []u8 {
    if (len[SwitchArm](sw.arms) == 0) { return ""; }
    let a0: SwitchArm = get[SwitchArm](sw.arms, 0);
    if (len[[]u8](a0.tags) == 0) { return ""; }
    return get[[]u8](a0.tags, 0);
}

// Emit the case labels + body for one arm. `prefix` is the union/enum name.
fn gen_switch_arm(buf: *ArrayList[u8], arm: SwitchArm, prefix: []u8, is_u: i32, dl: ArrayList[*Node], fnret: []u8) void {
    let ti: i32 = 0;
    while (ti < len[[]u8](arm.tags)) {
        emit(buf, "    case ");
        if (prefix.len > 0) { emit(buf, prefix); emit(buf, "_"); }
        emit(buf, get[[]u8](arm.tags, ti));
        emit(buf, ":\n");
        ti = ti + 1;
    }
    emit(buf, "    {\n");
    if (is_u == 1 && arm.has_cap == 1) {
        // capture the active payload; __auto_type lets us stay type-unaware
        emit(buf, "        __auto_type ");
        emit(buf, arm.cap);
        emit(buf, " = __sw.u.");
        emit(buf, get[[]u8](arm.tags, 0));
        emit(buf, ";\n");
    }
    gen_block(buf, arm.body, dl, fnret);
    emit(buf, "        break;\n    }\n");
}

fn gen_switch(buf: *ArrayList[u8], sw: Switch, dl: ArrayList[*Node], fnret: []u8) void {
    let tag0: []u8 = switch_first_tag(sw);
    let uname: []u8 = union_name_for_tag(dl, tag0);
    let is_u: i32 = 0;
    let prefix: []u8 = "";
    if (uname.len > 0) { is_u = 1; prefix = uname; }
    else { prefix = enum_name_for_tag(dl, tag0); }

    // A fresh block scopes the fixed `__sw` temp, so nested/sequential switches
    // don't collide without needing a global counter.
    emit(buf, "    {\n");
    if (is_u == 1) {
        emit(buf, "    "); emit(buf, prefix); emit(buf, " __sw = ");
        gen_expr(buf, sw.subject, dl);
        emit(buf, ";\n    switch (__sw.tag) {\n");
    } else {
        emit(buf, "    switch (");
        gen_expr(buf, sw.subject, dl);
        emit(buf, ") {\n");
    }
    let ai: i32 = 0;
    while (ai < len[SwitchArm](sw.arms)) {
        gen_switch_arm(buf, get[SwitchArm](sw.arms, ai), prefix, is_u, dl, fnret);
        ai = ai + 1;
    }
    if (sw.has_els == 1) {
        emit(buf, "    default:\n    {\n");
        gen_block(buf, sw.els_body, dl, fnret);
        emit(buf, "        break;\n    }\n");
    }
    emit(buf, "    }\n    }\n");
}

fn gen_stmt(buf: *ArrayList[u8], n: *Node, dl: ArrayList[*Node], fnret: []u8) void {
    switch (n.*) {
        .let_ => |l| {
            emit(buf, "    ");
            if (l.calign > 0) {   // @cacheAlign(N): pin this local to its own cache line
                emit(buf, "_Alignas(");
                emit(buf, _zag_i64_to_str(l.calign as i64));
                emit(buf, ") ");
            }
            emit(buf, ctype(l.dty));
            emit(buf, " ");
            emit(buf, l.name);
            if (l.has_init == 1) {
                emit(buf, " = ");
                if (is_opt_type(l.dty)) {
                    gen_opt_value(buf, l.dty, l.expr, dl);   // ?T = null | value | optional
                } else if (is_try_expr(l.expr)) {
                    gen_try(buf, fnret, un_inner(l.expr), dl);   // let x = try f();
                } else if (is_rns_ty(l.dty) == 1 && is_int_literal(l.expr) == 1) {
                    // rns_N from an int literal → zag_rns_from_i64(literal)
                    emit(buf, "zag_rns_from_i64(");
                    gen_expr(buf, l.expr, dl);
                    emit(buf, ")");
                } else {
                    gen_expr(buf, l.expr, dl);
                }
            }
            emit(buf, ";\n");
        }
        .ret => |r| {
            emit(buf, "    return");
            if (r.has_expr == 1) {
                emit(buf, " ");
                if (is_opt_type(fnret)) {
                    gen_opt_value(buf, fnret, r.expr, dl);   // wrap into the ?T return
                } else if (is_err_type(fnret) && !is_try_expr(r.expr)) {
                    gen_err_value(buf, fnret, r.expr, dl);   // wrap into the !T return
                } else if (is_try_expr(r.expr)) {
                    gen_try(buf, fnret, un_inner(r.expr), dl);
                } else {
                    gen_expr(buf, r.expr, dl);
                }
            }
            emit(buf, ";\n");
        }
        .if_ => |x| {
            if (x.has_cap == 1) {
                // if-let: `if (opt) |cap| { then } else { els }`
                emit(buf, "    { __auto_type __ifopt = ");
                gen_expr(buf, x.cond, dl);
                emit(buf, "; if (__ifopt._has) {\n");
                emit(buf, "        __auto_type ");
                emit(buf, x.cap);
                emit(buf, " = __ifopt._val;\n");
                gen_block(buf, x.then_body, dl, fnret);
                emit(buf, "    }");
                if (x.has_els == 1) {
                    emit(buf, " else {\n");
                    gen_block(buf, x.els_body, dl, fnret);
                    emit(buf, "    }");
                }
                emit(buf, " }\n");
            } else {
                emit(buf, "    if (");
                gen_expr(buf, x.cond, dl);
                emit(buf, ") {\n");
                gen_block(buf, x.then_body, dl, fnret);
                emit(buf, "    }");
                if (x.has_els == 1) {
                    emit(buf, " else {\n");
                    gen_block(buf, x.els_body, dl, fnret);
                    emit(buf, "    }");
                }
                emit(buf, "\n");
            }
        }
        .while_ => |w| {
            if (w.has_cap == 1) {
                // while-let: `while (opt) |cap| { body }` — loop while optional has value
                emit(buf, "    { __auto_type __wopt; while ((__wopt = (");
                gen_expr(buf, w.cond, dl);
                emit(buf, "))._has) { __auto_type ");
                emit(buf, w.cap);
                emit(buf, " = __wopt._val;\n");
                gen_block(buf, w.body, dl, fnret);
                emit(buf, "    } }\n");
            } else {
                emit(buf, "    while (");
                gen_expr(buf, w.cond, dl);
                emit(buf, ") {\n");
                gen_block(buf, w.body, dl, fnret);
                emit(buf, "    }\n");
            }
        }
        .assign => |a| {
            emit(buf, "    ");
            gen_expr(buf, a.target, dl);
            emit(buf, " = ");
            gen_expr(buf, a.expr, dl);
            emit(buf, ";\n");
        }
        .switch_ => |sw| { gen_switch(buf, sw, dl, fnret); }
        .estmt => |e| {
            emit(buf, "    ");
            gen_expr(buf, e.expr, dl);
            emit(buf, ";\n");
        }
        else => { }
    }
}

// ── type pass: classify index/slice bases as slice (.ptr) vs pointer ──────────
// The codegen is otherwise type-unaware, but `s[i]` on a []T slice must become
// `s.ptr[i]` while `p[i]` on a *T pointer stays `p[i]`. Both are ident-based, so
// we run a small per-function pass that builds a name→type scope (params + typed
// lets) and stamps each Index/Slice node's `ptr_base` flag before codegen.
struct Binding { name: []u8, ty: []u8 }

fn env_lookup(env: ArrayList[Binding], name: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[Binding](env)) {
        if (@strEq(get[Binding](env, i).name, name)) { return get[Binding](env, i).ty; }
        i = i + 1;
    }
    return "";
}

// "StringMap[V]" → "StringMap"; leaves a plain name unchanged.
fn strip_gapp(t: []u8) []u8 {
    if (is_generic_app(t)) { return t[0..index_of(t, '[')]; }
    return t;
}

// Declared type of `field` on a struct value of type `sty` (or "" if unknown).
fn struct_field_type(sty: []u8, field: []u8, dl: ArrayList[*Node]) []u8 {
    let base: []u8 = strip_gapp(sty);
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .struct_ => |s| {
                if (@strEq(s.name, base)) {
                    let j: i32 = 0;
                    while (j < len[Param](s.fields)) {
                        if (@strEq(get[Param](s.fields, j).name, field)) { return get[Param](s.fields, j).pty; }
                        j = j + 1;
                    }
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// The fname of a field access (or "" if `n` is not a field).
fn field_fname(n: *Node) []u8 {
    return switch (n.*) {
        .fld => |f| f.fname,
        else => "",
    };
}

// Coarse type of an expression — enough to tell []T (slice) from *T (pointer).
fn base_type(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    return switch (n.*) {
        .id  => |x| env_lookup(env, x.name),
        .cast_ => |c| c.target,
        .fld => |f| base_field_type(f, env, dl),
        .idx => |x| base_elem_type(base_type(x.base, env, dl)),
        else => "",
    };
}

fn base_field_type(f: Field, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    if (@strEq(f.fname, "*")) {
        // pointer deref: *T → T
        let bt: []u8 = base_type(f.base, env, dl);
        if (bt.len > 1 && bt[0] == '*') { return bt[1..]; }
        return "";
    }
    return struct_field_type(base_type(f.base, env, dl), f.fname, dl);
}

// Element type of an indexable: []T → T, *T → T.
fn base_elem_type(bt: []u8) []u8 {
    if (bt.len > 2 && bt[0] == '[' && bt[1] == ']') { return bt[2..]; }
    if (bt.len > 1 && bt[0] == '*') { return bt[1..]; }
    return "";
}

// ── expression typing (for heterogeneous-numeric op lowering) ────────────────
// Result type of a numeric @-builtin call (the casts/quire ops). "" otherwise.
fn numeric_builtin_ret(name: []u8) []u8 {
    if (name.len < 2 || name[0] != '@') { return ""; }
    let b: []u8 = name[1..];
    if (@strEq(b, "intToPosit") || @strEq(b, "floatToPosit")) { return "p32"; }
    if (@strEq(b, "positToFloat")) { return "f64"; }
    if (@strEq(b, "positToBits")) { return "u64"; }
    if (@strEq(b, "intToP8") || @strEq(b, "floatToP8")) { return "p8"; }
    if (@strEq(b, "intToP16") || @strEq(b, "floatToP16")) { return "p16"; }
    if (@strEq(b, "intToP64") || @strEq(b, "floatToP64")) { return "p64"; }
    if (@strEq(b, "p8ToFloat") || @strEq(b, "p16ToFloat") || @strEq(b, "p64ToFloat")) { return "f64"; }
    if (@strEq(b, "p8ToBits") || @strEq(b, "p16ToBits") || @strEq(b, "p64ToBits")) { return "u64"; }
    if (@strEq(b, "quireZero") || @strEq(b, "quireFMA")) { return "quire"; }
    if (@strEq(b, "quireToPosit")) { return "p32"; }
    return "";
}

// Declared return type of a (non-generic) user fn named `nm`, or "" if unknown.
fn cg_fn_ret_type(nm: []u8, dl: ArrayList[*Node]) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| { if (@strEq(f.name, nm)) { return f.ret; } }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// Coarse type of an expression, enough to drive numeric op lowering.
fn expr_type(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    return switch (n.*) {
        .ilit => |x| "int_lit",
        .id   => |x| env_lookup(env, x.name),
        .cast_ => |c| c.target,
        .fld  => |f| base_field_type(f, env, dl),
        .idx  => |x| base_elem_type(expr_type(x.base, env, dl)),
        .un   => |u| expr_type(u.e, env, dl),
        .call => |c| call_result_type(c, env, dl),
        .bin  => |b| bin_result_type(b, env, dl),
        else  => "",
    };
}

fn call_result_type(c: Call, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    let nm: []u8 = cg_callee_name(c.callee);
    if (nm.len > 0 && nm[0] == '@') {
        let r: []u8 = numeric_builtin_ret(nm);
        if (r.len > 0) { return r; }
        return "";
    }
    return cg_fn_ret_type(nm, dl);
}

// Result type of `l <op> b.r`, mirroring sema's numeric typeOfBin rules.
fn bin_result_type(b: Bin, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    // comparisons → bool
    if (@strEq(b.op, "==") || @strEq(b.op, "!=") || @strEq(b.op, "<") || @strEq(b.op, ">")
        || @strEq(b.op, "<=") || @strEq(b.op, ">=") || @strEq(b.op, "and") || @strEq(b.op, "or")
        || @strEq(b.op, "&&") || @strEq(b.op, "||")) { return "bool"; }
    let lt: []u8 = expr_type(b.l, env, dl);
    let rt: []u8 = expr_type(b.r, env, dl);
    // a concrete numeric type wins over an int_lit on the other side
    if (is_numeric_concrete(lt) == 1) { return lt; }
    if (is_numeric_concrete(rt) == 1) { return rt; }
    if (lt.len > 0 && !@strEq(lt, "int_lit")) { return lt; }
    if (rt.len > 0 && !@strEq(rt, "int_lit")) { return rt; }
    return lt;
}

// 1 iff t is a concrete heterogeneous numeric type (not int_lit / a plain int).
fn is_numeric_concrete(t: []u8) i32 {
    if (cg_is_posit(t) == 1) { return 1; }
    if (@strEq(t, "quire")) { return 1; }
    if (is_sat_ty(t) == 1) { return 1; }
    if (is_rns_ty(t) == 1) { return 1; }
    if (is_fixed_ty(t) == 1) { return 1; }
    if (is_arb_int_ty(t) == 1) { return 1; }
    if (is_bignum_ty(t) == 1) { return 1; }
    return 0;
}

// index `base[i]`: 1 (direct) unless base is a known []T slice → 0 (use .ptr).
fn classify_idx(base: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) i32 {
    let bt: []u8 = base_type(base, env, dl);
    if (bt.len > 2 && bt[0] == '[' && bt[1] == ']') { return 0; }
    return 1;
}

// slice `base[lo..hi]`: 1 if base is a *T pointer, 0 if a []T slice; when the
// type is unknown, fall back to shape (a non-deref struct field is a pointer).
fn classify_slice(base: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) i32 {
    let bt: []u8 = base_type(base, env, dl);
    if (bt.len > 1 && bt[0] == '*') { return 1; }
    if (bt.len > 2 && bt[0] == '[' && bt[1] == ']') { return 0; }
    let fn_: []u8 = field_fname(base);
    if (fn_.len > 0 && !@strEq(fn_, "*")) { return 1; }
    return 0;
}

// Declared payload type of a union tag (e.g. tag "fn_decl" of union Node → FnDecl).
fn union_payload_type(dl: ArrayList[*Node], tag: []u8) []u8 {
    let uname: []u8 = union_name_for_tag(dl, tag);
    if (uname.len == 0) { return ""; }
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .union_ => |u| {
                if (@strEq(u.name, uname)) {
                    let j: i32 = 0;
                    while (j < len[Param](u.fields)) {
                        if (@strEq(get[Param](u.fields, j).name, tag)) { return get[Param](u.fields, j).pty; }
                        j = j + 1;
                    }
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

fn build_env_block(body: ArrayList[*Node], env: *ArrayList[Binding], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { build_env_stmt(get[*Node](body, i), env, dl); i = i + 1; }
}

fn build_env_stmt(n: *Node, env: *ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .let_   => |l| { if (l.has_dty == 1) { push[Binding](env, Binding{ .name = l.name, .ty = l.dty }); } }
        .if_    => |x| {
            // if-let `if (opt) |cap| {}` binds cap to the optional's payload type
            if (x.has_cap == 1) {
                let ct: []u8 = expr_type(x.cond, env.*, dl);
                if (ct.len > 1 && ct[0] == '?') { push[Binding](env, Binding{ .name = x.cap, .ty = ct[1..] }); }
            }
            build_env_block(x.then_body, env, dl);
            if (x.has_els == 1) { build_env_block(x.els_body, env, dl); }
        }
        .while_ => |w| { build_env_block(w.body, env, dl); }
        .switch_ => |sw| {
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) {
                let arm: SwitchArm = get[SwitchArm](sw.arms, ai);
                // a union-switch capture `|cap|` binds cap to the tag's payload type
                if (arm.has_cap == 1 && len[[]u8](arm.tags) > 0) {
                    let pt: []u8 = union_payload_type(dl, get[[]u8](arm.tags, 0));
                    if (pt.len > 0) { push[Binding](env, Binding{ .name = arm.cap, .ty = pt }); }
                }
                build_env_block(arm.body, env, dl);
                ai = ai + 1;
            }
            if (sw.has_els == 1) { build_env_block(sw.els_body, env, dl); }
        }
        else => { }
    }
}

fn build_env(params: ArrayList[Param], body: ArrayList[*Node], dl: ArrayList[*Node]) ArrayList[Binding] {
    let env: ArrayList[Binding] = make[Binding](8);
    let i: i32 = 0;
    while (i < len[Param](params)) {
        push[Binding](&env, Binding{ .name = get[Param](params, i).name, .ty = get[Param](params, i).pty });
        i = i + 1;
    }
    build_env_block(body, &env, dl);
    return env;
}

// ── method dispatch (value.method(args) → RecvType_method(value, args)) ───────
fn id_name_of(n: *Node) []u8 {
    return switch (n.*) {
        .id  => |x| x.name,
        else => "",
    };
}

fn find_enum(dl: ArrayList[*Node], name: []u8) bool {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .enum_ => |e| { if (@strEq(e.name, name)) { return true; } }
            else => { }
        }
        i = i + 1;
    }
    return false;
}

fn fn_exists(dl: ArrayList[*Node], name: []u8) bool {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| { if (@strEq(f.name, name)) { return true; } }
            else => { }
        }
        i = i + 1;
    }
    return false;
}

// Type-name of a method receiver expression, used to form `RecvType_method`.
fn recv_field_type(f: Field, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    // enum member access `EnumName.Member` has type `EnumName`
    let bn: []u8 = id_name_of(f.base);
    if (bn.len > 0 && find_enum(dl, bn)) { return bn; }
    return base_field_type(f, env, dl);
}

fn recv_type(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    return switch (n.*) {
        .id    => |x| env_lookup(env, x.name),
        .call  => |c| call_result_type(c, env, dl),
        .cast_ => |c| c.target,
        .idx   => |x| base_elem_type(recv_type(x.base, env, dl)),
        .fld   => |f| recv_field_type(f, env, dl),
        .slit_ => |s| s.sname,
        else   => "",
    };
}

// Rewrite a method call `base.method(args)` in place into the flat C call
// `RecvType_method(base, args)`, when such a method exists. Returns true if
// rewritten (n.* mutated).
fn try_method_call(n: *Node, c: Call, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (c.callee.*) {
        .fld => |f| {
            if (@strEq(f.fname, "*") || @strEq(f.fname, "?")) { return; }
            // enum-member value access (Day.Mon) is not a method call
            let bn: []u8 = id_name_of(f.base);
            if (bn.len > 0 && find_enum(dl, bn) && first_is_upper(f.fname)) { return; }
            let rt: []u8 = recv_type(f.base, env, dl);
            if (rt.len == 0) { return; }
            // Interface dispatch: s.method(args) → __idsp_IfaceName_method(s, args)
            if (iface_method_count(dl, rt) > 0) {
                let dname: []u8 = _zag_str_concat("__idsp_", _zag_str_concat(rt, _zag_str_concat("_", f.fname)));
                let nargs: ArrayList[*Node] = make[*Node](4);
                push[*Node](&nargs, f.base);
                let k: i32 = 0;
                while (k < len[*Node](c.args)) { push[*Node](&nargs, get[*Node](c.args, k)); k = k + 1; }
                n.* = Node{ .call = Call{ .callee = mk_ident(dname), .args = nargs, .targs = c.targs } };
                return;
            }
            // Concrete method: value.method(args) → RecvType_method(value, args)
            let mname: []u8 = _zag_str_concat(_zag_str_concat(rt, "_"), f.fname);
            if (!fn_exists(dl, mname)) { return; }
            let nargs: ArrayList[*Node] = make[*Node](4);
            push[*Node](&nargs, f.base);
            let k: i32 = 0;
            while (k < len[*Node](c.args)) { push[*Node](&nargs, get[*Node](c.args, k)); k = k + 1; }
            n.* = Node{ .call = Call{ .callee = mk_ident(mname), .args = nargs, .targs = c.targs } };
        }
        else => { }
    }
}

// Interface coercion in the annotate pass: when a call has an interface-typed
// parameter and the argument is a concrete struct, insert a special marker call
// `__icrc_IfaceName_ConcreteName(arg)` so gen_expr can emit the fat-pointer.
// We rebuild the entire args list (and thus n.*) to avoid circular aliasing.
fn try_iface_coerce(n: *Node, c: Call, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    let cn: []u8 = cg_callee_name(c.callee);
    if (cn.len == 0) { return; }
    // First pass: check if any coercion is needed.
    let needs: i32 = 0;
    let i: i32 = 0;
    while (i < len[*Node](c.args)) {
        let pt: []u8 = callee_param_type(cn, i, dl);
        if (iface_method_count(dl, pt) > 0) {
            let argty: []u8 = expr_type(get[*Node](c.args, i), env, dl);
            if (argty.len > 0 && iface_method_count(dl, argty) == 0) { needs = 1; }
        }
        i = i + 1;
    }
    if (needs == 0) { return; }
    // Second pass: build fresh args list with coercions inserted.
    let nargs: ArrayList[*Node] = make[*Node](4);
    let j: i32 = 0;
    while (j < len[*Node](c.args)) {
        let pt: []u8 = callee_param_type(cn, j, dl);
        let arg: *Node = get[*Node](c.args, j);
        if (iface_method_count(dl, pt) > 0) {
            let argty: []u8 = expr_type(arg, env, dl);
            if (argty.len > 0 && iface_method_count(dl, argty) == 0) {
                // Wrap: __icrc_IfaceName_ConcreteName(arg)
                let marker: []u8 = _zag_str_concat("__icrc_", _zag_str_concat(pt, _zag_str_concat("_", argty)));
                let ca: ArrayList[*Node] = make[*Node](1);
                push[*Node](&ca, arg);   // arg is a *Node — reuse the existing heap node
                push[*Node](&nargs, mk_call(mk_ident(marker), ca));
            } else {
                push[*Node](&nargs, arg);
            }
        } else {
            push[*Node](&nargs, arg);
        }
        j = j + 1;
    }
    n.* = Node{ .call = Call{ .callee = c.callee, .args = nargs, .targs = c.targs } };
}

// ── heterogeneous-numeric op lowering ────────────────────────────────────────
// Rewrite a binary op on a numeric type into the runtime call / masked / shifted
// form, mirroring src/codegen.zig + src/numeric_prelude.c. `bt` is the operand
// result type. Children (b.l / b.r) are already annotated. Returns a *Node: the
// lowered form, or a faithful rebuild of the original op when nothing applies.
fn cg_call2(name: []u8, l: *Node, r: *Node) *Node {
    let args: ArrayList[*Node] = make[*Node](2);
    push[*Node](&args, l);
    push[*Node](&args, r);
    return mk_call(mk_ident(name), args);
}

fn lower_numeric_bin(b: Bin, bt: []u8) *Node {
    // posit p8/p16/p32/p64 → zag_pN_{add,sub,mul,div}
    if (cg_is_posit(bt) == 1) {
        let suf: []u8 = "";
        if (@strEq(b.op, "+")) { suf = "add"; }
        else if (@strEq(b.op, "-")) { suf = "sub"; }
        else if (@strEq(b.op, "*")) { suf = "mul"; }
        else if (@strEq(b.op, "/")) { suf = "div"; }
        if (suf.len > 0) {
            let nm: []u8 = _zag_str_concat(_zag_str_concat(_zag_str_concat("zag_", bt), "_"), suf);
            return cg_call2(nm, b.l, b.r);
        }
    }

    // saturating sat_<base> → zag_sat_{add,sub,mul}_<base>
    if (is_sat_ty(bt) == 1) {
        let suf: []u8 = "";
        if (@strEq(b.op, "+")) { suf = "add"; }
        else if (@strEq(b.op, "-")) { suf = "sub"; }
        else if (@strEq(b.op, "*")) { suf = "mul"; }
        if (suf.len > 0) {
            let nm: []u8 = _zag_str_concat(_zag_str_concat(_zag_str_concat("zag_sat_", suf), "_"), sat_base(bt));
            return cg_call2(nm, b.l, b.r);
        }
    }

    // RNS rns_N → zag_rns_{add,sub,mul} (lane-parallel modular arithmetic)
    if (is_rns_ty(bt) == 1) {
        let nm: []u8 = "";
        if (@strEq(b.op, "+")) { nm = "zag_rns_add"; }
        else if (@strEq(b.op, "-")) { nm = "zag_rns_sub"; }
        else if (@strEq(b.op, "*")) { nm = "zag_rns_mul"; }
        if (nm.len > 0) { return cg_call2(nm, b.l, b.r); }
    }

    // fixed_I_F: multiply does (a*b)>>F in int64; +/- stay native.
    if (is_fixed_ty(bt) == 1) {
        if (@strEq(b.op, "*")) {
            let f: i64 = fixed_frac_bits(bt);
            let prod: *Node = mk_bin("*", mk_cast(b.l, "i64"), b.r);
            let shft: *Node = mk_bin(">>", prod, mk_int(_zag_i64_to_str(f)));
            return mk_cast(shft, "i32");
        }
        // +, - : native int32 add/sub — fall through to a plain rebuild.
    }

    // arbitrary-width uN/iN: mask the result to N bits (unsigned; signed widths
    // fall through — the examples only exercise u7/u11). Applies to +,-,*,&,^,|.
    if (is_arb_int_ty(bt) == 1 && arb_int_signed(bt) == 0) {
        let is_mask_op: i32 = 0;
        if (@strEq(b.op, "+") || @strEq(b.op, "-") || @strEq(b.op, "*")
            || @strEq(b.op, "&") || @strEq(b.op, "^") || @strEq(b.op, "|")) { is_mask_op = 1; }
        if (is_mask_op == 1) {
            let raw: *Node = mk_bin(b.op, b.l, b.r);
            let mask: []u8 = arb_mask_str(arb_int_bits(bt));
            return mk_bin("&", raw, mk_int(mask));
        }
    }

    // bignum u_any/i_any and everything else: native C operator.
    return mk_bin(b.op, b.l, b.r);
}

// Walk the body, stamping ptr_base on every Index/Slice node.
fn annotate_expr(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .bin => |b| {
            // Compute the operand type from the ORIGINAL operands first (before
            // children are rewritten into runtime calls), then recurse, then
            // lower the node in place if it is a heterogeneous-numeric op.
            let bt: []u8 = bin_result_type(b, env, dl);
            annotate_expr(b.l, env, dl);
            annotate_expr(b.r, env, dl);
            if (!@strEq(b.op, "orelse")) {
                let lowered: *Node = lower_numeric_bin(b, bt);
                n.* = lowered.*;
            }
        }
        .un  => |u| { annotate_expr(u.e, env, dl); }
        .call => |c| {
            annotate_expr(c.callee, env, dl);
            let i: i32 = 0;
            while (i < len[*Node](c.args)) { annotate_expr(get[*Node](c.args, i), env, dl); i = i + 1; }
            // rewrite `value.method(args)` → `RecvType_method(value, args)` or `__idsp_*(args)`
            try_method_call(n, c, env, dl);
            // after method-call rewrite, coerce concrete→interface args
            switch (n.*) { .call => |c2| { try_iface_coerce(n, c2, env, dl); } else => { } }
        }
        .fld => |f| { annotate_expr(f.base, env, dl); }
        .cast_ => |c| { annotate_expr(c.expr, env, dl); }
        .idx => |x| {
            annotate_expr(x.base, env, dl); annotate_expr(x.idx, env, dl);
            n.* = Node{ .idx = Index{ .base = x.base, .idx = x.idx, .ptr_base = classify_idx(x.base, env, dl) } };
        }
        .slice_ => |s| {
            annotate_expr(s.base, env, dl); annotate_expr(s.lo, env, dl); annotate_expr(s.hi, env, dl);
            n.* = Node{ .slice_ = Slice{ .base = s.base, .lo = s.lo, .hi = s.hi, .has_hi = s.has_hi, .ptr_base = classify_slice(s.base, env, dl) } };
        }
        .slit_ => |s| {
            let i: i32 = 0;
            while (i < len[FieldInit](s.fields)) { annotate_expr(get[FieldInit](s.fields, i).val, env, dl); i = i + 1; }
        }
        else => { }
    }
}

// ── operator contracts: rewrite `a <op> b` (a,b : T) → decode(a, b) ───────────
// A pre-sema, type-driven pass: when both operands have a user type T carrying an
// `operator T { + => fn, ... }` contract, the binary op is rewritten into an
// explicit call to the named decode fn. Doing this BEFORE the effect checker runs
// means the decode fn's effect flows into the caller automatically (so a contract
// can't smuggle Alloc past an @realtime proof), and codegen needs no special case.
fn lo_expr(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .bin => |b| {
            lo_expr(b.l, env, dl);
            lo_expr(b.r, env, dl);
            if (@strEq(b.op, "+") || @strEq(b.op, "-") || @strEq(b.op, "*") || @strEq(b.op, "/")) {
                let lt: []u8 = expr_type(b.l, env, dl);
                let decode: []u8 = op_contract_fn(dl, lt, b.op);
                if (decode.len > 0) {
                    let call: *Node = cg_call2(decode, b.l, b.r);
                    n.* = call.*;
                }
            }
        }
        .un  => |u| { lo_expr(u.e, env, dl); }
        .call => |c| {
            lo_expr(c.callee, env, dl);
            let i: i32 = 0;
            while (i < len[*Node](c.args)) { lo_expr(get[*Node](c.args, i), env, dl); i = i + 1; }
        }
        .idx => |x| { lo_expr(x.base, env, dl); lo_expr(x.idx, env, dl); }
        .fld => |f| { lo_expr(f.base, env, dl); }
        .slice_ => |s| { lo_expr(s.base, env, dl); lo_expr(s.lo, env, dl); lo_expr(s.hi, env, dl); }
        .slit_ => |s| {
            let i: i32 = 0;
            while (i < len[FieldInit](s.fields)) { lo_expr(get[FieldInit](s.fields, i).val, env, dl); i = i + 1; }
        }
        else => { }
    }
}

fn lo_block(body: ArrayList[*Node], env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { lo_stmt(get[*Node](body, i), env, dl); i = i + 1; }
}

fn lo_stmt(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .let_   => |l| { lo_expr(l.expr, env, dl); }
        .ret    => |r| { if (r.has_expr == 1) { lo_expr(r.expr, env, dl); } }
        .if_    => |x| { lo_expr(x.cond, env, dl); lo_block(x.then_body, env, dl); if (x.has_els == 1) { lo_block(x.els_body, env, dl); } }
        .while_ => |w| { lo_expr(w.cond, env, dl); lo_block(w.body, env, dl); }
        .assign => |a| { lo_expr(a.target, env, dl); lo_expr(a.expr, env, dl); }
        .switch_ => |sw| {
            lo_expr(sw.subject, env, dl);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { lo_block(get[SwitchArm](sw.arms, ai).body, env, dl); ai = ai + 1; }
            if (sw.has_els == 1) { lo_block(sw.els_body, env, dl); }
        }
        .estmt  => |e| { lo_expr(e.expr, env, dl); }
        else => { }
    }
}

// Rewrite every operator-contract binary op in the program to its decode call.
// Idempotent: a second pass sees calls (no bins) and changes nothing.
fn lower_operators(decls: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        switch (get[*Node](decls, i).*) {
            .fn_decl => |f| {
                if (f.is_extern == 0 && len[[]u8](f.tparams) == 0 && cg_starts_with(f.name, "__op_") == 0) {
                    lo_block(f.body, build_env(f.params, f.body, decls), decls);
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

// ════════════════════════════════════════════════════════════════════════════
//  CAPTURING CLOSURES — the fat-pointer model.
//
//  A fn-typed value is lowered to a C struct { Ret (*fn)(void*, P...); void* env; }.
//  A closure literal `fn[gain](x){...}` becomes a hoisted fn `__clos_N` taking the
//  environment as a hidden first arg (void*), with the captures copied into a stack
//  env struct at the creation site. A named fn used as a value gets a thunk that
//  ignores the env. Calls through a fn value dispatch as `(v).fn((v).env, args)`.
//
//  This is a pre-codegen pass (runs before monomorphization & emission) that
//  mutates the AST: fn-value CALLS → `__clocall(callee, args...)`, fn-value
//  PRODUCTIONS (bare fn / closure ids in a fn-typed context) → `__clomake(id)`.
//  Codegen then lowers the two markers; sema is untouched (it has its own model).
// ════════════════════════════════════════════════════════════════════════════

// Type of field `fname` in struct `sname` (honours a generic-app base), "" if none.
fn cg_struct_field_ty(dl: ArrayList[*Node], sname: []u8, fname: []u8) []u8 {
    let base: []u8 = sname;
    let lb: i32 = index_of(sname, '[');
    if (lb > 0) { base = sname[0..lb]; }
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .struct_ => |s| {
                if (@strEq(s.name, base)) {
                    let j: i32 = 0;
                    while (j < len[Param](s.fields)) {
                        if (@strEq(get[Param](s.fields, j).name, fname)) { return get[Param](s.fields, j).pty; }
                        j = j + 1;
                    }
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// The fn type of a field-access callee `base.fname` if that field is fn-typed, else "".
fn field_fnval_ty(f: Field, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    if (@strEq(f.fname, "*") || @strEq(f.fname, "?")) { return ""; }
    let rt: []u8 = recv_type(f.base, env, dl);
    if (rt.len == 0) { return ""; }
    return cg_struct_field_ty(dl, rt, f.fname);
}

// 1 iff parameter #idx of any declared fn named `cn` (generic or not) is fn-typed.
fn cg_callee_param_is_fn(cn: []u8, idx: i32, dl: ArrayList[*Node]) i32 {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| {
                if (@strEq(f.name, cn)) {
                    if (idx < len[Param](f.params)) {
                        if (is_fn_type(get[Param](f.params, idx).pty) == 1) { return 1; }
                    }
                    return 0;
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return 0;
}

// Build the canonical fn-type string "fn(P1,P2)Ret" of a declared fn named `name`.
fn cg_fn_type_of(dl: ArrayList[*Node], name: []u8) []u8 {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| {
                if (@strEq(f.name, name)) {
                    let s: []u8 = "fn(";
                    let j: i32 = 0;
                    while (j < len[Param](f.params)) {
                        if (j > 0) { s = _zag_str_concat(s, ","); }
                        s = _zag_str_concat(s, get[Param](f.params, j).pty);
                        j = j + 1;
                    }
                    return _zag_str_concat(_zag_str_concat(s, ")"), f.ret);
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return "";
}

// Resolve a capturing closure's capture types from the binding env at its creation
// site, storing them (comma-joined) onto the closure's FnDecl. Runs once per closure.
fn set_clos_captypes(dl: ArrayList[*Node], closname: []u8, env: ArrayList[Binding]) void {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        let d: *Node = get[*Node](dl, i);
        switch (d.*) {
            .fn_decl => |f| {
                if (@strEq(f.name, closname) && f.cap_types.len == 0 && f.cap_names.len > 0) {
                    let names: ArrayList[[]u8] = split_args(f.cap_names);
                    let tys: []u8 = "";
                    let k: i32 = 0;
                    while (k < len[[]u8](names)) {
                        if (k > 0) { tys = _zag_str_concat(tys, ","); }
                        tys = _zag_str_concat(tys, env_lookup(env, get[[]u8](names, k)));
                        k = k + 1;
                    }
                    d.* = Node{ .fn_decl = FnDecl{
                        .name = f.name, .tparams = f.tparams, .params = f.params, .ret = f.ret,
                        .annots = f.annots, .body = f.body, .is_extern = f.is_extern,
                        .ret_eff = f.ret_eff, .caps = f.caps, .cap_names = f.cap_names, .cap_types = tys } };
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

// Wrap a bare fn / closure id used as a value into `__clomake(id)`; for a named fn
// record a thunk, for a capturing closure resolve its capture types.
fn lf_wrap(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node], thunks: *ArrayList[[]u8]) void {
    switch (n.*) {
        .id => |d| {
            if (fn_exists(dl, d.name)) {
                if (cg_starts_with(d.name, "__clos_") == 1) {
                    set_clos_captypes(dl, d.name, env);
                } else {
                    if (!seen_has(thunks.*, d.name)) { push[[]u8](thunks, d.name); }
                }
                let args: ArrayList[*Node] = make[*Node](1);
                push[*Node](&args, mk_ident(d.name));
                let mk: *Node = mk_call(mk_ident("__clomake"), args);
                n.* = mk.*;
            }
        }
        else => { }
    }
}

fn lf_expr(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node], thunks: *ArrayList[[]u8]) void {
    switch (n.*) {
        .call => |c| {
            let cn: []u8 = cg_callee_name(c.callee);
            if (@strEq(cn, "__clomake") || @strEq(cn, "__clocall")) { return; }
            // lower arguments first (nested calls / closures)
            let ai: i32 = 0;
            while (ai < len[*Node](c.args)) { lf_expr(get[*Node](c.args, ai), env, dl, thunks); ai = ai + 1; }
            // is the callee itself a fn VALUE (fn-typed local/param, or fn-typed field)?
            let isfv: i32 = 0;
            switch (c.callee.*) {
                .id => |d| {
                    if (!fn_exists(dl, d.name)) {
                        if (is_fn_type(env_lookup(env, d.name)) == 1) { isfv = 1; }
                    }
                }
                .fld => |f| {
                    if (is_fn_type(field_fnval_ty(f, env, dl)) == 1) { isfv = 1; }
                    else { lf_expr(f.base, env, dl, thunks); }
                }
                else => { lf_expr(c.callee, env, dl, thunks); }
            }
            if (isfv == 1) {
                // (callee).fn((callee).env, args...) — pass callee as marker arg0
                let nargs: ArrayList[*Node] = make[*Node](4);
                push[*Node](&nargs, c.callee);
                let k: i32 = 0;
                while (k < len[*Node](c.args)) { push[*Node](&nargs, get[*Node](c.args, k)); k = k + 1; }
                let mk: *Node = mk_call(mk_ident("__clocall"), nargs);
                n.* = mk.*;
                return;
            }
            // ordinary call: wrap any bare-fn argument bound to a fn-typed parameter
            let wi: i32 = 0;
            while (wi < len[*Node](c.args)) {
                if (cg_callee_param_is_fn(cn, wi, dl) == 1) { lf_wrap(get[*Node](c.args, wi), env, dl, thunks); }
                wi = wi + 1;
            }
        }
        .bin => |b| { lf_expr(b.l, env, dl, thunks); lf_expr(b.r, env, dl, thunks); }
        .un  => |u| { lf_expr(u.e, env, dl, thunks); }
        .idx => |x| { lf_expr(x.base, env, dl, thunks); lf_expr(x.idx, env, dl, thunks); }
        .fld => |f| { lf_expr(f.base, env, dl, thunks); }
        .slice_ => |s| { lf_expr(s.base, env, dl, thunks); lf_expr(s.lo, env, dl, thunks); lf_expr(s.hi, env, dl, thunks); }
        .slit_ => |s| {
            let i: i32 = 0;
            while (i < len[FieldInit](s.fields)) {
                let fi: FieldInit = get[FieldInit](s.fields, i);
                lf_expr(fi.val, env, dl, thunks);
                if (is_fn_type(cg_struct_field_ty(dl, s.sname, fi.name)) == 1) { lf_wrap(fi.val, env, dl, thunks); }
                i = i + 1;
            }
        }
        else => { }
    }
}

fn lf_block(body: ArrayList[*Node], f: FnDecl, env: ArrayList[Binding], dl: ArrayList[*Node], thunks: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { lf_stmt(get[*Node](body, i), f, env, dl, thunks); i = i + 1; }
}

fn lf_stmt(n: *Node, f: FnDecl, env: ArrayList[Binding], dl: ArrayList[*Node], thunks: *ArrayList[[]u8]) void {
    switch (n.*) {
        .let_   => |l| { lf_expr(l.expr, env, dl, thunks); if (is_fn_type(l.dty) == 1) { lf_wrap(l.expr, env, dl, thunks); } }
        .ret    => |r| { if (r.has_expr == 1) { lf_expr(r.expr, env, dl, thunks); if (is_fn_type(f.ret) == 1) { lf_wrap(r.expr, env, dl, thunks); } } }
        .if_    => |x| { lf_expr(x.cond, env, dl, thunks); lf_block(x.then_body, f, env, dl, thunks); if (x.has_els == 1) { lf_block(x.els_body, f, env, dl, thunks); } }
        .while_ => |w| { lf_expr(w.cond, env, dl, thunks); lf_block(w.body, f, env, dl, thunks); }
        .assign => |a| { lf_expr(a.target, env, dl, thunks); lf_expr(a.expr, env, dl, thunks); }
        .switch_ => |sw| {
            lf_expr(sw.subject, env, dl, thunks);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { lf_block(get[SwitchArm](sw.arms, ai).body, f, env, dl, thunks); ai = ai + 1; }
            if (sw.has_els == 1) { lf_block(sw.els_body, f, env, dl, thunks); }
        }
        .estmt  => |e| { lf_expr(e.expr, env, dl, thunks); }
        else => { }
    }
}

// Program-wide closure lowering. Runs over every non-extern fn (generic templates
// included, so monomorphized clones inherit the rewrites). Collects the named-fn
// thunks the program needs.
fn lower_fnvalues(decls: ArrayList[*Node], thunks: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        switch (get[*Node](decls, i).*) {
            .fn_decl => |f| {
                if (f.is_extern == 0 && cg_starts_with(f.name, "__op_") == 0) {
                    lf_block(f.body, f, build_env(f.params, f.body, decls), decls, thunks);
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

fn annotate_block(body: ArrayList[*Node], env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { annotate_stmt(get[*Node](body, i), env, dl); i = i + 1; }
}

fn annotate_stmt(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .let_   => |l| { annotate_expr(l.expr, env, dl); }
        .ret    => |r| { if (r.has_expr == 1) { annotate_expr(r.expr, env, dl); } }
        .if_    => |x| { annotate_expr(x.cond, env, dl); annotate_block(x.then_body, env, dl); if (x.has_els == 1) { annotate_block(x.els_body, env, dl); } }
        .while_ => |w| { annotate_expr(w.cond, env, dl); annotate_block(w.body, env, dl); }
        .assign => |a| { annotate_expr(a.target, env, dl); annotate_expr(a.expr, env, dl); }
        .switch_ => |sw| {
            annotate_expr(sw.subject, env, dl);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { annotate_block(get[SwitchArm](sw.arms, ai).body, env, dl); ai = ai + 1; }
            if (sw.has_els == 1) { annotate_block(sw.els_body, env, dl); }
        }
        .estmt  => |e| { annotate_expr(e.expr, env, dl); }
        else => { }
    }
}

// ── function declarations ────────────────────────────────────────────────────
fn gen_params(buf: *ArrayList[u8], params: ArrayList[Param]) void {
    if (len[Param](params) == 0) {
        emit(buf, "void");
        return;
    }
    let i: i32 = 0;
    while (i < len[Param](params)) {
        if (i > 0) { emit(buf, ", "); }
        let p: Param = get[Param](params, i);
        emit(buf, ctype(p.pty));
        emit(buf, " ");
        emit(buf, p.name);
        i = i + 1;
    }
}

// Hoisted-closure param list: a hidden `void* __zenv` first, then the real params.
fn gen_clos_params(buf: *ArrayList[u8], params: ArrayList[Param]) void {
    emit(buf, "void* __zenv");
    let i: i32 = 0;
    while (i < len[Param](params)) {
        let p: Param = get[Param](params, i);
        emit(buf, ", ");
        emit(buf, ctype(p.pty));
        emit(buf, " ");
        emit(buf, p.name);
        i = i + 1;
    }
}

// Unpack a capturing closure's environment into locals at the top of its body.
fn gen_clos_unpack(buf: *ArrayList[u8], f: FnDecl) void {
    if (f.cap_names.len == 0) { emit(buf, "    (void)__zenv;\n"); return; }
    let names: ArrayList[[]u8] = split_args(f.cap_names);
    let tys: ArrayList[[]u8] = split_args(f.cap_types);
    let i: i32 = 0;
    while (i < len[[]u8](names)) {
        emit(buf, "    ");
        if (i < len[[]u8](tys)) { emit(buf, ctype(get[[]u8](tys, i))); } else { emit(buf, "int32_t"); }
        emit(buf, " ");
        emit(buf, get[[]u8](names, i));
        emit(buf, " = ((");
        emit(buf, f.name);
        emit(buf, "_env*)__zenv)->");
        emit(buf, get[[]u8](names, i));
        emit(buf, ";\n");
        i = i + 1;
    }
}

fn gen_fn_proto(buf: *ArrayList[u8], f: FnDecl) void {
    if (@strEq(f.name, "main")) { return; }
    if (cg_starts_with(f.name, "__op_") == 1) { return; }   // operator contract: a sema/codegen table, emits no C
    if (cg_starts_with(f.name, "__iface_") == 1) { return; } // interface decl: synthesized vtable, not a fn
    if (len[[]u8](f.tparams) > 0) { return; }  // generic template: emitted via monomorphization
    if (cg_starts_with(f.name, "__clos_") == 1) {
        // hoisted closure: env-first signature
        emit(buf, "static "); emit(buf, ctype(f.ret)); emit(buf, " "); emit(buf, f.name);
        emit(buf, "("); gen_clos_params(buf, f.params); emit(buf, ");\n");
        return;
    }
    // extern fn → C prototype with the literal symbol name (impl from libc/runtime).
    if (f.is_extern == 1) {
        emit(buf, "extern ");
        emit(buf, ctype(f.ret));
        emit(buf, " ");
        emit(buf, f.name);
        emit(buf, "(");
        gen_params(buf, f.params);
        emit(buf, ");\n");
        return;
    }
    emit(buf, "static ");
    emit(buf, ctype(f.ret));
    emit(buf, " ");
    emit(buf, f.name);
    emit(buf, "(");
    gen_params(buf, f.params);
    emit(buf, ");\n");
}

fn gen_fn(buf: *ArrayList[u8], f: FnDecl, dl: ArrayList[*Node]) void {
    if (f.is_extern == 1) { return; }
    if (cg_starts_with(f.name, "__op_") == 1) { return; }   // operator contract: emits no C
    if (cg_starts_with(f.name, "__iface_") == 1) { return; } // interface decl: synthesised vtable, not a fn
    if (len[[]u8](f.tparams) > 0) { return; }  // generic template: emitted via monomorphization
    let is_clos: i32 = cg_starts_with(f.name, "__clos_");
    let is_main: i32 = 0;
    if (@strEq(f.name, "main")) { is_main = 1; }
    if (is_main == 1) {
        emit(buf, "int main(void) {\n");
    } else if (is_clos == 1) {
        // hoisted closure: env-first signature + capture unpacking
        emit(buf, "static "); emit(buf, ctype(f.ret)); emit(buf, " "); emit(buf, f.name);
        emit(buf, "("); gen_clos_params(buf, f.params); emit(buf, ") {\n");
        gen_clos_unpack(buf, f);
    } else {
        emit(buf, "static ");
        emit(buf, ctype(f.ret));
        emit(buf, " ");
        emit(buf, f.name);
        emit(buf, "(");
        gen_params(buf, f.params);
        emit(buf, ") {\n");
    }
    annotate_block(f.body, build_env(f.params, f.body, dl), dl);   // classify index/slice bases
    gen_block(buf, f.body, dl, f.ret);
    if (is_main == 1) { emit(buf, "    return 0;\n"); }
    emit(buf, "}\n");
}

// ── type declarations ────────────────────────────────────────────────────────
// Named-struct forward declaration: `typedef struct N_s N;`. Emitting all
// forwards first lets pointer fields reference any struct regardless of order.
fn gen_struct_fwd(buf: *ArrayList[u8], name: []u8) void {
    emit(buf, "typedef struct "); emit(buf, name); emit(buf, "_s ");
    emit(buf, name); emit(buf, ";\n");
}

fn gen_struct_decl(buf: *ArrayList[u8], s: StructDecl) void {
    // Generic structs need monomorphization (not yet) — skip the template.
    if (len[[]u8](s.tparams) > 0) { return; }
    emit(buf, "struct "); emit(buf, s.name); emit(buf, "_s { ");
    let i: i32 = 0;
    while (i < len[Param](s.fields)) {
        let f: Param = get[Param](s.fields, i);
        if (f.calign > 0) {   // @cacheAlign(N) field: pin to its own cache line
            emit(buf, "_Alignas(");
            emit(buf, _zag_i64_to_str(f.calign as i64));
            emit(buf, ") ");
        }
        emit(buf, ctype(f.pty));
        emit(buf, " ");
        emit(buf, f.name);
        emit(buf, "; ");
        i = i + 1;
    }
    emit(buf, "};\n");
}

fn gen_enum_decl(buf: *ArrayList[u8], e: EnumDecl) void {
    // the program's error set → ZAG_OK=0, ZAG_ERR_<Name>=n constants
    if (@strEq(e.name, "__zag_errors")) {
        emit(buf, "enum { ZAG_OK = 0");
        let k: i32 = 0;
        while (k < len[[]u8](e.members)) {
            emit(buf, ", ZAG_ERR_");
            emit(buf, get[[]u8](e.members, k));
            emit(buf, " = ");
            emit(buf, _zag_i64_to_str((k + 1) as i64));
            k = k + 1;
        }
        emit(buf, " };\n");
        return;
    }
    emit(buf, "typedef enum { ");
    let i: i32 = 0;
    while (i < len[[]u8](e.members)) {
        if (i > 0) { emit(buf, ", "); }
        emit(buf, e.name);
        emit(buf, "_");
        emit(buf, get[[]u8](e.members, i));
        i = i + 1;
    }
    emit(buf, " } ");
    emit(buf, e.name);
    emit(buf, ";\n");
}

// Tagged union → tag-constant enum + { tag; union { payloads } u; }.
// A payload-less variant (pty "void"/"") gets an int32_t placeholder slot.
// Union forward decl: the tag enum + `typedef struct N_s N;`. The tag constants
// must be visible before any construction/switch, so they go in the fwd phase.
fn gen_union_fwd(buf: *ArrayList[u8], u: UnionDecl) void {
    emit(buf, "enum { ");
    let i: i32 = 0;
    while (i < len[Param](u.fields)) {
        if (i > 0) { emit(buf, ", "); }
        emit(buf, u.name); emit(buf, "_"); emit(buf, get[Param](u.fields, i).name);
        i = i + 1;
    }
    emit(buf, " };\n");
    gen_struct_fwd(buf, u.name);
}

fn gen_union_decl(buf: *ArrayList[u8], u: UnionDecl) void {
    emit(buf, "struct "); emit(buf, u.name); emit(buf, "_s { int32_t tag; union { ");
    let j: i32 = 0;
    while (j < len[Param](u.fields)) {
        let f: Param = get[Param](u.fields, j);
        let pt: []u8 = f.pty;
        if (@strEq(pt, "void") || @strEq(pt, "")) { pt = "i32"; }
        emit(buf, ctype(pt)); emit(buf, " "); emit(buf, f.name); emit(buf, "; ");
        j = j + 1;
    }
    emit(buf, "} u; };\n");
}

// Forward phase: enums (full, independent) + struct/union forward typedefs.
fn gen_type_fwd(buf: *ArrayList[u8], d: *Node) void {
    switch (d.*) {
        .struct_ => |s| { if (len[[]u8](s.tparams) == 0) { gen_struct_fwd(buf, s.name); } }
        .enum_   => |e| { gen_enum_decl(buf, e); }
        .union_  => |u| { gen_union_fwd(buf, u); }
        else => { }
    }
}

// Body phase: struct/union bodies (enums already fully emitted in the fwd phase).
fn gen_type_body(buf: *ArrayList[u8], d: *Node) void {
    switch (d.*) {
        .struct_ => |s| { gen_struct_decl(buf, s); }
        .union_  => |u| { gen_union_decl(buf, u); }
        else => { }
    }
}

fn gen_decl_proto(buf: *ArrayList[u8], d: *Node) void {
    switch (d.*) {
        .fn_decl => |f| { gen_fn_proto(buf, f); }
        else => { }
    }
}

fn gen_decl(buf: *ArrayList[u8], d: *Node, dl: ArrayList[*Node]) void {
    switch (d.*) {
        .fn_decl => |f| { gen_fn(buf, f, dl); }
        else => { }
    }
}

// ── collect generic instantiations from the program ──────────────────────────
fn collect_call(c: Call, decls: ArrayList[*Node], insts: *ArrayList[Inst]) void {
    let ai: i32 = 0;
    while (ai < len[*Node](c.args)) {
        collect_expr(get[*Node](c.args, ai), decls, insts);
        ai = ai + 1;
    }
    if (len[[]u8](c.targs) > 0) {
        let cn: []u8 = cg_callee_name(c.callee);
        let mangled: []u8 = mangle_generic(cn, c.targs);
        if (!inst_seen(insts.*, mangled)) {
            // find the generic fn template with this name
            let di: i32 = 0;
            while (di < len[*Node](decls)) {
                let d: *Node = get[*Node](decls, di);
                switch (d.*) {
                    .fn_decl => |f| {
                        if (len[[]u8](f.tparams) > 0 && @strEq(f.name, cn)) {
                            let cb: ArrayList[*Node] = clone_block(f.body, f.tparams, c.targs);
                            push[Inst](insts, Inst{ .mangled = mangled, .f = f, .targs = c.targs, .cbody = cb });
                        }
                    }
                    else => { }
                }
                di = di + 1;
            }
        }
    }
}

fn collect_expr(n: *Node, decls: ArrayList[*Node], insts: *ArrayList[Inst]) void {
    switch (n.*) {
        .call  => |c| { collect_call(c, decls, insts); }
        .bin   => |b| { collect_expr(b.l, decls, insts); collect_expr(b.r, decls, insts); }
        .un    => |u| { collect_expr(u.e, decls, insts); }
        .fld   => |f| { collect_expr(f.base, decls, insts); }
        .idx   => |x| { collect_expr(x.base, decls, insts); collect_expr(x.idx, decls, insts); }
        .cast_ => |c| { collect_expr(c.expr, decls, insts); }
        .slice_ => |s| { collect_expr(s.base, decls, insts); collect_expr(s.lo, decls, insts); collect_expr(s.hi, decls, insts); }
        .slit_ => |s| {
            let i: i32 = 0;
            while (i < len[FieldInit](s.fields)) {
                collect_expr(get[FieldInit](s.fields, i).val, decls, insts);
                i = i + 1;
            }
        }
        else => { }
    }
}

fn collect_block(body: ArrayList[*Node], decls: ArrayList[*Node], insts: *ArrayList[Inst]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        collect_stmt(get[*Node](body, i), decls, insts);
        i = i + 1;
    }
}

fn collect_stmt(n: *Node, decls: ArrayList[*Node], insts: *ArrayList[Inst]) void {
    switch (n.*) {
        .let_   => |l| { collect_expr(l.expr, decls, insts); }
        .ret    => |r| { if (r.has_expr == 1) { collect_expr(r.expr, decls, insts); } }
        .if_    => |x| { collect_expr(x.cond, decls, insts); collect_block(x.then_body, decls, insts); if (x.has_els == 1) { collect_block(x.els_body, decls, insts); } }
        .while_ => |w| { collect_expr(w.cond, decls, insts); collect_block(w.body, decls, insts); }
        .assign => |a| { collect_expr(a.target, decls, insts); collect_expr(a.expr, decls, insts); }
        .switch_ => |sw| {
            collect_expr(sw.subject, decls, insts);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { collect_block(get[SwitchArm](sw.arms, ai).body, decls, insts); ai = ai + 1; }
            if (sw.has_els == 1) { collect_block(sw.els_body, decls, insts); }
        }
        .estmt  => |e| { collect_expr(e.expr, decls, insts); }
        else => { }
    }
}

// ── generic struct instantiations ────────────────────────────────────────────
struct SInst { mangled: []u8, decl: StructDecl, targs: ArrayList[[]u8] }

fn sinst_seen(sinsts: ArrayList[SInst], mangled: []u8) bool {
    let i: i32 = 0;
    while (i < len[SInst](sinsts)) {
        if (@strEq(get[SInst](sinsts, i).mangled, mangled)) { return true; }
        i = i + 1;
    }
    return false;
}

fn record_sinst(sname: []u8, targs: ArrayList[[]u8], decls: ArrayList[*Node], sinsts: *ArrayList[SInst]) void {
    if (len[[]u8](targs) == 0) { return; }
    let mangled: []u8 = mangle_generic(sname, targs);
    if (sinst_seen(sinsts.*, mangled)) { return; }
    let di: i32 = 0;
    while (di < len[*Node](decls)) {
        let d: *Node = get[*Node](decls, di);
        switch (d.*) {
            .struct_ => |s| {
                if (len[[]u8](s.tparams) > 0 && @strEq(s.name, sname)) {
                    // Record field-type instantiations FIRST so a dependency like
                    // StringMap[i32].entries: *MapEntry[i32] emits MapEntry[i32]
                    // before StringMap[i32]. (The codebase has no cyclic generic
                    // structs, so this terminates.)
                    let fi: i32 = 0;
                    while (fi < len[Param](s.fields)) {
                        record_type_sinst(subst_type(get[Param](s.fields, fi).pty, s.tparams, targs), decls, sinsts);
                        fi = fi + 1;
                    }
                    if (!sinst_seen(sinsts.*, mangled)) {
                        push[SInst](sinsts, SInst{ .mangled = mangled, .decl = s, .targs = targs });
                    }
                }
            }
            else => { }
        }
        di = di + 1;
    }
}

fn collect_sinst_expr(n: *Node, decls: ArrayList[*Node], sinsts: *ArrayList[SInst]) void {
    switch (n.*) {
        .slit_ => |s| {
            record_sinst(s.sname, s.targs, decls, sinsts);
            let i: i32 = 0;
            while (i < len[FieldInit](s.fields)) {
                collect_sinst_expr(get[FieldInit](s.fields, i).val, decls, sinsts);
                i = i + 1;
            }
        }
        .call => |c| {
            let i: i32 = 0;
            while (i < len[*Node](c.args)) {
                collect_sinst_expr(get[*Node](c.args, i), decls, sinsts);
                i = i + 1;
            }
        }
        .bin => |b| { collect_sinst_expr(b.l, decls, sinsts); collect_sinst_expr(b.r, decls, sinsts); }
        .un  => |u| { collect_sinst_expr(u.e, decls, sinsts); }
        .fld => |f| { collect_sinst_expr(f.base, decls, sinsts); }
        .idx => |x| { collect_sinst_expr(x.base, decls, sinsts); collect_sinst_expr(x.idx, decls, sinsts); }
        .cast_ => |c| { record_type_sinst(c.target, decls, sinsts); collect_sinst_expr(c.expr, decls, sinsts); }
        .slice_ => |s| { collect_sinst_expr(s.base, decls, sinsts); collect_sinst_expr(s.lo, decls, sinsts); collect_sinst_expr(s.hi, decls, sinsts); }
        else => { }
    }
}

fn collect_sinst_block(body: ArrayList[*Node], decls: ArrayList[*Node], sinsts: *ArrayList[SInst]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        collect_sinst_stmt(get[*Node](body, i), decls, sinsts);
        i = i + 1;
    }
}

// Record a struct instantiation implied by a type string like "Pair[i32]".
// Strips leading * / ? / ! / [] so e.g. `*MapEntry[i32]` records MapEntry[i32].
fn record_type_sinst(t: []u8, decls: ArrayList[*Node], sinsts: *ArrayList[SInst]) void {
    let u: []u8 = t;
    let go: bool = true;
    while (go) {
        if (u.len > 1 && (u[0] == '*' || u[0] == '?' || u[0] == '!')) { u = u[1..]; }
        else if (u.len > 2 && u[0] == '[' && u[1] == ']') { u = u[2..]; }
        else { go = false; }
    }
    if (!is_generic_app(u)) { return; }
    let lb: i32 = index_of(u, '[');
    let base: []u8 = u[0..lb];
    let arglist: ArrayList[[]u8] = split_args(u[lb + 1..u.len - 1]);
    record_sinst(base, arglist, decls, sinsts);
}

fn collect_sinst_stmt(n: *Node, decls: ArrayList[*Node], sinsts: *ArrayList[SInst]) void {
    switch (n.*) {
        .let_   => |l| { record_type_sinst(l.dty, decls, sinsts); collect_sinst_expr(l.expr, decls, sinsts); }
        .ret    => |r| { if (r.has_expr == 1) { collect_sinst_expr(r.expr, decls, sinsts); } }
        .if_    => |x| { collect_sinst_expr(x.cond, decls, sinsts); collect_sinst_block(x.then_body, decls, sinsts); if (x.has_els == 1) { collect_sinst_block(x.els_body, decls, sinsts); } }
        .while_ => |w| { collect_sinst_expr(w.cond, decls, sinsts); collect_sinst_block(w.body, decls, sinsts); }
        .assign => |a| { collect_sinst_expr(a.target, decls, sinsts); collect_sinst_expr(a.expr, decls, sinsts); }
        .switch_ => |sw| {
            collect_sinst_expr(sw.subject, decls, sinsts);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { collect_sinst_block(get[SwitchArm](sw.arms, ai).body, decls, sinsts); ai = ai + 1; }
            if (sw.has_els == 1) { collect_sinst_block(sw.els_body, decls, sinsts); }
        }
        .estmt  => |e| { collect_sinst_expr(e.expr, decls, sinsts); }
        else => { }
    }
}

// Emit a monomorphized struct typedef (type-params substituted per field).
fn emit_sinst_fwd(buf: *ArrayList[u8], si: SInst) void {
    gen_struct_fwd(buf, si.mangled);
}

fn emit_sinst(buf: *ArrayList[u8], si: SInst) void {
    let s: StructDecl = si.decl;
    emit(buf, "struct "); emit(buf, si.mangled); emit(buf, "_s { ");
    let i: i32 = 0;
    while (i < len[Param](s.fields)) {
        let f: Param = get[Param](s.fields, i);
        emit(buf, ctype(subst_type(f.pty, s.tparams, si.targs)));
        emit(buf, " ");
        emit(buf, f.name);
        emit(buf, "; ");
        i = i + 1;
    }
    emit(buf, "};\n");
}

// Emit a monomorphized fn signature (used for both prototype and body header).
fn emit_mono_sig(buf: *ArrayList[u8], inst: Inst) void {
    let f: FnDecl = inst.f;
    emit(buf, "static ");
    emit(buf, ctype(subst_type(f.ret, f.tparams, inst.targs)));
    emit(buf, " ");
    emit(buf, inst.mangled);
    emit(buf, "(");
    if (len[Param](f.params) == 0) {
        emit(buf, "void");
    } else {
        let i: i32 = 0;
        while (i < len[Param](f.params)) {
            if (i > 0) { emit(buf, ", "); }
            let p: Param = get[Param](f.params, i);
            emit(buf, ctype(subst_type(p.pty, f.tparams, inst.targs)));
            emit(buf, " ");
            emit(buf, p.name);
            i = i + 1;
        }
    }
    emit(buf, ")");
}

fn emit_mono_proto(buf: *ArrayList[u8], inst: Inst) void {
    emit_mono_sig(buf, inst);
    emit(buf, ";\n");
}

fn emit_mono_body(buf: *ArrayList[u8], inst: Inst, dl: ArrayList[*Node]) void {
    emit_mono_sig(buf, inst);
    emit(buf, " {\n");
    // build the scope from substituted param types + the (already-substituted)
    // body so index/slice bases classify against concrete types
    let penv: ArrayList[Binding] = make[Binding](8);
    let pi: i32 = 0;
    while (pi < len[Param](inst.f.params)) {
        let p: Param = get[Param](inst.f.params, pi);
        push[Binding](&penv, Binding{ .name = p.name, .ty = subst_type(p.pty, inst.f.tparams, inst.targs) });
        pi = pi + 1;
    }
    build_env_block(inst.cbody, &penv, dl);
    annotate_block(inst.cbody, penv, dl);
    // the instance's return type drives ?T wrapping inside the body
    gen_block(buf, inst.cbody, dl, subst_type(inst.f.ret, inst.f.tparams, inst.targs));
    emit(buf, "}\n");
}

// ── optional types: collect every ?T so we can emit its ZagOpt_ typedef ───────
// Strip * and [] prefixes; if what remains is an optional ?T, record it.
fn collect_opt(t: []u8, out: *ArrayList[[]u8]) void {
    let inner: []u8 = t;
    let go: bool = true;
    while (go) {
        if (inner.len > 1 && inner[0] == '*') { inner = inner[1..]; }
        else if (inner.len > 2 && inner[0] == '[' && inner[1] == ']') { inner = inner[2..]; }
        else { go = false; }
    }
    if (inner.len > 1 && inner[0] == '?') {
        if (!seen_has(out.*, inner)) { push[[]u8](out, inner); }
    }
}

fn collect_opts_block(body: ArrayList[*Node], out: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        collect_opts_stmt(get[*Node](body, i), out);
        i = i + 1;
    }
}

fn collect_opts_stmt(n: *Node, out: *ArrayList[[]u8]) void {
    switch (n.*) {
        .let_   => |l| { collect_opt(l.dty, out); }
        .if_    => |x| { collect_opts_block(x.then_body, out); if (x.has_els == 1) { collect_opts_block(x.els_body, out); } }
        .while_ => |w| { collect_opts_block(w.body, out); }
        .switch_ => |sw| {
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) {
                collect_opts_block(get[SwitchArm](sw.arms, ai).body, out);
                ai = ai + 1;
            }
            if (sw.has_els == 1) { collect_opts_block(sw.els_body, out); }
        }
        else => { }
    }
}

fn collect_opts_params(params: ArrayList[Param], out: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[Param](params)) {
        collect_opt(get[Param](params, i).pty, out);
        i = i + 1;
    }
}

// ── error-union type collection (mirrors the optional collection above) ───────
fn collect_err(t: []u8, out: *ArrayList[[]u8]) void {
    let inner: []u8 = t;
    let go: bool = true;
    while (go) {
        if (inner.len > 1 && inner[0] == '*') { inner = inner[1..]; }
        else if (inner.len > 2 && inner[0] == '[' && inner[1] == ']') { inner = inner[2..]; }
        else { go = false; }
    }
    if (inner.len > 1 && inner[0] == '!') {
        if (!seen_has(out.*, inner)) { push[[]u8](out, inner); }
    }
}

fn collect_errs_block(body: ArrayList[*Node], out: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { collect_errs_stmt(get[*Node](body, i), out); i = i + 1; }
}

fn collect_errs_stmt(n: *Node, out: *ArrayList[[]u8]) void {
    switch (n.*) {
        .let_   => |l| { collect_err(l.dty, out); }
        .if_    => |x| { collect_errs_block(x.then_body, out); if (x.has_els == 1) { collect_errs_block(x.els_body, out); } }
        .while_ => |w| { collect_errs_block(w.body, out); }
        .switch_ => |sw| {
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { collect_errs_block(get[SwitchArm](sw.arms, ai).body, out); ai = ai + 1; }
            if (sw.has_els == 1) { collect_errs_block(sw.els_body, out); }
        }
        else => { }
    }
}

fn collect_errs_params(params: ArrayList[Param], out: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[Param](params)) { collect_err(get[Param](params, i).pty, out); i = i + 1; }
}

// Emit `typedef struct { int32_t _err; <T> _val; } ZagErr_<T>;` for each !T.
fn emit_err_typedefs(buf: *ArrayList[u8], errs: ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[[]u8](errs)) {
        let et: []u8 = get[[]u8](errs, i);    // "!T"
        let inner: []u8 = et[1..];            // "T"
        emit(buf, "typedef struct { int32_t _err; ");
        emit(buf, ctype(inner));
        emit(buf, " _val; } ");
        emit(buf, ctype(et));                  // ZagErr_<mangle(inner)>
        emit(buf, ";\n");
        i = i + 1;
    }
}

// Emit `typedef struct { int32_t _has; <T> _val; } ZagOpt_<T>;` for each ?T.
fn emit_opt_typedefs(buf: *ArrayList[u8], opts: ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[[]u8](opts)) {
        let ot: []u8 = get[[]u8](opts, i);          // "?T"
        let inner: []u8 = ot[1..];                  // "T"
        emit(buf, "typedef struct { int32_t _has; ");
        emit(buf, ctype(inner));
        emit(buf, " _val; } ");
        emit(buf, ctype(ot));                        // ZagOpt_<mangle(inner)>
        emit(buf, ";\n");
        i = i + 1;
    }
}

// Is `callee` a (non-extern) fn whose declared return type is optional?
fn callee_returns_opt(callee: *Node, dl: ArrayList[*Node]) bool {
    let nm: []u8 = cg_callee_name(callee);
    if (nm.len == 0) { return false; }
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| {
                if (@strEq(f.name, nm)) {
                    if (f.ret.len > 0 && f.ret[0] == '?') { return true; }
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return false;
}

// True if expr is the `null` literal (parser lowers null to an ident).
fn is_null_expr(n: *Node) bool {
    return switch (n.*) {
        .id  => |x| @strEq(x.name, "null"),
        else => false,
    };
}

// True if expr is already an optional value (null, or a call to a ?-returning
// fn, or an orelse). Used to decide wrap-vs-passthrough at ?T assignment sites.
fn expr_is_optional(n: *Node, dl: ArrayList[*Node]) bool {
    return switch (n.*) {
        .id   => |x| @strEq(x.name, "null"),
        .call => |c| callee_returns_opt(c.callee, dl),
        else  => false,
    };
}

// ── driver: source → C string ────────────────────────────────────────────────
// Back-compat entry: no import base dir (relative @imports resolve from cwd).
fn codegen(src: []u8) ArrayList[u8] {
    return codegen_dir(src, "");
}

// Codegen with an import base directory so relative @imports in `src` resolve
// against the source file's own directory.
fn codegen_dir(src: []u8, base_dir: []u8) ArrayList[u8] {
    return codegen_decls(parse_program_dir(src, base_dir));
}

// ── numeric runtime (ported verbatim from src/numeric_prelude.c) ──────────────
// Saturating arith, RNS, posit p8/p16/p32/p64, the 512-bit quire. Emitted into
// the output C whenever a program uses any heterogeneous numeric type.
fn emit_numeric_runtime(buf: *ArrayList[u8]) void {
    emit(buf, "/* ── Saturating arithmetic ────────────────────────────────────────────────────\n");
    emit(buf, "   Key property: sat ops CANNOT overflow → Zag's effect system never adds Panic.\n");
    emit(buf, "   DSP/embedded use: sat_i16 audio samples clamp at ±32767 instead of wrapping.\n");
    emit(buf, "   ARM64: these inline as SQADD/UQADD (1 cycle).  x86: SSE PADDSW.  Fallback: C.\n");
    emit(buf, "   Note: sat_mul is intentionally truncating-then-clamping (standard DSP behavior). */\n");
    emit(buf, "#define ZAG_SAT_ADD(T, MIN, MAX) \\\n");
    emit(buf, "static T zag_sat_add_##T(T a, T b){ int64_t r=(int64_t)a+(int64_t)b; return (T)(r>MAX?MAX:r<MIN?MIN:r); }\n");
    emit(buf, "#define ZAG_SAT_SUB(T, MIN, MAX) \\\n");
    emit(buf, "static T zag_sat_sub_##T(T a, T b){ int64_t r=(int64_t)a-(int64_t)b; return (T)(r>MAX?MAX:r<MIN?MIN:r); }\n");
    emit(buf, "#define ZAG_SAT_MUL(T, MIN, MAX) \\\n");
    emit(buf, "static T zag_sat_mul_##T(T a, T b){ int64_t r=(int64_t)a*(int64_t)b; return (T)(r>MAX?MAX:r<MIN?MIN:r); }\n");
    emit(buf, "typedef int8_t   i8; typedef int16_t  i16; typedef int32_t  i32;\n");
    emit(buf, "typedef uint8_t  u8; typedef uint16_t u16; typedef uint32_t u32;\n");
    emit(buf, "ZAG_SAT_ADD(i8, -128, 127)        ZAG_SAT_SUB(i8, -128, 127)        ZAG_SAT_MUL(i8, -128, 127)\n");
    emit(buf, "ZAG_SAT_ADD(i16,-32768,32767)     ZAG_SAT_SUB(i16,-32768,32767)     ZAG_SAT_MUL(i16,-32768,32767)\n");
    emit(buf, "ZAG_SAT_ADD(u8, 0, 255)           ZAG_SAT_SUB(u8, 0, 255)           ZAG_SAT_MUL(u8, 0, 255)\n");
    emit(buf, "ZAG_SAT_ADD(u16,0, 65535)         ZAG_SAT_SUB(u16,0, 65535)         ZAG_SAT_MUL(u16,0, 65535)\n");
    emit(buf, "/* i32/u32 sat: widen to int64_t (always fits) */\n");
    emit(buf, "static i32 zag_sat_add_i32(i32 a,i32 b){int64_t r=(int64_t)a+b;return(i32)(r>(int64_t)2147483647?2147483647:r<(int64_t)-2147483648?-2147483648:r);}\n");
    emit(buf, "static i32 zag_sat_sub_i32(i32 a,i32 b){int64_t r=(int64_t)a-b;return(i32)(r>(int64_t)2147483647?2147483647:r<(int64_t)-2147483648?-2147483648:r);}\n");
    emit(buf, "static i32 zag_sat_mul_i32(i32 a,i32 b){int64_t r=(int64_t)a*(int64_t)b;return(i32)(r>(int64_t)2147483647?2147483647:r<(int64_t)-2147483648?-2147483648:r);}\n");
    emit(buf, "static u32 zag_sat_add_u32(u32 a,u32 b){uint64_t r=(uint64_t)a+b;return(u32)(r>4294967295ULL?4294967295U:r);}\n");
    emit(buf, "static u32 zag_sat_sub_u32(u32 a,u32 b){return a>b?(u32)(a-b):0u;}\n");
    emit(buf, "static u32 zag_sat_mul_u32(u32 a,u32 b){uint64_t r=(uint64_t)a*b;return(u32)(r>4294967295ULL?4294967295U:r);}\n");
    emit(buf, "/* i64/u64: widen to __int128 */\n");
    emit(buf, "static int64_t  zag_sat_add_i64(int64_t a,int64_t b){__int128 r=(__int128)a+b;int64_t MAX=(int64_t)9223372036854775807LL,MIN=-(MAX)-1;return(int64_t)(r>MAX?MAX:r<MIN?MIN:r);}\n");
    emit(buf, "static int64_t  zag_sat_sub_i64(int64_t a,int64_t b){__int128 r=(__int128)a-b;int64_t MAX=(int64_t)9223372036854775807LL,MIN=-(MAX)-1;return(int64_t)(r>MAX?MAX:r<MIN?MIN:r);}\n");
    emit(buf, "static int64_t  zag_sat_mul_i64(int64_t a,int64_t b){__int128 r=(__int128)a*b;int64_t MAX=(int64_t)9223372036854775807LL,MIN=-(MAX)-1;return(int64_t)(r>MAX?MAX:r<MIN?MIN:r);}\n");
    emit(buf, "static uint64_t zag_sat_add_u64(uint64_t a,uint64_t b){__int128 r=(__int128)a+b;uint64_t MAX=18446744073709551615ULL;return(uint64_t)(r>(unsigned __int128)MAX?MAX:r);}\n");
    emit(buf, "static uint64_t zag_sat_sub_u64(uint64_t a,uint64_t b){return a>b?a-b:0ULL;}\n");
    emit(buf, "static uint64_t zag_sat_mul_u64(uint64_t a,uint64_t b){__int128 r=(__int128)a*b;uint64_t MAX=18446744073709551615ULL;return(uint64_t)(r>(unsigned __int128)MAX?MAX:r);}\n");
    emit(buf, "\n");
    emit(buf, "/* ── Residue Number System (rns_N) ──────────────────────────────────────────\n");
    emit(buf, "   Stores a value as N residues over fixed coprime moduli.  Add/mul are\n");
    emit(buf, "   lane-independent: no carry, no data dependency across channels.  Ideal for\n");
    emit(buf, "   HPC SIMD where each lane computes one modulus in parallel.\n");
    emit(buf, "   Phase RNS-1: rns_3 uses moduli M1=2^16−15, M2=2^16−5, M3=2^16−3 (coprime primes\n");
    emit(buf, "   near 65536 → max representable value ≈ 2.81 × 10^14).  Phase RNS-2 adds\n");
    emit(buf, "   CRT reconstruction (comparison, conversion to/from int) via precomputed constants. */\n");
    emit(buf, "#define ZAG_RNS_M1 65521u   /* 2^16 - 15, a prime */\n");
    emit(buf, "#define ZAG_RNS_M2 65531u   /* 2^16 - 5,  a prime */\n");
    emit(buf, "#define ZAG_RNS_M3 65533u   /* 2^16 - 3,  a prime */\n");
    emit(buf, "typedef struct { uint32_t r1, r2, r3; } ZagRns;\n");
    emit(buf, "static ZagRns zag_rns_from_i64(int64_t x){\n");
    emit(buf, "    return (ZagRns){(uint32_t)(((uint64_t)(x%ZAG_RNS_M1)+ZAG_RNS_M1)%ZAG_RNS_M1),\n");
    emit(buf, "                    (uint32_t)(((uint64_t)(x%ZAG_RNS_M2)+ZAG_RNS_M2)%ZAG_RNS_M2),\n");
    emit(buf, "                    (uint32_t)(((uint64_t)(x%ZAG_RNS_M3)+ZAG_RNS_M3)%ZAG_RNS_M3)};}\n");
    emit(buf, "static ZagRns zag_rns_add(ZagRns a, ZagRns b){\n");
    emit(buf, "    return (ZagRns){(a.r1+b.r1)%ZAG_RNS_M1,(a.r2+b.r2)%ZAG_RNS_M2,(a.r3+b.r3)%ZAG_RNS_M3};}\n");
    emit(buf, "static ZagRns zag_rns_sub(ZagRns a, ZagRns b){\n");
    emit(buf, "    return (ZagRns){(a.r1+ZAG_RNS_M1-b.r1)%ZAG_RNS_M1,\n");
    emit(buf, "                    (a.r2+ZAG_RNS_M2-b.r2)%ZAG_RNS_M2,\n");
    emit(buf, "                    (a.r3+ZAG_RNS_M3-b.r3)%ZAG_RNS_M3};}\n");
    emit(buf, "static ZagRns zag_rns_mul(ZagRns a, ZagRns b){\n");
    emit(buf, "    return (ZagRns){(uint32_t)(((uint64_t)a.r1*b.r1)%ZAG_RNS_M1),\n");
    emit(buf, "                    (uint32_t)(((uint64_t)a.r2*b.r2)%ZAG_RNS_M2),\n");
    emit(buf, "                    (uint32_t)(((uint64_t)a.r3*b.r3)%ZAG_RNS_M3)};}\n");
    emit(buf, "\n");
    emit(buf, "/* ── Posit runtime: p32, es=2 (useed = 2^(2^2) = 16). Reference software emulation. ──\n");
    emit(buf, "   decode is exact bit-manipulation; arithmetic goes decode->f64->encode with round-to-\n");
    emit(buf, "   nearest-even on repack. f64's 53-bit mantissa >= p32's <=27 fraction bits, so this is\n");
    emit(buf, "   exact in the normal range (the optimized branchless integer path is Phase P2). */\n");
    emit(buf, "static double zag_p32_to_f64(uint32_t bits){\n");
    emit(buf, "    if (bits == 0u) return 0.0;\n");
    emit(buf, "    if (bits == 0x80000000u) return NAN;                 /* NaR */\n");
    emit(buf, "    int neg = (bits >> 31) & 1;\n");
    emit(buf, "    uint32_t u = neg ? (uint32_t)(-(int32_t)bits) : bits; /* magnitude (sign cleared) */\n");
    emit(buf, "    int b = 30, k;\n");
    emit(buf, "    if (((u >> 30) & 1) == 1) {                          /* regime = run of 1s */\n");
    emit(buf, "        int run = 0; while (b >= 0 && ((u >> b) & 1) == 1) { run++; b--; }\n");
    emit(buf, "        if (b >= 0) b--;                                 /* consume the 0 terminator */\n");
    emit(buf, "        k = run - 1;\n");
    emit(buf, "    } else {                                             /* regime = run of 0s */\n");
    emit(buf, "        int run = 0; while (b >= 0 && ((u >> b) & 1) == 0) { run++; b--; }\n");
    emit(buf, "        if (b >= 0) b--;                                 /* consume the 1 terminator */\n");
    emit(buf, "        k = -run;\n");
    emit(buf, "    }\n");
    emit(buf, "    int e = 0;                                           /* es=2 exponent bits (zero-padded) */\n");
    emit(buf, "    for (int i = 0; i < 2; i++) { e <<= 1; if (b >= 0) { e |= (u >> b) & 1; b--; } }\n");
    emit(buf, "    int fbits = b + 1;\n");
    emit(buf, "    double fraction = 1.0;\n");
    emit(buf, "    if (fbits > 0) {\n");
    emit(buf, "        uint32_t fr = u & ((fbits >= 32) ? 0xFFFFFFFFu : ((1u << fbits) - 1u));\n");
    emit(buf, "        fraction = 1.0 + (double)fr / (double)((uint64_t)1 << fbits);\n");
    emit(buf, "    }\n");
    emit(buf, "    double val = ldexp(fraction, 4 * k + e);             /* useed^k * 2^e = 2^(4k+e) */\n");
    emit(buf, "    return neg ? -val : val;\n");
    emit(buf, "}\n");
    emit(buf, "static uint32_t zag_f64_to_p32(double x){\n");
    emit(buf, "    if (x == 0.0) return 0u;\n");
    emit(buf, "    if (isnan(x) || isinf(x)) return 0x80000000u;        /* NaR */\n");
    emit(buf, "    int neg = (x < 0.0); double ax = fabs(x);\n");
    emit(buf, "    int E2; double m = frexp(ax, &E2); m *= 2.0; int E = E2 - 1;  /* ax = m * 2^E, m in [1,2) */\n");
    emit(buf, "    int k = (E >= 0) ? (E / 4) : -(((-E) + 3) / 4);      /* floor(E/4) */\n");
    emit(buf, "    int e = E - 4 * k;                                   /* 0..3 */\n");
    emit(buf, "    double fr = m - 1.0;\n");
    emit(buf, "    unsigned char bs[80]; int n = 0;                     /* MSB-first magnitude bit stream */\n");
    emit(buf, "    if (k >= 0) { for (int i = 0; i <= k && n < 80; i++) bs[n++] = 1; if (n < 80) bs[n++] = 0; }\n");
    emit(buf, "    else        { for (int i = 0; i < -k && n < 80; i++) bs[n++] = 0; if (n < 80) bs[n++] = 1; }\n");
    emit(buf, "    if (n < 80) bs[n++] = (e >> 1) & 1;\n");
    emit(buf, "    if (n < 80) bs[n++] = e & 1;\n");
    emit(buf, "    while (n < 80) { fr *= 2.0; int d = (int)fr; bs[n++] = (unsigned char)d; fr -= d; }\n");
    emit(buf, "    uint32_t mag = 0;\n");
    emit(buf, "    for (int i = 0; i < 31; i++) mag = (mag << 1) | (i < n ? bs[i] : 0);\n");
    emit(buf, "    int roundb = (31 < n) ? bs[31] : 0, sticky = 0;\n");
    emit(buf, "    for (int i = 32; i < n; i++) sticky |= bs[i];\n");
    emit(buf, "    if (roundb && (sticky || (mag & 1))) mag++;          /* round to nearest, ties to even */\n");
    emit(buf, "    uint32_t word = mag & 0x7FFFFFFFu;\n");
    emit(buf, "    return neg ? (uint32_t)(-(int32_t)word) : word;\n");
    emit(buf, "}\n");
    emit(buf, "static uint32_t zag_p32_from_i64(int64_t v){ return zag_f64_to_p32((double)v); }\n");
    emit(buf, "static uint64_t zag_p32_bits(uint32_t b){ return (uint64_t)b; }\n");
    emit(buf, "\n");
    emit(buf, "/* ── P2: branchless integer-only path (Path A). decode via CLZ, integer significand math,\n");
    emit(buf, "      integer repack with round-to-nearest-even — NO float intermediate. Validated bit-for-bit\n");
    emit(buf, "      against a long-double oracle over 5M+ inputs. value = (-1)^neg * sig * 2^sexp. ── */\n");
    emit(buf, "static void zag_p32_fields(uint32_t bits, int* neg, int* sexp, uint64_t* sig){\n");
    emit(buf, "    if (bits == 0u) { *neg = 0; *sexp = 0; *sig = 0; return; }\n");
    emit(buf, "    int n = (bits >> 31) & 1;\n");
    emit(buf, "    uint32_t u = n ? (uint32_t)(-(int32_t)bits) : bits;\n");
    emit(buf, "    uint32_t w = u << 1;                                    /* first regime bit -> bit31 */\n");
    emit(buf, "    int r = (int)(w >> 31);\n");
    emit(buf, "    int run = __builtin_clz(r ? ~w : w);                    /* CLZ counts the regime run, branchless */\n");
    emit(buf, "    int k = r ? (run - 1) : (-run);\n");
    emit(buf, "    int rembits = 30 - run, e, F; uint64_t frac;\n");
    emit(buf, "    if (rembits >= 2) {\n");
    emit(buf, "        uint32_t field = u & ((rembits >= 32) ? 0xFFFFFFFFu : ((1u << rembits) - 1u));\n");
    emit(buf, "        e = field >> (rembits - 2); F = rembits - 2;\n");
    emit(buf, "        frac = field & ((F >= 32) ? 0xFFFFFFFFu : ((1u << F) - 1u));\n");
    emit(buf, "    } else if (rembits == 1) { e = (u & 1) << 1; F = 0; frac = 0; }\n");
    emit(buf, "    else { e = 0; F = 0; frac = 0; }\n");
    emit(buf, "    *neg = n; *sig = ((uint64_t)1 << F) | frac; *sexp = (4 * k + e) - F;\n");
    emit(buf, "}\n");
    emit(buf, "static uint32_t zag_p32_enc_int(int sign, uint64_t P, int pe){   /* value = (-1)^sign * P * 2^pe -> p32, RNE */\n");
    emit(buf, "    if (P == 0) return 0u;\n");
    emit(buf, "    int L = 64 - __builtin_clzll(P), E = pe + L - 1;\n");
    emit(buf, "    int k = (E >= 0) ? (E / 4) : -(((-E) + 3) / 4), e = E - 4 * k;\n");
    emit(buf, "    unsigned char bs[96]; int n = 0;\n");
    emit(buf, "    if (k >= 0) { for (int i = 0; i <= k && n < 96; i++) bs[n++] = 1; if (n < 96) bs[n++] = 0; }\n");
    emit(buf, "    else        { for (int i = 0; i < -k && n < 96; i++) bs[n++] = 0; if (n < 96) bs[n++] = 1; }\n");
    emit(buf, "    if (n < 96) bs[n++] = (e >> 1) & 1; if (n < 96) bs[n++] = e & 1;\n");
    emit(buf, "    for (int i = L - 2; i >= 0 && n < 96; i--) bs[n++] = (unsigned char)((P >> i) & 1);\n");
    emit(buf, "    uint32_t mag = 0; for (int i = 0; i < 31; i++) mag = (mag << 1) | (i < n ? bs[i] : 0);\n");
    emit(buf, "    int rb = (31 < n) ? bs[31] : 0, st = 0; for (int i = 32; i < n; i++) st |= bs[i];\n");
    emit(buf, "    if (rb && (st || (mag & 1))) mag++;\n");
    emit(buf, "    uint32_t word = mag & 0x7FFFFFFFu; if (word == 0) word = 1;\n");
    emit(buf, "    return sign ? (uint32_t)(-(int32_t)word) : word;\n");
    emit(buf, "}\n");
    emit(buf, "#ifndef ZAG_TARGET_PPU32  /* software math: compiled out when --target ppu32 selects hardware path */\n");
    emit(buf, "static uint32_t zag_p32_add_core(int na, int ea, uint64_t sa, int nb, int eb, uint64_t sb){\n");
    emit(buf, "    int G = 60, anchor = (ea > eb) ? ea : eb, sticky = 0, sh; __int128 acc = 0;\n");
    emit(buf, "    sh = ea - anchor + G;\n");
    emit(buf, "    { __int128 m; if (sh >= 0) m = (__int128)sa << sh;\n");
    emit(buf, "      else { int rs = -sh; if (rs < 64) { if (sa & (((uint64_t)1 << rs) - 1)) sticky = 1; m = (__int128)(sa >> rs); } else { if (sa) sticky = 1; m = 0; } }\n");
    emit(buf, "      acc += na ? -m : m; }\n");
    emit(buf, "    sh = eb - anchor + G;\n");
    emit(buf, "    { __int128 m; if (sh >= 0) m = (__int128)sb << sh;\n");
    emit(buf, "      else { int rs = -sh; if (rs < 64) { if (sb & (((uint64_t)1 << rs) - 1)) sticky = 1; m = (__int128)(sb >> rs); } else { if (sb) sticky = 1; m = 0; } }\n");
    emit(buf, "      acc += nb ? -m : m; }\n");
    emit(buf, "    if (acc == 0) return sticky ? 1u : 0u;\n");
    emit(buf, "    int rsgn = (acc < 0); unsigned __int128 mag = rsgn ? (unsigned __int128)(-acc) : (unsigned __int128)acc;\n");
    emit(buf, "    int L = 0; { unsigned __int128 t = mag; while (t) { L++; t >>= 1; } }\n");
    emit(buf, "    int drop = (L > 60) ? (L - 60) : 0;\n");
    emit(buf, "    if (drop > 0) { unsigned __int128 lm = (((unsigned __int128)1) << drop) - 1; if (mag & lm) sticky = 1; }\n");
    emit(buf, "    uint64_t P = (uint64_t)(mag >> drop); if (sticky) P |= 1;\n");
    emit(buf, "    return zag_p32_enc_int(rsgn, P, (anchor - G) + drop);\n");
    emit(buf, "}\n");
    emit(buf, "static uint32_t zag_p32_mul(uint32_t a, uint32_t b){\n");
    emit(buf, "    if (a == 0x80000000u || b == 0x80000000u) return 0x80000000u;\n");
    emit(buf, "    if (a == 0 || b == 0) return 0u;\n");
    emit(buf, "    int na, nb, ea, eb; uint64_t sa, sb;\n");
    emit(buf, "    zag_p32_fields(a, &na, &ea, &sa); zag_p32_fields(b, &nb, &eb, &sb);\n");
    emit(buf, "    return zag_p32_enc_int(na ^ nb, sa * sb, ea + eb);\n");
    emit(buf, "}\n");
    emit(buf, "static uint32_t zag_p32_add(uint32_t a, uint32_t b){\n");
    emit(buf, "    if (a == 0x80000000u || b == 0x80000000u) return 0x80000000u;\n");
    emit(buf, "    if (a == 0) return b; if (b == 0) return a;\n");
    emit(buf, "    int na, nb, ea, eb; uint64_t sa, sb;\n");
    emit(buf, "    zag_p32_fields(a, &na, &ea, &sa); zag_p32_fields(b, &nb, &eb, &sb);\n");
    emit(buf, "    return zag_p32_add_core(na, ea, sa, nb, eb, sb);\n");
    emit(buf, "}\n");
    emit(buf, "static uint32_t zag_p32_sub(uint32_t a, uint32_t b){\n");
    emit(buf, "    if (a == 0x80000000u || b == 0x80000000u) return 0x80000000u;\n");
    emit(buf, "    if (b == 0) return a; if (a == 0) return (uint32_t)(-(int32_t)b);\n");
    emit(buf, "    int na, nb, ea, eb; uint64_t sa, sb;\n");
    emit(buf, "    zag_p32_fields(a, &na, &ea, &sa); zag_p32_fields(b, &nb, &eb, &sb);\n");
    emit(buf, "    return zag_p32_add_core(na, ea, sa, !nb, eb, sb);\n");
    emit(buf, "}\n");
    emit(buf, "static uint32_t zag_p32_div(uint32_t a, uint32_t b){\n");
    emit(buf, "    if (a == 0x80000000u || b == 0x80000000u || b == 0) return 0x80000000u;\n");
    emit(buf, "    if (a == 0) return 0u;\n");
    emit(buf, "    int na, nb, ea, eb; uint64_t sa, sb;\n");
    emit(buf, "    zag_p32_fields(a, &na, &ea, &sa); zag_p32_fields(b, &nb, &eb, &sb);\n");
    emit(buf, "    int La = 64 - __builtin_clzll(sa), Lb = 64 - __builtin_clzll(sb), shift = 60 - (La - Lb);\n");
    emit(buf, "    __int128 num = (__int128)sa << shift;\n");
    emit(buf, "    uint64_t Q = (uint64_t)(num / sb); if ((uint64_t)(num % sb)) Q |= 1;\n");
    emit(buf, "    return zag_p32_enc_int(na ^ nb, Q, ea - eb - shift);\n");
    emit(buf, "}\n");
    emit(buf, "#endif /* ZAG_TARGET_PPU32 */\n");
    emit(buf, "\n");
    emit(buf, "/* ── Quire: 512-bit fixed-point exact accumulator for p32 (Posit Standard: n²/2 bits). ──\n");
    emit(buf, "   Holds sums of products with NO rounding until read out. LSB weight = 2^-240, so it spans\n");
    emit(buf, "   minpos² (2^-240) .. maxpos² (2^240) with carry headroom in the top limbs. This is the posit\n");
    emit(buf, "   feature with no IEEE/hardware equivalent: a fused dot product that rounds exactly once. */\n");
    emit(buf, "typedef struct { uint64_t limb[8]; int nar; } ZagQuire;\n");
    emit(buf, "/* (zag_p32_fields — the branchless CLZ decode above — is shared by the quire) */\n");
    emit(buf, "static ZagQuire zag_quire_zero(void){ ZagQuire q; for (int i = 0; i < 8; i++) q.limb[i] = 0; q.nar = 0; return q; }\n");
    emit(buf, "static void q_add_at(uint64_t* L, int off, uint64_t lo, uint64_t hi){\n");
    emit(buf, "    if (off > 7) return;\n");
    emit(buf, "    unsigned __int128 s = (unsigned __int128)L[off] + lo; L[off] = (uint64_t)s; uint64_t c = (uint64_t)(s >> 64);\n");
    emit(buf, "    if (off + 1 <= 7) { unsigned __int128 s2 = (unsigned __int128)L[off+1] + hi + c; L[off+1] = (uint64_t)s2; c = (uint64_t)(s2 >> 64);\n");
    emit(buf, "        for (int i = off + 2; i < 8 && c; i++) { unsigned __int128 s3 = (unsigned __int128)L[i] + c; L[i] = (uint64_t)s3; c = (uint64_t)(s3 >> 64); } }\n");
    emit(buf, "}\n");
    emit(buf, "static void q_sub_at(uint64_t* L, int off, uint64_t lo, uint64_t hi){\n");
    emit(buf, "    if (off > 7) return;\n");
    emit(buf, "    unsigned __int128 d = (unsigned __int128)L[off] - lo; L[off] = (uint64_t)d; uint64_t br = (d >> 64) ? 1 : 0;\n");
    emit(buf, "    if (off + 1 <= 7) { unsigned __int128 d2 = (unsigned __int128)L[off+1] - hi - br; L[off+1] = (uint64_t)d2; br = (d2 >> 64) ? 1 : 0;\n");
    emit(buf, "        for (int i = off + 2; i < 8 && br; i++) { unsigned __int128 d3 = (unsigned __int128)L[i] - br; L[i] = (uint64_t)d3; br = (d3 >> 64) ? 1 : 0; } }\n");
    emit(buf, "}\n");
    emit(buf, "static ZagQuire zag_quire_fma(ZagQuire q, uint32_t a, uint32_t b){   /* q += a*b, EXACTLY */\n");
    emit(buf, "    if (a == 0x80000000u || b == 0x80000000u || q.nar) { q.nar = 1; return q; }\n");
    emit(buf, "    int na, nb, ea, eb; uint64_t sa, sb;\n");
    emit(buf, "    zag_p32_fields(a, &na, &ea, &sa); zag_p32_fields(b, &nb, &eb, &sb);\n");
    emit(buf, "    if (sa == 0 || sb == 0) return q;                 /* product is zero */\n");
    emit(buf, "    uint64_t P = sa * sb;                              /* <= 2^57, exact in uint64 */\n");
    emit(buf, "    int shift = (ea + eb) + 240;                       /* place at exact bit position */\n");
    emit(buf, "    if (shift < 0) return q;                           /* below quire LSB (unreachable for valid p32) */\n");
    emit(buf, "    int off = shift >> 6, bo = shift & 63;\n");
    emit(buf, "    uint64_t lo, hi;\n");
    emit(buf, "    if (bo == 0) { lo = P; hi = 0; } else { lo = P << bo; hi = P >> (64 - bo); }\n");
    emit(buf, "    if (na ^ nb) q_sub_at(q.limb, off, lo, hi); else q_add_at(q.limb, off, lo, hi);\n");
    emit(buf, "    return q;\n");
    emit(buf, "}\n");
    emit(buf, "static int q_bit(const uint64_t* L, int i){ return (int)((L[i >> 6] >> (i & 63)) & 1); }\n");
    emit(buf, "static uint32_t zag_quire_to_p32(ZagQuire q){           /* round the exact value to p32 (RNE) */\n");
    emit(buf, "    if (q.nar) return 0x80000000u;\n");
    emit(buf, "    uint64_t m[8]; int neg = (q.limb[7] >> 63) & 1;\n");
    emit(buf, "    if (neg) { uint64_t c = 1; for (int i = 0; i < 8; i++) { unsigned __int128 t = (unsigned __int128)(~q.limb[i]) + c; m[i] = (uint64_t)t; c = (uint64_t)(t >> 64); } }\n");
    emit(buf, "    else for (int i = 0; i < 8; i++) m[i] = q.limb[i];\n");
    emit(buf, "    int M = -1; for (int i = 511; i >= 0; i--) if (q_bit(m, i)) { M = i; break; }\n");
    emit(buf, "    if (M < 0) return 0u;\n");
    emit(buf, "    uint64_t hi53 = 0;\n");
    emit(buf, "    for (int j = 0; j < 53; j++) { int bi = M - j; hi53 = (hi53 << 1) | (bi >= 0 ? (uint64_t)q_bit(m, bi) : 0); }\n");
    emit(buf, "    int sticky = 0; for (int i = 0; i <= M - 53; i++) if (q_bit(m, i)) { sticky = 1; break; }\n");
    emit(buf, "    if (sticky) hi53 |= 1ull;                           /* round-to-odd: makes the final RNE correct */\n");
    emit(buf, "    double val = ldexp((double)hi53, (M - 52) - 240);\n");
    emit(buf, "    return zag_f64_to_p32(neg ? -val : val);\n");
    emit(buf, "}\n");
    emit(buf, "\n");
    emit(buf, "/* ── p8: n=8, es=0, useed=2; range [2^-6, 2^6] = [1/64, 64]; max 6 fraction bits ── */\n");
    emit(buf, "static double zag_p8_to_f64(uint8_t bits){\n");
    emit(buf, "    if (!bits) return 0.0; if (bits == 0x80u) return NAN;\n");
    emit(buf, "    int neg = (bits >> 7) & 1;\n");
    emit(buf, "    uint8_t u = neg ? (uint8_t)(0u - (unsigned)bits) : bits;\n");
    emit(buf, "    uint32_t wu = (uint32_t)u << 25;          /* bit6 of u -> bit31 for __builtin_clz */\n");
    emit(buf, "    int r = (int)(wu >> 31);\n");
    emit(buf, "    int run = __builtin_clz(r ? ~wu : wu);    /* regime run length */\n");
    emit(buf, "    int k = r ? (run - 1) : (-run);           /* regime value; es=0: useed_exp=1, E=k */\n");
    emit(buf, "    int F = 6 - run;                          /* n-2-run fraction bits (may be 0 or neg) */\n");
    emit(buf, "    if (F < 0) F = 0;\n");
    emit(buf, "    double frac = F ? (double)(u & ((1u << F) - 1u)) / (double)(1u << F) : 0.0;\n");
    emit(buf, "    return (neg ? -1.0 : 1.0) * ldexp(1.0 + frac, k);\n");
    emit(buf, "}\n");
    emit(buf, "static uint8_t zag_f64_to_p8(double x){\n");
    emit(buf, "    if (x == 0.0) return 0u; if (isnan(x) || isinf(x)) return 0x80u;\n");
    emit(buf, "    int neg = (x < 0.0); double ax = fabs(x);\n");
    emit(buf, "    int E2; double m = frexp(ax, &E2); m *= 2.0; int E = E2 - 1;\n");
    emit(buf, "    int k = E;                                /* es=0: k=E, e=0 */\n");
    emit(buf, "    double fr = m - 1.0; unsigned char bs[24]; int n = 0;\n");
    emit(buf, "    if(k>=0){for(int i=0;i<=k&&n<24;i++)bs[n++]=1;if(n<24)bs[n++]=0;}\n");
    emit(buf, "    else    {for(int i=0;i<-k&&n<24;i++)bs[n++]=0;if(n<24)bs[n++]=1;}\n");
    emit(buf, "    while(n<24){fr*=2.0;int d=(int)fr;bs[n++]=(unsigned char)d;fr-=d;}\n");
    emit(buf, "    uint8_t mag=0; for(int i=0;i<7;i++) mag=(uint8_t)((mag<<1)|(i<n?bs[i]:0));\n");
    emit(buf, "    int rb=(7<n)?bs[7]:0,st=0; for(int i=8;i<n;i++) st|=bs[i];\n");
    emit(buf, "    if(rb&&(st||(mag&1))) mag++;\n");
    emit(buf, "    uint8_t w = mag & 0x7Fu; if(!w) w=1;\n");
    emit(buf, "    return neg ? (uint8_t)(0u-(unsigned)w) : w;\n");
    emit(buf, "}\n");
    emit(buf, "static uint8_t  zag_p8_from_i64(int64_t v){ return zag_f64_to_p8((double)v); }\n");
    emit(buf, "static uint64_t zag_p8_bits(uint8_t b){ return (uint64_t)b; }\n");
    emit(buf, "static uint8_t  zag_p8_add(uint8_t a,uint8_t b){ if(a==0x80u||b==0x80u)return 0x80u; return zag_f64_to_p8(zag_p8_to_f64(a)+zag_p8_to_f64(b)); }\n");
    emit(buf, "static uint8_t  zag_p8_sub(uint8_t a,uint8_t b){ if(a==0x80u||b==0x80u)return 0x80u; return zag_f64_to_p8(zag_p8_to_f64(a)-zag_p8_to_f64(b)); }\n");
    emit(buf, "static uint8_t  zag_p8_mul(uint8_t a,uint8_t b){ if(a==0x80u||b==0x80u)return 0x80u;if(!a||!b)return 0u; return zag_f64_to_p8(zag_p8_to_f64(a)*zag_p8_to_f64(b)); }\n");
    emit(buf, "static uint8_t  zag_p8_div(uint8_t a,uint8_t b){ if(a==0x80u||b==0x80u||!b)return 0x80u;if(!a)return 0u; return zag_f64_to_p8(zag_p8_to_f64(a)/zag_p8_to_f64(b)); }\n");
    emit(buf, "\n");
    emit(buf, "/* ── p16: n=16, es=1, useed=4; range [2^-28, 2^28]; max 14 fraction bits ── */\n");
    emit(buf, "static double zag_p16_to_f64(uint16_t bits){\n");
    emit(buf, "    if (!bits) return 0.0; if (bits == 0x8000u) return NAN;\n");
    emit(buf, "    int neg = (bits >> 15) & 1;\n");
    emit(buf, "    uint16_t u = neg ? (uint16_t)(0u - (unsigned)bits) : bits;\n");
    emit(buf, "    uint32_t wu = (uint32_t)u << 17;          /* bit14 of u -> bit31 */\n");
    emit(buf, "    int r = (int)(wu >> 31);\n");
    emit(buf, "    int run = __builtin_clz(r ? ~wu : wu);\n");
    emit(buf, "    int k = r ? (run - 1) : (-run);\n");
    emit(buf, "    int rem = 14 - run;                       /* n-2-run */\n");
    emit(buf, "    int e = 0;\n");
    emit(buf, "    if (rem >= 1) { e = (u >> (rem - 1)) & 1; rem--; }  /* es=1: one exp bit */\n");
    emit(buf, "    int F = rem > 0 ? rem : 0;\n");
    emit(buf, "    double frac = F ? (double)(u & ((1u << F) - 1u)) / (double)(1u << F) : 0.0;\n");
    emit(buf, "    return (neg ? -1.0 : 1.0) * ldexp(1.0 + frac, 2 * k + e);\n");
    emit(buf, "}\n");
    emit(buf, "static uint16_t zag_f64_to_p16(double x){\n");
    emit(buf, "    if (x == 0.0) return 0u; if (isnan(x) || isinf(x)) return 0x8000u;\n");
    emit(buf, "    int neg = (x < 0.0); double ax = fabs(x);\n");
    emit(buf, "    int E2; double m = frexp(ax, &E2); m *= 2.0; int E = E2 - 1;\n");
    emit(buf, "    int k = (E >= 0) ? (E / 2) : -(((-E) + 1) / 2);    /* floor(E/2) for es=1 */\n");
    emit(buf, "    int e = E - 2 * k;\n");
    emit(buf, "    double fr = m - 1.0; unsigned char bs[48]; int n = 0;\n");
    emit(buf, "    if(k>=0){for(int i=0;i<=k&&n<48;i++)bs[n++]=1;if(n<48)bs[n++]=0;}\n");
    emit(buf, "    else    {for(int i=0;i<-k&&n<48;i++)bs[n++]=0;if(n<48)bs[n++]=1;}\n");
    emit(buf, "    if(n<48) bs[n++]=e&1;                    /* es=1: single exp bit */\n");
    emit(buf, "    while(n<48){fr*=2.0;int d=(int)fr;bs[n++]=(unsigned char)d;fr-=d;}\n");
    emit(buf, "    uint16_t mag=0; for(int i=0;i<15;i++) mag=(uint16_t)((mag<<1)|(i<n?bs[i]:0));\n");
    emit(buf, "    int rb=(15<n)?bs[15]:0,st=0; for(int i=16;i<n;i++) st|=bs[i];\n");
    emit(buf, "    if(rb&&(st||(mag&1))) mag++;\n");
    emit(buf, "    uint16_t w = mag & 0x7FFFu; if(!w) w=1;\n");
    emit(buf, "    return neg ? (uint16_t)(0u-(unsigned)w) : w;\n");
    emit(buf, "}\n");
    emit(buf, "static uint16_t zag_p16_from_i64(int64_t v){ return zag_f64_to_p16((double)v); }\n");
    emit(buf, "static uint64_t zag_p16_bits(uint16_t b){ return (uint64_t)b; }\n");
    emit(buf, "static uint16_t zag_p16_add(uint16_t a,uint16_t b){ if(a==0x8000u||b==0x8000u)return 0x8000u; return zag_f64_to_p16(zag_p16_to_f64(a)+zag_p16_to_f64(b)); }\n");
    emit(buf, "static uint16_t zag_p16_sub(uint16_t a,uint16_t b){ if(a==0x8000u||b==0x8000u)return 0x8000u; return zag_f64_to_p16(zag_p16_to_f64(a)-zag_p16_to_f64(b)); }\n");
    emit(buf, "static uint16_t zag_p16_mul(uint16_t a,uint16_t b){ if(a==0x8000u||b==0x8000u)return 0x8000u;if(!a||!b)return 0u; return zag_f64_to_p16(zag_p16_to_f64(a)*zag_p16_to_f64(b)); }\n");
    emit(buf, "static uint16_t zag_p16_div(uint16_t a,uint16_t b){ if(a==0x8000u||b==0x8000u||!b)return 0x8000u;if(!a)return 0u; return zag_f64_to_p16(zag_p16_to_f64(a)/zag_p16_to_f64(b)); }\n");
    emit(buf, "\n");
    emit(buf, "/* ── p64: n=64, es=3, useed=256; range [2^-240, 2^240]; max 59 fraction bits.\n");
    emit(buf, "   Decode/encode via long double (64-bit mantissa ≥ 59 frac bits → exact).\n");
    emit(buf, "   Arithmetic via long double (exact for +/-; mul has ≤1 ULP — 120-bit product > 64-bit mant). ── */\n");
    emit(buf, "static long double zag_p64_to_ld(uint64_t bits){\n");
    emit(buf, "    if (!bits) return 0.0L;\n");
    emit(buf, "    if (bits == 0x8000000000000000ULL) return (long double)NAN;\n");
    emit(buf, "    int neg = (int)(bits >> 63);\n");
    emit(buf, "    uint64_t u = neg ? (uint64_t)(0ULL - bits) : bits;\n");
    emit(buf, "    uint64_t w = u << 1;                          /* bit62 of u -> bit63, for __builtin_clzll */\n");
    emit(buf, "    int r = (int)(w >> 63);\n");
    emit(buf, "    int run = __builtin_clzll(r ? ~w : w);\n");
    emit(buf, "    int k = r ? (run - 1) : (-run);\n");
    emit(buf, "    int rem = 62 - run;                            /* n-2-run bits remaining */\n");
    emit(buf, "    int e = 0;\n");
    emit(buf, "    if (rem >= 3) { e = (int)((u >> (rem - 3)) & 7ULL); rem -= 3; }   /* es=3: 3 exp bits */\n");
    emit(buf, "    else if (rem > 0) { e = (int)((u & ((1ULL << rem) - 1ULL)) << (3 - rem)); rem = 0; }\n");
    emit(buf, "    int F = rem > 0 ? rem : 0;\n");
    emit(buf, "    long double frac = F ? (long double)(u & ((F >= 64) ? ~0ULL : ((1ULL << F) - 1ULL)))\n");
    emit(buf, "                         / (long double)(1ULL << F) : 0.0L;\n");
    emit(buf, "    return (neg ? -1.0L : 1.0L) * ldexpl(1.0L + frac, 8 * k + e);\n");
    emit(buf, "}\n");
    emit(buf, "static uint64_t zag_ld_to_p64(long double x){\n");
    emit(buf, "    if (x == 0.0L) return 0ULL;\n");
    emit(buf, "    if (isnan(x) || isinf(x)) return 0x8000000000000000ULL;\n");
    emit(buf, "    int neg = (x < 0.0L); long double ax = fabsl(x);\n");
    emit(buf, "    int E2; long double m = frexpl(ax, &E2); m *= 2.0L; int E = E2 - 1;\n");
    emit(buf, "    int k = (E >= 0) ? (E / 8) : -(((-E) + 7) / 8);\n");
    emit(buf, "    int e = E - 8 * k;\n");
    emit(buf, "    long double fr = m - 1.0L; unsigned char bs[200]; int n = 0;\n");
    emit(buf, "    if(k>=0){for(int i=0;i<=k&&n<200;i++)bs[n++]=1;if(n<200)bs[n++]=0;}\n");
    emit(buf, "    else    {for(int i=0;i<-k&&n<200;i++)bs[n++]=0;if(n<200)bs[n++]=1;}\n");
    emit(buf, "    if(n<200)bs[n++]=(e>>2)&1; if(n<200)bs[n++]=(e>>1)&1; if(n<200)bs[n++]=e&1;\n");
    emit(buf, "    while(n<200){fr*=2.0L;int d=(int)fr;bs[n++]=(unsigned char)d;fr-=d;}\n");
    emit(buf, "    uint64_t mag=0; for(int i=0;i<63;i++) mag=(mag<<1)|(i<n?(uint64_t)bs[i]:0ULL);\n");
    emit(buf, "    int rb=(63<n)?bs[63]:0,st=0; for(int i=64;i<n;i++) st|=bs[i];\n");
    emit(buf, "    if(rb&&(st||(int)(mag&1))) mag++;\n");
    emit(buf, "    uint64_t w2 = mag & 0x7FFFFFFFFFFFFFFFULL; if(!w2) w2=1;\n");
    emit(buf, "    return neg ? (uint64_t)(0ULL - w2) : w2;\n");
    emit(buf, "}\n");
    emit(buf, "static double   zag_p64_to_f64(uint64_t b){ return (double)zag_p64_to_ld(b); }\n");
    emit(buf, "static uint64_t zag_f64_to_p64(double x){ return zag_ld_to_p64((long double)x); }\n");
    emit(buf, "static uint64_t zag_p64_from_i64(int64_t v){ return zag_ld_to_p64((long double)v); }\n");
    emit(buf, "static uint64_t zag_p64_bits(uint64_t b){ return b; }\n");
    emit(buf, "static uint64_t zag_p64_add(uint64_t a,uint64_t b){\n");
    emit(buf, "    if(a==0x8000000000000000ULL||b==0x8000000000000000ULL)return 0x8000000000000000ULL;\n");
    emit(buf, "    return zag_ld_to_p64(zag_p64_to_ld(a)+zag_p64_to_ld(b)); }\n");
    emit(buf, "static uint64_t zag_p64_sub(uint64_t a,uint64_t b){\n");
    emit(buf, "    if(a==0x8000000000000000ULL||b==0x8000000000000000ULL)return 0x8000000000000000ULL;\n");
    emit(buf, "    return zag_ld_to_p64(zag_p64_to_ld(a)-zag_p64_to_ld(b)); }\n");
    emit(buf, "static uint64_t zag_p64_mul(uint64_t a,uint64_t b){\n");
    emit(buf, "    if(a==0x8000000000000000ULL||b==0x8000000000000000ULL)return 0x8000000000000000ULL;\n");
    emit(buf, "    if(!a||!b)return 0ULL;\n");
    emit(buf, "    return zag_ld_to_p64(zag_p64_to_ld(a)*zag_p64_to_ld(b)); }\n");
    emit(buf, "static uint64_t zag_p64_div(uint64_t a,uint64_t b){\n");
    emit(buf, "    if(a==0x8000000000000000ULL||b==0x8000000000000000ULL||!b)return 0x8000000000000000ULL;\n");
    emit(buf, "    if(!a)return 0ULL;\n");
    emit(buf, "    return zag_ld_to_p64(zag_p64_to_ld(a)/zag_p64_to_ld(b)); }\n");
}

// ── special slice typedefs ───────────────────────────────────────────────────
// A []T with T != u8 maps to `ZagSlice_<mangled T>`; emit the struct typedef the
// first time we see one. (Plain []u8 → ZagSliceU8, already in the prelude.)
fn slice_seen_has(seen: ArrayList[[]u8], name: []u8) i32 {
    let i: i32 = 0;
    while (i < len[[]u8](seen)) {
        if (@strEq(get[[]u8](seen, i), name)) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn emit_one_slice_typedef(buf: *ArrayList[u8], t: []u8, seen: *ArrayList[[]u8]) void {
    if (t.len < 3) { return; }
    if (t[0] != '[' || t[1] != ']') { return; }
    if (@strEq(t, "[]u8")) { return; }     // prelude ZagSliceU8
    let elem: []u8 = t[2..];
    let name: []u8 = _zag_str_concat("ZagSlice_", mangle_targ(elem));
    if (slice_seen_has(seen.*, name) == 1) { return; }
    push[[]u8](seen, name);
    emit(buf, "typedef struct { ");
    emit(buf, ctype(elem));
    emit(buf, "* ptr; int32_t len; } ");
    emit(buf, name);
    emit(buf, ";\n");
}

// Walk a body, emitting a slice typedef for every typed let with a []T type.
fn emit_slice_typedefs_block(buf: *ArrayList[u8], body: ArrayList[*Node], seen: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        switch (get[*Node](body, i).*) {
            .let_   => |l| { if (l.has_dty == 1) { emit_one_slice_typedef(buf, l.dty, seen); } }
            .if_    => |x| { emit_slice_typedefs_block(buf, x.then_body, seen); if (x.has_els == 1) { emit_slice_typedefs_block(buf, x.els_body, seen); } }
            .while_ => |w| { emit_slice_typedefs_block(buf, w.body, seen); }
            .switch_ => |sw| {
                let ai: i32 = 0;
                while (ai < len[SwitchArm](sw.arms)) { emit_slice_typedefs_block(buf, get[SwitchArm](sw.arms, ai).body, seen); ai = ai + 1; }
                if (sw.has_els == 1) { emit_slice_typedefs_block(buf, sw.els_body, seen); }
            }
            else => { }
        }
        i = i + 1;
    }
}

fn emit_slice_typedefs_decl(buf: *ArrayList[u8], d: *Node, seen: *ArrayList[[]u8]) void {
    switch (d.*) {
        .fn_decl => |f| {
            if (len[[]u8](f.tparams) > 0) { return; }   // generic template: handled by mono
            let pj: i32 = 0;
            while (pj < len[Param](f.params)) {
                emit_one_slice_typedef(buf, get[Param](f.params, pj).pty, seen);
                pj = pj + 1;
            }
            emit_one_slice_typedef(buf, f.ret, seen);
            if (f.is_extern == 0) { emit_slice_typedefs_block(buf, f.body, seen); }
        }
        else => { }
    }
}

// ── unannotated `let` type inference ──────────────────────────────────────────
// `let x = expr;` (no `: Type`) needs a concrete C type. We infer it from the
// initializer and stamp the let's dty/has_dty so every later pass (slice typedefs,
// optional collection, env building, codegen) sees a real type. Conservative: an
// unknown inference leaves the let untouched (defaults to int32_t downstream).

// Declared-type string of a struct literal (honours generic application).
fn infer_slit_type(s: StructLit) []u8 {
    if (len[[]u8](s.targs) == 0) { return s.sname; }
    let t: []u8 = _zag_str_concat(s.sname, "[");
    let i: i32 = 0;
    while (i < len[[]u8](s.targs)) {
        if (i > 0) { t = _zag_str_concat(t, ","); }
        t = _zag_str_concat(t, get[[]u8](s.targs, i));
        i = i + 1;
    }
    return _zag_str_concat(t, "]");
}

fn infer_decl_type(e: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    switch (e.*) {
        .slit  => |x| { return "[]u8"; }            // string literal → byte slice
        .slit_ => |s| { return infer_slit_type(s); }
        else => { }
    }
    let t: []u8 = expr_type(e, env, dl);
    if (@strEq(t, "int_lit")) { return "i32"; }
    if (@strEq(t, "")) { return ""; }
    return t;
}

fn infer_block(body: ArrayList[*Node], env: *ArrayList[Binding], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { infer_stmt(get[*Node](body, i), env, dl); i = i + 1; }
}

fn infer_stmt(n: *Node, env: *ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .let_ => |l| {
            if (l.has_dty == 0) {
                let t: []u8 = infer_decl_type(l.expr, env.*, dl);
                if (t.len > 0) {
                    n.* = Node{ .let_ = Let{ .name = l.name, .dty = t, .has_dty = 1, .has_init = l.has_init, .expr = l.expr, .eff = l.eff, .calign = l.calign } };
                    push[Binding](env, Binding{ .name = l.name, .ty = t });
                }
            } else {
                push[Binding](env, Binding{ .name = l.name, .ty = l.dty });
            }
        }
        .if_ => |x| { infer_block(x.then_body, env, dl); if (x.has_els == 1) { infer_block(x.els_body, env, dl); } }
        .while_ => |w| { infer_block(w.body, env, dl); }
        .switch_ => |sw| {
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { infer_block(get[SwitchArm](sw.arms, ai).body, env, dl); ai = ai + 1; }
            if (sw.has_els == 1) { infer_block(sw.els_body, env, dl); }
        }
        else => { }
    }
}

// ── generic argument inference (call a generic fn without explicit type args) ──
// `unbox(bi)` where unbox[T](b: Box[T]) and bi: Box[i32] infers T=i32. We unify
// each parameter's declared type against the argument's inferred type to bind the
// type-params, then stamp the call's `targs` so collection + codegen monomorphize.

// Find the generic fn template named `nm` (tparams > 0), or a null marker.
fn find_generic_fn(decls: ArrayList[*Node], nm: []u8) i32 {
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        switch (get[*Node](decls, i).*) {
            .fn_decl => |f| { if (len[[]u8](f.tparams) > 0 && @strEq(f.name, nm)) { return i; } }
            else => { }
        }
        i = i + 1;
    }
    return 0 - 1;
}

// Unify a declared param type `pty` against an arg type `aty`, returning the
// type bound to type-param `tp` (or "" if `tp` is not determined here).
fn unify_bind(pty: []u8, aty: []u8, tp: []u8) []u8 {
    if (aty.len == 0 || @strEq(aty, "int_lit")) { return ""; }
    if (@strEq(pty, tp)) { return aty; }
    // []X vs []Y
    if (pty.len > 2 && pty[0] == '[' && pty[1] == ']' && aty.len > 2 && aty[0] == '[' && aty[1] == ']') {
        return unify_bind(pty[2..], aty[2..], tp);
    }
    // *X vs *Y
    if (pty.len > 1 && pty[0] == '*' && aty.len > 1 && aty[0] == '*') {
        return unify_bind(pty[1..], aty[1..], tp);
    }
    // Base[X] vs Base[Y]
    if (is_generic_app(pty) && is_generic_app(aty)) {
        let pl: i32 = index_of(pty, '[');
        let al: i32 = index_of(aty, '[');
        let pargs: ArrayList[[]u8] = split_args(pty[pl + 1..pty.len - 1]);
        let aargs: ArrayList[[]u8] = split_args(aty[al + 1..aty.len - 1]);
        let k: i32 = 0;
        while (k < len[[]u8](pargs) && k < len[[]u8](aargs)) {
            let b: []u8 = unify_bind(get[[]u8](pargs, k), get[[]u8](aargs, k), tp);
            if (b.len > 0) { return b; }
            k = k + 1;
        }
    }
    return "";
}

// Infer type-args for a generic fn `f` from `args`; returns "" entries for any
// param the arguments don't determine (caller treats that as "cannot infer").
fn infer_targs(f: FnDecl, args: ArrayList[*Node], env: ArrayList[Binding], dl: ArrayList[*Node]) ArrayList[[]u8] {
    let out: ArrayList[[]u8] = make[[]u8](2);
    let ti: i32 = 0;
    while (ti < len[[]u8](f.tparams)) {
        let tp: []u8 = get[[]u8](f.tparams, ti);
        let bound: []u8 = "";
        let pi: i32 = 0;
        while (pi < len[Param](f.params) && pi < len[*Node](args)) {
            let aty: []u8 = expr_type(get[*Node](args, pi), env, dl);
            let b: []u8 = unify_bind(get[Param](f.params, pi).pty, aty, tp);
            if (b.len > 0) { bound = b; pi = len[Param](f.params); } else { pi = pi + 1; }
        }
        push[[]u8](&out, bound);
        ti = ti + 1;
    }
    return out;
}

fn try_infer_generic(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .call => |c| {
            if (len[[]u8](c.targs) > 0) { return; }
            let cn: []u8 = cg_callee_name(c.callee);
            if (cn.len == 0) { return; }
            let fi: i32 = find_generic_fn(dl, cn);
            if (fi < 0) { return; }
            switch (get[*Node](dl, fi).*) {
                .fn_decl => |f| {
                    let targs: ArrayList[[]u8] = infer_targs(f, c.args, env, dl);
                    // all type-params must be determined
                    let ok: i32 = 1;
                    let k: i32 = 0;
                    while (k < len[[]u8](targs)) { if (get[[]u8](targs, k).len == 0) { ok = 0; } k = k + 1; }
                    if (ok == 1 && len[[]u8](targs) == len[[]u8](f.tparams)) {
                        n.* = Node{ .call = Call{ .callee = c.callee, .args = c.args, .targs = targs } };
                    }
                }
                else => { }
            }
        }
        else => { }
    }
}

fn ginfer_expr(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .call => |c| {
            ginfer_expr(c.callee, env, dl);
            let i: i32 = 0;
            while (i < len[*Node](c.args)) { ginfer_expr(get[*Node](c.args, i), env, dl); i = i + 1; }
            try_infer_generic(n, env, dl);
        }
        .bin   => |b| { ginfer_expr(b.l, env, dl); ginfer_expr(b.r, env, dl); }
        .un    => |u| { ginfer_expr(u.e, env, dl); }
        .fld   => |f| { ginfer_expr(f.base, env, dl); }
        .idx   => |x| { ginfer_expr(x.base, env, dl); ginfer_expr(x.idx, env, dl); }
        .cast_ => |c| { ginfer_expr(c.expr, env, dl); }
        .slice_ => |s| { ginfer_expr(s.base, env, dl); ginfer_expr(s.lo, env, dl); ginfer_expr(s.hi, env, dl); }
        .slit_ => |s| {
            let i: i32 = 0;
            while (i < len[FieldInit](s.fields)) { ginfer_expr(get[FieldInit](s.fields, i).val, env, dl); i = i + 1; }
        }
        else => { }
    }
}

fn ginfer_block(body: ArrayList[*Node], env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) { ginfer_stmt(get[*Node](body, i), env, dl); i = i + 1; }
}

fn ginfer_stmt(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) void {
    switch (n.*) {
        .let_   => |l| { ginfer_expr(l.expr, env, dl); }
        .ret    => |r| { if (r.has_expr == 1) { ginfer_expr(r.expr, env, dl); } }
        .if_    => |x| { ginfer_expr(x.cond, env, dl); ginfer_block(x.then_body, env, dl); if (x.has_els == 1) { ginfer_block(x.els_body, env, dl); } }
        .while_ => |w| { ginfer_expr(w.cond, env, dl); ginfer_block(w.body, env, dl); }
        .assign => |a| { ginfer_expr(a.target, env, dl); ginfer_expr(a.expr, env, dl); }
        .switch_ => |sw| {
            ginfer_expr(sw.subject, env, dl);
            let ai: i32 = 0;
            while (ai < len[SwitchArm](sw.arms)) { ginfer_block(get[SwitchArm](sw.arms, ai).body, env, dl); ai = ai + 1; }
            if (sw.has_els == 1) { ginfer_block(sw.els_body, env, dl); }
        }
        .estmt  => |e| { ginfer_expr(e.expr, env, dl); }
        else => { }
    }
}

fn infer_generics(decls: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        switch (get[*Node](decls, i).*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) == 0 && f.is_extern == 0) {
                    ginfer_block(f.body, build_env(f.params, f.body, decls), decls);
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

fn infer_program(decls: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        switch (get[*Node](decls, i).*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) == 0 && f.is_extern == 0) {
                    let env: ArrayList[Binding] = make[Binding](8);
                    let pi: i32 = 0;
                    while (pi < len[Param](f.params)) {
                        push[Binding](&env, Binding{ .name = get[Param](f.params, pi).name, .ty = get[Param](f.params, pi).pty });
                        pi = pi + 1;
                    }
                    infer_block(f.body, &env, decls);
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

// Environment struct for a capturing closure: one field per capture.
fn emit_clos_env(buf: *ArrayList[u8], d: *Node) void {
    switch (d.*) {
        .fn_decl => |f| {
            if (cg_starts_with(f.name, "__clos_") == 1 && f.cap_names.len > 0) {
                let names: ArrayList[[]u8] = split_args(f.cap_names);
                let tys: ArrayList[[]u8] = split_args(f.cap_types);
                emit(buf, "typedef struct { ");
                let i: i32 = 0;
                while (i < len[[]u8](names)) {
                    if (i < len[[]u8](tys)) { emit(buf, ctype(get[[]u8](tys, i))); } else { emit(buf, "int32_t"); }
                    emit(buf, " "); emit(buf, get[[]u8](names, i)); emit(buf, "; ");
                    i = i + 1;
                }
                emit(buf, "} "); emit(buf, f.name); emit(buf, "_env;\n");
            }
        }
        else => { }
    }
}

// Thunk adapting a named fn to the env-first fat-closure calling convention.
fn emit_thunk(buf: *ArrayList[u8], name: []u8, dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| {
                if (@strEq(f.name, name)) {
                    emit(buf, "static "); emit(buf, ctype(f.ret));
                    emit(buf, " __thunk_"); emit(buf, name); emit(buf, "(void* __zenv");
                    let pj: i32 = 0;
                    while (pj < len[Param](f.params)) {
                        let p: Param = get[Param](f.params, pj);
                        emit(buf, ", "); emit(buf, ctype(p.pty)); emit(buf, " "); emit(buf, p.name);
                        pj = pj + 1;
                    }
                    emit(buf, "){ (void)__zenv; ");
                    if (!@strEq(f.ret, "void")) { emit(buf, "return "); }
                    emit(buf, name); emit(buf, "(");
                    let aj: i32 = 0;
                    while (aj < len[Param](f.params)) {
                        if (aj > 0) { emit(buf, ", "); }
                        emit(buf, get[Param](f.params, aj).name);
                        aj = aj + 1;
                    }
                    emit(buf, "); }\n");
                    return;
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

// ── function-pointer typedefs (`typedef Ret (*ZagFn_..)(Params);`) ────────────
fn emit_one_fn_typedef(buf: *ArrayList[u8], t: []u8, seen: *ArrayList[[]u8]) void {
    if (is_fn_type(t) == 0) { return; }
    let name: []u8 = mangle_fn(t);
    if (slice_seen_has(seen.*, name) == 1) { return; }
    push[[]u8](seen, name);
    // fat closure pointer: a code pointer (env-first) + an environment pointer.
    emit(buf, "typedef struct { ");
    emit(buf, ctype(fn_type_ret(t)));
    emit(buf, " (*fn)(void*");
    let ps: []u8 = fn_type_params(t);
    if (ps.len > 0) {
        let args: ArrayList[[]u8] = split_args(ps);
        let i: i32 = 0;
        while (i < len[[]u8](args)) {
            emit(buf, ", ");
            emit(buf, ctype(get[[]u8](args, i)));
            i = i + 1;
        }
    }
    emit(buf, "); void* env; } ");
    emit(buf, name);
    emit(buf, ";\n");
}

fn emit_fn_typedefs_block(buf: *ArrayList[u8], body: ArrayList[*Node], seen: *ArrayList[[]u8]) void {
    let i: i32 = 0;
    while (i < len[*Node](body)) {
        switch (get[*Node](body, i).*) {
            .let_   => |l| { if (l.has_dty == 1) { emit_one_fn_typedef(buf, l.dty, seen); } }
            .if_    => |x| { emit_fn_typedefs_block(buf, x.then_body, seen); if (x.has_els == 1) { emit_fn_typedefs_block(buf, x.els_body, seen); } }
            .while_ => |w| { emit_fn_typedefs_block(buf, w.body, seen); }
            .switch_ => |sw| {
                let ai: i32 = 0;
                while (ai < len[SwitchArm](sw.arms)) { emit_fn_typedefs_block(buf, get[SwitchArm](sw.arms, ai).body, seen); ai = ai + 1; }
                if (sw.has_els == 1) { emit_fn_typedefs_block(buf, sw.els_body, seen); }
            }
            else => { }
        }
        i = i + 1;
    }
}

fn emit_fn_typedefs_decl(buf: *ArrayList[u8], d: *Node, seen: *ArrayList[[]u8]) void {
    switch (d.*) {
        .fn_decl => |f| {
            if (len[[]u8](f.tparams) > 0) { return; }
            let pj: i32 = 0;
            while (pj < len[Param](f.params)) {
                emit_one_fn_typedef(buf, get[Param](f.params, pj).pty, seen);
                pj = pj + 1;
            }
            emit_one_fn_typedef(buf, f.ret, seen);
            if (f.is_extern == 0) { emit_fn_typedefs_block(buf, f.body, seen); }
        }
        .struct_ => |s| {
            if (len[[]u8](s.tparams) > 0) { return; }
            let fj: i32 = 0;
            while (fj < len[Param](s.fields)) {
                emit_one_fn_typedef(buf, get[Param](s.fields, fj).pty, seen);
                fj = fj + 1;
            }
        }
        .union_ => |u| {
            let fj: i32 = 0;
            while (fj < len[Param](u.fields)) {
                emit_one_fn_typedef(buf, get[Param](u.fields, fj).pty, seen);
                fj = fj + 1;
            }
        }
        else => { }
    }
}

// Codegen from an already-resolved decl list (the driver parses once to also
// collect runtime.c paths, then reuses the decls here).
// RISC-V PPU hardware posit path (--target ppu32). The software p32 math in
// emit_numeric_runtime is `#ifndef ZAG_TARGET_PPU32`'d out (we emit the #define
// for ppu32), and these hardware ops — padd.s/psub.s/pmul.s/pdiv.s — replace it.
// p32 bits move through 32-bit float registers; memcpy bit-punning is a single
// fmv.w.x/fmv.x.w at -O1+. (--emit-c only; an actual build needs a riscv64 cc.)
fn emit_ppu_math(buf: *ArrayList[u8]) void {
    emit(buf, "\n");
    emit(buf, "/* ── P4: RISC-V PPU hardware posit path — padd.s/psub.s/pmul.s/pdiv.s ── */\n");
    emit(buf, "#if !defined(__riscv)\n");
    emit(buf, "#warning \"zagc --target ppu32: generated for RISC-V PPU; cross-compile with a riscv64 toolchain\"\n");
    emit(buf, "#endif\n");
    emit(buf, "static inline float   _zp_load(uint32_t b){ float f; __builtin_memcpy(&f,&b,4); return f; }\n");
    emit(buf, "static inline uint32_t _zp_store(float f){ uint32_t b; __builtin_memcpy(&b,&f,4); return b; }\n");
    emit(buf, "static uint32_t zag_p32_add(uint32_t a, uint32_t b){\n");
    emit(buf, "    float _r; __asm__ volatile(\"padd.s %0,%1,%2\":\"=f\"(_r):\"f\"(_zp_load(a)),\"f\"(_zp_load(b))); return _zp_store(_r); }\n");
    emit(buf, "static uint32_t zag_p32_sub(uint32_t a, uint32_t b){\n");
    emit(buf, "    float _r; __asm__ volatile(\"psub.s %0,%1,%2\":\"=f\"(_r):\"f\"(_zp_load(a)),\"f\"(_zp_load(b))); return _zp_store(_r); }\n");
    emit(buf, "static uint32_t zag_p32_mul(uint32_t a, uint32_t b){\n");
    emit(buf, "    float _r; __asm__ volatile(\"pmul.s %0,%1,%2\":\"=f\"(_r):\"f\"(_zp_load(a)),\"f\"(_zp_load(b))); return _zp_store(_r); }\n");
    emit(buf, "static uint32_t zag_p32_div(uint32_t a, uint32_t b){\n");
    emit(buf, "    float _r; __asm__ volatile(\"pdiv.s %0,%1,%2\":\"=f\"(_r):\"f\"(_zp_load(a)),\"f\"(_zp_load(b))); return _zp_store(_r); }\n");
    emit(buf, "\n");
}

// ── interface vtable emission ─────────────────────────────────────────────────
fn iface_pi_str(pi: i32) []u8 {
    if (pi == 0) { return "0"; }
    if (pi == 1) { return "1"; }
    if (pi == 2) { return "2"; }
    if (pi == 3) { return "3"; }
    return _zag_i64_to_str(pi as i64);
}
// Count comma-separated tokens in ptys that are NOT "self". Used for extra
// thunk params beyond the implicit void* receiver.
fn iface_extra_param_count(ptys: []u8) i32 {
    let n: i32 = 0;
    let i: i32 = 0;
    // collect one token at a time, skip "self"
    let tok_start: i32 = 0;
    while (i <= ptys.len) {
        if (i == ptys.len || ptys[i] == ',') {
            // token: ptys[tok_start..i]
            let tlen: i32 = i - tok_start;
            if (tlen > 0) {
                // check if it's "self"
                let is_self: i32 = 0;
                if (tlen == 4) {
                    if (ptys[tok_start] == 's' && ptys[tok_start+1] == 'e' && ptys[tok_start+2] == 'l' && ptys[tok_start+3] == 'f') { is_self = 1; }
                }
                if (is_self == 0) { n = n + 1; }
            }
            tok_start = i + 1;
        }
        i = i + 1;
    }
    return n;
}

// Emit vtable struct + fat-pointer struct for one interface.
// Produces: typedef struct { ret (*mname)(void*, extra...); } __vtbl_Iname_t;
//           typedef struct { __vtbl_Iname_t *vtbl; void *data; } Iname;
fn emit_one_iface_type(buf: *ArrayList[u8], iname: []u8, methods: ArrayList[Param]) void {
    emit(buf, "typedef struct { ");
    let m: i32 = 0;
    while (m < len[Param](methods)) {
        let meth: Param = get[Param](methods, m);
        emit(buf, ctype(meth.pty));
        emit(buf, " (*");
        emit(buf, meth.name);
        emit(buf, ")(void*");
        // extra params (non-self types from meth.eff)
        let ptys: []u8 = meth.eff;
        let i: i32 = 0;
        let tok_start: i32 = 0;
        let pi: i32 = 0;
        while (i <= ptys.len) {
            if (i == ptys.len || ptys[i] == ',') {
                let tlen: i32 = i - tok_start;
                if (tlen > 0) {
                    let is_self: i32 = 0;
                    if (tlen == 4) {
                        if (ptys[tok_start] == 's' && ptys[tok_start+1] == 'e' && ptys[tok_start+2] == 'l' && ptys[tok_start+3] == 'f') { is_self = 1; }
                    }
                    if (is_self == 0) {
                        emit(buf, ", ");
                        emit(buf, ctype(ptys[tok_start..i]));
                        pi = pi + 1;
                    }
                }
                tok_start = i + 1;
            }
            i = i + 1;
        }
        emit(buf, "); ");
        m = m + 1;
    }
    emit(buf, "} __vtbl_");
    emit(buf, iname);
    emit(buf, "_t;\n");
    emit(buf, "typedef struct { __vtbl_");
    emit(buf, iname);
    emit(buf, "_t *vtbl; void *data; } ");
    emit(buf, iname);
    emit(buf, ";\n");
}

// Check if a concrete type implements an interface (has all methods as fn decls).
fn concrete_impls_iface(dl: ArrayList[*Node], cname: []u8, iname: []u8) i32 {
    let methods: ArrayList[Param] = find_iface(dl, iname);
    let nm: i32 = len[Param](methods);
    if (nm == 0) { return 0; }
    let m: i32 = 0;
    while (m < nm) {
        let mname: []u8 = get[Param](methods, m).name;
        let full: []u8 = _zag_str_concat(_zag_str_concat(cname, "_"), mname);
        if (!fn_exists(dl, full)) { return 0; }
        m = m + 1;
    }
    return 1;
}

// Collect all struct names that implement the interface `iname`.
fn collect_iface_impls(dl: ArrayList[*Node], iname: []u8) ArrayList[[]u8] {
    let out: ArrayList[[]u8] = make[[]u8](4);
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .struct_ => |s| {
                if (len[[]u8](s.tparams) == 0 && concrete_impls_iface(dl, s.name, iname) == 1) {
                    push[[]u8](&out, s.name);
                }
            }
            else => { }
        }
        i = i + 1;
    }
    return out;
}

// Emit thunks + vtable instance for (cname, iname) pair.
fn emit_iface_thunks_for(buf: *ArrayList[u8], cname: []u8, iname: []u8, dl: ArrayList[*Node]) void {
    let methods: ArrayList[Param] = find_iface(dl, iname);
    let m: i32 = 0;
    while (m < len[Param](methods)) {
        let meth: Param = get[Param](methods, m);
        let thunk: []u8 = _zag_str_concat("__thunk_", _zag_str_concat(cname, _zag_str_concat("_", _zag_str_concat(iname, _zag_str_concat("_", meth.name)))));
        emit(buf, "static ");
        emit(buf, ctype(meth.pty));
        emit(buf, " ");
        emit(buf, thunk);
        emit(buf, "(void* _d");
        // extra params
        let ptys: []u8 = meth.eff;
        let i: i32 = 0;
        let tok_start: i32 = 0;
        let pi: i32 = 0;
        while (i <= ptys.len) {
            if (i == ptys.len || ptys[i] == ',') {
                let tlen: i32 = i - tok_start;
                if (tlen > 0) {
                    let is_self: i32 = 0;
                    if (tlen == 4) {
                        if (ptys[tok_start] == 's' && ptys[tok_start+1] == 'e' && ptys[tok_start+2] == 'l' && ptys[tok_start+3] == 'f') { is_self = 1; }
                    }
                    if (is_self == 0) {
                        emit(buf, ", ");
                        emit(buf, ctype(ptys[tok_start..i]));
                        emit(buf, " _p");
                        emit(buf, iface_pi_str(pi));
                        pi = pi + 1;
                    }
                }
                tok_start = i + 1;
            }
            i = i + 1;
        }
        emit(buf, ") { ");
        emit(buf, cname);
        emit(buf, " _s = *(");
        emit(buf, cname);
        emit(buf, "*)_d; return ");
        emit(buf, cname);
        emit(buf, "_");
        emit(buf, meth.name);
        emit(buf, "(_s");
        let pi2: i32 = 0;
        while (pi2 < pi) {
            emit(buf, ", _p");
            emit(buf, iface_pi_str(pi2));
            pi2 = pi2 + 1;
        }
        emit(buf, "); }\n");
        m = m + 1;
    }
    // vtable instance
    emit(buf, "static __vtbl_");
    emit(buf, iname);
    emit(buf, "_t __vtbl_");
    emit(buf, cname);
    emit(buf, "_");
    emit(buf, iname);
    emit(buf, " = { ");
    let k: i32 = 0;
    while (k < len[Param](methods)) {
        if (k > 0) { emit(buf, ", "); }
        let meth: Param = get[Param](methods, k);
        emit(buf, "__thunk_");
        emit(buf, cname);
        emit(buf, "_");
        emit(buf, iname);
        emit(buf, "_");
        emit(buf, meth.name);
        k = k + 1;
    }
    emit(buf, " };\n");
}

// Emit dispatch-helper fns for each interface: __idsp_Shape_area(Shape s) → s.vtbl->area(s.data)
fn emit_iface_dispatch_helpers(buf: *ArrayList[u8], iname: []u8, methods: ArrayList[Param]) void {
    let m: i32 = 0;
    while (m < len[Param](methods)) {
        let meth: Param = get[Param](methods, m);
        emit(buf, "static inline ");
        emit(buf, ctype(meth.pty));
        emit(buf, " __idsp_");
        emit(buf, iname);
        emit(buf, "_");
        emit(buf, meth.name);
        emit(buf, "(");
        emit(buf, iname);
        emit(buf, " _s");
        // extra params
        let ptys: []u8 = meth.eff;
        let i: i32 = 0;
        let tok_start: i32 = 0;
        let pi: i32 = 0;
        while (i <= ptys.len) {
            if (i == ptys.len || ptys[i] == ',') {
                let tlen: i32 = i - tok_start;
                if (tlen > 0) {
                    let is_self: i32 = 0;
                    if (tlen == 4) {
                        if (ptys[tok_start] == 's' && ptys[tok_start+1] == 'e' && ptys[tok_start+2] == 'l' && ptys[tok_start+3] == 'f') { is_self = 1; }
                    }
                    if (is_self == 0) {
                        emit(buf, ", ");
                        emit(buf, ctype(ptys[tok_start..i]));
                        emit(buf, " _p");
                        emit(buf, iface_pi_str(pi));
                        pi = pi + 1;
                    }
                }
                tok_start = i + 1;
            }
            i = i + 1;
        }
        emit(buf, ") { return _s.vtbl->");
        emit(buf, meth.name);
        emit(buf, "(_s.data");
        let pi2: i32 = 0;
        while (pi2 < pi) {
            emit(buf, ", _p");
            emit(buf, iface_pi_str(pi2));
            pi2 = pi2 + 1;
        }
        emit(buf, "); }\n");
        m = m + 1;
    }
}

// Phase 1 (before protos): emit vtable struct typedefs + interface fat-pointer types.
fn emit_iface_types(buf: *ArrayList[u8], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| {
                if (cg_starts_with(f.name, "__iface_") == 1) {
                    let iname: []u8 = f.name[8..];
                    emit_one_iface_type(buf, iname, f.params);
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

// Phase 2 (after protos): emit thunks, vtable instances, dispatch helpers.
fn emit_iface_impls(buf: *ArrayList[u8], dl: ArrayList[*Node]) void {
    let i: i32 = 0;
    while (i < len[*Node](dl)) {
        switch (get[*Node](dl, i).*) {
            .fn_decl => |f| {
                if (cg_starts_with(f.name, "__iface_") == 1) {
                    let iname: []u8 = f.name[8..];
                    let impls: ArrayList[[]u8] = collect_iface_impls(dl, iname);
                    let k: i32 = 0;
                    while (k < len[[]u8](impls)) {
                        emit_iface_thunks_for(buf, get[[]u8](impls, k), iname, dl);
                        k = k + 1;
                    }
                    emit_iface_dispatch_helpers(buf, iname, f.params);
                }
            }
            else => { }
        }
        i = i + 1;
    }
}

// Emit all interface infrastructure: types, thunks, vtable instances, dispatch helpers.
fn emit_iface_all(buf: *ArrayList[u8], dl: ArrayList[*Node]) void {
    emit_iface_types(buf, dl);
    emit_iface_impls(buf, dl);
}

// Interface type name of the receiver at a call site (for method rewriting).
// Returns "" if the receiver is not an interface type.
fn iface_recv_type(n: *Node, env: ArrayList[Binding], dl: ArrayList[*Node]) []u8 {
    let rt: []u8 = recv_type(n, env, dl);
    if (rt.len == 0) { return ""; }
    if (iface_method_count(dl, rt) > 0) { return rt; }
    return "";
}

fn codegen_decls(decls: ArrayList[*Node]) ArrayList[u8] {
    return codegen_decls_t(decls, 0);
}

// `ppu32` = 1 selects the RISC-V PPU hardware-posit target: emit
// `#define ZAG_TARGET_PPU32` (compiling out the software p32 math) and append
// the inline-asm padd.s/psub.s/pmul.s/pdiv.s ops after the numeric runtime.
fn codegen_decls_t(decls: ArrayList[*Node], ppu32: i32) ArrayList[u8] {
    // infer types for unannotated `let`s before any type-dependent pass runs
    infer_program(decls);
    // rewrite operator-contract binary ops (a + b → decode(a,b)) before codegen
    lower_operators(decls);
    // lower fn-values / capturing closures to the fat-pointer model (must run
    // before monomorphization so cloned generic bodies inherit the rewrites)
    let thunks: ArrayList[[]u8] = make[[]u8](4);
    lower_fnvalues(decls, &thunks);
    // infer type-args for generic calls written without explicit `[T]`
    infer_generics(decls);
    let buf: ArrayList[u8] = make[u8](4096);
    // ppu32: compile out the software posit math; the hardware ops are appended below.
    if (ppu32 == 1) { emit(&buf, "#define ZAG_TARGET_PPU32\n"); }
    emit(&buf, "#include <stdint.h>\n");
    emit(&buf, "#include <stdio.h>\n");
    emit(&buf, "#include <stdlib.h>\n");
    emit(&buf, "#include <string.h>\n");
    emit(&buf, "#include <stdbool.h>\n");
    emit(&buf, "#include <math.h>\n");
    emit(&buf, "static void* _zag_heap_dup(const void* p, size_t n){ void* q=malloc(n); if(q) memcpy(q,p,n); return q; }\n");
    emit(&buf, "typedef struct { const uint8_t* ptr; int32_t len; } ZagSliceU8;\n");
    // ── cache-line control runtime (portable; @prefetch/@cacheAlign/@cacheAligned*) ──
    emit(&buf, "#define ZAG_CACHE_LINE 64\n");
    // []f32 slice + its allocator/deallocator (DSP examples: zalloc/zfree).
    emit(&buf, "typedef struct { float* ptr; int32_t len; } ZagSlice_f32;\n");
    emit(&buf, "static ZagSlice_f32 zalloc(int32_t n){ ZagSlice_f32 s; s.ptr=(float*)malloc((size_t)n*sizeof(float)); s.len=n; return s; }\n");
    emit(&buf, "static void zfree(ZagSlice_f32 s){ free(s.ptr); }\n");
    // cache-line-aligned []f32: base pinned to a 64-byte line (no false sharing / straddle).
    emit(&buf, "static ZagSlice_f32 zag_cache_aligned_alloc(int32_t n){ ZagSlice_f32 s; size_t bytes=(size_t)n*sizeof(float); size_t rb=(bytes + (ZAG_CACHE_LINE-1)) & ~((size_t)(ZAG_CACHE_LINE-1)); void* p=0;\n");
    emit(&buf, "#if defined(_ISOC11_SOURCE) || (defined(__STDC_VERSION__) && __STDC_VERSION__ >= 201112L)\n");
    emit(&buf, "  p=aligned_alloc(ZAG_CACHE_LINE, rb);\n#else\n  if (posix_memalign(&p, ZAG_CACHE_LINE, rb)!=0) p=0;\n#endif\n");
    emit(&buf, "  s.ptr=(float*)p; s.len=n; return s; }\n");
    emit(&buf, "static void zag_cache_aligned_free(ZagSlice_f32 s){ free(s.ptr); }\n");
    emit(&buf, "typedef struct { int32_t* ptr; int32_t len; } ZagSlice_i32;\n");
    emit(&buf, "static ZagSlice_i32 zalloc_i(int32_t n){ ZagSlice_i32 s; s.ptr=(int32_t*)malloc((size_t)n*sizeof(int32_t)); s.len=n; return s; }\n");
    emit(&buf, "static void zfree_i(ZagSlice_i32 s){ free(s.ptr); }\n");
    emit(&buf, "static void print_i32(int32_t x){ printf(\"%d\\n\", x); }\n");
    emit(&buf, "static void print_i64(int64_t x){ printf(\"%lld\\n\", (long long)x); }\n");
    emit(&buf, "static void print_u64(uint64_t x){ printf(\"%llu\\n\", (unsigned long long)x); }\n");
    emit(&buf, "static void print_f32(float x){ printf(\"%g\\n\", (double)x); }\n");
    emit(&buf, "static void print_f64(double x){ printf(\"%g\\n\", x); }\n");
    emit(&buf, "static void print_str(ZagSliceU8 s){ fwrite(s.ptr, 1, s.len, stdout); putchar('\\n'); }\n");
    emit(&buf, "static int32_t _zag_str_len(ZagSliceU8 s){ return s.len; }\n");
    emit(&buf, "static int32_t _zag_str_eq(ZagSliceU8 a, ZagSliceU8 b){ if (a.len != b.len) return 0; for (int32_t i=0;i<a.len;i++) if (a.ptr[i]!=b.ptr[i]) return 0; return 1; }\n");
    // Heterogeneous numeric runtime (posits/quire/sat/rns) — emitted up front so
    // any program that uses these types links against the prelude functions.
    emit_numeric_runtime(&buf);
    // ppu32 hardware posit ops (padd.s/…): replace the #ifndef'd-out software p32.
    if (ppu32 == 1) { emit_ppu_math(&buf); }
    // Special slice typedefs (ZagSlice_<elem>) for every []T (T != u8) that
    // appears in a fn signature or a typed let — slices of numeric/struct
    // element types the prelude doesn't predeclare.
    let slice_seen: ArrayList[[]u8] = make[[]u8](4);
    push[[]u8](&slice_seen, "ZagSlice_f32");   // already emitted in the prelude
    push[[]u8](&slice_seen, "ZagSlice_i32");   // already emitted in the prelude
    let sli: i32 = 0;
    while (sli < len[*Node](decls)) {
        emit_slice_typedefs_decl(&buf, get[*Node](decls, sli), &slice_seen);
        sli = sli + 1;
    }
    // function-pointer typedefs (fn-type params / lets / struct fields)
    let fn_seen: ArrayList[[]u8] = make[[]u8](4);
    let fni: i32 = 0;
    while (fni < len[*Node](decls)) {
        emit_fn_typedefs_decl(&buf, get[*Node](decls, fni), &fn_seen);
        fni = fni + 1;
    }
    // collect generic instantiations from all (non-generic) fn bodies
    let insts: ArrayList[Inst] = make[Inst](8);
    let sinsts: ArrayList[SInst] = make[SInst](8);
    let ci: i32 = 0;
    while (ci < len[*Node](decls)) {
        let d: *Node = get[*Node](decls, ci);
        switch (d.*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) == 0 && f.is_extern == 0) {
                    collect_block(f.body, decls, &insts);
                    collect_sinst_block(f.body, decls, &sinsts);
                }
            }
            else => { }
        }
        ci = ci + 1;
    }
    // fixpoint: a generic fn body may call other generics (make[i32] calls
    // alloc_table[i32]; put[i32] calls grow[i32]). Walk each instance's
    // (substituted) body, appending newly-needed instances until stable.
    let fp: i32 = 0;
    while (fp < len[Inst](insts)) {
        collect_block(get[Inst](insts, fp).cbody, decls, &insts);
        fp = fp + 1;
    }
    // fn-pointer typedefs needed by the monomorphized instances (e.g. mapInPlace
    // at f32 needs ZagFn_f32_f32 from its substituted `fn(T)T` parameter).
    let ifn: i32 = 0;
    while (ifn < len[Inst](insts)) {
        let inst2: Inst = get[Inst](insts, ifn);
        let pj2: i32 = 0;
        while (pj2 < len[Param](inst2.f.params)) {
            emit_one_fn_typedef(&buf, subst_type(get[Param](inst2.f.params, pj2).pty, inst2.f.tparams, inst2.targs), &fn_seen);
            pj2 = pj2 + 1;
        }
        emit_one_fn_typedef(&buf, subst_type(inst2.f.ret, inst2.f.tparams, inst2.targs), &fn_seen);
        ifn = ifn + 1;
    }
    // also collect struct instantiations from the monomorphized (concrete) fn
    // bodies — e.g. make_pair[i32]'s body builds Pair[i32]{...}
    let mi: i32 = 0;
    while (mi < len[Inst](insts)) {
        let inst: Inst = get[Inst](insts, mi);
        collect_sinst_block(inst.cbody, decls, &sinsts);
        record_type_sinst(subst_type(inst.f.ret, inst.f.tparams, inst.targs), decls, &sinsts);
        let ip: i32 = 0;
        while (ip < len[Param](inst.f.params)) {
            record_type_sinst(subst_type(get[Param](inst.f.params, ip).pty, inst.f.tparams, inst.targs), decls, &sinsts);
            ip = ip + 1;
        }
        mi = mi + 1;
    }
    // also collect struct insts from concrete fn signatures (param + ret types) —
    // e.g. a fn taking ArrayList[i32] never built via a let still needs the typedef.
    let fsi: i32 = 0;
    while (fsi < len[*Node](decls)) {
        switch (get[*Node](decls, fsi).*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) == 0) {
                    let pj: i32 = 0;
                    while (pj < len[Param](f.params)) {
                        record_type_sinst(get[Param](f.params, pj).pty, decls, &sinsts);
                        pj = pj + 1;
                    }
                    record_type_sinst(f.ret, decls, &sinsts);
                }
            }
            else => { }
        }
        fsi = fsi + 1;
    }

    // ── type declarations, ordered for C ──────────────────────────────────────
    // 1. forward-declare every struct/union (named `typedef struct N_s N;`) +
    //    emit enums; so any *pointer* field resolves regardless of order.
    let tf: i32 = 0;
    while (tf < len[*Node](decls)) { gen_type_fwd(&buf, get[*Node](decls, tf)); tf = tf + 1; }
    let sfwd: i32 = 0;
    while (sfwd < len[SInst](sinsts)) { emit_sinst_fwd(&buf, get[SInst](sinsts, sfwd)); sfwd = sfwd + 1; }
    // 2. generic-instance bodies (their element types are referenced by pointer,
    //    so forward decls suffice; a user struct holds these by value).
    let sg: i32 = 0;
    while (sg < len[SInst](sinsts)) { emit_sinst(&buf, get[SInst](sinsts, sg)); sg = sg + 1; }
    // 3. user struct/union bodies in source order (already dependency-ordered;
    //    the instance structs they hold by value are now complete).
    let tb: i32 = 0;
    while (tb < len[*Node](decls)) { gen_type_body(&buf, get[*Node](decls, tb)); tb = tb + 1; }
    // 4. interface vtable struct typedefs + fat-pointer types (after concrete structs they wrap).
    emit_iface_types(&buf, decls);
    // capturing-closure environment structs (after user structs they may hold).
    let ce: i32 = 0;
    while (ce < len[*Node](decls)) { emit_clos_env(&buf, get[*Node](decls, ce)); ce = ce + 1; }

    // collect optional types (?T) from signatures, bodies, and mono instances,
    // then emit a ZagOpt_ struct typedef for each (after the structs they wrap).
    let opts: ArrayList[[]u8] = make[[]u8](4);
    let oi: i32 = 0;
    while (oi < len[*Node](decls)) {
        switch (get[*Node](decls, oi).*) {
            .fn_decl => |f| {
                // skip generic templates — their ?V would emit ZagOpt_V; the
                // concrete ?i32 etc. come from the monomorphized instances below.
                if (len[[]u8](f.tparams) == 0) {
                    collect_opts_params(f.params, &opts);
                    collect_opt(f.ret, &opts);
                    if (f.is_extern == 0) { collect_opts_block(f.body, &opts); }
                }
            }
            .struct_ => |s| { if (len[[]u8](s.tparams) == 0) { collect_opts_params(s.fields, &opts); } }
            .union_  => |u| { collect_opts_params(u.fields, &opts); }
            else => { }
        }
        oi = oi + 1;
    }
    let omi: i32 = 0;
    while (omi < len[Inst](insts)) {
        let minst: Inst = get[Inst](insts, omi);
        let pj: i32 = 0;
        while (pj < len[Param](minst.f.params)) {
            collect_opt(subst_type(get[Param](minst.f.params, pj).pty, minst.f.tparams, minst.targs), &opts);
            pj = pj + 1;
        }
        collect_opt(subst_type(minst.f.ret, minst.f.tparams, minst.targs), &opts);
        collect_opts_block(minst.cbody, &opts);
        omi = omi + 1;
    }
    emit_opt_typedefs(&buf, opts);

    // collect error-union types (!T) from signatures + bodies, emit ZagErr_ structs
    let errs: ArrayList[[]u8] = make[[]u8](4);
    let ei: i32 = 0;
    while (ei < len[*Node](decls)) {
        switch (get[*Node](decls, ei).*) {
            .fn_decl => |f| {
                if (len[[]u8](f.tparams) == 0) {
                    collect_errs_params(f.params, &errs);
                    collect_err(f.ret, &errs);
                    if (f.is_extern == 0) { collect_errs_block(f.body, &errs); }
                }
            }
            .struct_ => |s| { if (len[[]u8](s.tparams) == 0) { collect_errs_params(s.fields, &errs); } }
            .union_  => |u| { collect_errs_params(u.fields, &errs); }
            else => { }
        }
        ei = ei + 1;
    }
    emit_err_typedefs(&buf, errs);

    // prototypes: monomorphized generics first, then regular fns
    let mp: i32 = 0;
    while (mp < len[Inst](insts)) {
        emit_mono_proto(&buf, get[Inst](insts, mp));
        mp = mp + 1;
    }
    let i: i32 = 0;
    while (i < len[*Node](decls)) {
        gen_decl_proto(&buf, get[*Node](decls, i));
        i = i + 1;
    }
    // interface thunks, vtable instances, and dispatch helpers
    // (after fn protos so they can reference the concrete-type fns by forward decl).
    emit_iface_impls(&buf, decls);
    // thunks: adapt a named fn to the env-first closure calling convention.
    let ti: i32 = 0;
    while (ti < len[[]u8](thunks)) {
        emit_thunk(&buf, get[[]u8](thunks, ti), decls);
        ti = ti + 1;
    }
    // bodies: monomorphized generics, then regular fns
    let mb: i32 = 0;
    while (mb < len[Inst](insts)) {
        emit_mono_body(&buf, get[Inst](insts, mb), decls);
        mb = mb + 1;
    }
    let j: i32 = 0;
    while (j < len[*Node](decls)) {
        gen_decl(&buf, get[*Node](decls, j), decls);
        j = j + 1;
    }
    return buf;
}
