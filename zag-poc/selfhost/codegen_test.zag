// selfhost/codegen_test.zag — exercises the self-hosted C backend.
// Codegens a recursive fib(10) program and prints the resulting C to stdout.
// The test harness compiles that C and checks it computes 55.

@import("codegen.zag")

fn main() void {
    let src: []u8 = "fn fib(n: i32) i32 { if (n < 2) { return n; } return fib(n - 1) + fib(n - 2); } fn main() void { print_i32(fib(10)); }";
    let buf: ArrayList[u8] = codegen(src);
    _zag_print(buf.data[0..buf.len]);
}
