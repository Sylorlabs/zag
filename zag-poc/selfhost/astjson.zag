// selfhost/astjson.zag — AI-native AST → JSON, written in Zag.
//
// The self-hosted twin of the Zig bootstrap's `zagc ast` (moat feature #2):
// parse a source file and emit its AST as machine-readable JSON for tools/LLMs.
// Pure AST-traversal-to-string — the shape the self-hosted codegen already
// excels at — so it ports cleanly into the Zag-written compiler.

@import("parse.zag")

// ── byte-buffer + JSON string helpers ────────────────────────────────────────
fn aj(buf: *ArrayList[u8], s: []u8) void {
    let i: i32 = 0;
    while (i < s.len) {
        push[u8](buf, s[i]);
        i = i + 1;
    }
}

fn aj_esc(buf: *ArrayList[u8], s: []u8) void {
    let i: i32 = 0;
    while (i < s.len) {
        let c: i32 = s[i] as i32;
        if (c == '"') { aj(buf, "\\\""); }
        else if (c == '\\') { aj(buf, "\\\\"); }
        else if (c == '\n') { aj(buf, "\\n"); }
        else { push[u8](buf, s[i]); }
        i = i + 1;
    }
}

fn aj_q(buf: *ArrayList[u8], s: []u8) void {
    aj(buf, "\"");
    aj_esc(buf, s);
    aj(buf, "\"");
}

// "key": "value"
fn aj_kv(buf: *ArrayList[u8], k: []u8, v: []u8) void {
    aj_q(buf, k);
    aj(buf, ": ");
    aj_q(buf, v);
}

// "key":
fn aj_key(buf: *ArrayList[u8], k: []u8) void {
    aj_q(buf, k);
    aj(buf, ": ");
}

fn aj_bool(buf: *ArrayList[u8], flag: i32) void {
    if (flag != 0) { aj(buf, "true"); } else { aj(buf, "false"); }
}

// ── list emitters ────────────────────────────────────────────────────────────
fn aj_strs(buf: *ArrayList[u8], xs: ArrayList[[]u8]) void {
    aj(buf, "[");
    let i: i32 = 0;
    while (i < len[[]u8](xs)) {
        if (i > 0) { aj(buf, ", "); }
        aj_q(buf, get[[]u8](xs, i));
        i = i + 1;
    }
    aj(buf, "]");
}

fn aj_params(buf: *ArrayList[u8], ps: ArrayList[Param]) void {
    aj(buf, "[");
    let i: i32 = 0;
    while (i < len[Param](ps)) {
        if (i > 0) { aj(buf, ", "); }
        let p: Param = get[Param](ps, i);
        aj(buf, "{");
        aj_kv(buf, "name", p.name);
        aj(buf, ", ");
        aj_kv(buf, "type", p.pty);
        aj(buf, "}");
        i = i + 1;
    }
    aj(buf, "]");
}

fn aj_nodes(buf: *ArrayList[u8], xs: ArrayList[*Node]) void {
    aj(buf, "[");
    let i: i32 = 0;
    while (i < len[*Node](xs)) {
        if (i > 0) { aj(buf, ", "); }
        aj_node(buf, get[*Node](xs, i));
        i = i + 1;
    }
    aj(buf, "]");
}

fn aj_fieldinits(buf: *ArrayList[u8], fs: ArrayList[FieldInit]) void {
    aj(buf, "[");
    let i: i32 = 0;
    while (i < len[FieldInit](fs)) {
        if (i > 0) { aj(buf, ", "); }
        let fi: FieldInit = get[FieldInit](fs, i);
        aj(buf, "{");
        aj_kv(buf, "name", fi.name);
        aj(buf, ", ");
        aj_key(buf, "value");
        aj_node(buf, fi.val);
        aj(buf, "}");
        i = i + 1;
    }
    aj(buf, "]");
}

// ── one node → JSON object ───────────────────────────────────────────────────
fn aj_node(buf: *ArrayList[u8], n: *Node) void {
    switch (n.*) {
        .fn_decl => |f| {
            aj(buf, "{");
            aj_kv(buf, "kind", "fn_decl"); aj(buf, ", ");
            aj_kv(buf, "name", f.name); aj(buf, ", ");
            aj_key(buf, "params"); aj_params(buf, f.params); aj(buf, ", ");
            aj_kv(buf, "ret", f.ret); aj(buf, ", ");
            aj_key(buf, "annots"); aj_strs(buf, f.annots); aj(buf, ", ");
            aj_key(buf, "tparams"); aj_strs(buf, f.tparams); aj(buf, ", ");
            aj_key(buf, "extern"); aj_bool(buf, f.is_extern); aj(buf, ", ");
            aj_key(buf, "body"); aj_nodes(buf, f.body);
            aj(buf, "}");
        }
        .let_ => |l| {
            aj(buf, "{");
            aj_kv(buf, "kind", "let"); aj(buf, ", ");
            aj_kv(buf, "name", l.name);
            if (l.has_dty == 1) { aj(buf, ", "); aj_kv(buf, "declared_type", l.dty); }
            aj(buf, ", "); aj_key(buf, "value"); aj_node(buf, l.expr);
            aj(buf, "}");
        }
        .ret => |r| {
            aj(buf, "{");
            aj_kv(buf, "kind", "return");
            if (r.has_expr == 1) { aj(buf, ", "); aj_key(buf, "value"); aj_node(buf, r.expr); }
            aj(buf, "}");
        }
        .if_ => |x| {
            aj(buf, "{");
            aj_kv(buf, "kind", "if"); aj(buf, ", ");
            aj_key(buf, "cond"); aj_node(buf, x.cond); aj(buf, ", ");
            aj_key(buf, "then"); aj_nodes(buf, x.then_body);
            if (x.has_els == 1) { aj(buf, ", "); aj_key(buf, "else"); aj_nodes(buf, x.els_body); }
            aj(buf, "}");
        }
        .while_ => |w| {
            aj(buf, "{");
            aj_kv(buf, "kind", "while"); aj(buf, ", ");
            aj_key(buf, "cond"); aj_node(buf, w.cond); aj(buf, ", ");
            aj_key(buf, "body"); aj_nodes(buf, w.body);
            aj(buf, "}");
        }
        .assign => |a| {
            aj(buf, "{");
            aj_kv(buf, "kind", "assign"); aj(buf, ", ");
            aj_key(buf, "target"); aj_node(buf, a.target); aj(buf, ", ");
            aj_key(buf, "value"); aj_node(buf, a.expr);
            aj(buf, "}");
        }
        .estmt => |e| {
            aj(buf, "{");
            aj_kv(buf, "kind", "expr_stmt"); aj(buf, ", ");
            aj_key(buf, "expr"); aj_node(buf, e.expr);
            aj(buf, "}");
        }
        .ilit => |v| {
            aj(buf, "{");
            aj_kv(buf, "kind", "int"); aj(buf, ", ");
            aj_kv(buf, "value", v.text);
            aj(buf, "}");
        }
        .slit => |v| {
            aj(buf, "{");
            aj_kv(buf, "kind", "str"); aj(buf, ", ");
            aj_kv(buf, "value", v.text);
            aj(buf, "}");
        }
        .id => |v| {
            aj(buf, "{");
            aj_kv(buf, "kind", "ident"); aj(buf, ", ");
            aj_kv(buf, "name", v.name);
            aj(buf, "}");
        }
        .bin => |b| {
            aj(buf, "{");
            aj_kv(buf, "kind", "bin"); aj(buf, ", ");
            aj_kv(buf, "op", b.op); aj(buf, ", ");
            aj_key(buf, "lhs"); aj_node(buf, b.l); aj(buf, ", ");
            aj_key(buf, "rhs"); aj_node(buf, b.r);
            aj(buf, "}");
        }
        .un => |u| {
            aj(buf, "{");
            aj_kv(buf, "kind", "un"); aj(buf, ", ");
            aj_kv(buf, "op", u.op); aj(buf, ", ");
            aj_key(buf, "operand"); aj_node(buf, u.e);
            aj(buf, "}");
        }
        .cast_ => |c| {
            aj(buf, "{");
            aj_kv(buf, "kind", "cast"); aj(buf, ", ");
            aj_kv(buf, "target", c.target); aj(buf, ", ");
            aj_key(buf, "expr"); aj_node(buf, c.expr);
            aj(buf, "}");
        }
        .call => |c| {
            aj(buf, "{");
            aj_kv(buf, "kind", "call"); aj(buf, ", ");
            aj_key(buf, "callee"); aj_node(buf, c.callee); aj(buf, ", ");
            aj_key(buf, "args"); aj_nodes(buf, c.args); aj(buf, ", ");
            aj_key(buf, "targs"); aj_strs(buf, c.targs);
            aj(buf, "}");
        }
        .idx => |x| {
            aj(buf, "{");
            aj_kv(buf, "kind", "index"); aj(buf, ", ");
            aj_key(buf, "base"); aj_node(buf, x.base); aj(buf, ", ");
            aj_key(buf, "index"); aj_node(buf, x.idx);
            aj(buf, "}");
        }
        .fld => |x| {
            aj(buf, "{");
            aj_kv(buf, "kind", "field"); aj(buf, ", ");
            aj_kv(buf, "field", x.fname); aj(buf, ", ");
            aj_key(buf, "base"); aj_node(buf, x.base);
            aj(buf, "}");
        }
        .slit_ => |s| {
            aj(buf, "{");
            aj_kv(buf, "kind", "struct_lit"); aj(buf, ", ");
            aj_kv(buf, "struct", s.sname); aj(buf, ", ");
            aj_key(buf, "fields"); aj_fieldinits(buf, s.fields);
            aj(buf, "}");
        }
        .struct_ => |s| {
            aj(buf, "{");
            aj_kv(buf, "kind", "struct_decl"); aj(buf, ", ");
            aj_kv(buf, "name", s.name); aj(buf, ", ");
            aj_key(buf, "fields"); aj_params(buf, s.fields); aj(buf, ", ");
            aj_key(buf, "tparams"); aj_strs(buf, s.tparams);
            aj(buf, "}");
        }
        .enum_ => |e| {
            aj(buf, "{");
            aj_kv(buf, "kind", "enum_decl"); aj(buf, ", ");
            aj_kv(buf, "name", e.name); aj(buf, ", ");
            aj_key(buf, "members"); aj_strs(buf, e.members);
            aj(buf, "}");
        }
        .union_ => |u| {
            aj(buf, "{");
            aj_kv(buf, "kind", "union_decl"); aj(buf, ", ");
            aj_kv(buf, "name", u.name); aj(buf, ", ");
            aj_key(buf, "variants"); aj_params(buf, u.fields);
            aj(buf, "}");
        }
        .switch_ => |sw| {
            aj(buf, "{");
            aj_kv(buf, "kind", "switch"); aj(buf, ", ");
            aj_key(buf, "subject"); aj_node(buf, sw.subject);
            aj(buf, "}");
        }
        .slice_ => |s| {
            aj(buf, "{");
            aj_kv(buf, "kind", "slice"); aj(buf, ", ");
            aj_key(buf, "base"); aj_node(buf, s.base);
            aj(buf, "}");
        }
    }
}

// ── top level: source → JSON document ────────────────────────────────────────
fn ast_json(src: []u8) ArrayList[u8] {
    let decls: ArrayList[*Node] = parse_program(src);
    let buf: ArrayList[u8] = make[u8](256);
    aj(&buf, "{\n  ");
    aj_kv(&buf, "schema", "zag.ast/v1");
    aj(&buf, ",\n  ");
    aj_key(&buf, "decls");
    aj_nodes(&buf, decls);
    aj(&buf, "\n}\n");
    return buf;
}
